@startuml
' Biểu đồ phân rã chức năng - Hệ thống quản lý ký túc xá
skinparam dpi 150
skinparam defaultFontName Arial
skinparam shadowing false
skinparam linetype ortho

title Biểu đồ phân rã chức năng - Hệ thống quản lý ký túc xá

node "Hệ thống quản lý ký túc xá" as System {
}

node "Đăng ký & hồ sơ" as UC_Register
node "Tra cứu & hỗ trợ" as UC_Lookup
node "Cấu hình chính sách" as UC_Config
node "Mô phỏng & phân bổ" as UC_Sim
node "Quản lý phòng" as UC_Rooms
node "Thông báo & realtime" as UC_Notify
node "Báo cáo & thống kê" as UC_Report

System --> UC_Register
System --> UC_Lookup
System --> UC_Config
System --> UC_Sim
System --> UC_Rooms
System --> UC_Notify
System --> UC_Report

' Sub-functions for Đăng ký & hồ sơ
node "Đăng nhập" as R_Login
node "Khai báo thông tin" as R_Fill
node "Nộp minh chứng" as R_Submit
node "Kiểm duyệt hồ sơ" as R_Verify
UC_Register --> R_Login
UC_Register --> R_Fill
UC_Register --> R_Submit
UC_Register --> R_Verify

' Sub-functions for Tra cứu & hỗ trợ
node "Tra cứu trạng thái" as L_Check
node "Xem kết quả phân bổ" as L_Result
node "Gửi phản hồi / khiếu nại" as L_Feedback
UC_Lookup --> L_Check
UC_Lookup --> L_Result
UC_Lookup --> L_Feedback

' Sub-functions for Cấu hình chính sách
node "Quản lý mẫu chính sách" as C_Templates
node "Chỉnh trọng số & ràng buộc" as C_Params
node "Phiên bản & audit" as C_Audit
UC_Config --> C_Templates
UC_Config --> C_Params
UC_Config --> C_Audit

' Sub-functions for Mô phỏng & phân bổ
node "Chạy mô phỏng" as S_Run
node "So sánh phương án" as S_Compare
node "Xác nhận / Commit" as S_Commit
UC_Sim --> S_Run
UC_Sim --> S_Compare
UC_Sim --> S_Commit

' Sub-functions for Quản lý phòng
node "Thêm / Sửa / Xóa phòng" as P_CRUD
node "Cập nhật sức chứa" as P_Capacity
node "Liên kết ảnh / sơ đồ" as P_Visual
UC_Rooms --> P_CRUD
UC_Rooms --> P_Capacity
UC_Rooms --> P_Visual

' Sub-functions for Thông báo
node "Đẩy thông báo" as N_Push
node "Hàng đợi & retry" as N_Queue
node "Ghi nhật ký sự kiện" as N_Log
UC_Notify --> N_Push
UC_Notify --> N_Queue
UC_Notify --> N_Log

' Sub-functions for Báo cáo & thống kê
node "Báo cáo phân bổ" as Rpt_Alloc
node "Thống kê KPI" as Rpt_KPI
UC_Report --> Rpt_Alloc
UC_Report --> Rpt_KPI

' Layout hints (try to keep hierarchy clear)
System -down-> UC_Register
System -down-> UC_Lookup
System -down-> UC_Config
System -down-> UC_Sim
System -down-> UC_Rooms
System -down-> UC_Notify
System -down-> UC_Report

@enduml
