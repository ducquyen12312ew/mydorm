@startuml
top to bottom direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor LightGoldenRodYellow
  BorderColor GoldenRod
  FontName Arial
  FontSize 12
  ArrowColor GoldenRod
}

actor "Sinh viên" as Student
actor "Cán bộ quản lý" as Manager

rectangle "Tra cứu kết quả, khiếu nại và tương tác" {
  (Xem kết quả phân bổ và audit) as UC_View
  (Nộp khiếu nại) as UC_Complain
  (Xử lý khiếu nại) as UC_Handle
}

Student --> UC_View : "1. Đăng nhập và xem kết quả + lời giải thích"
Student --> UC_Complain : "2. Nếu không đồng ý, gửi khiếu nại với tài liệu"
Manager --> UC_Handle : "3. Cán bộ nhận và xử lý khiếu nại, cập nhật trạng thái"

UC_Complain --> UC_Handle
UC_View --> UC_Complain : "Cho phép đính kèm tài liệu"

@enduml
