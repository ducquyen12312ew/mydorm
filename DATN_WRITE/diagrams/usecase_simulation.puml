@startuml
top to bottom direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor LightGoldenRodYellow
  BorderColor GoldenRod
  FontName Arial
  FontSize 12
  ArrowColor GoldenRod
}

actor "Cán bộ quản lý" as Manager
actor "Hệ thống" as System

rectangle "Chạy mô phỏng & thực thi phân bổ" {
  (Chạy mô phỏng) as UC_Simulate
  (Thực thi phân bổ) as UC_Execute
  (Sinh báo cáo và log giải thích) as UC_Report
  (Quyết định commit/không commit) as UC_Decide
  (Báo vi phạm ràng buộc) as UC_Violation
}

Manager --> UC_Simulate : "1. Chọn chế độ mô phỏng hoặc thực thi"
System --> UC_Report : "2. Chạy engine, sinh báo cáo và log"
Manager --> UC_Decide : "3. Xem kết quả và quyết định commit"

UC_Report --> UC_Decide
UC_Report --> UC_Violation : "Nếu có vi phạm - báo chi tiết và đề xuất điều chỉnh"
UC_Execute --> System : "Cập nhật trạng thái phòng và hồ sơ khi commit"

@enduml
