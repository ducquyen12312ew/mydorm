PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/dormitory
MONGODB_URI=mongodb://localhost:27017/dormitory

# Session & JWT
SESSION_SECRET=change-this-to-a-long-random-string-in-production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Redis (for Socket.IO multi-server, optional)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# 2FA / OTP
OTP_MAX_ATTEMPTS=5
OTP_LOCK_DURATION_MINUTES=15
TOTP_ISSUER=KTX-HUST

# Mobile JWT
MOBILE_JWT_EXPIRES_IN=15m
MOBILE_REFRESH_TOKEN_EXPIRES_IN=30d
MOBILE_ANOMALY_RISK_THRESHOLD=70
INVALIDATE_ON_TOKEN_ANOMALY=false
ALERT_ON_TOKEN_ANOMALY=true

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
