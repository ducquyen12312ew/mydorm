# ============================================================
# HUST DORMITORY MANAGEMENT SYSTEM — ENVIRONMENT TEMPLATE
# ============================================================
# Copy this file to .env and fill in every value marked REQUIRED.
# NEVER commit .env to git. It is already in .gitignore.
#
# Generate secure random secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================


# ============================================================
# APPLICATION
# ============================================================

# REQUIRED — 'development' or 'production'
NODE_ENV=development

# OPTIONAL — server port (default: 5000)
PORT=5000

# OPTIONAL — log verbosity: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info


# ============================================================
# DATABASE
# ============================================================

# REQUIRED — MongoDB connection URI.
# Local:   mongodb://127.0.0.1:27017/Dormitory
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/Dormitory?retryWrites=true&w=majority
#
# IMPORTANT: The app reads MONGO_URI first, then MONGODB_URI as fallback.
# Set both to the same value to avoid confusion.
MONGO_URI=mongodb://127.0.0.1:27017/Dormitory
MONGODB_URI=mongodb://127.0.0.1:27017/Dormitory

# OPTIONAL — Redis connection URL for Socket.IO cluster adapter.
# If blank, Socket.IO runs in single-server mode (fine for development/single-instance prod).
# Redis enables horizontal scaling across multiple backend instances.
# Example: redis://127.0.0.1:6379
# Example (with auth): redis://:yourpassword@127.0.0.1:6379
REDIS_URL=


# ============================================================
# SESSION & WEB SECURITY
# ============================================================

# REQUIRED IN PRODUCTION — express-session signing secret.
# Must be a long random string. The app warns at startup if this is missing in production.
# In development, defaults to 'dev-secret' (insecure, acceptable for local only).
SESSION_SECRET=change-this-to-a-long-random-string-in-production


# ============================================================
# JWT / MOBILE AUTHENTICATION
# ============================================================

# REQUIRED — JWT signing secrets for the mobile app.
# MOBILE_JWT_ACCESS_SECRET and MOBILE_JWT_REFRESH_SECRET are preferred.
# If only JWT_ACCESS_SECRET / JWT_REFRESH_SECRET are set, those are used as fallback.
# Generate each independently: they MUST be different from each other.
MOBILE_JWT_ACCESS_SECRET=change-this-mobile-access-secret-in-production
MOBILE_JWT_REFRESH_SECRET=change-this-mobile-refresh-secret-in-production

# OPTIONAL fallbacks — used if the MOBILE_JWT_* keys above are not set.
# Not needed if you set the MOBILE_JWT_* keys.
# JWT_ACCESS_SECRET=change-this-jwt-access-secret-in-production
# JWT_REFRESH_SECRET=change-this-jwt-refresh-secret-in-production

# OPTIONAL — token lifetimes (default: 15m access, 30d refresh)
MOBILE_ACCESS_TOKEN_TTL=15m
MOBILE_REFRESH_TOKEN_TTL=30d


# ============================================================
# QR RESIDENT CARD
# ============================================================

# REQUIRED IN PRODUCTION — HMAC-SHA256 secret for signing QR tokens.
# Falls back to JWT_SECRET if not set (insecure in production — always set this).
# Must NOT be the same as your JWT secrets.
QR_SECRET=change-this-qr-signing-secret-in-production


# ============================================================
# MOBILE TOKEN SECURITY
# ============================================================

# OPTIONAL — risk score threshold above which a refresh is rejected (default: 70, range 0-100)
MOBILE_ANOMALY_RISK_THRESHOLD=70

# OPTIONAL — log a warning when token anomaly is detected (default: true)
MOBILE_ALERT_ON_TOKEN_ANOMALY=true

# OPTIONAL — revoke token immediately on anomaly (default: false — score-based rejection only)
MOBILE_INVALIDATE_ON_TOKEN_ANOMALY=false


# ============================================================
# 2FA / OTP SETTINGS
# ============================================================

# OPTIONAL — maximum failed OTP attempts before lockout (default: 5)
OTP_MAX_ATTEMPTS=5

# OPTIONAL — lockout duration in minutes after too many failed attempts (default: 15)
OTP_LOCK_DURATION_MINUTES=15

# OPTIONAL — TOTP issuer name shown in authenticator apps (e.g. Google Authenticator)
TOTP_ISSUER=KTX-HUST


# ============================================================
# EMAIL (SMTP / NODEMAILER)
# ============================================================
# Used for: 2FA OTP delivery, notification emails, password reset.
# If not configured, email sending will fail silently.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to Google Account → Security → App Passwords.
#   3. Generate a 16-character app password.
#   4. Use that as SMTP_PASSWORD (not your regular Gmail password).

# OPTIONAL — Nodemailer service shorthand (default: 'gmail')
SMTP_SERVICE=gmail

# OPTIONAL — SMTP host (default: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# OPTIONAL — SMTP port (default: 587 for STARTTLS)
SMTP_PORT=587

# REQUIRED FOR EMAIL — Gmail address or SMTP username
SMTP_USER=your-email@gmail.com

# REQUIRED FOR EMAIL — Gmail app password or SMTP password (NOT your Gmail login password)
SMTP_PASSWORD=your-16-char-app-password

# REQUIRED FOR EMAIL — Displayed "From" address in sent emails
SMTP_FROM_EMAIL=your-email@gmail.com

# OPTIONAL — Displayed "From" name in sent emails
SMTP_FROM=Dormitory System <your-email@gmail.com>

# OPTIONAL — Reply-To address
SMTP_REPLY_TO=support@ktxhust.edu.vn

# OPTIONAL — Set to 'true' in development to skip actual email sending (just logs)
SKIP_EMAIL=false


# ============================================================
# SMS (TWILIO) — OPTIONAL
# ============================================================
# Used for: SMS-based 2FA OTP delivery.
# Leave blank to disable SMS (TOTP-based 2FA still works without this).

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=


# ============================================================
# SOCKET.IO / REALTIME
# ============================================================
# (No additional env vars required beyond REDIS_URL above.)
# Socket.IO uses the same PORT as the HTTP server.
# Redis adapter is automatically enabled when REDIS_URL is set.


# ============================================================
# SENTRY — CRASH REPORTING & OBSERVABILITY
# ============================================================

# Backend DSN — from sentry.io project settings (Node.js)
# Get it at: https://sentry.io → Your Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Mobile DSN is set in mobile/app.json under expo.extra.sentryDsn (not here)


# ============================================================
# ADMIN / INTERNAL API KEYS
# ============================================================

# OPTIONAL — API key to authorize the cohort-shift endpoint from external scripts.
# If not set, the endpoint falls back to requiring an admin session.
COHORT_SHIFT_API_KEY=


# ============================================================
# EVENT TRANSPORT (ADVANCED / OPTIONAL)
# ============================================================
# Controls how domain events are dispatched internally.
# 'local' = in-process (default, suitable for single-server deployments)
# 'redis' = publish to Redis channel (requires REDIS_URL)
# 'kafka' = publish to Kafka topic (requires KAFKA_BROKERS)
EVENT_TRANSPORT=local

# Required if EVENT_TRANSPORT=redis:
# EVENT_TRANSPORT_CHANNEL=domain-events

# Required if EVENT_TRANSPORT=kafka:
# KAFKA_BROKERS=localhost:9092
# KAFKA_TOPIC=domain-events


# ============================================================
# MOBILE / EXPO — app.json (not process.env)
# ============================================================
# The mobile app does NOT read process.env. API URLs are configured in:
#   mobile/app.json  →  expo.extra
#
# Keys used in mobile/app.json:
#   extra.apiBaseUrl     = Android emulator dev URL  (default: http://10.0.2.2:5000)
#   extra.apiBaseUrlIos  = iOS simulator dev URL     (default: http://localhost:5000)
#   extra.apiBaseUrlProd = Production URL            (default: https://api.hust-dormitory.edu.vn)
#
# For production builds, update mobile/app.json extra.apiBaseUrlProd to your actual
# server URL before running: eas build --profile production
