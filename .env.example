# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!
# ============================================

# Application
NODE_ENV=development
PORT=5000
APP_NAME=KTX_HUST

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/dormitory
MONGODB_USER=
MONGODB_PASSWORD=

# ============================================
# SESSION & SECURITY
# ============================================
SESSION_SECRET=
JWT_SECRET=
CSRF_TOKEN_SECRET=

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
SENTRY_DSN=

# ============================================
# EMAIL/SMS NOTIFICATIONS
# ============================================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# 2FA/MFA
# ============================================
TOTP_WINDOW=1
OTP_EXPIRY_TIME=300

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,docx
UPLOAD_DIR=./uploads

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ============================================
# HTTPS/SSL
# ============================================
USE_HTTPS=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# ============================================
# ADMIN SETTINGS
# ============================================
ADMIN_EMAIL=
ADMIN_PHONE=
DEFAULT_ADMIN_PASSWORD=

# ============================================
# API KEYS (Third-party services)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
