<!-- 
  Workflow Progress Component
  Displays application status with step-by-step visualization
  
  Required data:
  - application: Application object with status, timeline, etc
  - currentStep: Current workflow step code
  - timeline: Array of timeline events
  - missingDocuments: Array of missing document objects
-->

<%
  // Import workflow constants
  const workflowConstants = require('../../src/utils/workflowConstants');
  
  // Helper function to format date
  function formatDate(date) {
    if (!date) return 'N/A';
    const d = new Date(date);
    return d.toLocaleDateString('vi-VN', { 
      day: '2-digit', 
      month: '2-digit', 
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  }
  
  // Determine which steps are completed, current, and pending
  const workflowSequence = workflowConstants.WORKFLOW_SEQUENCE;
  const currentStepIndex = workflowSequence.indexOf(currentStep);
  
  function getStepStatus(step) {
    const stepIndex = workflowSequence.indexOf(step);
    if (stepIndex < currentStepIndex) return 'completed';
    if (stepIndex === currentStepIndex) return 'active';
    return 'pending';
  }
  
  function getStepStatusClass(step) {
    const status = getStepStatus(step);
    if (status === 'completed') return 'completed';
    if (status === 'active') return 'active';
    if (currentStep === 'REJECTED' || currentStep === 'WITHDRAWN') return 'failed';
    return 'pending';
  }
  
  // Calculate progress percentage
  const progressPercent = (currentStepIndex / workflowSequence.length) * 100;
  
  // Get failed step if application was rejected/withdrawn
  const failedSteps = (currentStep === 'REJECTED' || currentStep === 'WITHDRAWN') ? [currentStep] : [];
%>

<div class="workflow-container">
  <!-- Header -->
  <div class="workflow-header" style="margin-bottom: 1.5rem;">
    <h2 class="workflow-title">
      <i class="fas fa-tasks"></i>
      Trạng thái đơn đăng ký
    </h2>
    <p class="workflow-subtitle">
      Theo dõi tiến trình xử lý đơn đăng ký của bạn
    </p>
  </div>

  <!-- Progress Bar with Steps -->
  <div class="workflow-steps" style="--progress-percent: <%= progressPercent %>%;">
    <% workflowSequence.forEach((step, index) => { %>
      <% const stepDetails = workflowConstants.getStepDetails(step); %>
      <% const status = getStepStatusClass(step); %>
      
      <div class="step <%= status %>" style="flex: <%= Math.max(1, 3 - index) %>;">
        <div class="step-circle" data-tooltip="<%= stepDetails.description %>">
          <i class="<%= stepDetails.icon %>"></i>
        </div>
        <div class="step-label"><%= stepDetails.label %></div>
      </div>
    <% }); %>
  </div>

  <!-- Current Status Panel -->
  <div class="workflow-status-panel">
    <div class="status-panel-title">
      <i class="fas fa-info-circle"></i>
      Thông tin hiện tại
    </div>
    <div class="status-grid">
      <div class="status-item">
        <div class="status-item-icon primary">
          <i class="fas fa-circle-info"></i>
        </div>
        <div class="status-item-content">
          <div class="status-item-label">Trạng thái</div>
          <div class="status-item-value">
            <% const currentDetails = workflowConstants.getStepDetails(currentStep); %>
            <i class="<%= currentDetails.icon %>" style="color: <%= currentDetails.textColor %>;"></i>
            <%= currentDetails.label %>
          </div>
        </div>
      </div>

      <div class="status-item">
        <div class="status-item-icon primary">
          <i class="fas fa-calendar"></i>
        </div>
        <div class="status-item-content">
          <div class="status-item-label">Cập nhật lần cuối</div>
          <div class="status-item-value"><%= formatDate(application.updatedAt) %></div>
        </div>
      </div>

      <% if (application.status === 'APPROVED') { %>
        <div class="status-item">
          <div class="status-item-icon success">
            <i class="fas fa-check-circle"></i>
          </div>
          <div class="status-item-content">
            <div class="status-item-label">Phòng được cấp</div>
            <div class="status-item-value">
              <%= application.roomNumber || 'Đang xử lý...' %>
            </div>
          </div>
        </div>
      <% } %>

      <% if (application.status === 'REJECTED') { %>
        <div class="status-item">
          <div class="status-item-icon danger">
            <i class="fas fa-times-circle"></i>
          </div>
          <div class="status-item-content">
            <div class="status-item-label">Lý do từ chối</div>
            <div class="status-item-value">
              <%= application.rejectionReason || 'Không xác định' %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Missing Documents Alert -->
  <% if (missingDocuments && missingDocuments.length > 0) { %>
    <div class="missing-docs-alert">
      <div class="missing-docs-alert-icon">
        <i class="fas fa-file-circle-exclamation"></i>
      </div>
      <div class="missing-docs-content">
        <div class="missing-docs-title">
          Thiếu <%= missingDocuments.length %> tài liệu
        </div>
        <ul class="missing-docs-list">
          <% missingDocuments.forEach(doc => { %>
            <li><strong><%= doc.name %></strong> - <%= doc.description %></li>
          <% }); %>
        </ul>
        <button class="btn-request-docs" onclick="requestMissingDocuments('<%= application._id %>')">
          <i class="fas fa-upload"></i>
          Gửi tài liệu
        </button>
      </div>
    </div>
  <% } %>

  <!-- Timeline of Actions -->
  <div class="workflow-timeline">
    <div class="timeline-title">
      <i class="fas fa-history"></i>
      Lịch sử xử lý
    </div>
    
    <div class="timeline-items">
      <% if (!timeline || timeline.length === 0) { %>
        <div style="color: var(--text-tertiary); text-align: center; padding: 2rem;">
          <i class="fas fa-inbox" style="font-size: 2rem; margin-bottom: 0.5rem; display: block;"></i>
          Chưa có sự kiện nào
        </div>
      <% } else { %>
        <% timeline.forEach((event, idx) => { %>
          <% 
            let eventClass = 'timeline-item';
            if (event.status === 'SUCCESS' || event.status === 'APPROVED') {
              eventClass += ' success';
            } else if (event.status === 'REJECTED' || event.status === 'ERROR') {
              eventClass += ' error';
            } else if (event.status === 'WARNING' || event.status === 'PENDING') {
              eventClass += ' warning';
            }
          %>
          
          <div class="<%= eventClass %>">
            <div class="timeline-content">
              <div class="timeline-time"><%= formatDate(event.timestamp) %></div>
              <div class="timeline-action">
                <i class="fas fa-<%= event.iconClass || 'info-circle' %>"></i>
                <%= event.actionLabel %>
              </div>
              
              <% if (event.reason) { %>
                <div class="timeline-reason">
                  "<%= event.reason %>"
                </div>
              <% } %>
              
              <% if (event.actor) { %>
                <div class="timeline-actor">
                  <i class="fas fa-user"></i>
                  Thực hiện bởi: <strong><%= event.actor %></strong>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Action Buttons -->
  <% if (application.status !== 'REJECTED' && application.status !== 'WITHDRAWN' && application.status !== 'APPROVED') { %>
    <div class="workflow-actions">
      <button class="btn-workflow btn-workflow-secondary" onclick="viewApplicationDetails('<%= application._id %>')">
        <i class="fas fa-eye"></i>
        Xem chi tiết
      </button>
      
      <% if (application.status === 'DRAFT' || application.status === 'SUBMITTED') { %>
        <button class="btn-workflow btn-workflow-primary" onclick="editApplication('<%= application._id %>')">
          <i class="fas fa-edit"></i>
          Chỉnh sửa
        </button>
      <% } %>
      
      <button class="btn-workflow btn-workflow-secondary" onclick="withdrawApplication('<%= application._id %>')" 
              style="margin-left: auto;">
        <i class="fas fa-trash"></i>
        Rút lại
      </button>
    </div>
  <% } %>
</div>

<script>
/**
 * Workflow Actions
 */

function requestMissingDocuments(appId) {
  if (!confirm('Bạn muốn gửi yêu cầu bổ sung tài liệu?')) return;
  
  fetch(`/api/applications/${appId}/request-documents`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      alert('Yêu cầu đã được gửi! Vui lòng kiểm tra email của bạn.');
      location.reload();
    } else {
      alert('Lỗi: ' + (d.message || 'Không thể gửi yêu cầu'));
    }
  })
  .catch(e => alert('Lỗi kết nối: ' + e.message));
}

function viewApplicationDetails(appId) {
  window.location.href = `/applications/${appId}`;
}

function editApplication(appId) {
  window.location.href = `/applications/${appId}/edit`;
}

function withdrawApplication(appId) {
  if (!confirm('Bạn chắc chắn muốn rút lại đơn đăng ký này? Hành động này không thể hoàn tác.')) return;
  
  fetch(`/api/applications/${appId}/withdraw`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      alert('Đơn đã được rút lại!');
      location.reload();
    } else {
      alert('Lỗi: ' + (d.message || 'Không thể rút lại'));
    }
  })
  .catch(e => alert('Lỗi kết nối: ' + e.message));
}

/**
 * Initialize workflow visualization
 */
document.addEventListener('DOMContentLoaded', function() {
  // Add smooth scroll to timeline items
  const timelineItems = document.querySelectorAll('.timeline-item');
  timelineItems.forEach(item => {
    item.addEventListener('mouseenter', function() {
      this.style.transform = 'translateX(8px)';
    });
    item.addEventListener('mouseleave', function() {
      this.style.transform = 'translateX(0)';
    });
  });
});
</script>
