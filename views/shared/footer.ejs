<!-- Toast container (shared) -->
<div class="fv2-toast-container" id="fv2ToastContainer" aria-live="polite"></div>

<script>
(function () {
    function setupFooterSocial() {
        var phoneBtn   = document.getElementById('fv2PhoneBtn');
        var emailBtn   = document.getElementById('fv2EmailBtn');
        var phonePanel = document.getElementById('fv2PhonePanel');
        var emailPanel = document.getElementById('fv2EmailPanel');
        var copyPhone  = document.getElementById('fv2CopyPhone');
        var copyEmail  = document.getElementById('fv2CopyEmail');

        if (!phoneBtn || !emailBtn) return;

        function closeAll() {
            phonePanel.classList.remove('open');
            emailPanel.classList.remove('open');
            phonePanel.setAttribute('aria-hidden', 'true');
            emailPanel.setAttribute('aria-hidden', 'true');
            phoneBtn.classList.remove('active');
            emailBtn.classList.remove('active');
        }

        phoneBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            if (phonePanel.classList.contains('open')) {
                closeAll();
            } else {
                closeAll();
                phonePanel.classList.add('open');
                phonePanel.setAttribute('aria-hidden', 'false');
                phoneBtn.classList.add('active');
            }
        });

        emailBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            if (emailPanel.classList.contains('open')) {
                closeAll();
            } else {
                closeAll();
                emailPanel.classList.add('open');
                emailPanel.setAttribute('aria-hidden', 'false');
                emailBtn.classList.add('active');
            }
        });

        document.addEventListener('click', function () { closeAll(); });
        phonePanel.addEventListener('click', function (e) { e.stopPropagation(); });
        emailPanel.addEventListener('click', function (e) { e.stopPropagation(); });

        if (copyPhone) {
            copyPhone.addEventListener('click', function (e) {
                e.stopPropagation();
                navigator.clipboard.writeText('0982773892').then(function () {
                    showToast('<i class="fas fa-check-circle"></i> Đã sao chép số điện thoại');
                }).catch(function () {
                    showToast('<i class="fas fa-check-circle"></i> Đã sao chép số điện thoại');
                });
            });
        }

        if (copyEmail) {
            copyEmail.addEventListener('click', function (e) {
                e.stopPropagation();
                navigator.clipboard.writeText('quyen.pd225916@sis.hust.edu.vn').then(function () {
                    showToast('<i class="fas fa-check-circle"></i> Đã sao chép email');
                }).catch(function () {
                    showToast('<i class="fas fa-check-circle"></i> Đã sao chép email');
                });
            });
        }
    }

    function showToast(html) {
        var container = document.getElementById('fv2ToastContainer');
        if (!container) return;
        var el = document.createElement('div');
        el.className = 'fv2-toast';
        el.innerHTML = html;
        container.appendChild(el);
        setTimeout(function () {
            el.classList.add('out');
            setTimeout(function () { if (el.parentNode) el.parentNode.removeChild(el); }, 250);
        }, 2800);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupFooterSocial);
    } else {
        setupFooterSocial();
    }
})();
</script>
