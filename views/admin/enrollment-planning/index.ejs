<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kế hoạch tuyển sinh — Admin KTX HUST</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #F8F9FA; color: #111827; }
    .page-wrap { max-width: 1100px; margin: 28px auto; padding: 0 24px; }

    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
    .page-header h1 { font-size: 20px; font-weight: 700; color: #111827; }
    .page-header h1 span { color: #C8102E; }
    .page-header p { font-size: 13px; color: #6B7280; margin-top: 3px; }

    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: background .15s; }
    .btn-red { background: #C8102E; color: #fff; }
    .btn-red:hover { background: #a50d24; }
    .btn-outline { background: #fff; border: 1px solid #E5E7EB; color: #374151; }
    .btn-outline:hover { border-color: #C8102E; color: #C8102E; }
    .btn-sm { padding: 5px 12px; font-size: 12px; }

    .card { background: #fff; border: 1px solid #E5E7EB; border-radius: 10px; box-shadow: 0 1px 3px rgba(0,0,0,.06); margin-bottom: 20px; }
    .card-body { padding: 0; }

    .plans-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .plans-table thead th { background: #F9FAFB; font-size: 11px; font-weight: 700; color: #6B7280; text-transform: uppercase; letter-spacing: .05em; padding: 10px 16px; text-align: left; border-bottom: 1px solid #E5E7EB; }
    .plans-table thead th:last-child { text-align: right; }
    .plans-table tbody td { padding: 13px 16px; border-bottom: 1px solid #F3F4F6; color: #374151; vertical-align: middle; }
    .plans-table tbody tr:last-child td { border-bottom: none; }
    .plans-table tbody tr:hover td { background: #FAFAFA; }

    .year-tag { font-size: 11px; font-weight: 700; color: #C8102E; text-transform: uppercase; letter-spacing: .06em; }
    .plan-name { font-weight: 600; color: #111827; font-size: 13px; }
    .num-val { font-weight: 700; color: #111827; }
    .num-sub { font-size: 11px; color: #9CA3AF; margin-top: 1px; }

    .occ-bar-wrap { display: flex; align-items: center; gap: 8px; }
    .occ-bar-track { flex: 1; height: 6px; background: #F3F4F6; border-radius: 3px; overflow: hidden; min-width: 60px; }
    .occ-bar-fill { height: 100%; border-radius: 3px; }
    .fill-ok   { background: #22C55E; }
    .fill-warn { background: #FBBF24; }
    .fill-over { background: #EF4444; }
    .occ-pct { font-size: 12px; font-weight: 700; white-space: nowrap; }

    .badge { display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-draft    { background: #F3F4F6; color: #6B7280; }
    .badge-review   { background: #FEF3C7; color: #92400E; }
    .badge-approved { background: #D1FAE5; color: #065F46; }
    .badge-locked   { background: #EDE9FE; color: #5B21B6; }

    .empty-state { text-align: center; padding: 64px 24px; color: #9CA3AF; }
    .empty-state i { font-size: 48px; display: block; margin-bottom: 16px; }
    .empty-state p { font-size: 15px; font-weight: 600; color: #374151; margin-bottom: 8px; }
    .empty-state span { font-size: 13px; display: block; margin-bottom: 24px; }
  </style>
<link rel="preconnect" href="https://fonts.googleapis.com"><link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"><style>body{font-family:"Be Vietnam Pro",system-ui,sans-serif!important;background:linear-gradient(180deg,#FBF8F3,#F5EFE7)!important;color:#2B2320!important;}</style></head>
<body>
<%- include('../navbar', { activeNav: 'enrollmentplanning' }) %>

<div class="page-wrap">
  <div class="page-header">
    <div>
      <h1>Kế hoạch <span>Tuyển sinh</span></h1>
      <p>Quản lý chỉ tiêu tuyển sinh và dự kiến KTX theo năm học</p>
    </div>
    <a href="/admin/enrollment-planning/new" class="btn btn-red">
      <i class="fas fa-plus"></i> Tạo kế hoạch mới
    </a>
  </div>

  <div class="card">
    <% if (plans.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-calendar-alt"></i>
        <p>Chưa có kế hoạch tuyển sinh nào</p>
        <span>Tạo kế hoạch đầu tiên để bắt đầu quản lý chỉ tiêu</span>
        <a href="/admin/enrollment-planning/new" class="btn btn-red"><i class="fas fa-plus"></i> Tạo kế hoạch</a>
      </div>
    <% } else { %>
    <div class="card-body">
      <table class="plans-table">
        <thead>
          <tr>
            <th>Năm học</th>
            <th>Chỉ tiêu tuyển sinh</th>
            <th>Chỉ tiêu KTX</th>
            <th>Số ngành</th>
            <th>Lấp đầy dự kiến</th>
            <th>Trạng thái</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% plans.forEach(plan => {
            const rawOcc = plan.projectedOccupancy || 0;
            const barPct = Math.min(rawOcc, 100);
            const fillClass = rawOcc > 100 ? 'fill-over' : rawOcc > 85 ? 'fill-warn' : 'fill-ok';
            const statusLabels = { draft:'Nháp', review:'Chờ duyệt', approved:'Đã duyệt', locked:'Đã khoá' };
          %>
          <tr>
            <td>
              <div class="year-tag"><%= plan.academicYear %></div>
              <div class="plan-name" style="margin-top:3px"><%= plan.planName %></div>
            </td>
            <td>
              <div class="num-val"><%= (plan.totalPlannedQuota || 0).toLocaleString('vi-VN') %></div>
              <div class="num-sub">sinh viên</div>
            </td>
            <td>
              <div class="num-val"><%= (plan.totalExpectedDorm || 0).toLocaleString('vi-VN') %></div>
              <div class="num-sub">dự kiến ở KTX</div>
            </td>
            <td><%= (plan.programs || []).length %> ngành</td>
            <td style="min-width:140px;">
              <div class="occ-bar-wrap">
                <div class="occ-bar-track">
                  <div class="occ-bar-fill <%= fillClass %>" style="width:<%= barPct %>%"></div>
                </div>
                <span class="occ-pct" style="color:<%= rawOcc > 100 ? '#EF4444' : rawOcc > 85 ? '#D97706' : '#16A34A' %>"><%= rawOcc %>%</span>
              </div>
              <% if ((plan.capacityGap || 0) > 0) { %>
                <div style="font-size:11px;color:#EF4444;margin-top:4px;"><i class="fas fa-exclamation-triangle"></i> Thiếu <%= plan.capacityGap.toLocaleString('vi-VN') %> chỗ</div>
              <% } %>
            </td>
            <td>
              <span class="badge badge-<%= plan.status %>"><%= statusLabels[plan.status] || plan.status %></span>
            </td>
            <td style="text-align:right;white-space:nowrap;">
              <a href="/admin/enrollment-planning/<%= plan._id %>" class="btn btn-outline btn-sm">
                <i class="fas fa-<%= plan.status === 'draft' || plan.status === 'review' ? 'edit' : 'eye' %>"></i>
                <%= plan.status === 'draft' || plan.status === 'review' ? 'Chỉnh sửa' : 'Xem chi tiết' %>
              </a>
              <button class="btn btn-outline btn-sm" onclick="copyPlan('<%= plan._id %>','<%= plan.academicYear %>')" title="Sao chép">
                <i class="fas fa-copy"></i>
              </button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<!-- Copy modal -->
<div id="copyModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1000;align-items:center;justify-content:center">
  <div style="background:#fff;border-radius:12px;padding:24px;width:min(420px,90vw)">
    <h3 style="margin-bottom:16px;font-size:15px;font-weight:700;">Sao chép kế hoạch</h3>
    <div style="margin-bottom:12px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:5px">Năm học mới</label>
      <input type="text" id="copyYear" placeholder="YYYY-YYYY" style="width:100%;padding:8px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:13px">
    </div>
    <div style="margin-bottom:16px">
      <label style="font-size:12px;font-weight:600;display:block;margin-bottom:5px">Tên kế hoạch</label>
      <input type="text" id="copyName" placeholder="Tên kế hoạch..." style="width:100%;padding:8px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:13px">
    </div>
    <div style="display:flex;justify-content:flex-end;gap:8px">
      <button class="btn btn-outline btn-sm" onclick="document.getElementById('copyModal').style.display='none'">Huỷ</button>
      <button class="btn btn-red btn-sm" onclick="submitCopy()"><i class="fas fa-copy"></i> Sao chép</button>
    </div>
  </div>
</div>

<script>
let copySourceId = '';
function copyPlan(id, year) {
  copySourceId = id;
  const nextYear = year.split('-').map(y => parseInt(y) + 1).join('-');
  document.getElementById('copyYear').value = nextYear;
  document.getElementById('copyName').value = '';
  document.getElementById('copyModal').style.display = 'flex';
}
async function submitCopy() {
  const year = document.getElementById('copyYear').value;
  const name = document.getElementById('copyName').value;
  if (!year.match(/^\d{4}-\d{4}$/)) return alert('Định dạng năm học: YYYY-YYYY');
  const r = await fetch(`/admin/enrollment-planning/${copySourceId}/copy`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ newAcademicYear: year, newPlanName: name })
  });
  const d = await r.json();
  if (d.success) window.location.href = `/admin/enrollment-planning/${d.id}`;
  else alert('Lỗi: ' + d.error);
}
</script>
<%- include('../../shared/footer') %>
</body>
</html>
