<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tạo kế hoạch tuyển sinh — Admin KTX HUST</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --red:#C8102E; --red-dark:#9E0D25; --bg:#F5F6F8; --card:#FFFFFF; --border:#EAECF0; --text:#2D3748; --muted:#9AA3AD; --radius:12px; }
    body { font-family:'Segoe UI',system-ui,sans-serif; background:var(--bg); color:var(--text); }
    .admin-content { min-height:100vh; }
    .page-wrap { max-width:1100px; margin:0 auto; padding:1.5rem; }
    .back-link { display:inline-flex;align-items:center;gap:.4rem;color:var(--muted);font-size:.85rem;text-decoration:none;margin-bottom:1.25rem; }
    .back-link:hover { color:var(--red); }
    h1 { font-size:1.3rem; font-weight:700; margin-bottom:1.5rem; }
    h1 span { color:var(--red); }

    .card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); padding:1.5rem; margin-bottom:1.25rem; }
    .card-title { font-size:.88rem; font-weight:700; color:var(--text); margin-bottom:1.25rem; border-bottom:1px solid var(--border); padding-bottom:.75rem; }
    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
    .form-group { margin-bottom:1rem; }
    .form-group.full { grid-column:1/-1; }
    .form-label { font-size:.82rem; font-weight:600; display:block; margin-bottom:.4rem; }
    .form-control { width:100%; padding:.6rem .9rem; border:1px solid var(--border); border-radius:8px; font-size:.88rem; color:var(--text); }
    .form-control:focus { outline:none; border-color:var(--red); }

    /* Programs table */
    .prog-table { width:100%; border-collapse:collapse; }
    .prog-table th { background:#F8F9FB; font-size:.75rem; font-weight:700; color:var(--muted); text-transform:uppercase; padding:.6rem .75rem; text-align:left; border-bottom:1px solid var(--border); }
    .prog-table td { padding:.5rem .75rem; border-bottom:1px solid var(--border); font-size:.85rem; vertical-align:middle; }
    .prog-table tr:last-child td { border-bottom:none; }
    .prog-table input[type=number] { width:90px; padding:.35rem .5rem; border:1px solid var(--border); border-radius:6px; font-size:.82rem; }
    .prog-table input[type=number]:focus { outline:none; border-color:var(--red); }
    .prog-table .expected { color:var(--muted); font-size:.8rem; }

    .type-badge { display:inline-block; padding:.15rem .5rem; border-radius:20px; font-size:.7rem; font-weight:700; }
    .type-standard     { background:#F0FDF4; color:#166534; }
    .type-advanced     { background:#EFF6FF; color:#1E40AF; }
    .type-international { background:#FDF4FF; color:#6B21A8; }
    .type-talent       { background:#FFF7ED; color:#9A3412; }

    .summary-bar { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:1.25rem; }
    .sum-card { background:var(--card); border:1px solid var(--border); border-radius:var(--radius); padding:1rem; }
    .sum-label { font-size:.75rem; color:var(--muted); font-weight:600; text-transform:uppercase; }
    .sum-value { font-size:1.5rem; font-weight:800; margin-top:.2rem; color:var(--text); }
    .sum-value.red { color:var(--red); }

    .btn { display:inline-flex; align-items:center; gap:.4rem; padding:.55rem 1.1rem; border-radius:8px; font-size:.85rem; font-weight:600; cursor:pointer; border:none; transition:all .2s; text-decoration:none; }
    .btn-red { background:var(--red); color:#fff; } .btn-red:hover { background:var(--red-dark); }
    .btn-outline { background:transparent; border:1px solid var(--border); color:var(--text); }
    .btn-outline:hover { border-color:var(--red); color:var(--red); }
    .footer-bar { display:flex; justify-content:flex-end; gap:.75rem; padding-top:1rem; }
    @media(max-width:768px){ .form-grid,.summary-bar{grid-template-columns:1fr;} .form-group.full{grid-column:auto;} }
  </style>
</head>
<body>
<%- include('../navbar', { activeNav: 'enrollmentplanning' }) %>
<div class="admin-content">
<div class="page-wrap">

  <a href="/admin/enrollment-planning" class="back-link"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
  <h1>Tạo kế hoạch <span>Tuyển sinh</span> mới</h1>

  <!-- Summary -->
  <div class="summary-bar">
    <div class="sum-card"><div class="sum-label">Tổng chỉ tiêu</div><div class="sum-value" id="sumQuota">0</div></div>
    <div class="sum-card"><div class="sum-label">Dự kiến ở KTX</div><div class="sum-value red" id="sumDorm">0</div></div>
    <div class="sum-card"><div class="sum-label">Lấp đầy dự kiến</div><div class="sum-value" id="sumOcc">—</div></div>
    <div class="sum-card"><div class="sum-label">Chênh lệch</div><div class="sum-value" id="sumGap">—</div></div>
  </div>

  <!-- Basic info -->
  <div class="card">
    <div class="card-title"><i class="fas fa-info-circle" style="color:var(--red)"></i> Thông tin cơ bản</div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">Năm học <span style="color:var(--red)">*</span></label>
        <input type="text" id="academicYear" class="form-control" placeholder="2025-2026" pattern="\d{4}-\d{4}">
      </div>
      <div class="form-group">
        <label class="form-label">Tên kế hoạch <span style="color:var(--red)">*</span></label>
        <input type="text" id="planName" class="form-control" placeholder="VD: Kế hoạch tuyển sinh 2025-2026">
      </div>
      <div class="form-group full">
        <label class="form-label">Mô tả</label>
        <textarea id="description" class="form-control" rows="2" placeholder="Ghi chú về kế hoạch này..."></textarea>
      </div>
    </div>
  </div>

  <!-- Programs -->
  <div class="card">
    <div class="card-title"><i class="fas fa-graduation-cap" style="color:var(--red)"></i> Chỉ tiêu theo ngành</div>
    <p style="font-size:.82rem;color:var(--muted);margin-bottom:1rem">Nhập chỉ tiêu tuyển sinh và tỷ lệ đăng ký KTX cho từng ngành học HUST.</p>
    <div style="overflow-x:auto">
      <table class="prog-table">
        <thead>
          <tr>
            <th>Ngành</th>
            <th>Khoa</th>
            <th>Loại</th>
            <th>Chỉ tiêu</th>
            <th>Tỷ lệ KTX (%)</th>
            <th>Dự kiến KTX</th>
          </tr>
        </thead>
        <tbody id="programsBody">
          <% programs.forEach((p, idx) => { %>
            <tr>
              <td><strong><%= p.name %></strong><br><span style="color:var(--muted);font-size:.75rem"><%= p.code %></span></td>
              <td style="font-size:.82rem"><%= p.faculty %></td>
              <td><span class="type-badge type-<%= p.type %>"><%= p.type %></span></td>
              <td>
                <input type="number" class="quota-input" data-idx="<%= idx %>" data-rate="45"
                  value="<%= p.defaultQuota %>" min="0" max="1000" oninput="recalc()">
              </td>
              <td>
                <input type="number" class="rate-input" data-idx="<%= idx %>"
                  value="45" min="0" max="100" step="1" oninput="recalc()">
              </td>
              <td><span class="expected" id="exp-<%= idx %>"><%= Math.round(p.defaultQuota * 0.45) %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="footer-bar">
    <a href="/admin/enrollment-planning" class="btn btn-outline"><i class="fas fa-times"></i> Huỷ</a>
    <button class="btn btn-red" onclick="savePlan()"><i class="fas fa-save"></i> Tạo kế hoạch</button>
  </div>

</div>
</div>

<script>
const PROGRAMS = <%- JSON.stringify(programs) %>;
const DORM_CAP = 1308;

function recalc() {
  let totalQ = 0, totalD = 0;
  PROGRAMS.forEach((p, idx) => {
    const q = parseInt(document.querySelector(`.quota-input[data-idx="${idx}"]`).value) || 0;
    const r = parseInt(document.querySelector(`.rate-input[data-idx="${idx}"]`).value) || 0;
    const exp = Math.round(q * r / 100);
    document.getElementById(`exp-${idx}`).textContent = exp;
    totalQ += q; totalD += exp;
  });
  document.getElementById('sumQuota').textContent = totalQ.toLocaleString('vi-VN');
  document.getElementById('sumDorm').textContent  = totalD.toLocaleString('vi-VN');
  const occ = totalD > 0 ? Math.round(totalD / DORM_CAP * 1000) / 10 : 0;
  document.getElementById('sumOcc').textContent = occ + '%';
  const gap = totalD - DORM_CAP;
  const gapEl = document.getElementById('sumGap');
  gapEl.textContent = (gap > 0 ? '+' : '') + gap.toLocaleString('vi-VN');
  gapEl.style.color = gap > 0 ? '#E05252' : '#6BAF95';
}

async function savePlan() {
  const ay = document.getElementById('academicYear').value.trim();
  const pn = document.getElementById('planName').value.trim();
  if (!ay.match(/^\d{4}-\d{4}$/)) return alert('Định dạng năm học: YYYY-YYYY');
  if (!pn) return alert('Vui lòng nhập tên kế hoạch');

  const programs = PROGRAMS.map((p, idx) => ({
    programCode: p.code,
    programName: p.name,
    faculty: p.faculty,
    programType: p.type,
    plannedQuota: parseInt(document.querySelector(`.quota-input[data-idx="${idx}"]`).value) || 0,
    dormApplicationRate: parseInt(document.querySelector(`.rate-input[data-idx="${idx}"]`).value) / 100 || 0.45
  }));

  const r = await fetch('/admin/enrollment-planning', {
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ academicYear: ay, planName: pn, description: document.getElementById('description').value, programs })
  });
  const d = await r.json();
  if (d.success) window.location.href = `/admin/enrollment-planning/${d.id}`;
  else alert('Lỗi: ' + d.error);
}

recalc();
</script>
</body>
</html>
