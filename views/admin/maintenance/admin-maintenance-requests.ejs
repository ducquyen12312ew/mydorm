﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Bảo trì - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --red: #C8102E;
            --red-grad: linear-gradient(135deg,#E11D2A,#B20C26);
            --red-dark: #9E0C24;
            --body-bg: linear-gradient(180deg,#FBF8F3,#F5EFE7);
            --card-bg: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            --card-border: #EFE8DF;
            --card-shadow: 0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);
            --text: #2B2320;
            --muted: #7C7166;
            --muted2: #A89C8E;
            --th-bg: #F7F1E8;
            --th-color: #9A8F84;
            --row-alt: #FDFBF8;
            --row-border: #F4EEE5;
            --row-hover: #FAF5EE;
        }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: var(--body-bg);
            color: var(--text);
            min-height: 100vh;
        }

        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }

        /* ── Priority badges ── */
        .priority-badge { padding: 3px 11px; border-radius: 20px; font-size: .75rem; font-weight: 700; letter-spacing: .02em; }
        .priority-low    { background: #F4EFE8; color: #7C7166; border: 1px solid #E0D8CF; }
        .priority-medium { background: #E9F0FE; color: #2563EB; border: 1px solid #AABEF8; }
        .priority-high   { background: #FBF1DC; color: #B07D1A; border: 1px solid #EDD28A; }
        .priority-urgent { background: var(--red-grad); color: #fff; box-shadow: 0 4px 10px -4px rgba(200,16,46,.45); }

        /* ── Status badges ── */
        .status-badge { padding: 3px 11px; border-radius: 20px; font-size: .75rem; font-weight: 700; }
        .status-submitted   { background: #FBF1DC; color: #B07D1A; border: 1px solid #EDD28A; }
        .status-in_progress { background: #E9F0FE; color: #2563EB; border: 1px solid #AABEF8; }
        .status-completed   { background: #E4F6EF; color: #0E9F6E; border: 1px solid #A7DFC8; }
        .status-cancelled   { background: #FCEDEF; color: #C8102E; border: 1px solid #F5C2C7; }

        /* ── Stat cards ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px,1fr));
            gap: 20px; margin-bottom: 28px;
        }
        .stat-card {
            background: var(--card-bg);
            padding: 22px 26px; border-radius: 17px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow);
            transition: transform .25s, box-shadow .25s;
        }
        .stat-card:hover { transform: translateY(-2px); box-shadow: 0 1px 2px rgba(43,35,32,.04),0 28px 44px -22px rgba(43,35,32,.28); }
        .stat-card:nth-child(1) { border-top: 3px solid #C8102E; }
        .stat-card:nth-child(2) { border-top: 3px solid #D9A22B; }
        .stat-card:nth-child(3) { border-top: 3px solid #0E9F6E; }
        .stat-card:nth-child(4) { border-top: 3px solid #A89C8E; }
        .stat-label { font-size: 10.5px; color: var(--th-color); text-transform: uppercase; letter-spacing: .08em; font-weight: 700; margin-bottom: 10px; }
        .stat-value { font-family: 'Inter', sans-serif; font-size: 36px; font-weight: 700; color: var(--text); }
        .stat-card:nth-child(1) .stat-value { color: #C8102E; }
        .stat-card:nth-child(2) .stat-value { color: #D9A22B; }
        .stat-card:nth-child(3) .stat-value { color: #0E9F6E; }
        .stat-card:nth-child(4) .stat-value { color: #7C7166; }

        /* ── Filters bar ── */
        .filters-bar {
            background: var(--card-bg);
            padding: 18px 24px; border-radius: 16px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow);
            margin-bottom: 24px;
            display: flex; flex-wrap: wrap; gap: 14px; align-items: center;
        }
        .filter-group { display: flex; align-items: center; gap: 10px; }
        .filter-label { font-weight: 700; font-size: 13px; color: var(--text); white-space: nowrap; }

        .form-select, .form-control {
            border: 1px solid var(--card-border) !important;
            border-radius: 10px !important;
            color: var(--text) !important;
            font-size: 13px !important;
            box-shadow: none !important;
            transition: border-color .18s !important;
            font-family: 'Inter', sans-serif !important;
        }
        .form-select:focus, .form-control:focus {
            border-color: var(--red) !important;
            box-shadow: 0 0 0 3px rgba(200,16,46,.08) !important;
            outline: none !important;
        }

        /* ── Table card ── */
        .table-card {
            background: var(--card-bg);
            border-radius: 17px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }
        .table { margin-bottom: 0 !important; font-size: 13.5px !important; font-family: 'Inter', sans-serif !important; }
        .table-light thead th, .table thead th {
            background: var(--th-bg) !important;
            color: var(--th-color) !important;
            font-size: 10.5px !important;
            font-weight: 700 !important;
            text-transform: uppercase !important;
            letter-spacing: .07em !important;
            border-bottom: 1px solid var(--row-border) !important;
            border-color: var(--row-border) !important;
            padding: 13px 16px !important;
        }
        .table tbody tr { border-color: var(--row-border) !important; }
        .table tbody tr:nth-child(even) td { background: var(--row-alt) !important; }
        .table-hover tbody tr:hover td { background: var(--row-hover) !important; }
        .table tbody td {
            border-color: var(--row-border) !important;
            color: var(--text) !important;
            vertical-align: middle;
            padding: 12px 16px !important;
        }
        code { background: #F4EFE8; color: var(--red); padding: 2px 7px; border-radius: 5px; font-size: .82em; }

        .action-btn { padding: 5px 12px; font-size: .82rem; border-radius: 9px; margin: 2px; }
        .type-icon  { font-size: 1.1rem; margin-right: 5px; color: var(--muted); }

        /* ── Page header ── */
        .page-header {
            background: var(--card-bg);
            padding: 20px 28px; border-radius: 17px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow);
            margin-bottom: 24px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .page-header h1 {
            font-family: 'Inter', sans-serif;
            font-size: 1.3rem; font-weight: 700;
            color: var(--text); margin: 0;
            display: flex; align-items: center; gap: 14px;
        }
        .page-header-icon {
            width: 48px; height: 48px;
            background: var(--red-grad); color: #fff;
            border-radius: 13px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px;
            box-shadow: 0 6px 18px -6px rgba(200,16,46,.5);
        }

        /* ── Bootstrap button overrides ── */
        .btn-primary {
            background: var(--red-grad) !important; border: none !important;
            color: #fff !important; border-radius: 11px !important;
            font-family: 'Inter', sans-serif !important; font-weight: 600 !important;
            box-shadow: 0 10px 24px -10px rgba(200,16,46,.65) !important;
            transition: transform .18s, box-shadow .18s !important;
        }
        .btn-primary:hover { transform: translateY(-1px) !important; box-shadow: 0 14px 28px -10px rgba(200,16,46,.75) !important; background: var(--red-grad) !important; }
        .btn-secondary { background: #fff !important; border: 1px solid #E7DECF !important; color: var(--text) !important; border-radius: 11px !important; font-weight: 600 !important; }
        .btn-secondary:hover { background: #FBF8F3 !important; border-color: #D4C9BC !important; color: var(--text) !important; }
        .btn-dark { background: var(--text) !important; border: none !important; color: #fff !important; border-radius: 11px !important; font-weight: 600 !important; }
        .btn-dark:hover { opacity: .88 !important; background: var(--text) !important; }

        /* ── Pagination ── */
        .page-item .page-link { border: 1px solid var(--card-border) !important; border-radius: 8px !important; color: var(--text) !important; margin: 0 2px !important; background: #fff !important; font-size: 13px !important; }
        .page-item.active .page-link { background: var(--red-grad) !important; border-color: var(--red) !important; color: #fff !important; box-shadow: 0 6px 14px -6px rgba(200,16,46,.55) !important; }
        .page-item .page-link:hover { background: #FBF8F3 !important; color: var(--text) !important; }

        /* ── Modal ── */
        .modal-content { border-radius: 17px !important; border: 1px solid var(--card-border) !important; border-top: 3px solid var(--red) !important; box-shadow: 0 24px 60px rgba(43,35,32,.18) !important; }
        .modal-header { border-bottom: 1px solid var(--card-border) !important; padding: 18px 22px !important; background: linear-gradient(180deg,#fff,#FCFAF6) !important; }
        .modal-title { font-family: 'Inter', sans-serif !important; font-weight: 700 !important; color: var(--text) !important; font-size: 1.05rem !important; }
        .modal-body { padding: 20px 22px !important; }
        .modal-footer { border-top: 1px solid var(--card-border) !important; padding: 14px 22px !important; }
        .form-label { font-size: 12.5px !important; font-weight: 700 !important; color: var(--text) !important; }
        .spinner-border { color: var(--red) !important; }
    </style>
</head>
<body>
    <%- include('../navbar.ejs', { activeNav: 'requests' }) %>

    <div class="container">
        <div class="page-header">
            <div>
                <h1>
                    <span class="page-header-icon"><i class="fas fa-tools"></i></span>
                    Quản lý bảo trì
                </h1>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Yêu cầu mới</div>
                <div class="stat-value" id="statSubmitted">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Đang xử lý</div>
                <div class="stat-value" id="statInProgress">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Đã hoàn thành</div>
                <div class="stat-value" id="statCompleted">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Từ chối</div>
                <div class="stat-value" id="statRejected">0</div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-bar">
            <div class="filter-group">
                <span class="filter-label">Trạng thái</span>
                <select class="form-select" id="filterStatus" style="width: 190px;">
                    <option value="">Tất cả</option>
                    <option value="submitted">Yêu cầu mới</option>
                    <option value="in_progress">Đang xử lý</option>
                    <option value="completed">Đã hoàn thành</option>
                    <option value="cancelled">Từ chối</option>
                </select>
            </div>
            <div class="filter-group">
                <span class="filter-label">Ưu tiên</span>
                <select class="form-select" id="filterPriority" style="width: 170px;">
                    <option value="">Tất cả</option>
                    <option value="low">Thấp</option>
                    <option value="medium">Trung bình</option>
                    <option value="high">Cao</option>
                    <option value="urgent">Khẩn cấp</option>
                </select>
            </div>
            <div class="filter-group">
                <span class="filter-label">Loại</span>
                <select class="form-select" id="filterType" style="width: 200px;">
                    <option value="">Tất cả</option>
                    <option value="electrical">Điện</option>
                    <option value="plumbing">Nước</option>
                    <option value="hvac">Điều hòa</option>
                    <option value="furniture">Nội thất</option>
                    <option value="door_lock">Cửa/Khóa</option>
                    <option value="window">Cửa sổ</option>
                    <option value="internet">Mạng</option>
                    <option value="cleaning">Vệ sinh</option>
                    <option value="pest_control">Diệt côn trùng</option>
                    <option value="other">Khác</option>
                </select>
            </div>
            <div class="filter-group" style="flex: 1; min-width: 220px;">
                <span class="filter-label">Tìm</span>
                <input type="text" class="form-control" id="filterSearch" placeholder="Mã yêu cầu, phòng...">
            </div>
            <button class="btn btn-primary" onclick="loadRequests()">
                <i class="fas fa-search me-1"></i> Tìm kiếm
            </button>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã YC</th>
                            <th>Loại</th>
                            <th>Tiêu đề</th>
                            <th>KTX - Phòng</th>
                            <th>Người báo</th>
                            <th>Độ ưu tiên</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="requestsTable">
                        <tr>
                            <td colspan="9" class="text-center py-4">
                                <div class="spinner-border text-dark" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        <nav class="mt-3">
            <ul class="pagination justify-content-center" id="pagination"></ul>
        </nav>
    </div>

    <!-- View/Manage Modal -->
    <div class="modal fade" id="viewRequestModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Chi tiết yêu cầu bảo trì</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="requestDetails">
                    <!-- Content loaded via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Complete Modal -->
    <div class="modal fade" id="completeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Hoàn thành yêu cầu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="completeForm">
                        <input type="hidden" id="completeRequestId">
                        <div class="mb-3">
                            <label class="form-label">Ghi chú hoàn thành</label>
                            <textarea class="form-control" name="completionNotes" rows="3"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" onclick="submitComplete()">Đã xử lý</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentPage = 1;
        let currentFilters = {};


        async function loadRequests() {
            currentFilters = {
                status: document.getElementById('filterStatus').value,
                priority: document.getElementById('filterPriority').value,
                type: document.getElementById('filterType').value
            };

            const params = new URLSearchParams({
                page: currentPage,
                limit: 20,
                ...currentFilters
            });

            try {
                const response = await fetch(`/api/admin/maintenance-requests?${params}`);
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                const data = await response.json();

                if (data.success && Array.isArray(data.requests)) {
                    renderTable(data.requests);
                    renderPagination(data.pagination);
                } else {
                    renderTable([]);
                    renderPagination({ pages: 1, page: 1 });
                }
            } catch (error) {
                console.error('Error:', error);
                renderTable([]);
            }
        }

        async function loadStats() {
            try {
                const response = await fetch('/api/admin/maintenance-requests/stats/summary');
                const data = await response.json();

                if (data.success) {
                    const statusMap = data.stats.byStatus.reduce((acc, item) => {
                        acc[item._id] = item.count;
                        return acc;
                    }, {});
                    applyStats(statusMap);
                }
            } catch (error) {
                console.error('Error loading stats:', error);
            }
        }

        function applyStats(map) {
            document.getElementById('statSubmitted').textContent = map.submitted || 0;
            document.getElementById('statInProgress').textContent = map.in_progress || 0;
            document.getElementById('statCompleted').textContent = map.completed || 0;
            document.getElementById('statRejected').textContent = map.cancelled || 0;
        }

        function renderTable(requests) {
            const tbody = document.getElementById('requestsTable');
            
            if (requests.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-center py-4">Không có dữ liệu</td></tr>';
                return;
            }

            const rows = requests.map(r => `
                <tr>
                    <td><code>${r.requestNumber}</code></td>
                    <td><i class="${getTypeIcon(r.type)} type-icon"></i>${getTypeLabel(r.type)}</td>
                    <td>${r.title}</td>
                    <td>${r.dormitoryName}<br><small class="text-muted">Phòng ${r.roomNumber}</small></td>
                    <td>${r.reportedBy.name}<br><small class="text-muted">${r.reportedBy.studentId}</small></td>
                    <td><span class="priority-badge priority-${r.priority}">${getPriorityLabel(r.priority)}</span></td>
                    <td><span class="status-badge status-${r.status}">${getStatusLabel(r.status)}</span></td>
                    <td>${new Date(r.reportedAt).toLocaleDateString('vi-VN')}</td>
                    <td>
                        <button class="btn btn-sm btn-primary action-btn" onclick="viewRequest('${r._id}')">
                            <i class="fas fa-eye"></i>
                        </button>
                    </td>
                </tr>
            `).join('');

            tbody.innerHTML = rows;
        }

        function renderPagination(pagination) {
            const nav = document.getElementById('pagination');
            let html = '';

            for (let i = 1; i <= pagination.pages; i++) {
                html += `
                    <li class="page-item ${i === pagination.page ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>
                    </li>
                `;
            }

            nav.innerHTML = html;
        }

        function changePage(page) {
            currentPage = page;
            loadRequests();
        }

        function getTypeIcon(type) {
            const icons = {
                electrical: 'fas fa-bolt',
                plumbing: 'fas fa-faucet',
                hvac: 'fas fa-fan',
                furniture: 'fas fa-couch',
                door_lock: 'fas fa-door-open',
                window: 'fas fa-window-restore',
                internet: 'fas fa-wifi',
                cleaning: 'fas fa-broom',
                pest_control: 'fas fa-bug',
                other: 'fas fa-wrench'
            };
            return icons[type] || 'fas fa-tools';
        }

        function getTypeLabel(type) {
            const labels = {
                electrical: 'Điện', plumbing: 'Nước', hvac: 'Điều hòa',
                furniture: 'Nội thất', door_lock: 'Cửa/Khóa', window: 'Cửa sổ',
                internet: 'Mạng', cleaning: 'Vệ sinh', pest_control: 'Diệt côn trùng',
                other: 'Khác'
            };
            return labels[type] || type;
        }

        function getPriorityLabel(priority) {
            const labels = { low: 'Thấp', medium: 'TB', high: 'Cao', urgent: 'Khẩn' };
            return labels[priority] || priority;
        }

        function getStatusLabel(status) {
            const labels = {
                submitted: 'Mới',
                in_progress: 'Đang xử lý',
                completed: 'Đã xử lý',
                cancelled: 'Từ chối'
            };
            return labels[status] || status;
        }

        async function viewRequest(id) {
            try {
                const response = await fetch(`/api/admin/maintenance-requests/${id}`);
                const data = await response.json();

                if (data.success) {
                    const r = data.request;
                    let actionsHTML = '';

                    if (r.status === 'submitted') {
                        actionsHTML = `
                            <button class="btn btn-dark" onclick="updateStatus('${r._id}', 'in_progress')">
                                <i class="fas fa-play me-1"></i> Đang xử lý
                            </button>
                            <button class="btn btn-secondary" onclick="updateStatus('${r._id}', 'cancelled')">
                                <i class="fas fa-ban me-1"></i> Từ chối
                            </button>
                        `;
                    } else if (r.status === 'in_progress') {
                        actionsHTML = `
                            <button class="btn btn-primary" onclick="showCompleteModal('${r._id}')">
                                <i class="fas fa-check me-1"></i> Đã xử lý
                            </button>
                            <button class="btn btn-secondary" onclick="updateStatus('${r._id}', 'cancelled')">
                                <i class="fas fa-ban me-1"></i> Từ chối
                            </button>
                        `;
                    }

                    document.getElementById('requestDetails').innerHTML = `
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Mã yêu cầu:</strong> <code>${r.requestNumber}</code><br>
                                <strong>Loại:</strong> ${getTypeLabel(r.type)}<br>
                                <strong>Độ ưu tiên:</strong> <span class="priority-badge priority-${r.priority}">${getPriorityLabel(r.priority)}</span><br>
                                <strong>Trạng thái:</strong> <span class="status-badge status-${r.status}">${getStatusLabel(r.status)}</span>
                            </div>
                            <div class="col-md-6">
                                <strong>KTX:</strong> ${r.dormitoryName}<br>
                                <strong>Phòng:</strong> ${r.roomNumber}<br>
                                <strong>Tầng:</strong> ${r.floorNumber}
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <strong>Tiêu đề:</strong><br>
                            <h5>${r.title}</h5>
                        </div>
                        
                        <div class="mb-3">
                            <strong>Mô tả chi tiết:</strong><br>
                            <p>${r.description}</p>
                        </div>
                        
                        <div class="mb-3">
                            <strong>Người báo cáo:</strong><br>
                            ${r.reportedBy.name} (${r.reportedBy.studentId})<br>
                            <small class="text-muted">SĐT: ${r.reportedBy.phone || 'N/A'}</small><br>
                            <small class="text-muted">Thời gian: ${new Date(r.reportedAt).toLocaleString('vi-VN')}</small>
                        </div>
                        
                        ${r.completionNotes ? `
                            <div class="mb-3">
                                <strong>Ghi chú hoàn thành:</strong><br>
                                <p>${r.completionNotes}</p>
                            </div>
                        ` : ''}
                        
                        <div class="mt-4">
                            ${actionsHTML}
                        </div>
                    `;

                    new bootstrap.Modal(document.getElementById('viewRequestModal')).show();
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        function showCompleteModal(id) {
            document.getElementById('completeRequestId').value = id;
            bootstrap.Modal.getInstance(document.getElementById('viewRequestModal')).hide();
            new bootstrap.Modal(document.getElementById('completeModal')).show();
        }


        async function submitComplete() {
            const form = document.getElementById('completeForm');
            const formData = new FormData(form);
            const data = {
                completionNotes: formData.get('completionNotes')
            };
            const id = document.getElementById('completeRequestId').value;

            try {
                const response = await fetch(`/api/admin/maintenance-requests/${id}/complete`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    alert('Đã hoàn thành yêu cầu');
                    bootstrap.Modal.getInstance(document.getElementById('completeModal')).hide();
                    form.reset();
                    loadRequests();
                    loadStats();
                } else {
                    alert('Lỗi: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Lỗi hệ thống');
            }
        }

        async function updateStatus(id, status) {
            try {
                const response = await fetch(`/api/admin/maintenance-requests/${id}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });

                const data = await response.json();

                if (data.success) {
                    alert('Đã cập nhật trạng thái');
                    bootstrap.Modal.getInstance(document.getElementById('viewRequestModal')).hide();
                    loadRequests();
                    loadStats();
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        // Load initial data (fallback to demo nếu API lỗi)
        loadRequests();
        loadStats();
    </script>
    <%- include('../footer') %>
</body>
</html>