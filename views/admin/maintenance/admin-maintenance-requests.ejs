<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Bảo trì - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #e61a1a;
            --success: #28a745;
            --warning: #ffc107;
            --danger: #dc3545;
            --info: #17a2b8;
        }
        
        body { background: #f5f7fa; font-family: 'Segoe UI', sans-serif; }
        
        .priority-badge { padding: 4px 12px; border-radius: 12px; font-size: 0.85rem; font-weight: 600; }
        .priority-low { background: #d4edda; color: #155724; }
        .priority-medium { background: #fff3cd; color: #856404; }
        .priority-high { background: #f8d7da; color: #721c24; }
        .priority-urgent { background: #721c24; color: white; }
        
        .status-badge { padding: 4px 12px; border-radius: 12px; font-size: 0.85rem; font-weight: 600; }
        .status-submitted { background: #cfe2ff; color: #084298; }
        .status-assigned { background: #fff3cd; color: #856404; }
        .status-in_progress { background: #cff4fc; color: #087990; }
        .status-completed { background: #d4edda; color: #155724; }
        .status-cancelled { background: #e2e3e5; color: #383d41; }
        
        .stat-card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-2px); }
        .stat-value { font-size: 2rem; font-weight: 700; }
        .stat-label { color: #6c757d; font-size: 0.9rem; margin-top: 5px; }
        
        .filter-card { background: white; border-radius: 12px; padding: 20px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        
        .table-card { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        
        .action-btn { padding: 5px 12px; font-size: 0.85rem; border-radius: 6px; margin: 2px; }
        
        .type-icon { font-size: 1.2rem; margin-right: 5px; }
    </style>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-tools me-2"></i>Quản lý Yêu cầu Bảo trì</h2>
            <a href="/admin/dashboard" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Quay lại Dashboard
            </a>
        </div>

        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="stat-card border-start border-4 border-info">
                    <div class="stat-value text-info" id="statSubmitted">0</div>
                    <div class="stat-label">Yêu cầu mới</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card border-start border-4 border-warning">
                    <div class="stat-value text-warning" id="statAssigned">0</div>
                    <div class="stat-label">Đã phân công</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card border-start border-4 border-primary">
                    <div class="stat-value text-primary" id="statInProgress">0</div>
                    <div class="stat-label">Đang xử lý</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card border-start border-4 border-success">
                    <div class="stat-value text-success" id="statCompleted">0</div>
                    <div class="stat-label">Đã hoàn thành</div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filter-card">
            <div class="row g-3">
                <div class="col-md-2">
                    <select class="form-select" id="filterStatus">
                        <option value="">Tất cả trạng thái</option>
                        <option value="submitted">Yêu cầu mới</option>
                        <option value="assigned">Đã phân công</option>
                        <option value="in_progress">Đang xử lý</option>
                        <option value="completed">Đã hoàn thành</option>
                        <option value="cancelled">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" id="filterPriority">
                        <option value="">Tất cả độ ưu tiên</option>
                        <option value="low">Thấp</option>
                        <option value="medium">Trung bình</option>
                        <option value="high">Cao</option>
                        <option value="urgent">Khẩn cấp</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select" id="filterType">
                        <option value="">Tất cả loại</option>
                        <option value="electrical">Điện</option>
                        <option value="plumbing">Nước</option>
                        <option value="hvac">Điều hòa</option>
                        <option value="furniture">Nội thất</option>
                        <option value="door_lock">Cửa/Khóa</option>
                        <option value="window">Cửa sổ</option>
                        <option value="internet">Mạng</option>
                        <option value="cleaning">Vệ sinh</option>
                        <option value="pest_control">Diệt côn trùng</option>
                        <option value="other">Khác</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" class="form-control" id="filterSearch" placeholder="Tìm theo mã yêu cầu, phòng...">
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" onclick="loadRequests()">
                        <i class="fas fa-search me-1"></i> Tìm kiếm
                    </button>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="table-card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã YC</th>
                            <th>Loại</th>
                            <th>Tiêu đề</th>
                            <th>KTX - Phòng</th>
                            <th>Người báo</th>
                            <th>Độ ưu tiên</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="requestsTable">
                        <tr>
                            <td colspan="9" class="text-center py-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        <nav class="mt-3">
            <ul class="pagination justify-content-center" id="pagination"></ul>
        </nav>
    </div>

    <!-- View/Manage Modal -->
    <div class="modal fade" id="viewRequestModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Chi tiết yêu cầu bảo trì</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="requestDetails">
                    <!-- Content loaded via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Assign Staff Modal -->
    <div class="modal fade" id="assignStaffModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Phân công nhân viên</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="assignStaffForm">
                        <input type="hidden" id="assignRequestId">
                        <div class="mb-3">
                            <label class="form-label">Tên nhân viên *</label>
                            <input type="text" class="form-control" name="staffName" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Số điện thoại</label>
                            <input type="text" class="form-control" name="staffPhone">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" onclick="submitAssignment()">Phân công</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Complete Modal -->
    <div class="modal fade" id="completeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Hoàn thành yêu cầu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="completeForm">
                        <input type="hidden" id="completeRequestId">
                        <div class="mb-3">
                            <label class="form-label">Ghi chú hoàn thành</label>
                            <textarea class="form-control" name="completionNotes" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Chi phí thực tế (VNĐ)</label>
                            <input type="number" class="form-control" name="actualCost" min="0" step="1000">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-success" onclick="submitComplete()">Hoàn thành</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentPage = 1;
        let currentFilters = {};

        async function loadRequests() {
            currentFilters = {
                status: document.getElementById('filterStatus').value,
                priority: document.getElementById('filterPriority').value,
                type: document.getElementById('filterType').value
            };

            const params = new URLSearchParams({
                page: currentPage,
                limit: 20,
                ...currentFilters
            });

            try {
                const response = await fetch(`/admin/maintenance-requests?${params}`);
                const data = await response.json();

                if (data.success) {
                    renderTable(data.requests);
                    renderPagination(data.pagination);
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        async function loadStats() {
            try {
                const response = await fetch('/admin/maintenance-requests/stats/summary');
                const data = await response.json();

                if (data.success) {
                    const statusMap = data.stats.byStatus.reduce((acc, item) => {
                        acc[item._id] = item.count;
                        return acc;
                    }, {});

                    document.getElementById('statSubmitted').textContent = statusMap.submitted || 0;
                    document.getElementById('statAssigned').textContent = statusMap.assigned || 0;
                    document.getElementById('statInProgress').textContent = statusMap.in_progress || 0;
                    document.getElementById('statCompleted').textContent = statusMap.completed || 0;
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        function renderTable(requests) {
            const tbody = document.getElementById('requestsTable');
            
            if (requests.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-center py-4">Không có dữ liệu</td></tr>';
                return;
            }

            tbody.innerHTML = requests.map(r => `
                <tr>
                    <td><code>${r.requestNumber}</code></td>
                    <td><i class="${getTypeIcon(r.type)} type-icon"></i>${getTypeLabel(r.type)}</td>
                    <td>${r.title}</td>
                    <td>${r.dormitoryName}<br><small class="text-muted">Phòng ${r.roomNumber}</small></td>
                    <td>${r.reportedBy.name}<br><small class="text-muted">${r.reportedBy.studentId}</small></td>
                    <td><span class="priority-badge priority-${r.priority}">${getPriorityLabel(r.priority)}</span></td>
                    <td><span class="status-badge status-${r.status}">${getStatusLabel(r.status)}</span></td>
                    <td>${new Date(r.reportedAt).toLocaleDateString('vi-VN')}</td>
                    <td>
                        <button class="btn btn-sm btn-primary action-btn" onclick="viewRequest('${r._id}')">
                            <i class="fas fa-eye"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function renderPagination(pagination) {
            const nav = document.getElementById('pagination');
            let html = '';

            for (let i = 1; i <= pagination.pages; i++) {
                html += `
                    <li class="page-item ${i === pagination.page ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>
                    </li>
                `;
            }

            nav.innerHTML = html;
        }

        function changePage(page) {
            currentPage = page;
            loadRequests();
        }

        function getTypeIcon(type) {
            const icons = {
                electrical: 'fas fa-bolt',
                plumbing: 'fas fa-faucet',
                hvac: 'fas fa-fan',
                furniture: 'fas fa-couch',
                door_lock: 'fas fa-door-open',
                window: 'fas fa-window-restore',
                internet: 'fas fa-wifi',
                cleaning: 'fas fa-broom',
                pest_control: 'fas fa-bug',
                other: 'fas fa-wrench'
            };
            return icons[type] || 'fas fa-tools';
        }

        function getTypeLabel(type) {
            const labels = {
                electrical: 'Điện', plumbing: 'Nước', hvac: 'Điều hòa',
                furniture: 'Nội thất', door_lock: 'Cửa/Khóa', window: 'Cửa sổ',
                internet: 'Mạng', cleaning: 'Vệ sinh', pest_control: 'Diệt côn trùng',
                other: 'Khác'
            };
            return labels[type] || type;
        }

        function getPriorityLabel(priority) {
            const labels = { low: 'Thấp', medium: 'TB', high: 'Cao', urgent: 'Khẩn' };
            return labels[priority] || priority;
        }

        function getStatusLabel(status) {
            const labels = {
                submitted: 'Mới', assigned: 'Đã phân', 
                in_progress: 'Đang xử lý', completed: 'Hoàn thành', 
                cancelled: 'Đã hủy'
            };
            return labels[status] || status;
        }

        async function viewRequest(id) {
            try {
                const response = await fetch(`/admin/maintenance-requests/${id}`);
                const data = await response.json();

                if (data.success) {
                    const r = data.request;
                    let actionsHTML = '';

                    if (r.status === 'submitted') {
                        actionsHTML = `
                            <button class="btn btn-primary" onclick="showAssignModal('${r._id}')">
                                <i class="fas fa-user-plus me-1"></i> Phân công
                            </button>
                            <button class="btn btn-secondary" onclick="updateStatus('${r._id}', 'cancelled')">
                                <i class="fas fa-times me-1"></i> Hủy
                            </button>
                        `;
                    } else if (r.status === 'assigned') {
                        actionsHTML = `
                            <button class="btn btn-info" onclick="updateStatus('${r._id}', 'in_progress')">
                                <i class="fas fa-play me-1"></i> Bắt đầu xử lý
                            </button>
                        `;
                    } else if (r.status === 'in_progress') {
                        actionsHTML = `
                            <button class="btn btn-success" onclick="showCompleteModal('${r._id}')">
                                <i class="fas fa-check me-1"></i> Hoàn thành
                            </button>
                        `;
                    }

                    document.getElementById('requestDetails').innerHTML = `
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Mã yêu cầu:</strong> <code>${r.requestNumber}</code><br>
                                <strong>Loại:</strong> ${getTypeLabel(r.type)}<br>
                                <strong>Độ ưu tiên:</strong> <span class="priority-badge priority-${r.priority}">${getPriorityLabel(r.priority)}</span><br>
                                <strong>Trạng thái:</strong> <span class="status-badge status-${r.status}">${getStatusLabel(r.status)}</span>
                            </div>
                            <div class="col-md-6">
                                <strong>KTX:</strong> ${r.dormitoryName}<br>
                                <strong>Phòng:</strong> ${r.roomNumber}<br>
                                <strong>Tầng:</strong> ${r.floorNumber}
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <strong>Tiêu đề:</strong><br>
                            <h5>${r.title}</h5>
                        </div>
                        
                        <div class="mb-3">
                            <strong>Mô tả chi tiết:</strong><br>
                            <p>${r.description}</p>
                        </div>
                        
                        <div class="mb-3">
                            <strong>Người báo cáo:</strong><br>
                            ${r.reportedBy.name} (${r.reportedBy.studentId})<br>
                            <small class="text-muted">SĐT: ${r.reportedBy.phone || 'N/A'}</small><br>
                            <small class="text-muted">Thời gian: ${new Date(r.reportedAt).toLocaleString('vi-VN')}</small>
                        </div>
                        
                        ${r.assignedTo ? `
                            <div class="mb-3">
                                <strong>Nhân viên phụ trách:</strong><br>
                                ${r.assignedTo.name}<br>
                                <small class="text-muted">SĐT: ${r.assignedTo.phone || 'N/A'}</small>
                            </div>
                        ` : ''}
                        
                        ${r.completionNotes ? `
                            <div class="mb-3">
                                <strong>Ghi chú hoàn thành:</strong><br>
                                <p>${r.completionNotes}</p>
                            </div>
                        ` : ''}
                        
                        ${r.actualCost ? `
                            <div class="mb-3">
                                <strong>Chi phí:</strong> ${r.actualCost.toLocaleString()} VNĐ
                            </div>
                        ` : ''}
                        
                        <div class="mt-4">
                            ${actionsHTML}
                        </div>
                    `;

                    new bootstrap.Modal(document.getElementById('viewRequestModal')).show();
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        function showAssignModal(id) {
            document.getElementById('assignRequestId').value = id;
            bootstrap.Modal.getInstance(document.getElementById('viewRequestModal')).hide();
            new bootstrap.Modal(document.getElementById('assignStaffModal')).show();
        }

        function showCompleteModal(id) {
            document.getElementById('completeRequestId').value = id;
            bootstrap.Modal.getInstance(document.getElementById('viewRequestModal')).hide();
            new bootstrap.Modal(document.getElementById('completeModal')).show();
        }

        async function submitAssignment() {
            const form = document.getElementById('assignStaffForm');
            const formData = new FormData(form);
            const data = {
                staffId: Date.now().toString(), // Temporary ID
                staffName: formData.get('staffName'),
                staffPhone: formData.get('staffPhone')
            };
            const id = document.getElementById('assignRequestId').value;

            try {
                const response = await fetch(`/admin/maintenance-requests/${id}/assign`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    alert('Đã phân công nhân viên');
                    bootstrap.Modal.getInstance(document.getElementById('assignStaffModal')).hide();
                    form.reset();
                    loadRequests();
                    loadStats();
                } else {
                    alert('Lỗi: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Lỗi hệ thống');
            }
        }

        async function submitComplete() {
            const form = document.getElementById('completeForm');
            const formData = new FormData(form);
            const data = {
                completionNotes: formData.get('completionNotes'),
                actualCost: parseFloat(formData.get('actualCost')) || 0
            };
            const id = document.getElementById('completeRequestId').value;

            try {
                const response = await fetch(`/admin/maintenance-requests/${id}/complete`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    alert('Đã hoàn thành yêu cầu');
                    bootstrap.Modal.getInstance(document.getElementById('completeModal')).hide();
                    form.reset();
                    loadRequests();
                    loadStats();
                } else {
                    alert('Lỗi: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Lỗi hệ thống');
            }
        }

        async function updateStatus(id, status) {
            try {
                const response = await fetch(`/admin/maintenance-requests/${id}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });

                const data = await response.json();

                if (data.success) {
                    alert('Đã cập nhật trạng thái');
                    bootstrap.Modal.getInstance(document.getElementById('viewRequestModal')).hide();
                    loadRequests();
                    loadStats();
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        // Load initial data
        loadRequests();
        loadStats();
    </script>
</body>
</html>