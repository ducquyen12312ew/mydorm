<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi Tiết Đơn Đăng Ký — Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #d63031;
            --primary-dark: #b71c1c;
            --success: #374151;
            --warning: #d97706;
            --danger: #dc2626;
            --text-dark: #1a2332;
            --text-light: #566070;
            --bg-light: #f8f9fb;
            --border: #e3e7ef;
            --shadow: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
            --shadow-lg: 0 4px 16px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.05);
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--adm-bg, #f4f6f9);
            min-height: 100vh;
            padding: 0;
        }

        .container-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem 2rem;
        }

        .page-header {
            background: white;
            border-radius: var(--adm-radius, 10px);
            padding: 1.1rem 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            border-left: 4px solid var(--primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .page-title {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-dark);
            margin: 0;
        }

        .page-title i {
            color: var(--primary);
            font-size: 1.1rem;
        }

        .btn {
            padding: 0.5rem 1.1rem;
            border-radius: 6px;
            border: none;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.15s, box-shadow 0.15s, border-color 0.15s;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            text-decoration: none;
            font-size: 0.875rem;
            white-space: nowrap;
        }

        .btn-back {
            background: var(--bg-light);
            color: var(--text-dark);
            border: 1px solid var(--border);
        }

        .btn-back:hover {
            background: white;
            border-color: #b8bece;
            color: var(--text-dark);
        }

        .btn-approve {
            background: var(--success);
            color: white;
        }

        .btn-approve:hover {
            background: #047857;
            box-shadow: 0 2px 8px rgba(5, 150, 105, 0.28);
        }

        .btn-reject {
            background: var(--danger);
            color: white;
        }

        .btn-reject:hover {
            background: #b91c1c;
            box-shadow: 0 2px 8px rgba(220, 38, 38, 0.28);
        }

        .btn-secondary {
            background: white;
            color: var(--text-dark);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            border-color: #b8bece;
            background: var(--bg-light);
        }

        .alert-card {
            background: white;
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin-bottom: 1.25rem;
            display: flex;
            gap: 0.875rem;
            align-items: flex-start;
            border-left: 3px solid;
            box-shadow: var(--shadow);
        }

        .alert-danger  { border-left-color: var(--danger);  background: #fef2f2; }
        .alert-warning { border-left-color: var(--warning); background: #fffbeb; }

        .alert-card i { font-size: 1.25rem; flex-shrink: 0; margin-top: 1px; }
        .alert-danger i  { color: var(--danger); }
        .alert-warning i { color: var(--warning); }

        .card {
            background: white;
            border-radius: 10px;
            margin-bottom: 1.25rem;
            box-shadow: var(--shadow);
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .card-header {
            background: var(--bg-light);
            border-bottom: 1px solid var(--border);
            padding: 1rem 1.5rem;
        }

        .card-header-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--text-dark);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin: 0;
        }

        .card-header-title i {
            width: 30px;
            height: 30px;
            background: var(--adm-primary-light, #fef2f2);
            color: var(--primary);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
        }

        .card-body {
            padding: 1.5rem;
        }

        .info-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .info-row:last-child { margin-bottom: 0; }

        .info-item {
            padding: 0.875rem 1rem;
            background: var(--bg-light);
            border-radius: 8px;
            border: 1px solid var(--border);
        }

        .info-label {
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.35rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .info-value {
            font-size: 0.95rem;
            color: var(--text-dark);
            font-weight: 600;
            word-break: break-word;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.28rem 0.72rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .badge-pending  { background: #fffbeb; color: #92400e; border-color: #fde68a; }
        .badge-approved { background: #F3F4F6; color: #374151; border-color: #E5E7EB; }
        .badge-rejected { background: #fef2f2; color: #991b1b; border-color: #fca5a5; }

        .priority-box {
            background: var(--primary);
            color: white;
            border-radius: 10px;
            padding: 1.5rem;
            text-align: center;
            margin-bottom: 1.25rem;
        }

        .priority-score {
            font-size: 3rem;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 0.4rem;
        }

        .priority-label {
            font-size: 0.9rem;
            opacity: 0.9;
            font-weight: 500;
        }

        .policy-list {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .policy-item {
            background: var(--bg-light);
            border-left: 3px solid var(--primary);
            padding: 0.875rem 1.1rem;
            border-radius: 6px;
            font-weight: 500;
            color: var(--text-dark);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .policy-item:hover { background: white; box-shadow: var(--shadow); }

        .policy-name { flex: 1; }

        .policy-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.35rem 0.8rem;
            background: var(--adm-primary-light, #fef2f2);
            color: var(--primary);
            border: 1px solid rgba(214,48,49,0.2);
            border-radius: 5px;
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.15s;
            flex-shrink: 0;
            margin-left: 0.75rem;
        }

        .policy-link:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .no-data {
            text-align: center;
            padding: 2.5rem;
            color: var(--text-light);
        }

        .no-data i {
            font-size: 2.5rem;
            color: #d1d5db;
            margin-bottom: 0.75rem;
            display: block;
        }

        .action-bar {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
            padding: 1.1rem 1.5rem;
            background: var(--bg-light);
            border-top: 1px solid var(--border);
        }

        @media (max-width: 768px) {
            body {
                padding: 1rem 0.5rem;
            }

            .page-header {
                padding: 1.5rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .card-body {
                padding: 1.5rem;
            }

            .info-row {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .action-bar {
                flex-direction: column;
                padding: 1rem;
            }

            .btn {
                width: 100%;
                justify-content: center;
            }

            .policy-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .policy-link {
                margin-left: 0;
                margin-top: 0.75rem;
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card {
            animation: fadeIn 0.5s ease-out;
        }

        .card:nth-child(2) { animation-delay: 0.1s; }
        .card:nth-child(3) { animation-delay: 0.2s; }
        .card:nth-child(4) { animation-delay: 0.3s; }
        .card:nth-child(5) { animation-delay: 0.4s; }
    </style>
</head>
<body>
    <%- include('../navbar', { activeNav: 'applications' }) %>

    <div class="container-wrapper">
        <!-- Header -->
        <div class="page-header">
            <h1 class="page-title">
                <i class="fas fa-file-alt"></i>
                Chi Tiết Đơn Đăng Ký
            </h1>
        </div>

        <% if (application) { %>

        <!-- Alerts -->
        <% if (application.studentExistsInfo) { %>
        <div class="alert-card alert-danger">
            <i class="fas fa-exclamation-triangle"></i>
            <div>
                <strong>Cảnh báo:</strong> Sinh viên đã được cấp phòng tại <strong><%= application.studentExistsInfo.dormitoryName %></strong> - Phòng <strong><%= application.studentExistsInfo.roomNumber %></strong>
            </div>
        </div>
        <% } %>

        <% if (application.isRoomFull) { %>
        <div class="alert-card alert-warning">
            <i class="fas fa-info-circle"></i>
            <div>
                <strong>Thông báo:</strong> Phòng <%= application.roomNumber %> đã đầy (<%= application.currentOccupants %>/<%= application.roomCapacity %> chỗ)
            </div>
        </div>
        <% } %>

        <!-- Student Info -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-user-graduate"></i>
                    Thông Tin Sinh Viên
                </h2>
            </div>
            <div class="card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-id-card"></i> Mã Sinh Viên</div>
                        <div class="info-value"><%= application.studentId %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-user"></i> Họ và Tên</div>
                        <div class="info-value"><%= application.fullName %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-envelope"></i> Email</div>
                        <div class="info-value"><%= application.email %></div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-phone"></i> Số Điện Thoại</div>
                        <div class="info-value"><%= application.phone || 'Chưa cập nhật' %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-graduation-cap"></i> Khoa</div>
                        <div class="info-value"><%= application.faculty %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-calendar"></i> Niên Khóa</div>
                        <div class="info-value"><%= application.academicYear %></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Room Info -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-door-open"></i>
                    Thông Tin Phòng
                </h2>
            </div>
            <div class="card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-building"></i> Ký Túc Xá</div>
                        <div class="info-value"><%= application.dormitoryName %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-door-closed"></i> Số Phòng</div>
                        <div class="info-value"><%= application.roomNumber %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-users"></i> Sức Chứa</div>
                        <div class="info-value"><%= application.currentOccupants %>/<%= application.roomCapacity %> người</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Application Status -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-clipboard-check"></i>
                    Trạng Thái Đơn
                </h2>
            </div>
            <div class="card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-info-circle"></i> Trạng Thái</div>
                        <div class="info-value">
                            <%
                            let badgeClass = 'badge-pending';
                            let statusText = 'Chờ Duyệt';
                            if (application.status === 'approved' || application.status === 'assigned_room') {
                                badgeClass = 'badge-approved';
                                statusText = 'Đã Duyệt';
                            } else if (application.status === 'rejected') {
                                badgeClass = 'badge-rejected';
                                statusText = 'Từ Chối';
                            }
                            %>
                            <span class="badge <%= badgeClass %>">
                                <i class="fas fa-circle" style="font-size: 0.5rem;"></i>
                                <%= statusText %>
                            </span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-clock"></i> Ngày Nộp</div>
                        <div class="info-value"><%= new Date(application.createdAt).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Priority -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-star"></i>
                    Ưu Tiên & Chính Sách
                </h2>
            </div>
            <div class="card-body">
                <% if (application.priorityPolicies && application.priorityPolicies.length > 0) { %>
                <h3 style="font-size: 1rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-dark);">
                    <i class="fas fa-list-check"></i> Chính Sách Áp Dụng
                </h3>
                <div class="policy-list">
                    <% application.priorityPolicies.forEach((policy, idx) => { 
                        let policyName = '';
                        let policyDocument = '';
                        
                        if (typeof policy === 'string') {
                            policyName = policy;
                        } else if (typeof policy === 'object') {
                            if (policy.type === 'poor') policyName = 'Hộ Nghèo';
                            else if (policy.type === 'ethnic') policyName = 'Dân Tộc Thiểu Số' + (policy.ethnicity ? ' - ' + policy.ethnicity : '');
                            else if (policy.type === 'disability') policyName = 'Người Khuyết Tật';
                            else if (policy.type === 'orphan') policyName = 'Trẻ Mồ Côi';
                            else if (policy.type === 'martyr') policyName = 'Con em Liệt Sĩ';
                            else policyName = policy.name || policy.type || 'Chính sách';
                            
                            policyDocument = policy.proofDocument || policy.documentUrl || '';
                        }
                    %>
                    <div class="policy-item">
                        <span class="policy-name"><%= idx + 1 %>. <%= policyName %></span>
                        <% if (policyDocument) { %>
                        <a href="/uploads/priority-claims/<%= policyDocument %>" target="_blank" class="policy-link" title="Tải minh chứng">
                            <i class="fas fa-download"></i> Minh Chứng
                        </a>
                        <% } %>
                    </div>
                    <% }); %>
                </div>
                <% } else { %>
                <div class="no-data">
                    <i class="fas fa-inbox"></i>
                    <p>Không có chính sách ưu tiên</p>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Comments -->
        <% if (application.comments) { %>
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-comment-dots"></i>
                    Ghi Chú
                </h2>
            </div>
            <div class="card-body">
                <div class="info-item">
                    <div class="info-value"><%= application.comments %></div>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Actions -->
        <div class="card">
            <div class="action-bar">
                <% if (application.status === 'pending_review' || application.status === 'pending') { %>
                    <% if (!application.studentExistsInfo && !application.isRoomFull) { %>
                    <button class="btn btn-approve" onclick="approveApp()">
                        <i class="fas fa-check-circle"></i> Duyệt Đơn
                    </button>
                    <% } %>
                    <button class="btn btn-reject" onclick="rejectApp()">
                        <i class="fas fa-times-circle"></i> Từ Chối
                    </button>
                <% } %>
                <a href="/admin/application/<%= application._id %>/review-history" class="btn btn-secondary">
                    <i class="fas fa-history"></i> Lịch Sử
                </a>
            </div>
        </div>

        <% } else { %>
        <div class="alert-card alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <div>Không tìm thấy thông tin đơn đăng ký</div>
        </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const appId = '<%= application ? application._id : "" %>';

        function approveApp() {
            if (!confirm('Bạn có chắc muốn duyệt đơn này?')) return;
            
            fetch(`/admin/applications/${appId}/approve`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(r => r.json())
            .then(d => {
                if (d.ok || d.success) {
                    alert('Duyệt đơn thành công!');
                    location.reload();
                } else {
                    alert('Lỗi: ' + (d.error || d.message || 'Không thể duyệt'));
                }
            })
            .catch(e => {
                console.error(e);
                alert('Lỗi kết nối: ' + e.message);
            });
        }

        function rejectApp() {
            const reason = prompt('Nhập lý do từ chối:');
            if (!reason || !reason.trim()) return;
            
            fetch(`/admin/applications/${appId}/reject`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason })
            })
            .then(r => r.json())
            .then(d => {
                if (d.ok || d.success) {
                    alert('Từ chối đơn thành công!');
                    location.reload();
                } else {
                    alert('Lỗi: ' + (d.error || d.message || 'Không thể từ chối'));
                }
            })
            .catch(e => {
                console.error(e);
                alert('Lỗi kết nối: ' + e.message);
            });
        }
    </script>
</body>
</html>
