﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi Tiết Đơn Đăng Ký — Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Josefin Sans', 'Segoe UI', system-ui, sans-serif;
            min-height: 100vh;
            padding: 0;
        }

        .container-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem 3rem;
        }

        /* Page header — warm card with left gradient bar */
        .container-wrapper .page-header {
            background: var(--adm-surface, linear-gradient(180deg,#fff,#FCFAF6));
            border-radius: var(--adm-radius, 14px);
            padding: 1.2rem 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--adm-shadow, 0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2));
            border: 1px solid var(--adm-border, #EFE8DF);
            border-left: 6px solid var(--adm-primary, #C8102E);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .page-title {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 1.4rem;
            font-weight: 600;
            color: var(--adm-text, #2B2320);
            margin: 0;
        }

        .page-title i {
            color: var(--adm-primary, #C8102E);
            font-size: 1.1rem;
        }

        /* Buttons */
        .btn-back {
            background: #fff;
            color: var(--adm-text, #2B2320);
            border: 1px solid var(--adm-border, #EFE8DF);
        }

        .btn-back:hover {
            background: var(--adm-surface-raised, #FBF8F3);
            border-color: #D8CABA;
            color: var(--adm-text, #2B2320);
        }

        .btn-approve {
            background: linear-gradient(135deg,#1DA86A,#0E9F6E);
            color: #fff;
            box-shadow: 0 8px 20px -8px rgba(14,159,110,.45);
        }

        .btn-approve:hover {
            filter: brightness(1.07);
            transform: translateY(-1px);
        }

        .btn-reject {
            background: var(--adm-primary-grad, linear-gradient(135deg,#E11D2A,#B20C26));
            color: #fff;
            box-shadow: var(--adm-shadow-btn, 0 10px 24px -10px rgba(200,16,46,.65),inset 0 1px 0 rgba(255,255,255,.28));
        }

        .btn-reject:hover {
            filter: brightness(1.06);
            transform: translateY(-1px);
        }

        /* Alert cards */
        .alert-card {
            background: var(--adm-surface, #fff);
            border-radius: var(--adm-radius-sm, 8px);
            padding: 1rem 1.25rem;
            margin-bottom: 1.25rem;
            display: flex;
            gap: 0.875rem;
            align-items: flex-start;
            border-left: 4px solid;
            box-shadow: var(--adm-shadow-sm, 0 1px 2px rgba(43,35,32,.04));
        }

        .alert-danger  { border-left-color: var(--adm-primary, #C8102E); background: var(--adm-red-bg, #FCEDEF); }
        .alert-warning { border-left-color: var(--adm-yellow, #D9A22B); background: var(--adm-yellow-bg, #FBF1DC); }

        .alert-card i { font-size: 1.25rem; flex-shrink: 0; margin-top: 1px; }
        .alert-danger i  { color: var(--adm-primary, #C8102E); }
        .alert-warning i { color: var(--adm-yellow, #D9A22B); }

        /* Cards */
        .container-wrapper .card {
            background: var(--adm-surface, linear-gradient(180deg,#fff,#FCFAF6));
            border-radius: var(--adm-radius, 14px);
            margin-bottom: 1.25rem;
            box-shadow: var(--adm-shadow, 0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2));
            overflow: hidden;
            border: 1px solid var(--adm-border, #EFE8DF);
            animation: fadeInUp 0.45s ease-out both;
        }

        .container-wrapper .card:nth-child(2) { animation-delay: 0.08s; }
        .container-wrapper .card:nth-child(3) { animation-delay: 0.16s; }
        .container-wrapper .card:nth-child(4) { animation-delay: 0.24s; }
        .container-wrapper .card:nth-child(5) { animation-delay: 0.32s; }

        .card-header {
            background: #F7F1E8;
            border-bottom: 1px solid var(--adm-border, #EFE8DF);
            padding: 1rem 1.5rem;
        }

        .card-header-title {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--adm-text, #2B2320);
            display: flex;
            align-items: center;
            gap: 0.6rem;
            margin: 0;
        }

        .card-header-title i {
            width: 30px;
            height: 30px;
            background: var(--adm-primary-light, #FBEBED);
            color: var(--adm-primary, #C8102E);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
            flex-shrink: 0;
        }

        .card-body {
            padding: 1.5rem;
        }

        /* Info grid */
        .info-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .info-row:last-child { margin-bottom: 0; }

        .info-item {
            padding: 0.95rem 1.1rem;
            background: var(--adm-surface-raised, #FBF8F3);
            border-radius: 10px;
            border: 1px solid var(--adm-border, #EFE8DF);
            transition: border-color .18s, box-shadow .18s;
        }

        .info-item:hover {
            border-color: #D8CABA;
            box-shadow: var(--adm-shadow-sm, 0 1px 2px rgba(43,35,32,.04));
        }

        .info-label {
            font-size: 10.5px;
            font-weight: 700;
            color: #9A8F84;
            text-transform: uppercase;
            letter-spacing: 0.10em;
            margin-bottom: 0.4rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .info-value {
            font-size: 0.95rem;
            color: var(--adm-text, #2B2320);
            font-weight: 600;
            word-break: break-word;
        }

        /* Badges */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            padding: 0.28rem 0.75rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .badge::before {
            content: '';
            width: 6px; height: 6px;
            border-radius: 50%;
            background: currentColor;
            flex-shrink: 0;
        }

        .badge-pending  { background: var(--adm-yellow-bg, #FBF1DC); color: #A07010; border-color: var(--adm-yellow-bdr, #EDD28A); }
        .badge-approved { background: var(--adm-green-bg, #E4F6EF);  color: #0B7A54; border-color: var(--adm-green-bdr, #A7DFC8); }
        .badge-rejected { background: var(--adm-red-bg, #FCEDEF);    color: #9B1C30; border-color: var(--adm-red-bdr, #F5C2C7); }

        /* Priority box */
        .priority-box {
            background: var(--adm-primary-grad, linear-gradient(135deg,#E11D2A,#B20C26));
            color: #fff;
            border-radius: var(--adm-radius-sm, 8px);
            padding: 1.5rem;
            text-align: center;
            margin-bottom: 1.25rem;
            box-shadow: var(--adm-shadow-btn, 0 10px 24px -10px rgba(200,16,46,.65));
        }

        .priority-score {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 3rem;
            font-weight: 600;
            line-height: 1;
            margin-bottom: 0.4rem;
        }

        .priority-label {
            font-size: 0.9rem;
            opacity: 0.9;
            font-weight: 500;
        }

        /* Policy list */
        .policy-list {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .policy-item {
            background: var(--adm-surface-raised, #FBF8F3);
            border-left: 3px solid var(--adm-primary, #C8102E);
            padding: 0.875rem 1.1rem;
            border-radius: 8px;
            font-weight: 500;
            color: var(--adm-text, #2B2320);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background .15s, box-shadow .15s;
        }

        .policy-item:hover {
            background: #fff;
            box-shadow: var(--adm-shadow-sm, 0 1px 2px rgba(43,35,32,.04));
        }

        .policy-name { flex: 1; }

        .policy-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.35rem 0.8rem;
            background: var(--adm-primary-light, #FBEBED);
            color: var(--adm-primary, #C8102E);
            border: 1px solid var(--adm-red-bdr, #F5C2C7);
            border-radius: 8px;
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
            transition: all .15s;
            flex-shrink: 0;
            margin-left: 0.75rem;
        }

        .policy-link:hover {
            background: var(--adm-primary-grad, linear-gradient(135deg,#E11D2A,#B20C26));
            color: #fff;
            border-color: var(--adm-primary, #C8102E);
            box-shadow: 0 4px 12px rgba(200,16,46,.2);
        }

        /* No data */
        .no-data {
            text-align: center;
            padding: 2.5rem;
            color: var(--adm-text-soft, #7C7166);
        }

        .no-data i {
            font-size: 2.5rem;
            color: var(--adm-border, #EFE8DF);
            margin-bottom: 0.75rem;
            display: block;
        }

        /* Action bar */
        .action-bar {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            justify-content: flex-end;
            padding: 1.1rem 1.5rem;
            background: #F7F1E8;
            border-top: 1px solid var(--adm-border, #EFE8DF);
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 768px) {
            .container-wrapper .page-header { padding: 1rem 1.25rem; }
            .page-title { font-size: 1.2rem; }
            .card-body { padding: 1.25rem; }
            .info-row { grid-template-columns: 1fr; gap: 0.75rem; }
            .action-bar { flex-direction: column; padding: 1rem; }
            .policy-item { flex-direction: column; align-items: flex-start; }
            .policy-link { margin-left: 0; margin-top: 0.75rem; }
        }
    </style>
</head>
<body>
    <%- include('../navbar', { activeNav: 'applications' }) %>

    <div class="container-wrapper">
        <!-- Header -->
        <div class="page-header">
            <h1 class="page-title">
                <i class="fas fa-file-alt"></i>
                Chi Tiết Đơn Đăng Ký
            </h1>
        </div>

        <% if (application) { %>

        <!-- Alerts -->
        <% if (application.studentExistsInfo) { %>
        <div class="alert-card alert-danger">
            <i class="fas fa-exclamation-triangle"></i>
            <div>
                <strong>Cảnh báo:</strong> Sinh viên đã được cấp phòng tại <strong><%= application.studentExistsInfo.dormitoryName %></strong> - Phòng <strong><%= application.studentExistsInfo.roomNumber %></strong>
            </div>
        </div>
        <% } %>

        <% if (application.isRoomFull) { %>
        <div class="alert-card alert-warning">
            <i class="fas fa-info-circle"></i>
            <div>
                <strong>Thông báo:</strong> Phòng <%= application.roomNumber %> đã đầy (<%= application.currentOccupants %>/<%= application.roomCapacity %> chỗ)
            </div>
        </div>
        <% } %>

        <!-- Student Info -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-user-graduate"></i>
                    Thông Tin Sinh Viên
                </h2>
            </div>
            <div class="card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-id-card"></i> Mã Sinh Viên</div>
                        <div class="info-value"><%= application.studentId %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-user"></i> Họ và Tên</div>
                        <div class="info-value"><%= application.fullName %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-envelope"></i> Email</div>
                        <div class="info-value"><%= application.email %></div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-phone"></i> Số Điện Thoại</div>
                        <div class="info-value"><%= application.phone || 'Chưa cập nhật' %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-graduation-cap"></i> Khoa</div>
                        <div class="info-value"><%= application.faculty %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-calendar"></i> Niên Khóa</div>
                        <div class="info-value"><%= application.academicYear %></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Room Info -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-door-open"></i>
                    Thông Tin Phòng
                </h2>
            </div>
            <div class="card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-building"></i> Ký Túc Xá</div>
                        <div class="info-value"><%= application.dormitoryName %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-door-closed"></i> Số Phòng</div>
                        <div class="info-value"><%= application.roomNumber %></div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-users"></i> Sức Chứa</div>
                        <div class="info-value"><%= application.currentOccupants %>/<%= application.roomCapacity %> người</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Application Status -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-clipboard-check"></i>
                    Trạng Thái Đơn
                </h2>
            </div>
            <div class="card-body">
                <div class="info-row">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-info-circle"></i> Trạng Thái</div>
                        <div class="info-value">
                            <%
                            let badgeClass = 'badge-pending';
                            let statusText = 'Chờ Duyệt';
                            if (application.status === 'approved' || application.status === 'assigned_room') {
                                badgeClass = 'badge-approved';
                                statusText = 'Đã Duyệt';
                            } else if (application.status === 'rejected') {
                                badgeClass = 'badge-rejected';
                                statusText = 'Từ Chối';
                            }
                            %>
                            <span class="badge <%= badgeClass %>">
                                <i class="fas fa-circle" style="font-size: 0.5rem;"></i>
                                <%= statusText %>
                            </span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-clock"></i> Ngày Nộp</div>
                        <div class="info-value"><%= new Date(application.createdAt).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Priority -->
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-star"></i>
                    Ưu Tiên & Chính Sách
                </h2>
            </div>
            <div class="card-body">
                <% if (application.priorityPolicies && application.priorityPolicies.length > 0) { %>
                <h3 style="font-size: 1rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-dark);">
                    <i class="fas fa-list-check"></i> Chính Sách Áp Dụng
                </h3>
                <div class="policy-list">
                    <% application.priorityPolicies.forEach((policy, idx) => { 
                        let policyName = '';
                        let policyDocument = '';
                        
                        if (typeof policy === 'string') {
                            policyName = policy;
                        } else if (typeof policy === 'object') {
                            if (policy.type === 'poor') policyName = 'Hộ Nghèo';
                            else if (policy.type === 'ethnic') policyName = 'Dân Tộc Thiểu Số' + (policy.ethnicity ? ' - ' + policy.ethnicity : '');
                            else if (policy.type === 'disability') policyName = 'Người Khuyết Tật';
                            else if (policy.type === 'orphan') policyName = 'Trẻ Mồ Côi';
                            else if (policy.type === 'martyr') policyName = 'Con em Liệt Sĩ';
                            else policyName = policy.name || policy.type || 'Chính sách';
                            
                            policyDocument = policy.proofDocument || policy.documentUrl || '';
                        }
                    %>
                    <div class="policy-item">
                        <span class="policy-name"><%= idx + 1 %>. <%= policyName %></span>
                        <% if (policyDocument) { %>
                        <a href="/uploads/priority-claims/<%= policyDocument %>" target="_blank" class="policy-link" title="Tải minh chứng">
                            <i class="fas fa-download"></i> Minh Chứng
                        </a>
                        <% } %>
                    </div>
                    <% }); %>
                </div>
                <% } else { %>
                <div class="no-data">
                    <i class="fas fa-inbox"></i>
                    <p>Không có chính sách ưu tiên</p>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Comments -->
        <% if (application.comments) { %>
        <div class="card">
            <div class="card-header">
                <h2 class="card-header-title">
                    <i class="fas fa-comment-dots"></i>
                    Ghi Chú
                </h2>
            </div>
            <div class="card-body">
                <div class="info-item">
                    <div class="info-value"><%= application.comments %></div>
                </div>
            </div>
        </div>
        <% } %>

        <!-- Actions -->
        <div class="card">
            <div class="action-bar">
                <% if (application.status === 'pending_review' || application.status === 'pending') { %>
                    <% if (!application.studentExistsInfo && !application.isRoomFull) { %>
                    <button class="btn btn-approve" onclick="approveApp()">
                        <i class="fas fa-check-circle"></i> Duyệt Đơn
                    </button>
                    <% } %>
                    <button class="btn btn-reject" onclick="rejectApp()">
                        <i class="fas fa-times-circle"></i> Từ Chối
                    </button>
                <% } %>
                <a href="/admin/application/<%= application._id %>/review-history" class="btn btn-secondary">
                    <i class="fas fa-history"></i> Lịch Sử
                </a>
            </div>
        </div>

        <% } else { %>
        <div class="alert-card alert-warning">
            <i class="fas fa-exclamation-triangle"></i>
            <div>Không tìm thấy thông tin đơn đăng ký</div>
        </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const appId = '<%= application ? application._id : "" %>';

        function approveApp() {
            if (!confirm('Bạn có chắc muốn duyệt đơn này?')) return;
            
            fetch(`/admin/applications/${appId}/approve`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(r => r.json())
            .then(d => {
                if (d.ok || d.success) {
                    alert('Duyệt đơn thành công!');
                    location.reload();
                } else {
                    alert('Lỗi: ' + (d.error || d.message || 'Không thể duyệt'));
                }
            })
            .catch(e => {
                console.error(e);
                alert('Lỗi kết nối: ' + e.message);
            });
        }

        function rejectApp() {
            const reason = prompt('Nhập lý do từ chối:');
            if (!reason || !reason.trim()) return;
            
            fetch(`/admin/applications/${appId}/reject`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason })
            })
            .then(r => r.json())
            .then(d => {
                if (d.ok || d.success) {
                    alert('Từ chối đơn thành công!');
                    location.reload();
                } else {
                    alert('Lỗi: ' + (d.error || d.message || 'Không thể từ chối'));
                }
            })
            .catch(e => {
                console.error(e);
                alert('Lỗi kết nối: ' + e.message);
            });
        }
    </script>
    <%- include('../footer') %>
</body>
</html>
