<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Đơn Đăng Ký</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 1.5rem 2rem;
        }

        /* Stats grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card:nth-child(1) { border-left-color: #f59e0b; }
        .stat-card:nth-child(2) { border-left-color: #10b981; }
        .stat-card:nth-child(3) { border-left-color: var(--adm-primary); }
        .stat-card:nth-child(4) { border-left-color: #3b82f6; }

        .stat-card-title {
            font-size: 0.75rem;
            color: var(--adm-text-soft);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .stat-card-value {
            font-size: 2rem;
            font-weight: 700;
            line-height: 1;
            color: var(--adm-text);
        }

        .stat-card:nth-child(1) .stat-card-value { color: #d97706; }
        .stat-card:nth-child(2) .stat-card-value { color: #059669; }
        .stat-card:nth-child(3) .stat-card-value { color: var(--adm-primary); }
        .stat-card:nth-child(4) .stat-card-value { color: #3b82f6; }

        /* Filters */
        .filters-bar {
            padding: 1rem 1.25rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            align-items: center;
        }

        .filter-group {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .filter-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: var(--adm-text-soft);
            white-space: nowrap;
        }

        /* Table */
        .table-container {
            overflow-x: auto;
        }

        .application-table {
            width: 100%;
            border-collapse: collapse;
        }

        .application-table thead tr {
            background: var(--adm-surface-raised);
        }

        .application-table th {
            padding: 0.7rem 1rem;
            text-align: left;
            font-weight: 600;
            font-size: 0.77rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: var(--adm-text-soft);
            border-bottom: 1px solid var(--adm-border);
            white-space: nowrap;
        }

        .application-table td {
            padding: 0.85rem 1rem;
            border-bottom: 1px solid var(--adm-border-soft);
            font-size: 0.88rem;
            color: var(--adm-text);
            vertical-align: middle;
        }

        .application-table tbody tr:last-child td { border-bottom: none; }

        .application-table tbody tr:hover td { background: #fafbfc; }

        .action-buttons { display: flex; gap: 0.3rem; }

        .btn-view {
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
        }

        .btn-view:hover {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

        /* Loading & Empty States */
        .loading-spinner, .empty-state {
            text-align: center;
            padding: 3.5rem 1.5rem;
            color: var(--adm-text-muted);
        }

        .empty-state i {
            font-size: 3rem;
            color: #d1d5db;
            display: block;
            margin-bottom: 0.75rem;
        }

        .empty-state h3 { font-size: 1rem; color: var(--adm-text-soft); margin: 0 0 0.3rem; }
        .empty-state p  { font-size: 0.875rem; margin: 0; }

        @media (max-width: 900px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 600px) {
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .container  { padding: 0 1rem 1.5rem; }
            .filters-bar { flex-direction: column; align-items: stretch; }
            .filter-group { flex-direction: column; align-items: flex-start; }
            .filter-input { width: 100%; }
        }
    </style>
</head>
<body>
    <%- include('../navbar', { activeNav: 'applications' }) %>

    <div class="container">
        <!-- Page Header -->
        <div class="page-header">
            <h1><i class="fas fa-file-alt"></i> Quản Lý Đơn Đăng Ký</h1>
            <button class="btn btn-secondary" id="refreshButton">
                <i class="fas fa-sync-alt"></i> Làm mới
            </button>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-card-title">Đơn chờ duyệt</div>
                <div class="stat-card-value" id="pending-count">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-card-title">Đơn đã duyệt</div>
                <div class="stat-card-value" id="approved-count">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-card-title">Đơn bị từ chối</div>
                <div class="stat-card-value" id="rejected-count">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-card-title">Tổng đơn đăng ký</div>
                <div class="stat-card-value" id="total-count">0</div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-bar">
            <div class="filter-group">
                <label class="filter-label">Trạng thái:</label>
                <select class="filter-input" id="statusFilter">
                    <option value="all">Tất cả</option>
                    <option value="pending">Chờ duyệt</option>
                    <option value="approved">Đã duyệt</option>
                    <option value="rejected">Từ chối</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Tìm kiếm:</label>
                <input type="text" class="filter-input" id="searchInput" placeholder="MSSV hoặc tên...">
            </div>
            <button class="btn btn-primary" id="searchButton">
                <i class="fas fa-search"></i> Tìm kiếm
            </button>
        </div>

        <!-- Table -->
        <div class="table-container">
            <div id="loading-container" class="loading-spinner">
                <div class="spinner"></div>
                <p>Đang tải dữ liệu...</p>
            </div>

            <table class="application-table" id="application-table" style="display: none;">
                <thead>
                    <tr>
                        <th>MSSV</th>
                        <th>Họ và tên</th>
                        <th>Ký túc xá</th>
                        <th>Phòng</th>
                        <th style="text-align: center;">Ưu tiên</th>
                        <th>Ngày đăng ký</th>
                        <th>Trạng thái</th>
                        <th style="text-align: center;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="application-body">
                </tbody>
            </table>

            <div id="empty-state" class="empty-state" style="display: none;">
                <i class="fas fa-file-alt"></i>
                <h3>Không có đơn đăng ký nào</h3>
                <p>Hiện tại không có đơn đăng ký nào phù hợp với bộ lọc đã chọn.</p>
            </div>
        </div>
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const elements = {
                table: document.getElementById('application-table'),
                body: document.getElementById('application-body'),
                loading: document.getElementById('loading-container'),
                empty: document.getElementById('empty-state'),
                pending: document.getElementById('pending-count'),
                approved: document.getElementById('approved-count'),
                rejected: document.getElementById('rejected-count'),
                total: document.getElementById('total-count'),
                statusFilter: document.getElementById('statusFilter'),
                searchInput: document.getElementById('searchInput'),
                searchBtn: document.getElementById('searchButton'),
                refreshBtn: document.getElementById('refreshButton')
            };

            let currentFilter = { status: 'all', search: '' };

            function showLoading() {
                elements.table.style.display = 'none';
                elements.empty.style.display = 'none';
                elements.loading.style.display = 'block';
            }

            function showTable() {
                elements.loading.style.display = 'none';
                elements.empty.style.display = 'none';
                elements.table.style.display = 'table';
            }

            function showEmpty() {
                elements.loading.style.display = 'none';
                elements.table.style.display = 'none';
                elements.empty.style.display = 'block';
            }

            async function fetchData() {
                showLoading();
                try {
                    const response = await fetch(`/admin/applications/list?status=${currentFilter.status}&search=${encodeURIComponent(currentFilter.search)}`);
                    const data = await response.json();

                    if (data.success && data.applications) {
                        renderTable(data.applications);
                        updateStats(data.applications);
                    } else {
                        showEmpty();
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showEmpty();
                }
            }

            function renderTable(apps) {
                if (!apps || apps.length === 0) {
                    showEmpty();
                    return;
                }

                elements.body.innerHTML = apps.map(app => {
                    const date = new Date(app.createdAt).toLocaleDateString('vi-VN');
                    let statusClass = 'status-pending';
                    let statusText = 'Chờ duyệt';

                    if (app.status === 'approved' || app.status === 'approved_waiting_payment') {
                        statusClass = 'status-approved';
                        statusText = 'Đã duyệt';
                    } else if (app.status === 'rejected') {
                        statusClass = 'status-rejected';
                        statusText = 'Từ chối';
                    }
                    
                    // Priority score display - minimalist & professional
                    const priorityScore = app.priorityScore;
                    let priorityHtml = '<span style="color: #999; font-size: 13px;">—</span>';
                    
                    if (priorityScore !== undefined && priorityScore !== null) {
                        let color = '#999';
                        if (priorityScore >= 75) {
                            color = '#e74c3c';
                        } else if (priorityScore >= 60) {
                            color = '#f39c12';
                        } else if (priorityScore >= 45) {
                            color = '#3498db';
                        } else if (priorityScore >= 30) {
                            color = '#95a5a6';
                        }
                        const breakdown = app.priorityBreakdown || {};
                        const breakdownText = Object.entries(breakdown)
                            .map(([key, value]) => `${key}: ${value}`)
                            .join('\\n');
                        priorityHtml = `<span style="font-size: 16px; font-weight: 600; color: ${color}; cursor: help;" title="${breakdownText}">${priorityScore}%</span>`;
                    }

                    return `
                        <tr>
                            <td><strong>${app.studentId || '-'}</strong></td>
                            <td>${app.fullName || '-'}</td>
                            <td>${app.dormitoryName || '-'}</td>
                            <td>${app.roomNumber || '-'}</td>
                            <td style="text-align: center;">${priorityHtml}</td>
                            <td>${date}</td>
                            <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                            <td style="text-align: center;">
                                <a href="/admin/application/${app._id}" class="btn btn-sm btn-view" title="Xem chi tiết & duyệt đơn">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </td>
                        </tr>
                    `;
                }).join('');

                showTable();
            }

            function updateStats(apps) {
                const pending = apps.filter(a => a.status === 'pending').length;
                const approved = apps.filter(a => a.status === 'approved').length;
                const rejected = apps.filter(a => a.status === 'rejected').length;

                elements.pending.textContent = pending;
                elements.approved.textContent = approved;
                elements.rejected.textContent = rejected;
                elements.total.textContent = apps.length;
            }

            elements.searchBtn.addEventListener('click', () => {
                currentFilter.status = elements.statusFilter.value;
                currentFilter.search = elements.searchInput.value;
                fetchData();
            });

            elements.refreshBtn.addEventListener('click', fetchData);

            // Initialize
            fetchData();
        });
    </script>
</body>
</html>
