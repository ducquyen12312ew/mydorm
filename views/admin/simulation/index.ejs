<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Phân bổ Phòng — eDorm</title>
  <%- include('../navbar', { user, activeNav: 'simulation' }) %>
  <style>
    .sim-wrap { max-width: 1100px; margin: 32px auto; padding: 0 24px; }
    .sim-header { margin-bottom: 28px; }
    .sim-header h2 { font-size: 22px; font-weight: 700; color: #111827; margin: 0 0 6px; }
    .sim-header p  { font-size: 14px; color: #6B7280; margin: 0; }

    .ws-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: 16px; margin-bottom: 28px; }
    .ws-card {
      background: #fff; border: 1px solid #E5E7EB; border-radius: 10px;
      padding: 18px 20px;
    }
    .ws-card .label { font-size: 11px; font-weight: 600; color: #9CA3AF; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
    .ws-card .value { font-size: 26px; font-weight: 700; color: #111827; }
    .ws-card .sub   { font-size: 12px; color: #6B7280; margin-top: 3px; }

    .flow-section { background: #fff; border: 1px solid #E5E7EB; border-radius: 12px; padding: 24px 28px; margin-bottom: 24px; }
    .flow-section h3 { font-size: 15px; font-weight: 700; color: #111827; margin: 0 0 16px; }

    .flow-steps { display: flex; align-items: center; gap: 0; flex-wrap: wrap; }
    .flow-step {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      min-width: 100px;
    }
    .flow-step .icon {
      width: 44px; height: 44px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
    }
    .flow-step .icon.prod   { background: #EFF6FF; color: #2563EB; }
    .flow-step .icon.clone  { background: #F0FDF4; color: #16A34A; }
    .flow-step .icon.policy { background: #FEF9C3; color: #CA8A04; }
    .flow-step .icon.reg    { background: #FDF4FF; color: #7C3AED; }
    .flow-step .icon.alloc  { background: #FFF0F2; color: #C8102E; }
    .flow-step .name { font-size: 12px; font-weight: 600; color: #374151; text-align: center; }
    .flow-step .desc { font-size: 11px; color: #9CA3AF; text-align: center; }
    .flow-arrow { color: #D1D5DB; font-size: 18px; padding: 0 8px; margin-bottom: 20px; }

    .action-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; }
    .btn-sim {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 600;
      border: none; cursor: pointer; transition: background .15s, transform .1s;
      text-decoration: none;
    }
    .btn-sim:active { transform: scale(.97); }
    .btn-primary { background: #C8102E; color: #fff; }
    .btn-primary:hover { background: #a50d24; }
    .btn-secondary { background: #fff; color: #374151; border: 1px solid #D1D5DB; }
    .btn-secondary:hover { background: #F9FAFB; }
    .btn-warning { background: #FFF7ED; color: #C2410C; border: 1px solid #FED7AA; }
    .btn-warning:hover { background: #FFEDD5; }
    .btn-sim:disabled { opacity: .5; cursor: not-allowed; }

    .status-pill {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 12px; font-weight: 600; padding: 3px 10px; border-radius: 99px;
    }
    .pill-active   { background: #DCFCE7; color: #15803D; }
    .pill-init     { background: #FEF9C3; color: #854D0E; }
    .pill-none     { background: #F3F4F6; color: #6B7280; }
    .pill-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }

    .section-panel { background: #fff; border: 1px solid #E5E7EB; border-radius: 12px; padding: 24px 28px; margin-bottom: 20px; }
    .section-panel h3 { font-size: 14px; font-weight: 700; color: #111827; margin: 0 0 14px; }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 24px; }
    .info-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid #F3F4F6; }
    .info-row:last-child { border-bottom: none; }
    .info-label { font-size: 13px; color: #6B7280; }
    .info-value { font-size: 13px; font-weight: 600; color: #111827; }

    .toast-container { position: fixed; top: 72px; right: 24px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
    .toast {
      background: #1F2937; color: #F9FAFB; padding: 12px 18px; border-radius: 10px;
      font-size: 13px; min-width: 240px; box-shadow: 0 4px 16px rgba(0,0,0,.18);
      animation: slideIn .2s ease;
    }
    .toast.success { border-left: 4px solid #22C55E; }
    .toast.error   { border-left: 4px solid #EF4444; }
    .toast.info    { border-left: 4px solid #3B82F6; }
    @keyframes slideIn { from { transform: translateX(20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    #spinnerOverlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.35); z-index: 9000;
      align-items: center; justify-content: center; flex-direction: column; gap: 16px;
    }
    #spinnerOverlay.show { display: flex; }
    .spinner { width: 44px; height: 44px; border: 4px solid rgba(255,255,255,.3); border-top-color: #fff; border-radius: 50%; animation: spin .8s linear infinite; }
    .spinner-label { color: #fff; font-size: 15px; font-weight: 600; }
    .spinner-sub   { color: rgba(255,255,255,.7); font-size: 13px; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .ws-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; padding-top: 16px; border-top: 1px solid #F3F4F6; }
  </style>
</head>
<body>

<div id="spinnerOverlay">
  <div class="spinner"></div>
  <div class="spinner-label" id="spinnerLabel">Đang xử lý...</div>
  <div class="spinner-sub" id="spinnerSub"></div>
</div>
<div class="toast-container" id="toastContainer"></div>

<div class="sim-wrap">

  <div class="sim-header">
    <h2>Phân bổ Phòng Tự động</h2>
    <p>Thiết lập tiêu chí, chạy mô phỏng và xem trước kết quả phân bổ phòng ở KTX.</p>
  </div>

  <!-- Flow Diagram -->
  <div class="flow-section">
    <h3><i class="fas fa-route" style="color:#C8102E;margin-right:6px;"></i>Quy trình phân bổ</h3>
    <div class="flow-steps">
      <div class="flow-step">
        <div class="icon prod"><i class="fas fa-database"></i></div>
        <div class="name">Policy</div>
        <div class="desc">Chính sách phân bổ</div>
      </div>
      <div class="flow-arrow"><i class="fas fa-chevron-right"></i></div>
      <div class="flow-step">
        <div class="icon reg"><i class="fas fa-clipboard-list"></i></div>
        <div class="name">Registration</div>
        <div class="desc">Sinh viên đăng ký</div>
      </div>
      <div class="flow-arrow"><i class="fas fa-chevron-right"></i></div>
      <div class="flow-step">
        <div class="icon policy"><i class="fas fa-star"></i></div>
        <div class="name">Priority</div>
        <div class="desc">Tính điểm ưu tiên</div>
      </div>
      <div class="flow-arrow"><i class="fas fa-chevron-right"></i></div>
      <div class="flow-step">
        <div class="icon clone"><i class="fas fa-layer-group"></i></div>
        <div class="name">Allocation</div>
        <div class="desc">Engine phân bổ</div>
      </div>
      <div class="flow-arrow"><i class="fas fa-chevron-right"></i></div>
      <div class="flow-step">
        <div class="icon alloc"><i class="fas fa-bed"></i></div>
        <div class="name">Room Assignment</div>
        <div class="desc">Kết quả phân phòng</div>
      </div>
    </div>
  </div>

  <!-- Workspace Status -->
  <% if (workspaceStatus.hasWorkspace) { %>
  <div class="ws-grid">
    <div class="ws-card">
      <div class="label">Sinh viên</div>
      <div class="value"><%= workspaceStatus.liveCounts.studentCount.toLocaleString() %></div>
      <div class="sub">Đã tải vào hệ thống</div>
    </div>
    <div class="ws-card">
      <div class="label">Ký túc xá</div>
      <div class="value"><%= workspaceStatus.liveCounts.dormCount %></div>
      <div class="sub">Ký túc xá</div>
    </div>
    <div class="ws-card">
      <div class="label">Đăng ký mô phỏng</div>
      <div class="value"><%= workspaceStatus.liveCounts.regCount.toLocaleString() %></div>
      <div class="sub">Sinh viên trong hàng đợi</div>
    </div>
    <div class="ws-card">
      <div class="label">Chính sách</div>
      <div class="value"><%= workspaceStatus.liveCounts.policyCount %></div>
      <div class="sub"><%= workspaceStatus.liveCounts.cycleCount %> chu kỳ</div>
    </div>
  </div>
  <% } %>

  <!-- Actions -->
  <div class="action-row">
    <% if (!workspaceStatus.hasWorkspace) { %>
    <button class="btn-sim btn-primary" onclick="initWorkspace()">
      <i class="fas fa-play"></i> Khởi tạo không gian làm việc
    </button>
    <% } else { %>
    <a href="/admin/simulation/engine" class="btn-sim btn-primary" style="color:#fff;">
      <i class="fas fa-bolt"></i> Mở công cụ phân bổ
    </a>
    <button class="btn-sim btn-warning" onclick="resetWorkspace()">
      <i class="fas fa-redo"></i> Đặt lại &amp; Tải dữ liệu mới
    </button>
    <button class="btn-sim btn-secondary" onclick="refreshStatus()">
      <i class="fas fa-sync"></i> Làm mới
    </button>
    <% } %>
  </div>

  <!-- Workspace Detail -->
  <% if (workspaceStatus.hasWorkspace) { %>
  <div class="section-panel">
    <h3><i class="fas fa-info-circle" style="color:#3B82F6;margin-right:6px;"></i>Thông tin Không gian làm việc</h3>
    <div class="info-grid">
      <div>
        <div class="info-row">
          <span class="info-label">Trạng thái</span>
          <span class="info-value">
            <span class="status-pill pill-active">
              <span class="pill-dot"></span> ACTIVE
            </span>
          </span>
        </div>
        <div class="info-row">
          <span class="info-label">Khởi tạo lúc</span>
          <span class="info-value" id="clonedAt"><%= new Date(workspaceStatus.workspace.clonedAt).toLocaleString('vi-VN') %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Hoạt động gần nhất</span>
          <span class="info-value" id="lastActivity"><%= new Date(workspaceStatus.workspace.lastActivity).toLocaleString('vi-VN') %></span>
        </div>
      </div>
      <div>
        <div class="info-row">
          <span class="info-label">Số phòng</span>
          <span class="info-value"><%= workspaceStatus.workspace.snapshotSummary.roomCount %> phòng</span>
        </div>
      </div>
    </div>

    <!-- Workspace action buttons -->
    <div class="ws-actions">
      <a href="/admin/simulation/engine" class="btn-sim btn-secondary" style="font-size:13px;padding:8px 16px;color:#374151;">
        <i class="fas fa-cogs"></i> Phân phòng lại
      </a>
      <button id="undoBtn" class="btn-sim btn-secondary" style="font-size:13px;padding:8px 16px;display:none;" onclick="undoAllocation()">
        <i class="fas fa-undo" style="color:#DC2626;"></i> Hoàn tác phân phòng
      </button>
    </div>
  </div>

  <% } else { %>
  <div class="section-panel">
    <h3><i class="fas fa-info-circle" style="color:#3B82F6;margin-right:6px;"></i>Chưa khởi tạo</h3>
    <p style="color:#6B7280;font-size:14px;margin:0;">
      Nhấn <strong>Khởi tạo không gian làm việc</strong> để tải dữ liệu sinh viên, ký túc xá và chu kỳ phân bổ vào hệ thống.
    </p>
  </div>
  <% } %>

</div>

<script>
let _latestSnapshotId = null;
let _pollInterval     = null;

function showSpinner(label, sub) {
  document.getElementById('spinnerLabel').textContent = label || 'Đang xử lý...';
  document.getElementById('spinnerSub').textContent   = sub || '';
  document.getElementById('spinnerOverlay').classList.add('show');
}
function hideSpinner() {
  document.getElementById('spinnerOverlay').classList.remove('show');
  if (_pollInterval) { clearInterval(_pollInterval); _pollInterval = null; }
}
function toast(msg, type = 'info') {
  const c = document.getElementById('toastContainer');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 4500);
}

// ── Poll until workspace is ACTIVE, then redirect ─────────────────────────────
function pollForActive() {
  let attempts = 0;
  _pollInterval = setInterval(async () => {
    attempts++;
    try {
      const r = await fetch('/api/simulation/workspace/status');
      const d = await r.json();
      if (d.status === 'ACTIVE') {
        clearInterval(_pollInterval); _pollInterval = null;
        hideSpinner();
        toast('Khởi tạo thành công! Đang chuyển trang...', 'success');
        setTimeout(() => window.location.href = '/admin/simulation/engine', 900);
      }
    } catch(e) {}
    if (attempts >= 40) {
      clearInterval(_pollInterval); _pollInterval = null;
      hideSpinner();
      toast('Quá thời gian chờ. Tải lại trang để kiểm tra.', 'error');
    }
  }, 3000);
}

async function initWorkspace() {
  if (!confirm('Khởi tạo không gian làm việc? Quá trình này mất khoảng 20–40 giây.')) return;
  showSpinner('Đang khởi tạo không gian làm việc...', 'Vui lòng chờ (~30 giây)');
  pollForActive();
  try {
    const res  = await fetch('/api/simulation/workspace/init', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await res.json();
    if (_pollInterval) { clearInterval(_pollInterval); _pollInterval = null; }
    hideSpinner();
    if (data.success) {
      toast('Khởi tạo thành công! Đang chuyển trang...', 'success');
      setTimeout(() => window.location.href = '/admin/simulation/engine', 900);
    } else {
      toast('Lỗi: ' + data.error, 'error');
    }
  } catch (e) {
    if (_pollInterval) { clearInterval(_pollInterval); _pollInterval = null; }
    hideSpinner();
    toast('Lỗi kết nối server', 'error');
  }
}

async function resetWorkspace() {
  if (!confirm('Đặt lại & Tải dữ liệu mới sẽ xóa dữ liệu hiện tại và tải lại từ đầu. Tiếp tục?')) return;
  showSpinner('Đang tải dữ liệu mới...', 'Vui lòng chờ (~30 giây)');
  pollForActive();
  try {
    const res  = await fetch('/api/simulation/workspace/reset', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await res.json();
    if (_pollInterval) { clearInterval(_pollInterval); _pollInterval = null; }
    hideSpinner();
    if (data.success) {
      toast('Đã tải dữ liệu mới! Đang chuyển trang...', 'success');
      setTimeout(() => window.location.href = '/admin/simulation/engine', 900);
    } else {
      toast('Lỗi: ' + data.error, 'error');
    }
  } catch (e) {
    if (_pollInterval) { clearInterval(_pollInterval); _pollInterval = null; }
    hideSpinner();
    toast('Lỗi kết nối server', 'error');
  }
}

async function refreshStatus() {
  showSpinner('Đang cập nhật...', '');
  await new Promise(r => setTimeout(r, 300));
  hideSpinner();
  location.reload();
}

// ── Fetch latest snapshot on page load (to enable undo button) ────────────────
async function checkSnapshot() {
  try {
    const res  = await fetch('/api/simulation/engine/snapshot');
    const data = await res.json();
    if (data.success && data.snapshot && data.snapshot.status === 'APPLIED') {
      _latestSnapshotId = data.snapshot.snapshotId;
      const btn = document.getElementById('undoBtn');
      if (btn) btn.style.display = 'inline-flex';
    }
  } catch(e) {}
}

async function undoAllocation() {
  const snapshotId = _latestSnapshotId;
  if (!snapshotId) return toast('Không có kết quả để hoàn tác', 'error');
  if (!confirm('Hoàn tác phân phòng? Dữ liệu thật sẽ được khôi phục về trước khi áp dụng.')) return;

  showSpinner('Đang hoàn tác phân phòng...', '');
  try {
    const res  = await fetch(`/api/simulation/engine/undo/${snapshotId}`, { method: 'POST' });
    const data = await res.json();
    hideSpinner();
    if (!data.success) return toast('Lỗi: ' + data.error, 'error');
    toast('Đã hoàn tác — dữ liệu thật đã được khôi phục', 'success');
    _latestSnapshotId = null;
    const btn = document.getElementById('undoBtn');
    if (btn) btn.style.display = 'none';
  } catch(e) { hideSpinner(); toast('Lỗi kết nối', 'error'); }
}

// Check snapshot on load if workspace is active
<% if (workspaceStatus.hasWorkspace) { %>
checkSnapshot();
<% } %>
</script>
</body>
</html>
