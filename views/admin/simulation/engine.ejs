<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Simulation Engine — eDorm</title>
  <%- include('../navbar', { user, activeNav: 'simulation' }) %>
  <style>
/* ── Layout ─────────────────────────────────────────────────────────────── */
.eng-wrap{max-width:1200px;margin:28px auto;padding:0 24px;}
.eng-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;}
.eng-head h2{font-size:21px;font-weight:700;color:#111827;margin:0;}
.eng-head p{font-size:13px;color:#6B7280;margin:0;}
.sandbox-badge{display:inline-flex;align-items:center;gap:6px;background:#FFF7ED;color:#C2410C;border:1px solid #FED7AA;font-size:11px;font-weight:600;padding:2px 10px;border-radius:99px;}

/* ── Summary cards ───────────────────────────────────────────────────────── */
.metric-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:24px;}
.metric-card{background:#fff;border:1px solid #E5E7EB;border-radius:10px;padding:16px 18px;}
.metric-card .lbl{font-size:11px;font-weight:600;color:#9CA3AF;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;}
.metric-card .val{font-size:24px;font-weight:700;color:#111827;}
.metric-card .sub{font-size:11px;color:#6B7280;margin-top:2px;}
.metric-card.accent .val{color:#C8102E;}
.metric-card.green  .val{color:#16A34A;}
.metric-card.amber  .val{color:#D97706;}

/* ── Panel cards ─────────────────────────────────────────────────────────── */
.panel{background:#fff;border:1px solid #E5E7EB;border-radius:12px;padding:22px 24px;margin-bottom:20px;}
.panel-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px;}
.panel-hd h3{font-size:14px;font-weight:700;color:#111827;margin:0;display:flex;align-items:center;gap:7px;}
.panel-hd .panel-sub{font-size:12px;color:#6B7280;}

/* ── Cohort shift visual ─────────────────────────────────────────────────── */
.cohort-grid{display:flex;gap:0;align-items:center;flex-wrap:wrap;justify-content:center;padding:8px 0;}
.cohort-box{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  min-width:90px;padding:12px 10px;border-radius:10px;text-align:center;
}
.cohort-box .yr-badge{font-size:11px;font-weight:700;padding:2px 8px;border-radius:99px;margin-bottom:2px;}
.cohort-box .yr-count{font-size:26px;font-weight:800;}
.cohort-box .yr-label{font-size:11px;color:#6B7280;}
.cohort-arrow{font-size:20px;color:#D1D5DB;padding:0 6px;margin-bottom:14px;}
.yr1  {background:#EFF6FF;}.yr1  .yr-badge{background:#2563EB;color:#fff;}.yr1  .yr-count{color:#1D4ED8;}
.yr2  {background:#F0FDF4;}.yr2  .yr-badge{background:#16A34A;color:#fff;}.yr2  .yr-count{color:#15803D;}
.yr3  {background:#FDF4FF;}.yr3  .yr-badge{background:#7C3AED;color:#fff;}.yr3  .yr-count{color:#6D28D9;}
.yr4p {background:#FFF7ED;}.yr4p .yr-badge{background:#D97706;color:#fff;}.yr4p .yr-count{color:#B45309;}
.yr5p {background:#FFF1F2;}.yr5p .yr-badge{background:#9CA3AF;color:#fff;}.yr5p .yr-count{color:#6B7280;}

/* ── Form elements ───────────────────────────────────────────────────────── */
.form-row{display:flex;gap:16px;flex-wrap:wrap;align-items:flex-end;margin-bottom:14px;}
.form-group{display:flex;flex-direction:column;gap:5px;min-width:140px;}
.form-group label{font-size:12px;font-weight:600;color:#374151;}
.form-group input,.form-group select{
  border:1px solid #D1D5DB;border-radius:7px;padding:7px 10px;
  font-size:13px;color:#111827;outline:none;
  transition:border-color .15s;
}
.form-group input:focus,.form-group select:focus{border-color:#C8102E;}

/* ── Weight sliders ──────────────────────────────────────────────────────── */
.weight-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px;}
.weight-row{display:flex;flex-direction:column;gap:5px;}
.weight-label{display:flex;justify-content:space-between;align-items:center;}
.weight-label span{font-size:12px;font-weight:600;color:#374151;}
.weight-label .wval{font-size:13px;font-weight:700;color:#C8102E;min-width:32px;text-align:right;}
.weight-row input[type=range]{width:100%;accent-color:#C8102E;cursor:pointer;}
.weight-hint{font-size:11px;color:#9CA3AF;}

/* ── Buttons ─────────────────────────────────────────────────────────────── */
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:600;border:none;cursor:pointer;transition:background .15s,transform .1s;}
.btn:active{transform:scale(.97);}
.btn:disabled{opacity:.5;cursor:not-allowed;}
.btn-primary{background:#C8102E;color:#fff;}
.btn-primary:hover:not(:disabled){background:#a50d24;}
.btn-secondary{background:#fff;color:#374151;border:1px solid #D1D5DB;}
.btn-secondary:hover:not(:disabled){background:#F9FAFB;}
.btn-indigo{background:#4F46E5;color:#fff;}
.btn-indigo:hover:not(:disabled){background:#4338CA;}
.btn-green{background:#16A34A;color:#fff;}
.btn-green:hover:not(:disabled){background:#15803D;}

/* ── Tabs ────────────────────────────────────────────────────────────────── */
.tab-nav{display:flex;gap:0;border-bottom:2px solid #E5E7EB;margin-bottom:20px;overflow-x:auto;}
.tab-btn{
  padding:9px 18px;font-size:13px;font-weight:600;color:#6B7280;
  border:none;background:none;cursor:pointer;white-space:nowrap;
  border-bottom:2px solid transparent;margin-bottom:-2px;
  transition:color .15s;
}
.tab-btn:hover{color:#111827;}
.tab-btn.active{color:#C8102E;border-bottom-color:#C8102E;}
.tab-panel{display:none;}
.tab-panel.active{display:block;}

/* ── Tables ──────────────────────────────────────────────────────────────── */
.data-table{width:100%;border-collapse:collapse;font-size:13px;}
.data-table th{background:#F9FAFB;font-size:11px;font-weight:700;color:#6B7280;text-transform:uppercase;letter-spacing:.05em;padding:8px 12px;text-align:left;border-bottom:1px solid #E5E7EB;}
.data-table td{padding:9px 12px;border-bottom:1px solid #F3F4F6;color:#374151;vertical-align:middle;}
.data-table tr:last-child td{border-bottom:none;}
.data-table tr:hover td{background:#F9FAFB;}
.tbl-wrap{overflow-x:auto;border-radius:8px;border:1px solid #E5E7EB;}

/* ── Heatmap ─────────────────────────────────────────────────────────────── */
.heatmap-dorm{margin-bottom:24px;}
.heatmap-dorm-hd{font-size:14px;font-weight:700;color:#111827;margin-bottom:12px;display:flex;align-items:center;gap:10px;}
.heatmap-gender-badge{font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;}
.badge-male  {background:#EFF6FF;color:#1D4ED8;}
.badge-female{background:#FDF4FF;color:#6D28D9;}
.badge-mixed {background:#F0FDF4;color:#15803D;}
.floor-wrap{margin-bottom:12px;}
.floor-label{font-size:11px;font-weight:700;color:#9CA3AF;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;}
.rooms-row{display:flex;flex-wrap:wrap;gap:6px;}
.room-cell{
  width:44px;height:44px;border-radius:6px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:10px;font-weight:700;cursor:default;
  position:relative;transition:transform .12s;
  border:1.5px solid transparent;
}
.room-cell:hover{transform:scale(1.15);z-index:10;}
.room-empty  {background:#DCFCE7;color:#15803D;border-color:#BBF7D0;}
.room-partial{background:#FEF9C3;color:#854D0E;border-color:#FDE68A;}
.room-high   {background:#FED7AA;color:#9A3412;border-color:#FDBA74;}
.room-full   {background:#FEE2E2;color:#991B1B;border-color:#FECACA;}
.room-cell .r-num{font-size:9px;font-weight:600;}
.room-cell .r-occ{font-size:9px;}

/* ── Year-group stats ────────────────────────────────────────────────────── */
.yg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;}
.yg-card{border-radius:10px;padding:14px 16px;border:1.5px solid;}
.yg-card .yg-title{font-size:12px;font-weight:700;margin-bottom:10px;}
.yg-card .yg-stat{display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px solid rgba(0,0,0,.06);}
.yg-card .yg-stat:last-child{border:none;font-weight:700;}
.yg-yr1  {background:#EFF6FF;border-color:#BFDBFE;}.yg-yr1  .yg-title{color:#1D4ED8;}
.yg-yr2  {background:#F0FDF4;border-color:#BBF7D0;}.yg-yr2  .yg-title{color:#15803D;}
.yg-yr3  {background:#FDF4FF;border-color:#E9D5FF;}.yg-yr3  .yg-title{color:#6D28D9;}
.yg-yr4p {background:#FFF7ED;border-color:#FDE68A;}.yg-yr4p .yg-title{color:#B45309;}
.yg-yr5p {background:#F9FAFB;border-color:#E5E7EB;}.yg-yr5p .yg-title{color:#6B7280;}

/* ── Progress bar ────────────────────────────────────────────────────────── */
.prog-bar{height:8px;background:#F3F4F6;border-radius:99px;overflow:hidden;margin-top:6px;}
.prog-fill{height:100%;border-radius:99px;transition:width .4s ease;}
.fill-green{background:#22C55E;}
.fill-amber{background:#FBBF24;}
.fill-red  {background:#EF4444;}

/* ── Priority score pill ──────────────────────────────────────────────────── */
.score-pill{display:inline-flex;align-items:center;justify-content:center;min-width:36px;padding:2px 8px;border-radius:99px;font-size:12px;font-weight:700;}
.score-high  {background:#DCFCE7;color:#15803D;}
.score-mid   {background:#FEF9C3;color:#854D0E;}
.score-low   {background:#FEE2E2;color:#991B1B;}

/* ── Toast ───────────────────────────────────────────────────────────────── */
.toast-box{position:fixed;top:70px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast{background:#1F2937;color:#F9FAFB;padding:11px 16px;border-radius:9px;font-size:13px;min-width:220px;box-shadow:0 4px 16px rgba(0,0,0,.2);animation:tslide .2s ease;}
.toast.ok {border-left:4px solid #22C55E;}
.toast.err{border-left:4px solid #EF4444;}
.toast.inf{border-left:4px solid #3B82F6;}
@keyframes tslide{from{transform:translateX(16px);opacity:0}to{transform:translateX(0);opacity:1}}

/* ── Spinner overlay ─────────────────────────────────────────────────────── */
#spin{display:none;position:fixed;inset:0;background:rgba(0,0,0,.38);z-index:9000;align-items:center;justify-content:center;flex-direction:column;gap:14px;}
#spin.on{display:flex;}
.spin-ring{width:42px;height:42px;border:4px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:rot .8s linear infinite;}
.spin-lbl{color:#fff;font-size:14px;font-weight:600;}
@keyframes rot{to{transform:rotate(360deg)}}

/* ── Legend ──────────────────────────────────────────────────────────────── */
.hm-legend{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:14px;}
.hm-leg-item{display:flex;align-items:center;gap:5px;font-size:12px;color:#374151;}
.hm-leg-dot{width:14px;height:14px;border-radius:3px;}

/* Heatmap summary bar */
.dorm-summary{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:10px;}
.dorm-stat{font-size:12px;color:#6B7280;}
.dorm-stat b{color:#111827;font-weight:600;}

/* ── Action buttons in table ─────────────────────────────────────────────── */
.act-btn{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:5px;font-size:11px;font-weight:600;border:none;cursor:pointer;transition:background .12s;}
.act-move{background:#EFF6FF;color:#1D4ED8;}.act-move:hover{background:#DBEAFE;}
.act-remove{background:#FFF1F2;color:#BE123C;}.act-remove:hover{background:#FFE4E6;}
.act-promote{background:#F0FDF4;color:#15803D;}.act-promote:hover{background:#DCFCE7;}

/* ── Apply/Undo panel ────────────────────────────────────────────────────── */
.apply-panel{background:#fff;border:2px solid #16A34A;border-radius:12px;padding:22px 24px;margin-bottom:20px;}
.apply-panel.applied{border-color:#D97706;}
.apply-panel h3{font-size:14px;font-weight:700;color:#111827;margin:0 0 8px;display:flex;align-items:center;gap:7px;}
.apply-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-top:14px;}
.apply-stats{font-size:12px;color:#6B7280;background:#F9FAFB;border-radius:7px;padding:8px 12px;flex:1;min-width:200px;}
.apply-stats b{color:#111827;}
.btn-danger{background:#DC2626;color:#fff;}.btn-danger:hover:not(:disabled){background:#B91C1C;}
.btn-amber{background:#D97706;color:#fff;}.btn-amber:hover:not(:disabled){background:#B45309;}

/* ── Modal ───────────────────────────────────────────────────────────────── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:9500;align-items:center;justify-content:center;}
.modal-overlay.on{display:flex;}
.modal-box{background:#fff;border-radius:14px;padding:24px 28px;max-width:480px;width:90%;box-shadow:0 12px 40px rgba(0,0,0,.25);}
.modal-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.modal-hd h4{font-size:15px;font-weight:700;color:#111827;margin:0;}
.modal-close{background:none;border:none;font-size:18px;color:#9CA3AF;cursor:pointer;padding:0;}
.modal-body{display:flex;flex-direction:column;gap:12px;}
.modal-foot{display:flex;justify-content:flex-end;gap:10px;margin-top:18px;}
  </style>
</head>
<body>

<div id="spin"><div class="spin-ring"></div><div class="spin-lbl" id="spinLbl">Đang xử lý...</div></div>
<div class="toast-box" id="toastBox"></div>

<div class="eng-wrap">

  <!-- Header -->
  <div class="eng-head">
    <div>
      <div style="margin-bottom:8px;">
        <span class="sandbox-badge"><i class="fas fa-flask"></i> SANDBOX</span>
        &nbsp;
        <a href="/admin/simulation" style="font-size:12px;color:#6B7280;text-decoration:none;">
          <i class="fas fa-arrow-left"></i> Workspace
        </a>
      </div>
      <h2><i class="fas fa-cogs" style="color:#C8102E;margin-right:6px;"></i>Simulation Engine</h2>
      <p>Phân bổ thử nghiệm — không ảnh hưởng dữ liệu thật</p>
    </div>
    <div style="text-align:right;">
      <div style="font-size:12px;color:#6B7280;">Workspace ID</div>
      <div style="font-size:11px;font-family:monospace;color:#9CA3AF;"><%= workspace._id %></div>
    </div>
  </div>

  <!-- ══ STEP 1: COHORT SHIFT + SEED YEAR 1 ════════════════════════════════ -->
  <div class="panel">
    <div class="panel-hd">
      <h3><i class="fas fa-users-cog" style="color:#4F46E5;"></i> Bước 1 — Cohort Shift & Seed Năm 1</h3>
      <span class="panel-sub">Phân loại lại khóa và tạo sinh viên nhập học mới</span>
    </div>

    <!-- Cohort visualization -->
    <div class="cohort-grid" id="cohortGrid">
      <%
        const dist = distribution;
        const cohortBoxes = [
          { cls:'yr1',  label:'Năm 1',  count: dist.year1,     badge:'K' + (new Date().getFullYear()-2020+66) },
          { cls:'yr2',  label:'Năm 2',  count: dist.year2,     badge:'Năm 2' },
          { cls:'yr3',  label:'Năm 3',  count: dist.year3,     badge:'Năm 3' },
          { cls:'yr4p', label:'Năm 4+', count: dist.year4_plus, badge:'Năm 4+' },
          { cls:'yr5p', label:'Năm 5+', count: dist.year5plus, badge:'Ra KTX' },
        ];
      %>
      <% cohortBoxes.forEach((b, idx) => { %>
        <% if (idx > 0) { %><div class="cohort-arrow"><i class="fas fa-chevron-right"></i></div><% } %>
        <div class="cohort-box <%= b.cls %>">
          <div class="yr-badge"><%= b.badge %></div>
          <div class="yr-count" id="cnt-<%= b.cls %>"><%= b.count %></div>
          <div class="yr-label"><%= b.label %></div>
        </div>
      <% }) %>
    </div>

    <div style="height:1px;background:#F3F4F6;margin:16px 0;"></div>

    <div class="form-row">
      <div class="form-group">
        <label>Số sinh viên Năm 1</label>
        <input type="number" id="year1Count" value="200" min="50" max="500"/>
      </div>
      <div class="form-group">
        <label>Năm nhập học</label>
        <input type="number" id="enrollYear" value="<%= new Date().getFullYear() %>" min="2020" max="2030"/>
      </div>
      <div class="form-group">
        <label>Năm học mô phỏng</label>
        <input type="text" id="simYear" value="<%= new Date().getFullYear() %>-<%= new Date().getFullYear()+1 %>" placeholder="2025-2026"/>
      </div>
      <div class="form-group" style="justify-content:flex-end;">
        <button class="btn btn-indigo" onclick="seedYear1()">
          <i class="fas fa-user-plus"></i> Seed Năm 1 + Cohort Shift
        </button>
      </div>
    </div>
  </div>

  <!-- ══ STEP 2: PRIORITY ENGINE CONFIG ════════════════════════════════════ -->
  <div class="panel">
    <div class="panel-hd">
      <h3><i class="fas fa-sliders-h" style="color:#D97706;"></i> Bước 2 — Cấu hình Priority Engine</h3>
      <span class="panel-sub">Điều chỉnh trọng số cho từng tiêu chí ưu tiên</span>
    </div>

    <div class="weight-grid">

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-graduation-cap"></i> Năm học</span>
          <span class="wval" id="lbl-year">1.0</span>
        </div>
        <input type="range" id="w-year" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('year',this.value)"/>
        <div class="weight-hint">Năm 1 ưu tiên cao nhất (+30), Năm 5+ thấp nhất (−15)</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-map-marker-alt"></i> Khoảng cách</span>
          <span class="wval" id="lbl-distance">1.0</span>
        </div>
        <input type="range" id="w-distance" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('distance',this.value)"/>
        <div class="weight-hint">>500km +30 | 200–500km +20 | 50–200km +10 | <50km −10</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-home"></i> Hoàn cảnh gia đình</span>
          <span class="wval" id="lbl-family">1.0</span>
        </div>
        <input type="range" id="w-family" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('family',this.value)"/>
        <div class="weight-hint">Hộ nghèo +25 | Bình thường 0 | Khá giả −10</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-id-card"></i> Chính sách ưu tiên</span>
          <span class="wval" id="lbl-policy">1.0</span>
        </div>
        <input type="range" id="w-policy" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('policy',this.value)"/>
        <div class="weight-hint">Khó khăn TC +20 | Dân tộc +15 | Khuyết tật +25 | Nông thôn +10</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-flag"></i> Dân tộc thiểu số</span>
          <span class="wval" id="lbl-ethnicity">0.5</span>
        </div>
        <input type="range" id="w-ethnicity" min="0" max="2" step="0.1" value="0.5"
               oninput="updateWeight('ethnicity',this.value)"/>
        <div class="weight-hint">Dân tộc thiểu số +10 × hệ số này</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-ban"></i> Lịch sử vi phạm</span>
          <span class="wval" id="lbl-violation">1.0</span>
        </div>
        <input type="range" id="w-violation" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('violation',this.value)"/>
        <div class="weight-hint">Sạch +5 | Nhẹ −10 | Nặng −25 | Nghiêm trọng −40</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-history"></i> Lịch sử KTX</span>
          <span class="wval" id="lbl-dormHistory">0.3</span>
        </div>
        <input type="range" id="w-dormHistory" min="0" max="2" step="0.1" value="0.3"
               oninput="updateWeight('dormHistory',this.value)"/>
        <div class="weight-hint">Chưa từng ở +5 | Tốt +3 | Xấu −10 × hệ số</div>
      </div>

    </div>
  </div>

  <!-- ══ STEP 3: RUN ════════════════════════════════════════════════════════ -->
  <div class="panel" style="border:2px solid #C8102E;">
    <div class="panel-hd">
      <h3><i class="fas fa-play-circle" style="color:#C8102E;"></i> Bước 3 — Chạy Simulation</h3>
    </div>
    <p style="font-size:13px;color:#6B7280;margin:0 0 16px;">
      Engine sẽ tính điểm ưu tiên toàn bộ sinh viên, xếp hạng, rồi phân phòng tuần tự theo thứ tự điểm.
      Kết quả hiển thị bên dưới — <strong>không ghi vào dữ liệu thật</strong>.
    </p>
    <button class="btn btn-primary" onclick="runSimulation()" id="btnRun">
      <i class="fas fa-bolt"></i> Chạy Allocation Preview
    </button>
  </div>

  <!-- ══ RESULTS ════════════════════════════════════════════════════════════ -->
  <div id="resultsSection" style="display:<%= latestRun ? 'block' : 'none' %>;">
    <div class="panel">
      <div class="panel-hd">
        <h3><i class="fas fa-chart-bar" style="color:#16A34A;"></i> Kết quả Simulation</h3>
        <div style="display:flex;align-items:center;gap:10px;">
          <span class="panel-sub" id="runInfo">
            <% if (latestRun) { %>
              Run: <strong><%= latestRun.runId %></strong> &nbsp;|&nbsp;
              <%= new Date(latestRun.runAt).toLocaleString('vi-VN') %>
            <% } %>
          </span>
        </div>
      </div>

      <!-- Top metrics -->
      <div class="metric-grid" id="metricGrid">
        <% if (latestRun) { const s = latestRun.summary; %>
        <div class="metric-card">
          <div class="lbl">Tổng SV trong Queue</div>
          <div class="val"><%= s.totalStudentsInQueue.toLocaleString() %></div>
          <div class="sub">Đã đăng ký mô phỏng</div>
        </div>
        <div class="metric-card green">
          <div class="lbl">Được phân phòng</div>
          <div class="val"><%= s.allocated.toLocaleString() %></div>
          <div class="sub"><%= latestRun.byYearGroup?.year1?.allocated || 0 %> SV Năm 1</div>
        </div>
        <div class="metric-card accent">
          <div class="lbl">Danh sách chờ</div>
          <div class="val"><%= s.waitlisted.toLocaleString() %></div>
          <div class="sub">Không đủ giường</div>
        </div>
        <div class="metric-card">
          <div class="lbl">Tổng giường</div>
          <div class="val"><%= s.totalBeds.toLocaleString() %></div>
          <div class="sub"><%= s.totalRooms %> phòng</div>
        </div>
        <div class="metric-card amber">
          <div class="lbl">Occupancy trước</div>
          <div class="val"><%= s.occupancyRateBefore %>%</div>
          <div class="sub">Trước khi sim</div>
        </div>
        <div class="metric-card">
          <div class="lbl">Fill Rate</div>
          <div class="val"><%= s.fillRate %>%</div>
          <div class="sub">Giường trống đã lấp</div>
        </div>
        <% } %>
      </div>

      <!-- Tabs -->
      <div class="tab-nav">
        <button class="tab-btn active" onclick="switchTab('byYearGroup',this)">Theo Khóa</button>
        <button class="tab-btn" onclick="switchTab('accepted',this)">Được Nhận</button>
        <button class="tab-btn" onclick="switchTab('rejected',this)">Bị Loại</button>
        <button class="tab-btn" onclick="switchTab('heatmap',this)">Heatmap Phòng</button>
      </div>

      <!-- Tab: By Year Group -->
      <div class="tab-panel active" id="tab-byYearGroup">
        <div class="yg-grid" id="ygGrid">
          <% if (latestRun && latestRun.byYearGroup) {
            const ygLabels = { year1:'Năm 1', year2:'Năm 2', year3:'Năm 3', year4_plus:'Năm 4+', year5plus:'Năm 5+ (Ra KTX)' };
            const ygCls   = { year1:'yg-yr1', year2:'yg-yr2', year3:'yg-yr3', year4_plus:'yg-yr4p', year5plus:'yg-yr5p' };
            Object.entries(latestRun.byYearGroup).forEach(([yg, stat]) => {
              if (!stat.total && yg === 'year5plus') return;
          %>
          <div class="yg-card <%= ygCls[yg] %>">
            <div class="yg-title"><%= ygLabels[yg] || yg %></div>
            <div class="yg-stat"><span>Đăng ký</span><span><%= stat.total %></span></div>
            <div class="yg-stat"><span>Được nhận</span><span style="color:#16A34A;font-weight:700;"><%= stat.allocated %></span></div>
            <div class="yg-stat"><span>Chờ</span><span style="color:#D97706;"><%= stat.waitlisted %></span></div>
            <div class="yg-stat"><span>Tỷ lệ nhận</span><span><%= stat.rate %>%</span></div>
            <div class="prog-bar">
              <div class="prog-fill <%= stat.rate >= 80 ? 'fill-green' : stat.rate >= 50 ? 'fill-amber' : 'fill-red' %>"
                   style="width:<%= stat.rate %>%"></div>
            </div>
          </div>
          <% }); } %>
        </div>
      </div>

      <!-- Tab: Accepted -->
      <div class="tab-panel" id="tab-accepted">
        <div style="margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <input type="text" id="filterAccepted" placeholder="Tìm kiếm MSSV, tên..."
                 oninput="filterTable('acceptedTbl',this.value)"
                 style="border:1px solid #D1D5DB;border-radius:7px;padding:6px 12px;font-size:13px;outline:none;min-width:200px;"/>
          <span id="acceptedCount" style="font-size:12px;color:#6B7280;"></span>
        </div>
        <div class="tbl-wrap">
          <table class="data-table" id="acceptedTbl">
            <thead>
              <tr>
                <th>#</th><th>MSSV</th><th>Họ tên</th><th>Khóa</th>
                <th>Giới tính</th><th>Điểm ưu tiên</th>
                <th>Tòa</th><th>Tầng</th><th>Phòng</th><th>Hành động</th>
              </tr>
            </thead>
            <tbody id="acceptedBody">
              <% if (latestRun && latestRun.allocatedStudents) {
                latestRun.allocatedStudents.slice(0,300).forEach((s,i) => {
                  const sc = s.priorityScore;
                  const scCls = sc >= 70 ? 'score-high' : sc >= 50 ? 'score-mid' : 'score-low';
                  const ygLabel = {year1:'Năm 1',year2:'Năm 2',year3:'Năm 3',year4_plus:'Năm 4+',year5plus:'Năm 5+'};
                  const genLabel = {male:'Nam',female:'Nữ',other:'Khác'};
                  const sid = String(s.simStudentId || '');
              %>
              <tr data-sid="<%= sid %>">
                <td style="color:#9CA3AF;"><%= i+1 %></td>
                <td style="font-family:monospace;font-size:12px;"><%= s.studentId || '—' %></td>
                <td style="font-weight:600;"><%= s.name %><% if(s.isNewYear1){%><span style="font-size:10px;background:#EFF6FF;color:#2563EB;padding:1px 5px;border-radius:4px;margin-left:5px;">Mới</span><%}%></td>
                <td><%= ygLabel[s.yearGroup] || s.yearGroup %></td>
                <td><%= genLabel[s.gender] || s.gender %></td>
                <td><span class="score-pill <%= scCls %>"><%= sc %></span></td>
                <td><%= s.dormName %></td>
                <td>Tầng <%= s.floor %></td>
                <td style="font-weight:600;">P.<%= s.roomNumber %></td>
                <td style="white-space:nowrap;">
                  <button class="act-btn act-move" onclick="openMoveModal('<%= sid %>','<%= s.name.replace(/'/g,'') %>')">
                    <i class="fas fa-exchange-alt"></i> Đổi phòng
                  </button>
                  &nbsp;
                  <button class="act-btn act-remove" onclick="removeStudent('<%= sid %>')">
                    <i class="fas fa-times"></i> Loại
                  </button>
                </td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
        <% if (latestRun && latestRun.allocatedStudents && latestRun.allocatedStudents.length > 300) { %>
        <p style="font-size:12px;color:#9CA3AF;margin-top:8px;">Hiển thị 300 / <%= latestRun.allocatedStudents.length %> sinh viên được nhận.</p>
        <% } %>
      </div>

      <!-- Tab: Rejected / Waitlisted -->
      <div class="tab-panel" id="tab-rejected">
        <div style="margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <input type="text" id="filterRejected" placeholder="Tìm kiếm MSSV, tên..."
                 oninput="filterTable('rejectedTbl',this.value)"
                 style="border:1px solid #D1D5DB;border-radius:7px;padding:6px 12px;font-size:13px;outline:none;min-width:200px;"/>
          <span id="rejectedCount" style="font-size:12px;color:#6B7280;"></span>
        </div>
        <div class="tbl-wrap">
          <table class="data-table" id="rejectedTbl">
            <thead>
              <tr>
                <th>#</th><th>MSSV</th><th>Họ tên</th><th>Khóa</th>
                <th>Giới tính</th><th>Điểm ưu tiên</th><th>Lý do</th><th>Hành động</th>
              </tr>
            </thead>
            <tbody id="rejectedBody">
              <% if (latestRun && latestRun.waitlistedStudents) {
                latestRun.waitlistedStudents.slice(0,300).forEach((s,i) => {
                  const sc = s.priorityScore;
                  const scCls = sc >= 70 ? 'score-high' : sc >= 50 ? 'score-mid' : 'score-low';
                  const ygLabel = {year1:'Năm 1',year2:'Năm 2',year3:'Năm 3',year4_plus:'Năm 4+',year5plus:'Năm 5+'};
                  const genLabel = {male:'Nam',female:'Nữ',other:'Khác'};
                  const sid = String(s.simStudentId || '');
              %>
              <tr data-sid="<%= sid %>">
                <td style="color:#9CA3AF;"><%= i+1 %></td>
                <td style="font-family:monospace;font-size:12px;"><%= s.studentId || '—' %></td>
                <td style="font-weight:600;"><%= s.name %></td>
                <td><%= ygLabel[s.yearGroup] || s.yearGroup %></td>
                <td><%= genLabel[s.gender] || s.gender %></td>
                <td><span class="score-pill <%= scCls %>"><%= sc %></span></td>
                <td style="color:#DC2626;font-size:12px;"><%= s.reason %></td>
                <td>
                  <button class="act-btn act-promote" onclick="openPromoteModal('<%= sid %>','<%= s.name.replace(/'/g,'') %>')">
                    <i class="fas fa-arrow-up"></i> Phân phòng
                  </button>
                </td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Tab: Heatmap -->
      <div class="tab-panel" id="tab-heatmap">
        <div class="hm-legend">
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#DCFCE7;border:1px solid #BBF7D0;"></div>Trống (0%)</div>
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#FEF9C3;border:1px solid #FDE68A;"></div>Còn chỗ (<60%)</div>
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#FED7AA;border:1px solid #FDBA74;"></div>Gần đầy (60–99%)</div>
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#FEE2E2;border:1px solid #FECACA;"></div>Đầy (100%)</div>
        </div>

        <div id="heatmapContainer">
          <% if (latestRun && latestRun.heatmap) {
            latestRun.heatmap.forEach(dorm => {
          %>
          <div class="heatmap-dorm">
            <div class="heatmap-dorm-hd">
              <i class="fas fa-building" style="color:#6B7280;"></i>
              <%= dorm.dormName %>
              <span class="heatmap-gender-badge badge-<%= dorm.gender %>">
                <%= dorm.gender === 'male' ? 'Nam' : dorm.gender === 'female' ? 'Nữ' : 'Hỗn hợp' %>
              </span>
              <span style="font-size:12px;color:#6B7280;font-weight:400;">
                <%= dorm.occupiedBeds %>/<%= dorm.totalBeds %> giường (<%= dorm.occupancyRate %>%)
              </span>
            </div>
            <div class="prog-bar" style="margin-bottom:12px;">
              <div class="prog-fill <%= dorm.occupancyRate >= 90 ? 'fill-red' : dorm.occupancyRate >= 60 ? 'fill-amber' : 'fill-green' %>"
                   style="width:<%= dorm.occupancyRate %>%"></div>
            </div>
            <% dorm.floors.forEach(floor => { %>
            <div class="floor-wrap">
              <div class="floor-label">Tầng <%= floor.floorNumber %></div>
              <div class="rooms-row">
                <% floor.rooms.forEach(room => { %>
                <div class="room-cell room-<%= room.status %>"
                     title="Phòng <%= room.roomNumber %> — <%= room.occupied %>/<%= room.maxCapacity %> (<%= room.occupancyRate %>%)">
                  <div class="r-num"><%= room.roomNumber %></div>
                  <div class="r-occ"><%= room.occupied %>/<%= room.maxCapacity %></div>
                </div>
                <% }); %>
              </div>
            </div>
            <% }); %>
          </div>
          <% }); } %>
        </div>
      </div>

    </div><!-- /panel -->
  </div><!-- /resultsSection -->

  <!-- ══ APPLY / UNDO PANEL ════════════════════════════════════════════════ -->
  <% if (latestRun) { %>
  <div class="apply-panel" id="applyPanel">
    <h3><i class="fas fa-database" style="color:#16A34A;"></i> Áp dụng vào Dữ liệu Thật</h3>
    <p style="font-size:13px;color:#6B7280;margin:0;">
      Nhấn <strong>Apply</strong> để đẩy kết quả simulation vào database thật. Snapshot sẽ được tạo tự động để có thể undo.
      Sinh viên Năm 1 mô phỏng (không có ID thật) sẽ bị bỏ qua.
    </p>
    <div class="apply-row">
      <div class="apply-stats" id="applyStatsBox">
        Run: <b><%= latestRun.runId %></b> &nbsp;|&nbsp;
        <b><%= latestRun.summary.allocated %></b> sinh viên được nhận &nbsp;|&nbsp;
        Năm học: <b><%= latestRun.simYear || '—' %></b>
      </div>
      <button class="btn btn-green" id="btnApply" onclick="applyToReal()">
        <i class="fas fa-check-circle"></i> Apply to Real Allocation
      </button>
      <button class="btn btn-secondary" onclick="downloadReport()">
        <i class="fas fa-file-download"></i> Export Report
      </button>
    </div>
    <!-- Undo section (shown after apply) -->
    <div id="undoSection" style="display:none;margin-top:16px;padding:14px;background:#FFFBEB;border:1px solid #FDE68A;border-radius:9px;">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <div style="flex:1;">
          <div style="font-size:13px;font-weight:700;color:#92400E;">
            <i class="fas fa-history"></i> Snapshot đã tạo
          </div>
          <div style="font-size:12px;color:#78350F;margin-top:3px;" id="snapshotInfo">—</div>
        </div>
        <button class="btn btn-amber" id="btnUndo" onclick="undoAllocation()">
          <i class="fas fa-undo"></i> Undo Allocation
        </button>
      </div>
    </div>
  </div>
  <% } %>

</div><!-- /eng-wrap -->

<!-- ══ MODAL: Đổi phòng ══════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="moveModal">
  <div class="modal-box">
    <div class="modal-hd">
      <h4><i class="fas fa-exchange-alt" style="color:#1D4ED8;"></i> Đổi phòng</h4>
      <button class="modal-close" onclick="closeModal('moveModal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="font-size:13px;color:#6B7280;margin:0;">Sinh viên: <strong id="moveStudentName">—</strong></p>
      <input type="hidden" id="moveSimStudentId"/>
      <div class="form-group">
        <label>Tên tòa KTX</label>
        <input type="text" id="moveDormName" placeholder="VD: KTX A1"/>
      </div>
      <div class="form-group">
        <label>Tầng</label>
        <input type="number" id="moveFloor" placeholder="VD: 3" min="1" max="20"/>
      </div>
      <div class="form-group">
        <label>Số phòng</label>
        <input type="text" id="moveRoomNumber" placeholder="VD: 301"/>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('moveModal')">Hủy</button>
      <button class="btn btn-indigo" onclick="submitMoveRoom()">Xác nhận đổi phòng</button>
    </div>
  </div>
</div>

<!-- ══ MODAL: Phân phòng thủ công ══════════════════════════════════════════ -->
<div class="modal-overlay" id="promoteModal">
  <div class="modal-box">
    <div class="modal-hd">
      <h4><i class="fas fa-arrow-up" style="color:#15803D;"></i> Phân phòng thủ công</h4>
      <button class="modal-close" onclick="closeModal('promoteModal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="font-size:13px;color:#6B7280;margin:0;">Sinh viên: <strong id="promoteStudentName">—</strong></p>
      <input type="hidden" id="promoteSimStudentId"/>
      <div class="form-group">
        <label>Tên tòa KTX</label>
        <input type="text" id="promoteDormName" placeholder="VD: KTX A1"/>
      </div>
      <div class="form-group">
        <label>Tầng</label>
        <input type="number" id="promoteFloor" placeholder="VD: 3" min="1" max="20"/>
      </div>
      <div class="form-group">
        <label>Số phòng</label>
        <input type="text" id="promoteRoomNumber" placeholder="VD: 301"/>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('promoteModal')">Hủy</button>
      <button class="btn btn-green" onclick="submitPromote()">Phân phòng</button>
    </div>
  </div>
</div>

<script>
// ── Utility ──────────────────────────────────────────────────────────────────
function spin(on, lbl) {
  document.getElementById('spin').className = on ? 'on' : '';
  if (lbl) document.getElementById('spinLbl').textContent = lbl;
}
function toast(msg, type = 'inf') {
  const box = document.getElementById('toastBox');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  box.appendChild(t);
  setTimeout(() => t.remove(), 5000);
}

// ── Weight sliders ────────────────────────────────────────────────────────────
function updateWeight(name, val) {
  document.getElementById('lbl-' + name).textContent = parseFloat(val).toFixed(1);
}

// ── Table filter ─────────────────────────────────────────────────────────────
function filterTable(tblId, query) {
  const q = query.toLowerCase().trim();
  const rows = document.querySelectorAll(`#${tblId} tbody tr`);
  let visible = 0;
  rows.forEach(r => {
    const text = r.textContent.toLowerCase();
    const show = !q || text.includes(q);
    r.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  const countEl = document.getElementById(tblId === 'acceptedTbl' ? 'acceptedCount' : 'rejectedCount');
  if (countEl) countEl.textContent = q ? `${visible} kết quả` : '';
}

// ── Tab switch ────────────────────────────────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
}

// ── Seed Year 1 ───────────────────────────────────────────────────────────────
async function seedYear1() {
  const count = parseInt(document.getElementById('year1Count').value) || 200;
  const enrollYear = parseInt(document.getElementById('enrollYear').value) || new Date().getFullYear();
  const simAcademicYear = document.getElementById('simYear').value.trim() || `${enrollYear}-${enrollYear+1}`;

  spin(true, `Đang tạo ${count} sinh viên Năm 1 và áp dụng Cohort Shift...`);
  try {
    const res = await fetch('/api/simulation/engine/seed-year1', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ count, enrollmentYear: enrollYear, simAcademicYear })
    });
    const data = await res.json();
    spin(false);
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast(`Đã tạo ${data.seeded} SV Năm 1 + Cohort Shift hoàn tất`, 'ok');
    updateCohortDisplay(data.distribution);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

function updateCohortDisplay(dist) {
  if (!dist) return;
  const map = { 'cnt-yr1': dist.year1, 'cnt-yr2': dist.year2, 'cnt-yr3': dist.year3,
                'cnt-yr4p': dist.year4_plus, 'cnt-yr5p': dist.year5plus };
  Object.entries(map).forEach(([id, val]) => {
    const el = document.getElementById(id);
    if (el) el.textContent = val || 0;
  });
}

// ── Current run ID (from server) ─────────────────────────────────────────────
const CURRENT_RUN_ID = '<%= latestRun ? latestRun.runId : "" %>';
let currentSnapshotId = null;

// ── Modal helpers ─────────────────────────────────────────────────────────────
function openMoveModal(simStudentId, name) {
  document.getElementById('moveSimStudentId').value = simStudentId;
  document.getElementById('moveStudentName').textContent = name;
  document.getElementById('moveDormName').value = '';
  document.getElementById('moveFloor').value = '';
  document.getElementById('moveRoomNumber').value = '';
  document.getElementById('moveModal').classList.add('on');
}
function openPromoteModal(simStudentId, name) {
  document.getElementById('promoteSimStudentId').value = simStudentId;
  document.getElementById('promoteStudentName').textContent = name;
  document.getElementById('promoteDormName').value = '';
  document.getElementById('promoteFloor').value = '';
  document.getElementById('promoteRoomNumber').value = '';
  document.getElementById('promoteModal').classList.add('on');
}
function closeModal(id) {
  document.getElementById(id).classList.remove('on');
}

// ── Submit move room ──────────────────────────────────────────────────────────
async function submitMoveRoom() {
  const simStudentId = document.getElementById('moveSimStudentId').value;
  const dormName     = document.getElementById('moveDormName').value.trim();
  const floor        = document.getElementById('moveFloor').value;
  const roomNumber   = document.getElementById('moveRoomNumber').value.trim();
  if (!dormName || !floor || !roomNumber) return toast('Vui lòng điền đầy đủ thông tin phòng', 'err');

  spin(true, 'Đang chuyển phòng...');
  try {
    const res  = await fetch(`/api/simulation/engine/results/${CURRENT_RUN_ID}/move-room`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ simStudentId, dormName, floor: Number(floor), roomNumber })
    });
    const data = await res.json();
    spin(false);
    closeModal('moveModal');
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Đã chuyển phòng thành công', 'ok');
    setTimeout(() => location.reload(), 600);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Remove student (move to waitlist) ────────────────────────────────────────
async function removeStudent(simStudentId) {
  if (!confirm('Loại sinh viên này khỏi danh sách được nhận và chuyển sang danh sách chờ?')) return;
  spin(true, 'Đang xử lý...');
  try {
    const res  = await fetch(`/api/simulation/engine/results/${CURRENT_RUN_ID}/remove-student`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ simStudentId, reason: 'Điều chỉnh thủ công bởi admin' })
    });
    const data = await res.json();
    spin(false);
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Đã chuyển sang danh sách chờ', 'ok');
    setTimeout(() => location.reload(), 600);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Promote student (from waitlist to allocated) ──────────────────────────────
async function submitPromote() {
  const simStudentId = document.getElementById('promoteSimStudentId').value;
  const dormName     = document.getElementById('promoteDormName').value.trim();
  const floor        = document.getElementById('promoteFloor').value;
  const roomNumber   = document.getElementById('promoteRoomNumber').value.trim();
  if (!dormName || !floor || !roomNumber) return toast('Vui lòng điền đầy đủ thông tin phòng', 'err');

  spin(true, 'Đang phân phòng...');
  try {
    const res  = await fetch(`/api/simulation/engine/results/${CURRENT_RUN_ID}/promote-student`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ simStudentId, dormName, floor: Number(floor), roomNumber })
    });
    const data = await res.json();
    spin(false);
    closeModal('promoteModal');
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Phân phòng thủ công thành công', 'ok');
    setTimeout(() => location.reload(), 600);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Apply to Real Allocation ──────────────────────────────────────────────────
async function applyToReal() {
  if (!CURRENT_RUN_ID) return toast('Chưa có simulation run', 'err');
  if (!confirm('⚠️ Bạn có chắc muốn apply kết quả simulation vào database thật?\n\nHành động này sẽ tạo RoomAllocation thật cho sinh viên hiện có.\nBạn có thể undo ngay sau đó.')) return;

  const btn = document.getElementById('btnApply');
  btn.disabled = true;
  spin(true, 'Đang apply vào database thật...');
  try {
    const res  = await fetch('/api/simulation/engine/apply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ runId: CURRENT_RUN_ID })
    });
    const data = await res.json();
    spin(false);
    if (!data.success) {
      btn.disabled = false;
      return toast('Lỗi: ' + data.error, 'err');
    }
    currentSnapshotId = data.snapshotId;
    toast(data.message, 'ok');

    // Show undo section
    document.getElementById('undoSection').style.display = 'block';
    document.getElementById('snapshotInfo').textContent =
      `Snapshot: ${data.snapshotId} | Đã apply: ${data.stats.realStudents} SV | Bỏ qua Năm 1 mô phỏng: ${data.stats.skippedYear1}`;
    document.getElementById('applyPanel').classList.add('applied');
    btn.disabled = true;
    btn.textContent = '✓ Đã Apply';
  } catch(e) { spin(false); btn.disabled = false; toast('Lỗi kết nối', 'err'); }
}

// ── Undo Allocation ───────────────────────────────────────────────────────────
async function undoAllocation() {
  if (!currentSnapshotId) return toast('Không tìm thấy snapshot ID', 'err');
  if (!confirm('Khôi phục dữ liệu về trạng thái trước khi apply?')) return;

  spin(true, 'Đang undo...');
  try {
    const res  = await fetch(`/api/simulation/engine/undo/${currentSnapshotId}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    const data = await res.json();
    spin(false);
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast(data.message, 'ok');

    document.getElementById('btnUndo').disabled = true;
    document.getElementById('btnUndo').textContent = '✓ Đã Undo';
    document.getElementById('snapshotInfo').textContent += ' | ✓ UNDONE';
    document.getElementById('btnApply').disabled = false;
    document.getElementById('btnApply').innerHTML = '<i class="fas fa-check-circle"></i> Apply to Real Allocation';
    document.getElementById('applyPanel').classList.remove('applied');
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Export Report ─────────────────────────────────────────────────────────────
function downloadReport() {
  window.open('/api/simulation/engine/report?download=1', '_blank');
}

// ── Run Simulation ────────────────────────────────────────────────────────────
async function runSimulation() {
  const simAcademicYear = document.getElementById('simYear').value.trim()
    || `${new Date().getFullYear()}-${new Date().getFullYear()+1}`;

  const weights = {
    weightYear:        document.getElementById('w-year').value,
    weightDistance:    document.getElementById('w-distance').value,
    weightFamily:      document.getElementById('w-family').value,
    weightPolicy:      document.getElementById('w-policy').value,
    weightEthnicity:   document.getElementById('w-ethnicity').value,
    weightViolation:   document.getElementById('w-violation').value,
    weightDormHistory: document.getElementById('w-dormHistory').value,
    simAcademicYear
  };

  document.getElementById('btnRun').disabled = true;
  spin(true, 'Đang chạy Allocation Preview...');
  try {
    const res = await fetch('/api/simulation/engine/run', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(weights)
    });
    const data = await res.json();
    spin(false);
    document.getElementById('btnRun').disabled = false;
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast(`${data.message}`, 'ok');

    // Reload page to show full results
    setTimeout(() => location.reload(), 800);
  } catch(e) {
    spin(false);
    document.getElementById('btnRun').disabled = false;
    toast('Lỗi kết nối server', 'err');
  }
}
</script>
</body>
</html>
