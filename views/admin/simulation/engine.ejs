﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Công cụ phân bổ thử nghiệm — eDorm</title>
  <%- include('../navbar', { user, activeNav: 'simulation' }) %>
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
/* ── Design tokens ───────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --red: #C8102E; --red-dark: #9E0C24;
  --bg: #FBF8F3; --card: #FFFFFF;
  --border: #EFE8DF; --text: #2B2320; --muted: #7C7166; --muted2: #A89C8E;
  --success: #0E9F6E; --warning: #D9A22B; --info: #2563EB;
  --radius: 16px; --shadow: 0 1px 2px rgba(43,35,32,.04), 0 20px 38px -26px rgba(43,35,32,.2);
}
body { font-family: 'Josefin Sans', 'Segoe UI', system-ui, sans-serif; background: linear-gradient(180deg,#FBF8F3,#F5EFE7); min-height: 100vh; color: var(--text); }

/* ── Layout ─────────────────────────────────────────────────────────────── */
.eng-wrap{max-width:1200px;margin:28px auto;padding:0 24px 3rem;}
.eng-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:12px;}
.eng-head h2{font-family:'Josefin Sans',sans-serif;font-size:1.4rem;font-weight:700;color:var(--text);margin:0;}
.eng-head p{font-size:.82rem;color:var(--muted2);margin:.2rem 0 0;}

/* ── Summary cards ───────────────────────────────────────────────────────── */
.metric-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.75rem;margin-bottom:1.25rem;}
.metric-card{background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border:1px solid var(--border);border-radius:var(--radius);padding:1rem 1.1rem;box-shadow:var(--shadow);}
.metric-card .lbl{font-size:.7rem;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.3rem;}
.metric-card .val{font-family:'Josefin Sans',sans-serif;font-size:1.6rem;font-weight:700;color:var(--text);line-height:1;}
.metric-card .sub{font-size:.7rem;color:var(--muted2);margin-top:.2rem;}

/* ── Panel cards ─────────────────────────────────────────────────────────── */
.panel{background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border:1px solid var(--border);border-radius:var(--radius);padding:1.375rem 1.5rem;margin-bottom:1.25rem;box-shadow:var(--shadow);}
.panel-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:10px;}
.panel-hd h3{font-family:'Josefin Sans',sans-serif;font-size:.95rem;font-weight:600;color:var(--text);margin:0;display:flex;align-items:center;gap:7px;}
.panel-hd .panel-sub{font-size:.75rem;color:var(--muted2);}

/* ── Form elements ───────────────────────────────────────────────────────── */
.form-row{display:flex;gap:16px;flex-wrap:wrap;align-items:flex-end;margin-bottom:14px;}
.form-group{display:flex;flex-direction:column;gap:5px;min-width:140px;}
.form-group label{font-size:.75rem;font-weight:600;color:var(--text);}
.form-group input,.form-group select{
  border:1px solid var(--border);border-radius:10px;padding:7px 10px;
  font-size:.82rem;color:var(--text);outline:none;
  background:#fff;transition:border-color .15s;font-family:inherit;
}
.form-group input:focus,.form-group select:focus{border-color:var(--red);box-shadow:0 0 0 3px rgba(200,16,46,.08);}

/* ── Weight sliders ──────────────────────────────────────────────────────── */
.weight-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;}
.weight-row{display:flex;flex-direction:column;gap:5px;}
.weight-label{display:flex;justify-content:space-between;align-items:center;}
.weight-label span{font-size:.78rem;font-weight:600;color:var(--text);}
.weight-label .wval{font-family:'Josefin Sans',sans-serif;font-size:.88rem;font-weight:700;color:var(--red);min-width:32px;text-align:right;}
.weight-row input[type=range]{width:100%;accent-color:#C8102E;cursor:pointer;}
.weight-hint{font-size:.7rem;color:var(--muted2);}

/* ── Buttons ─────────────────────────────────────────────────────────────── */
.btn{display:inline-flex;align-items:center;gap:.45rem;padding:.55rem 1.25rem;border-radius:11px;font-size:.82rem;font-weight:600;border:none;cursor:pointer;transition:all .2s;font-family:inherit;}
.btn:active{transform:scale(.97);}
.btn:disabled{opacity:.5;cursor:not-allowed;}
.btn-primary{background:linear-gradient(135deg,#E11D2A,#B20C26);color:#fff;box-shadow:0 10px 24px -10px rgba(200,16,46,.65);}
.btn-primary:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 12px 28px -8px rgba(200,16,46,.7);}
.btn-secondary{background:#fff;color:var(--text);border:1px solid #E7DECF;}
.btn-secondary:hover:not(:disabled){background:#FBF8F3;}
.btn-indigo{background:#2563EB;color:#fff;}
.btn-indigo:hover:not(:disabled){background:#1D4ED8;}
.btn-green{background:#0E9F6E;color:#fff;}
.btn-green:hover:not(:disabled){background:#0A7A54;}
.btn-danger{background:linear-gradient(135deg,#E11D2A,#B20C26);color:#fff;box-shadow:0 10px 24px -10px rgba(200,16,46,.65);}
.btn-danger:hover:not(:disabled){transform:translateY(-1px);}

/* ── Tabs ────────────────────────────────────────────────────────────────── */
.tab-nav{display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:1.25rem;overflow-x:auto;}
.tab-btn{
  padding:.6rem 1.1rem;font-size:.82rem;font-weight:600;color:var(--muted2);
  border:none;background:none;cursor:pointer;white-space:nowrap;
  border-bottom:2px solid transparent;margin-bottom:-2px;
  transition:color .15s;font-family:inherit;
}
.tab-btn:hover{color:var(--text);}
.tab-btn.active{color:var(--red);border-bottom-color:var(--red);}
.tab-panel{display:none;}
.tab-panel.active{display:block;}

/* ── Tables ──────────────────────────────────────────────────────────────── */
.data-table{width:100%;border-collapse:collapse;font-size:.82rem;}
.data-table th{background:#F7F1E8;font-size:10.5px;font-weight:700;color:#9A8F84;text-transform:uppercase;letter-spacing:.05em;padding:.5rem .75rem;text-align:left;border-bottom:1px solid var(--border);}
.data-table td{padding:.6rem .75rem;border-bottom:1px solid #F4EEE5;color:var(--text);vertical-align:middle;}
.data-table tr:nth-child(even) td{background:#FDFBF8;}
.data-table tr:last-child td{border-bottom:none;}
.data-table tr:hover td{background:#FAF5EE;}
.tbl-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border);}

/* ── Heatmap ─────────────────────────────────────────────────────────────── */
.heatmap-dorm{margin-bottom:1.5rem;}
.heatmap-dorm-hd{font-size:.88rem;font-weight:700;color:var(--text);margin-bottom:.75rem;display:flex;align-items:center;gap:10px;}
.heatmap-gender-badge{font-size:.7rem;font-weight:600;padding:2px 8px;border-radius:99px;}
.badge-male  {background:#E9F0FE;color:#2563EB;}
.badge-female{background:#FBF1DC;color:#D9A22B;}
.badge-mixed {background:#E4F6EF;color:#0E9F6E;}
.floor-wrap{margin-bottom:.75rem;}
.floor-label{font-size:.7rem;font-weight:700;color:var(--muted2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.4rem;}
.rooms-row{display:flex;flex-wrap:wrap;gap:6px;}
.room-cell{
  width:44px;height:44px;border-radius:8px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  font-size:10px;font-weight:700;cursor:default;
  position:relative;transition:transform .12s;
  border:1.5px solid transparent;
}
.room-cell:hover{transform:scale(1.15);z-index:10;}
.room-empty  {background:#E4F6EF;color:#076641;border-color:#A7DFC8;}
.room-partial{background:#FBF1DC;color:#8A5C0E;border-color:#EDD28A;}
.room-high   {background:#FCEDEF;color:#9E0C24;border-color:#F5C2C7;}
.room-full   {background:#FCEDEF;color:#7A1A22;border-color:#E8A0A8;}
.room-cell .r-num{font-size:9px;font-weight:600;}
.room-cell .r-occ{font-size:9px;}

/* ── Year-group stats ────────────────────────────────────────────────────── */
.yg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.75rem;}
.yg-card{border-radius:var(--radius);padding:.875rem 1rem;border:1px solid var(--border);border-left:3px solid var(--border);background:linear-gradient(180deg,#FFFFFF,#FCFAF6);box-shadow:var(--shadow);}
.yg-card--year1     {border-left-color:#0E9F6E;}
.yg-card--year2     {border-left-color:#D9A22B;}
.yg-card--year3     {border-left-color:var(--red);}
.yg-card--year4_plus{border-left-color:#2563EB;}
.yg-card--year5plus {border-left-color:var(--muted2);}
.yg-card .yg-title{font-size:.75rem;font-weight:700;margin-bottom:.625rem;color:var(--text);}
.yg-card .yg-stat{display:flex;justify-content:space-between;font-size:.75rem;padding:3px 0;border-bottom:1px solid #F4EEE5;}
.yg-card .yg-stat:last-child{border:none;font-weight:700;}

/* ── Progress bar ────────────────────────────────────────────────────────── */
.prog-bar{height:6px;background:#EFE8DF;border-radius:99px;overflow:hidden;margin-top:.4rem;}
.prog-fill{height:100%;border-radius:99px;transition:width .4s ease;}
.fill-green{background:#0E9F6E;}
.fill-amber{background:#D9A22B;}
.fill-red  {background:var(--red);}

/* ── Priority score pill ─────────────────────────────────────────────────── */
.score-pill{display:inline-flex;align-items:center;justify-content:center;min-width:36px;padding:2px 8px;border-radius:99px;font-size:.72rem;font-weight:700;}
.score-high{background:#E4F6EF;color:#076641;}
.score-mid {background:#FBF1DC;color:#8A5C0E;}
.score-low {background:#FCEDEF;color:#9E0C24;}

/* ── Toast ───────────────────────────────────────────────────────────────── */
.toast-box{position:fixed;top:70px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px;}
.toast{background:#2B2320;color:#FBF8F3;padding:.7rem 1rem;border-radius:11px;font-size:.8rem;min-width:220px;box-shadow:0 4px 16px rgba(43,35,32,.25);animation:tslide .2s ease;}
.toast.ok {border-left:4px solid #0E9F6E;}
.toast.err{border-left:4px solid var(--red);}
.toast.inf{border-left:4px solid #2563EB;}
@keyframes tslide{from{transform:translateX(16px);opacity:0}to{transform:translateX(0);opacity:1}}

/* ── Spinner overlay ─────────────────────────────────────────────────────── */
#spin{display:none;position:fixed;inset:0;background:rgba(43,35,32,.45);z-index:9000;align-items:center;justify-content:center;flex-direction:column;gap:14px;}
#spin.on{display:flex;}
.spin-ring{width:42px;height:42px;border:4px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:rot .8s linear infinite;}
.spin-lbl{color:#fff;font-size:.88rem;font-weight:600;}
@keyframes rot{to{transform:rotate(360deg)}}

/* ── Heatmap legend ──────────────────────────────────────────────────────── */
.hm-legend{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:.875rem;}
.hm-leg-item{display:flex;align-items:center;gap:5px;font-size:.75rem;color:var(--text);}
.hm-leg-dot{width:14px;height:14px;border-radius:3px;}
.dorm-summary{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:10px;}
.dorm-stat{font-size:.75rem;color:var(--muted2);}
.dorm-stat b{color:var(--text);font-weight:600;}

/* ── Action buttons in table ─────────────────────────────────────────────── */
.act-btn{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:7px;font-size:.7rem;font-weight:600;border:none;cursor:pointer;transition:background .12s;}
.act-move   {background:#E9F0FE;color:#2563EB;}.act-move:hover{background:#AABEF8;color:#1D4ED8;}
.act-remove {background:#FCEDEF;color:#9E0C24;}.act-remove:hover{background:#F5C2C7;}
.act-promote{background:#E4F6EF;color:#076641;}.act-promote:hover{background:#A7DFC8;}

/* ── Apply/Confirm panel ─────────────────────────────────────────────────── */
.apply-panel{background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border:1px solid var(--border);border-radius:var(--radius);padding:1.375rem 1.5rem;margin-bottom:1.25rem;box-shadow:var(--shadow);}
.apply-panel h3{font-family:'Josefin Sans',sans-serif;font-size:.95rem;font-weight:600;color:var(--text);margin:0 0 .5rem;display:flex;align-items:center;gap:7px;}
.apply-row{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-top:.875rem;}
.apply-stats{font-size:.75rem;color:var(--muted2);background:#F5EFE7;border-radius:10px;padding:.5rem .75rem;flex:1;min-width:200px;border:1px solid var(--border);}
.apply-stats b{color:var(--text);}

/* ── Modal ───────────────────────────────────────────────────────────────── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(43,35,32,.45);z-index:9500;align-items:center;justify-content:center;}
.modal-overlay.on{display:flex;}
.modal-box{background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border-radius:18px;padding:1.5rem 1.75rem;max-width:480px;width:90%;box-shadow:0 24px 60px rgba(43,35,32,.25);border:1px solid var(--border);}
.modal-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.1rem;}
.modal-hd h4{font-family:'Josefin Sans',sans-serif;font-size:.95rem;font-weight:700;color:var(--text);margin:0;}
.modal-close{background:none;border:none;font-size:18px;color:var(--muted2);cursor:pointer;padding:0;}
.modal-body{display:flex;flex-direction:column;gap:.75rem;}
.modal-foot{display:flex;justify-content:flex-end;gap:.625rem;margin-top:1.1rem;}

/* ── Collapsible ─────────────────────────────────────────────────────────── */
details.adj-panel summary{cursor:pointer;list-style:none;display:flex;align-items:center;gap:6px;font-size:.82rem;font-weight:600;color:var(--text);padding:.5rem 0;user-select:none;}
details.adj-panel summary::-webkit-details-marker{display:none;}
details.adj-panel summary::before{content:'▶';font-size:10px;color:var(--muted2);transition:transform .15s;}
details.adj-panel[open] summary::before{transform:rotate(90deg);}
.adj-input{width:80px;border:1px solid var(--border);border-radius:10px;padding:5px 8px;font-size:.82rem;text-align:center;background:#fff;color:var(--text);font-family:inherit;}
.adj-input:focus{outline:none;border-color:var(--red);box-shadow:0 0 0 3px rgba(200,16,46,.08);}
  </style>
</head>
<body>

<div id="spin"><div class="spin-ring"></div><div class="spin-lbl" id="spinLbl">Đang xử lý...</div></div>
<div class="toast-box" id="toastBox"></div>

<div class="eng-wrap">

  <!-- Header -->
  <div class="eng-head">
    <div>
      <h2><i class="fas fa-cogs" style="color:#C8102E;margin-right:6px;"></i>Công cụ phân bổ thử nghiệm</h2>
      <p>Thiết lập tiêu chí và chạy mô phỏng phân bổ phòng ở KTX</p>
    </div>
    <a href="/admin/simulation" style="font-size:.78rem;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:.35rem;">
      <i class="fas fa-arrow-left"></i> Không gian làm việc
    </a>
  </div>

  <!-- Slow-load warning banner -->
  <% if (typeof slowLoad !== 'undefined' && slowLoad) { %>
  <div style="background:#FEF3C7;border:1px solid #F59E0B;border-radius:10px;padding:12px 18px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
    <i class="fas fa-exclamation-triangle" style="color:#D97706;"></i>
    <span style="font-size:13px;color:#92400E;">Dữ liệu mất quá 30 giây để tải — hiển thị trạng thái rỗng. Tải lại trang để thử lại.</span>
    <button class="btn btn-secondary" style="margin-left:auto;padding:5px 12px;font-size:12px;" onclick="location.reload()">Tải lại</button>
  </div>
  <% } %>

  <!-- ══ STEP 1: COHORT DATA ═══════════════════════════════════════════════════ -->
  <div class="panel">
    <div class="panel-hd">
      <h3><span style="color:var(--red);font-weight:800;margin-right:4px;">1.</span> Chuẩn bị dữ liệu</h3>
      <span class="panel-sub">Phân loại khóa tự động — Năm học 2026-2027</span>
    </div>

    <!-- Clean cohort table -->
    <div class="tbl-wrap" style="margin-bottom:16px;">
      <table class="data-table">
        <thead>
          <tr><th>Khóa</th><th>Số sinh viên</th><th>Ghi chú</th></tr>
        </thead>
        <tbody>
          <tr>
            <td style="font-weight:600;">Năm 1</td>
            <td><span id="cnt-y1" style="font-weight:700;color:var(--text);"><%= distribution.year1 %></span></td>
            <td style="color:var(--muted);">Sinh viên mới tự động tạo</td>
          </tr>
          <tr>
            <td style="font-weight:600;">Năm 2</td>
            <td><span id="cnt-y2" style="font-weight:700;color:var(--text);"><%= distribution.year2 %></span></td>
            <td></td>
          </tr>
          <tr>
            <td style="font-weight:600;">Năm 3</td>
            <td><span id="cnt-y3" style="font-weight:700;color:var(--text);"><%= distribution.year3 %></span></td>
            <td></td>
          </tr>
          <tr>
            <td style="font-weight:600;">Năm 4+</td>
            <td><span id="cnt-y4" style="font-weight:700;color:var(--text);"><%= distribution.year4_plus %></span></td>
            <td></td>
          </tr>
          <tr>
            <td style="color:var(--muted);">Năm 5+ (Ra KTX)</td>
            <td><span id="cnt-y5" style="color:var(--muted);"><%= distribution.year5plus %></span></td>
            <td style="color:var(--muted);">Bị loại tự động</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Collapsible: Điều chỉnh số lượng sinh viên -->
    <details class="adj-panel">
      <summary><i class="fas fa-sliders-h" style="color:var(--muted);font-size:.75rem;"></i> Chuẩn bị dữ liệu mô phỏng</summary>
      <div style="margin-top:.875rem;">
        <p style="font-size:.75rem;color:var(--muted);margin:0 0 .75rem;">Nhập số lượng mục tiêu cho từng khóa. Hệ thống sẽ thêm hoặc bớt sinh viên mô phỏng tương ứng.</p>
        <div class="tbl-wrap" style="max-width:460px;">
          <table class="data-table">
            <thead>
              <tr><th>Khóa</th><th>Hiện tại</th><th>Mục tiêu</th></tr>
            </thead>
            <tbody>
              <tr>
                <td style="font-weight:600;">Năm 1</td>
                <td><span id="adj-curr-y1"><%= distribution.year1 %></span></td>
                <td><input class="adj-input" type="number" id="adj-y1" value="<%= distribution.year1 %>" min="0" max="600"/></td>
              </tr>
              <tr>
                <td style="font-weight:600;">Năm 2</td>
                <td><span id="adj-curr-y2"><%= distribution.year2 %></span></td>
                <td><input class="adj-input" type="number" id="adj-y2" value="<%= distribution.year2 %>" min="0" max="600"/></td>
              </tr>
              <tr>
                <td style="font-weight:600;">Năm 3</td>
                <td><span id="adj-curr-y3"><%= distribution.year3 %></span></td>
                <td><input class="adj-input" type="number" id="adj-y3" value="<%= distribution.year3 %>" min="0" max="600"/></td>
              </tr>
              <tr>
                <td style="font-weight:600;">Năm 4+</td>
                <td><span id="adj-curr-y4"><%= distribution.year4_plus %></span></td>
                <td><input class="adj-input" type="number" id="adj-y4" value="<%= distribution.year4_plus %>" min="0" max="600"/></td>
              </tr>
            </tbody>
          </table>
        </div>
        <button class="btn btn-secondary" style="margin-top:12px;" onclick="adjustCohort()">
          <i class="fas fa-sync-alt"></i> Cập nhật số lượng
        </button>
      </div>
    </details>

    <p style="font-size:.72rem;color:var(--muted);margin:.75rem 0 0;">
      Phân loại khóa học được áp dụng tự động khi tải trang.
    </p>
  </div>

  <!-- ══ STEP 2: PRIORITY ENGINE CONFIG ════════════════════════════════════ -->
  <div class="panel">
    <div class="panel-hd">
      <h3><span style="color:var(--red);font-weight:800;margin-right:4px;">2.</span> Thiết lập tiêu chí ưu tiên</h3>
      <span class="panel-sub">Điều chỉnh trọng số cho từng tiêu chí ưu tiên</span>
    </div>

    <div class="weight-grid">

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-graduation-cap"></i> Năm học</span>
          <span class="wval" id="lbl-year">1.0</span>
        </div>
        <input type="range" id="w-year" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('year',this.value)"/>
        <div class="weight-hint">Ưu tiên theo năm học</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-map-marker-alt"></i> Khoảng cách</span>
          <span class="wval" id="lbl-distance">1.0</span>
        </div>
        <input type="range" id="w-distance" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('distance',this.value)"/>
        <div class="weight-hint">Ưu tiên sinh viên ở xa</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-home"></i> Hoàn cảnh gia đình</span>
          <span class="wval" id="lbl-family">1.0</span>
        </div>
        <input type="range" id="w-family" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('family',this.value)"/>
        <div class="weight-hint">Ưu tiên hoàn cảnh khó khăn</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-id-card"></i> Chính sách ưu tiên</span>
          <span class="wval" id="lbl-policy">1.0</span>
        </div>
        <input type="range" id="w-policy" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('policy',this.value)"/>
        <div class="weight-hint">Chính sách ưu tiên đặc biệt</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-flag"></i> Dân tộc thiểu số</span>
          <span class="wval" id="lbl-ethnicity">0.5</span>
        </div>
        <input type="range" id="w-ethnicity" min="0" max="2" step="0.1" value="0.5"
               oninput="updateWeight('ethnicity',this.value)"/>
        <div class="weight-hint">Ưu tiên dân tộc thiểu số</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-ban"></i> Lịch sử vi phạm</span>
          <span class="wval" id="lbl-violation">1.0</span>
        </div>
        <input type="range" id="w-violation" min="0" max="2" step="0.1" value="1.0"
               oninput="updateWeight('violation',this.value)"/>
        <div class="weight-hint">Trừ điểm theo vi phạm</div>
      </div>

      <div class="weight-row">
        <div class="weight-label">
          <span><i class="fas fa-history"></i> Lịch sử KTX</span>
          <span class="wval" id="lbl-dormHistory">0.3</span>
        </div>
        <input type="range" id="w-dormHistory" min="0" max="2" step="0.1" value="0.3"
               oninput="updateWeight('dormHistory',this.value)"/>
        <div class="weight-hint">Lịch sử cư trú</div>
      </div>

    </div>
  </div>

  <!-- ══ STEP 3: RUN ════════════════════════════════════════════════════════ -->
  <div class="panel">
    <div class="panel-hd">
      <h3><span style="color:var(--red);font-weight:800;margin-right:4px;">3.</span> Chạy mô phỏng</h3>
    </div>
    <p style="font-size:.82rem;color:var(--muted);margin:0 0 1rem;">
      Hệ thống tính điểm ưu tiên toàn bộ sinh viên, xếp hạng, rồi phân phòng tuần tự theo thứ tự điểm.
      Kết quả hiển thị bên dưới để xem xét trước khi áp dụng.
    </p>
    <button class="btn btn-danger" onclick="runSimulation()" id="btnRun">
      <i class="fas fa-play"></i> Bắt đầu mô phỏng
    </button>
  </div>

  <!-- ══ RESULTS ════════════════════════════════════════════════════════════ -->
  <div id="resultsSection" style="display:<%= latestRun ? 'block' : 'none' %>;">
    <div class="panel">
      <div class="panel-hd">
        <h3><i class="fas fa-chart-bar" style="color:var(--red);"></i> Kết quả mô phỏng</h3>
        <div style="display:flex;align-items:center;gap:10px;">
          <span class="panel-sub" id="runInfo">
            <% if (latestRun) { %>
              <%= new Date(latestRun.runAt).toLocaleString('vi-VN') %>
            <% } %>
          </span>
        </div>
      </div>

      <!-- Top metrics -->
      <div class="metric-grid" id="metricGrid">
        <% if (latestRun) { const s = latestRun.summary; %>
        <div class="metric-card">
          <div class="lbl">Tổng SV trong hàng đợi</div>
          <div class="val"><%= s.totalStudentsInQueue.toLocaleString() %></div>
          <div class="sub">Đã đăng ký mô phỏng</div>
        </div>
        <div class="metric-card">
          <div class="lbl">Được phân phòng</div>
          <div class="val" style="color:var(--success);"><%= s.allocated.toLocaleString() %></div>
          <div class="sub"><%= latestRun.byYearGroup?.year1?.allocated || 0 %> SV Năm 1</div>
        </div>
        <div class="metric-card">
          <div class="lbl">Danh sách chờ</div>
          <div class="val" style="color:var(--red);"><%= s.waitlisted.toLocaleString() %></div>
          <div class="sub">Không đủ giường</div>
        </div>
        <div class="metric-card">
          <div class="lbl">Tổng giường</div>
          <div class="val"><%= s.totalBeds.toLocaleString() %></div>
          <div class="sub"><%= s.totalRooms %> phòng</div>
        </div>
        <div class="metric-card">
          <div class="lbl">Tỷ lệ lấp đầy trước</div>
          <div class="val"><%= s.occupancyRateBefore %>%</div>
          <div class="sub">Trước khi mô phỏng</div>
        </div>
        <div class="metric-card">
          <div class="lbl">Tỷ lệ lấp đầy</div>
          <div class="val"><%= s.fillRate %>%</div>
          <div class="sub">Giường trống đã lấp</div>
        </div>
        <% } %>
      </div>

      <!-- Tabs -->
      <div class="tab-nav">
        <button class="tab-btn active" onclick="switchTab('byYearGroup',this)">Theo Khóa</button>
        <button class="tab-btn" onclick="switchTab('accepted',this)">Được Nhận</button>
        <button class="tab-btn" onclick="switchTab('rejected',this)">Bị Loại</button>
        <button class="tab-btn" onclick="switchTab('heatmap',this)">Phân bổ Phòng</button>
      </div>

      <!-- Tab: By Year Group -->
      <div class="tab-panel active" id="tab-byYearGroup">
        <div class="yg-grid" id="ygGrid">
          <% if (latestRun && latestRun.byYearGroup) {
            const ygLabels = { year1:'Năm 1', year2:'Năm 2', year3:'Năm 3', year4_plus:'Năm 4+', year5plus:'Năm 5+ (Ra KTX)' };
            Object.entries(latestRun.byYearGroup).forEach(([yg, stat]) => {
              if (!stat.total && yg === 'year5plus') return;
          %>
          <div class="yg-card yg-card--<%= yg %>">
            <div class="yg-title"><%= ygLabels[yg] || yg %></div>
            <div class="yg-stat"><span>Đăng ký</span><span><%= stat.total %></span></div>
            <div class="yg-stat"><span>Được nhận</span><span style="color:var(--success);font-weight:700;"><%= stat.allocated %></span></div>
            <div class="yg-stat"><span>Chờ</span><span style="color:var(--warning);"><%= stat.waitlisted %></span></div>
            <div class="yg-stat"><span>Tỷ lệ nhận</span><span><%= stat.rate %>%</span></div>
            <div class="prog-bar">
              <div class="prog-fill <%= stat.rate >= 80 ? 'fill-green' : stat.rate >= 50 ? 'fill-amber' : 'fill-red' %>"
                   style="width:<%= stat.rate %>%"></div>
            </div>
          </div>
          <% }); } %>
        </div>
      </div>

      <!-- Tab: Accepted -->
      <div class="tab-panel" id="tab-accepted">
        <div style="margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <input type="text" id="filterAccepted" placeholder="Tìm kiếm MSSV, tên..."
                 oninput="filterTable('acceptedTbl',this.value)"
                 style="border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:.82rem;outline:none;min-width:200px;color:var(--text);background:var(--card);"/>
          <span id="acceptedCount" style="font-size:.72rem;color:var(--muted);"></span>
        </div>
        <div class="tbl-wrap">
          <table class="data-table" id="acceptedTbl">
            <thead>
              <tr>
                <th>#</th><th>MSSV</th><th>Họ tên</th><th>Khóa</th>
                <th>Giới tính</th><th>Điểm ưu tiên</th>
                <th>Tòa</th><th>Tầng</th><th>Phòng</th><th>Hành động</th>
              </tr>
            </thead>
            <tbody id="acceptedBody">
              <% if (latestRun && latestRun.allocatedStudents) {
                latestRun.allocatedStudents.slice(0,300).forEach((s,i) => {
                  const sc = s.priorityScore;
                  const scCls = sc >= 70 ? 'score-high' : sc >= 50 ? 'score-mid' : 'score-low';
                  const ygLabel = {year1:'Năm 1',year2:'Năm 2',year3:'Năm 3',year4_plus:'Năm 4+',year5plus:'Năm 5+'};
                  const genLabel = {male:'Nam',female:'Nữ',other:'Khác'};
                  const sid = String(s.simStudentId || '');
              %>
              <tr data-sid="<%= sid %>">
                <td style="color:var(--muted);"><%= i+1 %></td>
                <td style="font-family:monospace;font-size:12px;"><%= s.studentId || '—' %></td>
                <td style="font-weight:600;"><%= s.name %><% if(s.isNewYear1){%><span style="font-size:10px;background:#EFF6FF;color:#2563EB;padding:1px 5px;border-radius:4px;margin-left:5px;">Mới</span><%}%></td>
                <td><%= ygLabel[s.yearGroup] || s.yearGroup %></td>
                <td><%= genLabel[s.gender] || s.gender %></td>
                <td><span class="score-pill <%= scCls %>"><%= sc %></span></td>
                <td><%= s.dormName %></td>
                <td>Tầng <%= s.floor %></td>
                <td style="font-weight:600;">P.<%= s.roomNumber %></td>
                <td style="white-space:nowrap;">
                  <button class="act-btn act-move" onclick="openMoveModal('<%= sid %>','<%= s.name.replace(/'/g,'') %>')">
                    <i class="fas fa-exchange-alt"></i> Đổi phòng
                  </button>
                  &nbsp;
                  <button class="act-btn act-remove" onclick="removeStudent('<%= sid %>')">
                    <i class="fas fa-times"></i> Loại
                  </button>
                </td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
        <% if (latestRun && latestRun.allocatedStudents && latestRun.allocatedStudents.length > 300) { %>
        <p style="font-size:.72rem;color:var(--muted);margin-top:.5rem;">Hiển thị 300 / <%= latestRun.allocatedStudents.length %> sinh viên được nhận.</p>
        <% } %>
      </div>

      <!-- Tab: Rejected / Waitlisted -->
      <div class="tab-panel" id="tab-rejected">
        <div style="margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <input type="text" id="filterRejected" placeholder="Tìm kiếm MSSV, tên..."
                 oninput="filterTable('rejectedTbl',this.value)"
                 style="border:1px solid var(--border);border-radius:7px;padding:6px 12px;font-size:.82rem;outline:none;min-width:200px;color:var(--text);background:var(--card);"/>
          <span id="rejectedCount" style="font-size:.72rem;color:var(--muted);"></span>
        </div>
        <div class="tbl-wrap">
          <table class="data-table" id="rejectedTbl">
            <thead>
              <tr>
                <th>#</th><th>MSSV</th><th>Họ tên</th><th>Khóa</th>
                <th>Giới tính</th><th>Điểm ưu tiên</th><th>Lý do</th><th>Hành động</th>
              </tr>
            </thead>
            <tbody id="rejectedBody">
              <% if (latestRun && latestRun.waitlistedStudents) {
                latestRun.waitlistedStudents.slice(0,300).forEach((s,i) => {
                  const sc = s.priorityScore;
                  const scCls = sc >= 70 ? 'score-high' : sc >= 50 ? 'score-mid' : 'score-low';
                  const ygLabel = {year1:'Năm 1',year2:'Năm 2',year3:'Năm 3',year4_plus:'Năm 4+',year5plus:'Năm 5+'};
                  const genLabel = {male:'Nam',female:'Nữ',other:'Khác'};
                  const sid = String(s.simStudentId || '');
              %>
              <tr data-sid="<%= sid %>">
                <td style="color:var(--muted);"><%= i+1 %></td>
                <td style="font-family:monospace;font-size:12px;"><%= s.studentId || '—' %></td>
                <td style="font-weight:600;"><%= s.name %></td>
                <td><%= ygLabel[s.yearGroup] || s.yearGroup %></td>
                <td><%= genLabel[s.gender] || s.gender %></td>
                <td><span class="score-pill <%= scCls %>"><%= sc %></span></td>
                <td style="color:var(--red);font-size:.75rem;"><%= s.reason %></td>
                <td>
                  <button class="act-btn act-promote" onclick="openPromoteModal('<%= sid %>','<%= s.name.replace(/'/g,'') %>')">
                    <i class="fas fa-arrow-up"></i> Phân phòng
                  </button>
                </td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Tab: Heatmap -->
      <div class="tab-panel" id="tab-heatmap">
        <div class="hm-legend">
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#DCFCE7;border:1px solid #BBF7D0;"></div>Trống (0%)</div>
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#FEF9C3;border:1px solid #FDE68A;"></div>Còn chỗ (&lt;60%)</div>
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#FED7AA;border:1px solid #FDBA74;"></div>Gần đầy (60–99%)</div>
          <div class="hm-leg-item"><div class="hm-leg-dot" style="background:#FEE2E2;border:1px solid #FECACA;"></div>Đầy (100%)</div>
        </div>

        <div id="heatmapContainer">
          <% if (latestRun && latestRun.heatmap) {
            latestRun.heatmap.forEach(dorm => {
          %>
          <div class="heatmap-dorm">
            <div class="heatmap-dorm-hd">
              <i class="fas fa-building" style="color:var(--muted);"></i>
              <%= dorm.dormName %>
              <span class="heatmap-gender-badge badge-<%= dorm.gender %>">
                <%= dorm.gender === 'male' ? 'Nam' : dorm.gender === 'female' ? 'Nữ' : 'Hỗn hợp' %>
              </span>
              <span style="font-size:.72rem;color:var(--muted);font-weight:400;">
                <%= dorm.occupiedBeds %>/<%= dorm.totalBeds %> giường (<%= dorm.occupancyRate %>%)
              </span>
            </div>
            <div class="prog-bar" style="margin-bottom:12px;">
              <div class="prog-fill <%= dorm.occupancyRate >= 90 ? 'fill-red' : dorm.occupancyRate >= 60 ? 'fill-amber' : 'fill-green' %>"
                   style="width:<%= dorm.occupancyRate %>%"></div>
            </div>
            <% dorm.floors.forEach(floor => { %>
            <div class="floor-wrap">
              <div class="floor-label">Tầng <%= floor.floorNumber %></div>
              <div class="rooms-row">
                <% floor.rooms.forEach(room => { %>
                <div class="room-cell room-<%= room.status %>"
                     title="Phòng <%= room.roomNumber %> — <%= room.occupied %>/<%= room.maxCapacity %> (<%= room.occupancyRate %>%)">
                  <div class="r-num"><%= room.roomNumber %></div>
                  <div class="r-occ"><%= room.occupied %>/<%= room.maxCapacity %></div>
                </div>
                <% }); %>
              </div>
            </div>
            <% }); %>
          </div>
          <% }); } %>
        </div>
      </div>

    </div><!-- /panel -->
  </div><!-- /resultsSection -->

  <!-- ══ APPLY / CONFIRM PANEL ═════════════════════════════════════════════ -->
  <% if (latestRun) { %>
  <div id="applySection">

    <% if (simState && simState.applied) { %>
    <!-- Applied banner -->
    <div id="appliedBanner" style="background:#EDF5F2;border:1px solid #AADBC8;border-radius:var(--radius);padding:.75rem 1.25rem;display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;flex-wrap:wrap;gap:10px;">
      <div style="display:flex;align-items:center;gap:.6rem;">
        <i class="fas fa-check-circle" style="color:var(--success);font-size:1rem;flex-shrink:0;"></i>
        <div>
          <strong style="color:#2D6B52;font-size:.82rem;">Đã áp dụng mô phỏng thành công</strong>
          <span style="font-size:.75rem;color:#3D7D62;margin-left:10px;">
            <strong id="savedCount"><%= simState.stats.allocated || 0 %></strong> sinh viên được lưu &nbsp;|&nbsp;
            Bỏ qua <strong id="skippedCount"><%= simState.stats.skippedYear1 || 0 %></strong> SV năm 1 mô phỏng
          </span>
        </div>
      </div>
      <button onclick="undoSimulation()" style="padding:.35rem .9rem;border:1px solid var(--red);background:var(--card);color:var(--red);border-radius:7px;font-size:.75rem;font-weight:600;cursor:pointer;white-space:nowrap;">
        <i class="fas fa-undo"></i> Hoàn tác
      </button>
    </div>
    <% } else { %>
    <!-- Confirm panel -->
    <div class="apply-panel" id="applyPanel">
      <h3><i class="fas fa-check-double" style="color:var(--success);"></i> Xác nhận kết quả</h3>
      <div class="apply-row">
        <div class="apply-stats" id="applyStatsBox">
          <b><%= latestRun.summary.allocated %></b> sinh viên được nhận &nbsp;|&nbsp;
          Năm học: <b>2026-2027</b>
        </div>
        <button class="btn btn-danger" id="btnApply" onclick="applyToReal()">
          <i class="fas fa-check-circle"></i> Xác nhận &amp; Lưu kết quả
        </button>
        <button class="btn btn-secondary" onclick="downloadReport()">
          <i class="fas fa-file-download"></i> Xuất báo cáo
        </button>
      </div>
      <!-- Success banner (shown after apply on this page visit) -->
      <div id="applySuccessBanner" style="display:none;margin-top:.875rem;background:#EDF5F2;border:1px solid #AADBC8;border-radius:var(--radius);padding:.75rem 1.25rem;">
        <div style="display:flex;align-items:center;gap:.6rem;flex-wrap:wrap;">
          <i class="fas fa-check-circle" style="color:var(--success);font-size:1rem;flex-shrink:0;"></i>
          <div style="flex:1;">
            <strong style="color:#2D6B52;font-size:.82rem;">Đã áp dụng mô phỏng thành công</strong>
            <span style="font-size:.75rem;color:#3D7D62;margin-left:8px;" id="snapshotInfo">—</span>
          </div>
          <button onclick="undoSimulation()" style="padding:.35rem .9rem;border:1px solid var(--red);background:var(--card);color:var(--red);border-radius:7px;font-size:.75rem;font-weight:600;cursor:pointer;white-space:nowrap;">
            <i class="fas fa-undo"></i> Hoàn tác
          </button>
        </div>
      </div>
    </div>
    <% } %>

  </div>
  <% } %>

  <!-- Workspace ID footnote -->
  <p style="font-size:.7rem;color:var(--border);margin-top:1.5rem;font-family:monospace;">
    Không gian làm việc: <%= workspace._id %>
  </p>

</div><!-- /eng-wrap -->

<!-- ══ MODAL: Đổi phòng ══════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="moveModal">
  <div class="modal-box">
    <div class="modal-hd">
      <h4><i class="fas fa-exchange-alt" style="color:#1D4ED8;"></i> Đổi phòng</h4>
      <button class="modal-close" onclick="closeModal('moveModal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="font-size:.82rem;color:var(--muted);margin:0;">Sinh viên: <strong id="moveStudentName">—</strong></p>
      <input type="hidden" id="moveSimStudentId"/>
      <div class="form-group">
        <label>Tên tòa KTX</label>
        <input type="text" id="moveDormName" placeholder="VD: KTX A1"/>
      </div>
      <div class="form-group">
        <label>Tầng</label>
        <input type="number" id="moveFloor" placeholder="VD: 3" min="1" max="20"/>
      </div>
      <div class="form-group">
        <label>Số phòng</label>
        <input type="text" id="moveRoomNumber" placeholder="VD: 301"/>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('moveModal')">Hủy</button>
      <button class="btn btn-indigo" onclick="submitMoveRoom()">Xác nhận đổi phòng</button>
    </div>
  </div>
</div>

<!-- ══ MODAL: Phân phòng thủ công ══════════════════════════════════════════ -->
<div class="modal-overlay" id="promoteModal">
  <div class="modal-box">
    <div class="modal-hd">
      <h4><i class="fas fa-arrow-up" style="color:#15803D;"></i> Phân phòng thủ công</h4>
      <button class="modal-close" onclick="closeModal('promoteModal')">✕</button>
    </div>
    <div class="modal-body">
      <p style="font-size:.82rem;color:var(--muted);margin:0;">Sinh viên: <strong id="promoteStudentName">—</strong></p>
      <input type="hidden" id="promoteSimStudentId"/>
      <div class="form-group">
        <label>Tên tòa KTX</label>
        <input type="text" id="promoteDormName" placeholder="VD: KTX A1"/>
      </div>
      <div class="form-group">
        <label>Tầng</label>
        <input type="number" id="promoteFloor" placeholder="VD: 3" min="1" max="20"/>
      </div>
      <div class="form-group">
        <label>Số phòng</label>
        <input type="text" id="promoteRoomNumber" placeholder="VD: 301"/>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn btn-secondary" onclick="closeModal('promoteModal')">Hủy</button>
      <button class="btn btn-green" onclick="submitPromote()">Phân phòng</button>
    </div>
  </div>
</div>

<script>
// ── Utility ──────────────────────────────────────────────────────────────────
function spin(on, lbl) {
  document.getElementById('spin').className = on ? 'on' : '';
  if (lbl) document.getElementById('spinLbl').textContent = lbl;
}
function toast(msg, type = 'inf') {
  const box = document.getElementById('toastBox');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  box.appendChild(t);
  setTimeout(() => t.remove(), 5000);
}

// ── Weight sliders ────────────────────────────────────────────────────────────
function updateWeight(name, val) {
  document.getElementById('lbl-' + name).textContent = parseFloat(val).toFixed(1);
}

// ── Table filter ─────────────────────────────────────────────────────────────
function filterTable(tblId, query) {
  const q = query.toLowerCase().trim();
  const rows = document.querySelectorAll(`#${tblId} tbody tr`);
  let visible = 0;
  rows.forEach(r => {
    const text = r.textContent.toLowerCase();
    const show = !q || text.includes(q);
    r.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  const countEl = document.getElementById(tblId === 'acceptedTbl' ? 'acceptedCount' : 'rejectedCount');
  if (countEl) countEl.textContent = q ? `${visible} kết quả` : '';
}

// ── Tab switch ────────────────────────────────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
}

// ── Adjust cohort ─────────────────────────────────────────────────────────────
async function adjustCohort() {
  const year1    = parseInt(document.getElementById('adj-y1').value) || 0;
  const year2    = parseInt(document.getElementById('adj-y2').value) || 0;
  const year3    = parseInt(document.getElementById('adj-y3').value) || 0;
  const year4plus = parseInt(document.getElementById('adj-y4').value) || 0;

  spin(true, 'Đang điều chỉnh dữ liệu...');
  try {
    const res = await fetch('/api/simulation/engine/adjust-cohort', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ year1, year2, year3, year4plus })
    });
    const data = await res.json();
    spin(false);
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Đã cập nhật số lượng sinh viên', 'ok');
    updateCohortDisplay(data.distribution);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

function updateCohortDisplay(dist) {
  if (!dist) return;
  const map = { 'cnt-y1': dist.year1, 'cnt-y2': dist.year2, 'cnt-y3': dist.year3,
                'cnt-y4': dist.year4_plus, 'cnt-y5': dist.year5plus };
  Object.entries(map).forEach(([id, val]) => {
    const el = document.getElementById(id);
    if (el) el.textContent = val || 0;
  });
  // Sync adjust-panel "current" column
  const adjMap = { 'adj-curr-y1': dist.year1, 'adj-curr-y2': dist.year2,
                   'adj-curr-y3': dist.year3,  'adj-curr-y4': dist.year4_plus };
  Object.entries(adjMap).forEach(([id, val]) => {
    const el = document.getElementById(id);
    if (el) el.textContent = val || 0;
  });
}

// ── Current run ID ────────────────────────────────────────────────────────────
const CURRENT_RUN_ID = '<%= latestRun ? latestRun.runId : "" %>';
let currentSnapshotId = null;

// ── Modal helpers ─────────────────────────────────────────────────────────────
function openMoveModal(simStudentId, name) {
  document.getElementById('moveSimStudentId').value = simStudentId;
  document.getElementById('moveStudentName').textContent = name;
  document.getElementById('moveDormName').value = '';
  document.getElementById('moveFloor').value = '';
  document.getElementById('moveRoomNumber').value = '';
  document.getElementById('moveModal').classList.add('on');
}
function openPromoteModal(simStudentId, name) {
  document.getElementById('promoteSimStudentId').value = simStudentId;
  document.getElementById('promoteStudentName').textContent = name;
  document.getElementById('promoteDormName').value = '';
  document.getElementById('promoteFloor').value = '';
  document.getElementById('promoteRoomNumber').value = '';
  document.getElementById('promoteModal').classList.add('on');
}
function closeModal(id) {
  document.getElementById(id).classList.remove('on');
}

// ── Submit move room ──────────────────────────────────────────────────────────
async function submitMoveRoom() {
  const simStudentId = document.getElementById('moveSimStudentId').value;
  const dormName     = document.getElementById('moveDormName').value.trim();
  const floor        = document.getElementById('moveFloor').value;
  const roomNumber   = document.getElementById('moveRoomNumber').value.trim();
  if (!dormName || !floor || !roomNumber) return toast('Vui lòng điền đầy đủ thông tin phòng', 'err');

  spin(true, 'Đang chuyển phòng...');
  try {
    const res  = await fetch(`/api/simulation/engine/results/${CURRENT_RUN_ID}/move-room`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ simStudentId, dormName, floor: Number(floor), roomNumber })
    });
    const data = await res.json();
    spin(false);
    closeModal('moveModal');
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Đã chuyển phòng thành công', 'ok');
    setTimeout(() => location.reload(), 600);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Remove student ────────────────────────────────────────────────────────────
async function removeStudent(simStudentId) {
  if (!confirm('Loại sinh viên này khỏi danh sách được nhận và chuyển sang danh sách chờ?')) return;
  spin(true, 'Đang xử lý...');
  try {
    const res  = await fetch(`/api/simulation/engine/results/${CURRENT_RUN_ID}/remove-student`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ simStudentId, reason: 'Điều chỉnh thủ công bởi admin' })
    });
    const data = await res.json();
    spin(false);
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Đã chuyển sang danh sách chờ', 'ok');
    setTimeout(() => location.reload(), 600);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Promote student ───────────────────────────────────────────────────────────
async function submitPromote() {
  const simStudentId = document.getElementById('promoteSimStudentId').value;
  const dormName     = document.getElementById('promoteDormName').value.trim();
  const floor        = document.getElementById('promoteFloor').value;
  const roomNumber   = document.getElementById('promoteRoomNumber').value.trim();
  if (!dormName || !floor || !roomNumber) return toast('Vui lòng điền đầy đủ thông tin phòng', 'err');

  spin(true, 'Đang phân phòng...');
  try {
    const res  = await fetch(`/api/simulation/engine/results/${CURRENT_RUN_ID}/promote-student`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ simStudentId, dormName, floor: Number(floor), roomNumber })
    });
    const data = await res.json();
    spin(false);
    closeModal('promoteModal');
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Phân phòng thủ công thành công', 'ok');
    setTimeout(() => location.reload(), 600);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Apply to Real Allocation ──────────────────────────────────────────────────
async function applyToReal() {
  if (!CURRENT_RUN_ID) return toast('Chưa có kết quả mô phỏng', 'err');
  if (!confirm('Xác nhận áp dụng kết quả mô phỏng?')) return;

  const btn = document.getElementById('btnApply');
  btn.disabled = true;
  spin(true, 'Đang xử lý...');
  try {
    const res  = await fetch('/api/simulation/engine/apply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ runId: CURRENT_RUN_ID })
    });
    const data = await res.json();
    spin(false);
    if (!data.success) {
      btn.disabled = false;
      return toast('Lỗi: ' + data.error, 'err');
    }
    currentSnapshotId = data.snapshotId;
    toast(data.message || 'Đã lưu kết quả mô phỏng', 'ok');

    const banner = document.getElementById('applySuccessBanner');
    if (banner) {
      banner.style.display = 'block';
      document.getElementById('snapshotInfo').textContent =
        `Đã lưu ${data.stats.realStudents} sinh viên | Bỏ qua ${data.stats.skippedYear1} SV năm 1 mô phỏng`;
    }
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-check-circle"></i> Đã áp dụng';
  } catch(e) { spin(false); btn.disabled = false; toast('Lỗi kết nối', 'err'); }
}

// ── Undo simulation ───────────────────────────────────────────────────────────
async function undoSimulation() {
  if (!confirm('Hoàn tác kết quả mô phỏng?')) return;
  spin(true, 'Đang hoàn tác...');
  try {
    const res = await fetch('/api/simulation/engine/undo-demo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    const data = await res.json();
    spin(false);
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast('Đã hoàn tác', 'ok');
    setTimeout(() => location.reload(), 600);
  } catch(e) { spin(false); toast('Lỗi kết nối', 'err'); }
}

// ── Export Report ─────────────────────────────────────────────────────────────
function downloadReport() {
  window.open('/api/simulation/engine/report?download=1', '_blank');
}

// ── Run Simulation ────────────────────────────────────────────────────────────
async function runSimulation() {
  const weights = {
    weightYear:        document.getElementById('w-year').value,
    weightDistance:    document.getElementById('w-distance').value,
    weightFamily:      document.getElementById('w-family').value,
    weightPolicy:      document.getElementById('w-policy').value,
    weightEthnicity:   document.getElementById('w-ethnicity').value,
    weightViolation:   document.getElementById('w-violation').value,
    weightDormHistory: document.getElementById('w-dormHistory').value,
    simAcademicYear:   '2026-2027'
  };

  document.getElementById('btnRun').disabled = true;
  spin(true, 'Đang chạy mô phỏng phân bổ...');
  try {
    const res = await fetch('/api/simulation/engine/run', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(weights)
    });
    const data = await res.json();
    spin(false);
    document.getElementById('btnRun').disabled = false;
    if (!data.success) return toast('Lỗi: ' + data.error, 'err');
    toast(`${data.message}`, 'ok');
    setTimeout(() => location.reload(), 800);
  } catch(e) {
    spin(false);
    document.getElementById('btnRun').disabled = false;
    toast('Lỗi kết nối server', 'err');
  }
}
</script>
