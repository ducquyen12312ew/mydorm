<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chi tiết yêu cầu chuyển phòng — Admin KTX HUST</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --red:#C8102E; --red-dark:#9E0D25;
      --bg:#F5F6F8; --card:#FFFFFF; --border:#EAECF0;
      --text:#2D3748; --muted:#9AA3AD;
      --success:#6BAF95; --warning:#C8AA60; --info:#6B9FC8; --danger:#E05252;
      --radius:12px; --shadow:0 1px 6px rgba(0,0,0,.04);
    }
    body { font-family:'Segoe UI',system-ui,sans-serif; background:var(--bg); color:var(--text); }
    .admin-content { min-height:100vh; }
    .page-wrap { max-width:1200px; margin:0 auto; padding:1.5rem; }
    .back-link { display:inline-flex; align-items:center; gap:.4rem; color:var(--muted); font-size:.85rem; text-decoration:none; margin-bottom:1.25rem; }
    .back-link:hover { color:var(--red); }
    .page-header { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:1.5rem; gap:1rem; flex-wrap:wrap; }
    .page-header h1 { font-size:1.25rem; font-weight:700; }
    .action-bar { display:flex; gap:.5rem; flex-wrap:wrap; }

    .grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; margin-bottom:1.25rem; }
    .card { background:var(--card); border-radius:var(--radius); border:1px solid var(--border); padding:1.25rem; }
    .card-title { font-size:.78rem; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.05em; margin-bottom:1rem; display:flex; align-items:center; gap:.4rem; }
    .info-row { display:flex; justify-content:space-between; align-items:flex-start; padding:.5rem 0; border-bottom:1px solid var(--border); gap:.5rem; }
    .info-row:last-child { border-bottom:none; }
    .info-label { font-size:.82rem; color:var(--muted); font-weight:600; min-width:120px; }
    .info-value { font-size:.85rem; text-align:right; }

    .badge { display:inline-flex; align-items:center; gap:.3rem; padding:.25rem .65rem; border-radius:20px; font-size:.75rem; font-weight:700; }
    .badge-pending  { background:#FEF3C7; color:#92400E; }
    .badge-approved { background:#DBEAFE; color:#1E40AF; }
    .badge-completed { background:#D1FAE5; color:#065F46; }
    .badge-rejected  { background:#FEE2E2; color:#991B1B; }
    .badge-cancelled { background:#F3F4F6; color:#6B7280; }

    .reason-box { background:#F8F9FB; border-radius:8px; padding:1rem; font-size:.88rem; line-height:1.6; border:1px solid var(--border); }

    /* Timeline */
    .timeline { list-style:none; padding:0; }
    .timeline li { display:flex; gap:.75rem; padding-bottom:1.25rem; position:relative; }
    .timeline li:not(:last-child)::before { content:''; position:absolute; left:10px; top:22px; bottom:0; width:2px; background:var(--border); }
    .tl-dot { width:22px; height:22px; border-radius:50%; background:var(--red); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.65rem; flex-shrink:0; }
    .tl-body { flex:1; }
    .tl-action { font-weight:700; font-size:.85rem; text-transform:capitalize; }
    .tl-meta { font-size:.78rem; color:var(--muted); margin-top:.15rem; }
    .tl-note { font-size:.82rem; margin-top:.25rem; color:#4A5568; font-style:italic; }

    /* Buttons */
    .btn { display:inline-flex; align-items:center; gap:.4rem; padding:.5rem 1rem; border-radius:8px; font-size:.84rem; font-weight:600; cursor:pointer; border:none; transition:all .2s; text-decoration:none; }
    .btn-red { background:var(--red); color:#fff; } .btn-red:hover { background:var(--red-dark); }
    .btn-green { background:var(--success); color:#fff; }
    .btn-outline { background:transparent; border:1px solid var(--border); color:var(--text); } .btn-outline:hover { border-color:var(--red); color:var(--red); }
    .btn-danger { background:var(--danger); color:#fff; }

    /* Modal */
    .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.4); z-index:1000; align-items:center; justify-content:center; }
    .modal-overlay.open { display:flex; }
    .modal { background:var(--card); border-radius:var(--radius); padding:1.5rem; width:min(520px,92vw); max-height:90vh; overflow-y:auto; }
    .modal h3 { font-size:1.1rem; font-weight:700; margin-bottom:1rem; }
    .form-group { margin-bottom:1rem; }
    .form-label { font-size:.82rem; font-weight:600; margin-bottom:.4rem; display:block; color:var(--text); }
    .form-control { width:100%; padding:.6rem .9rem; border:1px solid var(--border); border-radius:8px; font-size:.88rem; color:var(--text); }
    .form-control:focus { outline:none; border-color:var(--red); }
    select.form-control option { padding:.3rem; }
    .modal-footer { display:flex; justify-content:flex-end; gap:.5rem; margin-top:1.25rem; }
    .room-item { padding:.5rem .75rem; border:1px solid var(--border); border-radius:8px; cursor:pointer; margin-bottom:.4rem; transition:all .15s; }
    .room-item:hover, .room-item.selected { border-color:var(--red); background:#FFF1F3; }
    .room-item .ri-name { font-weight:600; font-size:.85rem; }
    .room-item .ri-meta { font-size:.78rem; color:var(--muted); }
    @media (max-width:768px) { .grid-2 { grid-template-columns:1fr; } }
  </style>
</head>
<body>
<%- include('../navbar', { activeNav: 'requests' }) %>
<div class="admin-content">
<div class="page-wrap">

  <a href="/admin/room-transfer" class="back-link"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>

  <div class="page-header">
    <div>
      <h1>Chi tiết yêu cầu chuyển phòng</h1>
      <div style="margin-top:.4rem">
        <% const lbls={pending:'Chờ duyệt',approved:'Đã duyệt',completed:'Hoàn thành',rejected:'Từ chối',cancelled:'Đã huỷ'} %>
        <span class="badge badge-<%= request.status %>"><%= lbls[request.status] || request.status %></span>
        <span style="font-size:.8rem;color:var(--muted);margin-left:.5rem">
          Gửi lúc <%= new Date(request.createdAt).toLocaleString('vi-VN') %>
        </span>
      </div>
    </div>
    <div class="action-bar">
      <% if (['pending','approved'].includes(request.status)) { %>
        <button class="btn btn-red" onclick="openAssignModal()">
          <i class="fas fa-door-open"></i> Phân phòng & Hoàn thành
        </button>
        <% if (request.status === 'pending') { %>
          <button class="btn btn-green" onclick="openApproveModal()">
            <i class="fas fa-check"></i> Duyệt
          </button>
        <% } %>
        <button class="btn btn-danger" onclick="openRejectModal()">
          <i class="fas fa-times"></i> Từ chối
        </button>
      <% } %>
    </div>
  </div>

  <div class="grid-2">
    <!-- Student info -->
    <div class="card">
      <div class="card-title"><i class="fas fa-user-graduate" style="color:var(--red)"></i>Thông tin sinh viên</div>
      <div class="info-row"><span class="info-label">Họ tên</span><span class="info-value"><strong><%= request.studentName %></strong></span></div>
      <div class="info-row"><span class="info-label">MSSV</span><span class="info-value"><%= request.studentMSSV || '—' %></span></div>
      <div class="info-row"><span class="info-label">Email</span><span class="info-value"><%= request.studentEmail || '—' %></span></div>
      <div class="info-row"><span class="info-label">Phòng hiện tại</span>
        <span class="info-value"><%= request.fromDormitoryName || '—' %> / <%= request.fromRoomNumber || '—' %></span>
      </div>
      <div class="info-row"><span class="info-label">Loại phòng hiện tại</span><span class="info-value"><%= request.fromRoomType || '—' %></span></div>
    </div>

    <!-- Preferences -->
    <div class="card">
      <div class="card-title"><i class="fas fa-sliders" style="color:var(--red)"></i>Yêu cầu chuyển</div>
      <div class="info-row"><span class="info-label">KTX mong muốn</span><span class="info-value"><%= request.preferredBuilding || 'Không yêu cầu' %></span></div>
      <div class="info-row"><span class="info-label">Loại phòng</span><span class="info-value"><%= request.preferredRoomType === 'any' ? 'Bất kỳ' : (request.preferredRoomType || '—') %></span></div>
      <div class="info-row"><span class="info-label">Ngày dự kiến</span>
        <span class="info-value"><%= request.expectedMoveDate ? new Date(request.expectedMoveDate).toLocaleDateString('vi-VN') : '—' %></span>
      </div>
      <% if (request.toDormitoryName) { %>
        <div class="info-row"><span class="info-label">Phòng được gán</span>
          <span class="info-value" style="color:var(--success);font-weight:700"><%= request.toDormitoryName %> / <%= request.toRoomNumber %></span>
        </div>
      <% } %>
    </div>
  </div>

  <div class="grid-2">
    <!-- Reason -->
    <div class="card">
      <div class="card-title"><i class="fas fa-comment-alt" style="color:var(--red)"></i>Lý do chuyển phòng</div>
      <div class="reason-box"><%= request.reason %></div>
      <% if (request.adminNote) { %>
        <div style="margin-top:1rem">
          <div class="card-title" style="margin-bottom:.5rem"><i class="fas fa-user-shield"></i>Ghi chú admin</div>
          <div class="reason-box" style="background:#F0F4FF"><%= request.adminNote %></div>
        </div>
      <% } %>
    </div>

    <!-- Timeline -->
    <div class="card">
      <div class="card-title"><i class="fas fa-history" style="color:var(--red)"></i>Lịch sử xử lý</div>
      <% if (!request.history || request.history.length === 0) { %>
        <p style="color:var(--muted);font-size:.85rem">Chưa có lịch sử</p>
      <% } else { %>
        <ul class="timeline">
          <% request.history.forEach(h => { %>
          <li>
            <div class="tl-dot"><i class="fas fa-circle" style="font-size:.45rem"></i></div>
            <div class="tl-body">
              <div class="tl-action"><%= h.action %></div>
              <div class="tl-meta"><%= h.performedByName || 'System' %> · <%= new Date(h.timestamp).toLocaleString('vi-VN') %></div>
              <% if (h.note) { %><div class="tl-note"><%= h.note %></div><% } %>
            </div>
          </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>

</div>
</div>

<!-- ASSIGN MODAL -->
<div class="modal-overlay" id="assignModal">
  <div class="modal">
    <h3><i class="fas fa-door-open" style="color:var(--red)"></i> Phân phòng cho sinh viên</h3>
    <div class="form-group">
      <label class="form-label">Lọc theo KTX</label>
      <input type="text" id="buildingFilter" class="form-control" placeholder="Tên KTX..." oninput="filterRooms()">
    </div>
    <div class="form-group">
      <label class="form-label">Loại phòng</label>
      <select id="typeFilter" class="form-control" onchange="filterRooms()">
        <option value="">Tất cả</option>
        <option value="8-person">8 người</option>
        <option value="4-person-service">4 người dịch vụ</option>
        <option value="5-person">5 người</option>
        <option value="10-person">10 người</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Chọn phòng trống <span id="roomCount" style="color:var(--muted)"></span></label>
      <div id="roomList" style="max-height:220px;overflow-y:auto">
        <p style="color:var(--muted);font-size:.85rem">Đang tải...</p>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Ghi chú</label>
      <textarea id="assignNote" class="form-control" rows="2" placeholder="Ghi chú (tuỳ chọn)"></textarea>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('assignModal')">Huỷ</button>
      <button class="btn btn-red" onclick="submitAssign()" id="assignBtn" disabled>
        <i class="fas fa-check"></i> Xác nhận phân phòng
      </button>
    </div>
  </div>
</div>

<!-- APPROVE MODAL -->
<div class="modal-overlay" id="approveModal">
  <div class="modal">
    <h3><i class="fas fa-check-circle" style="color:var(--success)"></i> Duyệt yêu cầu</h3>
    <p style="font-size:.88rem;margin-bottom:1rem;color:var(--muted)">Duyệt yêu cầu chuyển phòng mà chưa gán phòng cụ thể.</p>
    <div class="form-group">
      <label class="form-label">Ghi chú</label>
      <textarea id="approveNote" class="form-control" rows="3" placeholder="Ghi chú cho sinh viên..."></textarea>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('approveModal')">Huỷ</button>
      <button class="btn btn-green" onclick="submitApprove()"><i class="fas fa-check"></i> Duyệt</button>
    </div>
  </div>
</div>

<!-- REJECT MODAL -->
<div class="modal-overlay" id="rejectModal">
  <div class="modal">
    <h3><i class="fas fa-times-circle" style="color:var(--danger)"></i> Từ chối yêu cầu</h3>
    <div class="form-group">
      <label class="form-label">Lý do từ chối <span style="color:var(--red)">*</span></label>
      <textarea id="rejectNote" class="form-control" rows="3" placeholder="Bắt buộc nhập lý do..." required></textarea>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('rejectModal')">Huỷ</button>
      <button class="btn btn-danger" onclick="submitReject()"><i class="fas fa-times"></i> Từ chối</button>
    </div>
  </div>
</div>

<script>
const REQUEST_ID = '<%= request._id %>';
let allRooms = [];
let selectedRoom = null;

function openAssignModal() {
  document.getElementById('assignModal').classList.add('open');
  loadRooms();
}
function openApproveModal() { document.getElementById('approveModal').classList.add('open'); }
function openRejectModal()  { document.getElementById('rejectModal').classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

async function loadRooms() {
  try {
    const r = await fetch('/admin/api/room-transfer/available-rooms');
    const d = await r.json();
    allRooms = d.rooms || [];
    renderRooms(allRooms);
  } catch (e) {
    document.getElementById('roomList').innerHTML = '<p style="color:red;font-size:.85rem">Lỗi tải dữ liệu</p>';
  }
}

function filterRooms() {
  const bld = document.getElementById('buildingFilter').value.toLowerCase();
  const typ = document.getElementById('typeFilter').value;
  const filtered = allRooms.filter(r =>
    (!bld || r.dormitoryName.toLowerCase().includes(bld)) &&
    (!typ || r.roomType === typ)
  );
  renderRooms(filtered);
}

function renderRooms(rooms) {
  document.getElementById('roomCount').textContent = `(${rooms.length} phòng còn chỗ)`;
  if (rooms.length === 0) {
    document.getElementById('roomList').innerHTML = '<p style="color:var(--muted);font-size:.85rem">Không tìm thấy phòng phù hợp</p>';
    return;
  }
  document.getElementById('roomList').innerHTML = rooms.map(r => `
    <div class="room-item" onclick="selectRoom(this,'${r.dormitoryId}','${r.roomNumber}')">
      <div class="ri-name">${r.dormitoryName} — Phòng ${r.roomNumber} (Tầng ${r.floor})</div>
      <div class="ri-meta">${r.roomType} · ${r.occupancy}/${r.maxCapacity} chỗ đã dùng · còn ${r.slots} chỗ trống</div>
    </div>
  `).join('');
}

function selectRoom(el, dormId, roomNum) {
  document.querySelectorAll('.room-item').forEach(i => i.classList.remove('selected'));
  el.classList.add('selected');
  selectedRoom = { dormitoryId: dormId, roomNumber: roomNum };
  document.getElementById('assignBtn').disabled = false;
}

async function submitAssign() {
  if (!selectedRoom) return alert('Vui lòng chọn phòng');
  const note = document.getElementById('assignNote').value;
  const r = await fetch(`/admin/room-transfer/${REQUEST_ID}/assign`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ...selectedRoom, adminNote: note })
  });
  const d = await r.json();
  if (d.success) { alert('Đã phân phòng thành công!'); location.reload(); }
  else alert('Lỗi: ' + d.error);
}

async function submitApprove() {
  const note = document.getElementById('approveNote').value;
  const r = await fetch(`/admin/room-transfer/${REQUEST_ID}/approve`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ adminNote: note })
  });
  const d = await r.json();
  if (d.success) { location.reload(); }
  else alert('Lỗi: ' + d.error);
}

async function submitReject() {
  const note = document.getElementById('rejectNote').value;
  if (!note.trim()) return alert('Vui lòng nhập lý do từ chối');
  const r = await fetch(`/admin/room-transfer/${REQUEST_ID}/reject`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ adminNote: note })
  });
  const d = await r.json();
  if (d.success) { location.reload(); }
  else alert('Lỗi: ' + d.error);
}

document.querySelectorAll('.modal-overlay').forEach(m =>
  m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); })
);
</script>
</body>
</html>
