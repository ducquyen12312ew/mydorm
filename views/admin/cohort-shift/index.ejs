<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cohort Shift Timeline – KTX HUST Admin</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/cohort-shift.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>

<%- include('../navbar', { activeNav: 'cohort-shift' }) %>

<div class="cs-shell">

  <!-- ═══════ TOP BAR ═══════ -->
  <div class="cs-topbar">
    <div class="cs-topbar-left">
      <span class="cs-breadcrumb">
        <a href="/admin/dashboard"><i class="fas fa-home"></i></a>
        <i class="fas fa-chevron-right sep"></i>
        <span>Cohort Shift Timeline</span>
      </span>
      <h1 class="cs-title">
        <i class="fas fa-arrows-rotate"></i>
        Dịch Chuyển Nhóm Năm & Tái Tính Quota
      </h1>
      <p class="cs-subtitle">Tự động cập nhật nhóm năm theo năm học · K70 → Năm 2 · K71 → Năm 1</p>
    </div>
    <div class="cs-topbar-right">
      <select id="yearSelector" class="ys-select" onchange="switchYear(this.value)">
        <% yearList.forEach(y => { %>
          <option value="<%= y %>" <%= y === selectedYear ? 'selected' : '' %>><%= y %></option>
        <% }) %>
      </select>
      <button class="btn btn-primary" onclick="runShift()">
        <i class="fas fa-play"></i> Chạy Shift
      </button>
    </div>
  </div>

  <div class="cs-card kpi-strip-card">
    <div class="cs-card-header">
      <span class="cs-card-title"><i class="fas fa-gauge-high"></i> KPI nhanh 2025 → 2026 → 2027</span>
      <span class="cs-card-hint">So sánh tổng quota và sử dụng qua 3 mốc năm học</span>
    </div>
    <div class="cs-card-body">
      <div id="kpiStrip" class="kpi-strip"></div>
    </div>
  </div>

  <!-- ═══════ TIMELINE RAIL ═══════ -->
  <div class="cs-card timeline-card">
    <div class="cs-card-header">
      <span class="cs-card-title"><i class="fas fa-timeline"></i> Lịch sử dịch chuyển</span>
      <span class="cs-card-count"><%= snapshots.length %> năm học</span>
    </div>
    <div class="cs-card-body timeline-body">
      <div class="timeline-rail" id="timelineRail">
        <% if (snapshots.length === 0) { %>
          <div class="timeline-empty">
            <i class="fas fa-history fa-2x"></i>
            <p>Chưa có dữ liệu. Nhấn <strong>Chạy Shift</strong> để tạo snapshot đầu tiên.</p>
          </div>
        <% } else { %>
          <% const COHORT_LABELS2 = { year1: 'Năm 1', year2: 'Năm 2', year3: 'Năm 3', year4_plus: 'Năm 4+' }; %>
          <% snapshots.forEach((snap, idx) => { %>
          <div class="tl-node <%= snap.academicYear === selectedYear ? 'tl-node-active' : '' %>"
               onclick="loadSnapshot('<%= snap.academicYear %>')"
               data-year="<%= snap.academicYear %>">
            <div class="tl-dot">
              <i class="fas fa-circle-dot"></i>
            </div>
            <div class="tl-connector <%= idx < snapshots.length - 1 ? '' : 'tl-last' %>"></div>
            <div class="tl-card">
              <div class="tl-year"><%= snap.academicYear %></div>
              <div class="tl-meta">
                <% const s = snap.summary || {}; %>
                <% ['year1','year2','year3','year4_plus'].forEach(key => { const grp = s[key]; if (!grp || !grp.cohorts || !grp.cohorts.length) return; %>
                  <span class="tl-cohort-chip tl-chip-<%= key %>">
                    <% grp.cohorts.forEach(c => { %><span><%= c %></span><% }) %> → <%= COHORT_LABELS2[key] %>
                  </span>
                <% }) %>
              </div>
              <div class="tl-quota-row">
                <% ['year1','year2','year3','year4_plus'].forEach(key => { const g = s[key] || {}; if (!g.quota) return; %>
                  <span class="tl-quota-badge tl-qb-<%= key %>">
                    <%= g.quota %> phòng
                  </span>
                <% }) %>
              </div>
              <div class="tl-footer">
                <span class="tl-date"><i class="fas fa-clock"></i> <%= snap.generatedAt ? new Date(snap.generatedAt).toLocaleDateString('vi-VN') : '—' %></span>
                <% if (snap.isAutoGenerated) { %><span class="tl-auto-badge">Auto</span><% } %>
              </div>
            </div>
          </div>
          <% }) %>

          <!-- Preview node for next year -->
          <% if (previewSnap) { %>
          <div class="tl-node tl-node-preview">
            <div class="tl-dot tl-dot-preview"><i class="fas fa-circle-dashed"></i></div>
            <div class="tl-connector tl-last"></div>
            <div class="tl-card tl-card-preview">
              <div class="tl-year"><%= previewSnap.academicYear %> <span class="preview-pill">Dự kiến</span></div>
              <div class="tl-meta">
                <% const ps = previewSnap.summary || {};
                   ['year1','year2','year3','year4_plus'].forEach(key => {
                     const grp = ps[key]; if (!grp || !grp.cohorts || !grp.cohorts.length) return; %>
                  <span class="tl-cohort-chip tl-chip-<%= key %> chip-dim">
                    <% grp.cohorts.forEach(c => { %>
                      <span class="<%= previewSnap.cohorts.find(co => co.code === c && co.isNew) ? 'chip-new' : '' %>"><%= c %></span>
                    <% }) %> → <%= COHORT_LABELS2[key] %>
                  </span>
                <% }) %>
              </div>
              <div class="tl-quota-row">
                <% ['year1','year2','year3','year4_plus'].forEach(key => { const g = ps[key] || {}; if (!g.quota) return; %>
                  <span class="tl-quota-badge tl-qb-<%= key %> qb-dim"><%= g.quota %> phòng</span>
                <% }) %>
              </div>
              <div class="tl-footer">
                <span class="tl-date"><i class="fas fa-magic"></i> Dự báo tự động</span>
              </div>
            </div>
          </div>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ═══════ DETAIL SECTION ═══════ -->
  <div class="cs-row-2col" id="detailSection">

    <!-- Cohort table -->
    <div class="cs-card cohort-table-card">
      <div class="cs-card-header">
        <span class="cs-card-title"><i class="fas fa-table"></i> Bảng dịch chuyển nhóm</span>
        <span class="cs-year-badge" id="detailYearBadge"><%= selectedYear %></span>
      </div>
      <div class="cs-card-body p0" id="cohortTableWrap">
        <% if (currentSnap) { %>
          <%- include('_cohort_table', { snap: currentSnap }) %>
        <% } else { %>
          <div class="snap-empty">
            <i class="fas fa-circle-info"></i>
            Chưa có snapshot cho năm này. Nhấn <strong>Chạy Shift</strong>.
          </div>
        <% } %>
      </div>
    </div>

    <!-- Year-group summary chart -->
    <div class="cs-card chart-card">
      <div class="cs-card-header">
        <span class="cs-card-title"><i class="fas fa-chart-bar"></i> Quota vs Thực tế</span>
        <div class="chart-toggle-wrap">
          <button class="ct-btn active" id="btnBar"    onclick="switchChart('bar')">Cột</button>
          <button class="ct-btn"        id="btnRadar"  onclick="switchChart('radar')">Radar</button>
          <button class="ct-btn"        id="btnDonut"  onclick="switchChart('donut')">Tròn</button>
        </div>
      </div>
      <div class="cs-card-body chart-body">
        <canvas id="mainChart" class="chart-canvas"></canvas>
      </div>
    </div>

  </div>

  <div class="cs-card shift-flow-card">
    <div class="cs-card-header">
      <span class="cs-card-title"><i class="fas fa-shuffle"></i> Luồng dịch chuyển cohort</span>
      <span class="cs-card-hint" id="shiftFlowHint">So sánh với năm học trước</span>
    </div>
    <div class="cs-card-body">
      <div id="shiftFlowPanel" class="shift-flow-panel"></div>
    </div>
  </div>

  <!-- ═══════ TREND CHART ═══════ -->
  <div class="cs-card trend-card">
    <div class="cs-card-header">
      <span class="cs-card-title"><i class="fas fa-chart-line"></i> Xu hướng quota theo năm</span>
      <span class="cs-card-hint">So sánh hạn mức theo nhóm năm qua các năm học</span>
    </div>
    <div class="cs-card-body trend-body">
      <canvas id="trendChart" class="chart-canvas-wide"></canvas>
    </div>
  </div>

  <!-- ═══════ EDGE CASES PANEL ═══════ -->
  <% if (currentSnap) {
       const edgeCases = (currentSnap.cohorts || []).filter(c => c.yearInSchool >= 5);
     %>
  <% if (edgeCases.length > 0) { %>
  <div class="cs-card edge-card">
    <div class="cs-card-header">
      <span class="cs-card-title cs-title-warn"><i class="fas fa-triangle-exclamation"></i> Edge Cases – Năm học 5+</span>
      <span class="edge-count"><%= edgeCases.length %> nhóm</span>
    </div>
    <div class="cs-card-body">
      <div class="edge-grid">
        <% edgeCases.forEach(c => { %>
        <div class="edge-item">
          <div class="edge-code"><%= c.code %></div>
          <div class="edge-year">Năm học thứ <%= c.yearInSchool %></div>
          <div class="edge-pct"><%= c.percentage %>% · <%= c.quota %> phòng</div>
          <div class="edge-allocated"><%= c.allocated %> đã dùng</div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
  <% } %>
  <% } %>

</div><!-- /cs-shell -->

<!-- ═══════ RUN SHIFT MODAL ═══════ -->
<div class="modal-backdrop" id="runBackdrop" onclick="closeRunModal()"></div>
<div class="modal" id="runModal">
  <div class="modal-header">
    <h2><i class="fas fa-arrows-rotate"></i> Chạy Cohort Shift</h2>
    <button class="modal-close" onclick="closeRunModal()">&times;</button>
  </div>
  <div class="modal-body">
    <div class="form-group">
      <label>Năm học <span class="req">*</span></label>
      <select id="runYear" class="form-select">
        <% yearList.forEach(y => { %>
          <option value="<%= y %>" <%= y === selectedYear ? 'selected' : '' %>><%= y %></option>
        <% }) %>
      </select>
      <span class="form-hint">Hệ thống sẽ tính toán lại cohort mapping và quota cho năm này.</span>
    </div>
    <div class="form-group" style="margin-top:14px">
      <label>Ghi chú</label>
      <textarea id="runNotes" rows="2" class="form-textarea" placeholder="Lý do chạy shift..."></textarea>
    </div>

    <div class="info-box">
      <i class="fas fa-circle-info"></i>
      <div>
        <strong>Thao tác này sẽ:</strong>
        <ul>
          <li>Lấy dữ liệu sinh viên hiện tại từ DB</li>
          <li>Áp dụng chính sách đang hoạt động cho năm này</li>
          <li>Tạo snapshot dịch chuyển (upsert – không mất dữ liệu cũ)</li>
          <li>Tái tính quota theo tỷ lệ chính sách</li>
        </ul>
      </div>
    </div>
  </div>
  <div class="modal-footer">
    <button class="btn btn-ghost" onclick="closeRunModal()">Hủy</button>
    <button class="btn btn-primary" id="runBtn" onclick="confirmRunShift()">
      <i class="fas fa-play"></i> Xác nhận chạy
    </button>
  </div>
</div>

<div id="toast" class="toast" aria-live="polite"></div>

<script>
// ─── Inject server data ───────────────────────────────────────────────────────
const TIMELINE_DATA    = JSON.parse(decodeURIComponent('<%- encodeURIComponent(JSON.stringify(timeline)) %>'));
const CURRENT_SNAP     = JSON.parse(decodeURIComponent('<%- encodeURIComponent(JSON.stringify(currentSnap)) %>'));
const PREVIEW_SNAP     = JSON.parse(decodeURIComponent('<%- encodeURIComponent(JSON.stringify(previewSnap)) %>'));
const SELECTED_YEAR    = '<%= selectedYear %>';
const YEAR_LABELS = { year1:'Năm 1', year2:'Năm 2', year3:'Năm 3', year4_plus:'Năm 4+' };
const YEAR_COLORS = {
  year1:      { border:'#4361ee', bg:'rgba(67,97,238,.18)'  },
  year2:      { border:'#3a0ca3', bg:'rgba(58,12,163,.18)'  },
  year3:      { border:'#7209b7', bg:'rgba(114,9,183,.18)'  },
  year4_plus: { border:'#f72585', bg:'rgba(247,37,133,.18)' }
};
const COHORT_KEYS = ['year1','year2','year3','year4_plus'];
const TIMELINE_BY_YEAR = new Map((TIMELINE_DATA || []).map(item => [item.academicYear, item]));

// ─── Chart state ──────────────────────────────────────────────────────────────
let mainChartInst  = null;
let trendChartInst = null;
let chartType      = 'bar';
let activeSnapshot = CURRENT_SNAP;

function buildMainChart(snap) {
  const ctx  = document.getElementById('mainChart').getContext('2d');
  if (mainChartInst) mainChartInst.destroy();
  if (!snap) return;

  const labels     = COHORT_KEYS.map(k => YEAR_LABELS[k]);
  const quotaData  = COHORT_KEYS.map(k => (snap.summary && snap.summary[k] && snap.summary[k].quota)     || 0);
  const allocData  = COHORT_KEYS.map(k => (snap.summary && snap.summary[k] && snap.summary[k].allocated) || 0);
  const borders    = COHORT_KEYS.map(k => YEAR_COLORS[k].border);
  const bgs        = COHORT_KEYS.map(k => YEAR_COLORS[k].bg);

  const commonOpts = {
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { position:'bottom', labels:{ padding:20, font:{ size:12 } } },
      tooltip: { callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y !== undefined ? ctx.parsed.y : ctx.parsed.r} phòng` } }
    }
  };

  if (chartType === 'bar') {
    mainChartInst = new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [
          { label:'Hạn mức', data: quotaData, backgroundColor: bgs, borderColor: borders, borderWidth:2, borderRadius:6 },
          { label:'Thực tế', data: allocData, backgroundColor: borders.map(c => c + 'cc'), borderColor: borders, borderWidth:2, borderRadius:6 }
        ]
      },
      options: { ...commonOpts, scales: { y:{ beginAtZero:true, grid:{ color:'#f1f5f9' } }, x:{ grid:{ display:false } } } }
    });
  } else if (chartType === 'radar') {
    mainChartInst = new Chart(ctx, {
      type: 'radar',
      data: {
        labels,
        datasets: [
          { label:'Hạn mức', data: quotaData, backgroundColor: 'rgba(67,97,238,.12)', borderColor:'#4361ee', pointBackgroundColor:'#4361ee', borderWidth:2 },
          { label:'Thực tế', data: allocData, backgroundColor: 'rgba(247,37,133,.12)', borderColor:'#f72585', pointBackgroundColor:'#f72585', borderWidth:2 }
        ]
      },
      options: { ...commonOpts, scales: { r:{ beginAtZero:true, grid:{ color:'#e2e8f0' }, pointLabels:{ font:{ size:13, weight:'600' } } } } }
    });
  } else {
    mainChartInst = new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels,
        datasets: [{ data: quotaData, backgroundColor: borders, borderWidth:3, borderColor:'#fff', hoverOffset:6 }]
      },
      options: { ...commonOpts, cutout:'62%' }
    });
  }
}

function switchChart(type) {
  chartType = type;
  ['Bar','Radar','Donut'].forEach(t => {
    document.getElementById(`btn${t}`).classList.toggle('active', type === t.toLowerCase());
  });
  buildMainChart(activeSnapshot);
}

function buildTrendChart(timelineData) {
  const ctx = document.getElementById('trendChart').getContext('2d');
  if (trendChartInst) trendChartInst.destroy();
  if (!timelineData.length) return;

  const yearLabels = timelineData.map(t => t.academicYear);
  const datasets   = COHORT_KEYS.map(key => ({
    label:           YEAR_LABELS[key],
    data:            timelineData.map(t => (t.summary && t.summary[key] && t.summary[key].quota) || 0),
    borderColor:     YEAR_COLORS[key].border,
    backgroundColor: YEAR_COLORS[key].bg,
    tension:         0.4,
    fill:            false,
    pointRadius:     5,
    pointHoverRadius: 7,
    borderWidth:     2.5
  }));

  trendChartInst = new Chart(ctx, {
    type: 'line',
    data: { labels: yearLabels, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: {
        duration: 850,
        easing: 'easeOutQuart'
      },
      plugins: {
        legend: { position:'bottom', labels:{ padding:24, font:{ size:13 } } },
        tooltip: {
          mode: 'index',
          intersect: false,
          callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y} phòng` }
        }
      },
      scales: {
        y:{ beginAtZero:true, grid:{ color:'#f1f5f9' }, ticks:{ font:{ size:12 } } },
        x:{ grid:{ display:false }, ticks:{ font:{ size:13, weight:'600' } } }
      }
    }
  });
}

function parseAcademicYearStart(academicYear) {
  return Number(String(academicYear || '').split('-')[0]) || 0;
}

function renderKpiStrip(timelineData) {
  const wrap = document.getElementById('kpiStrip');
  if (!wrap) return;

  const byStart = new Map((timelineData || []).map(row => [parseAcademicYearStart(row.academicYear), row]));
  const starts = [2025, 2026, 2027];

  const cards = starts.map(start => {
    const row = byStart.get(start);
    if (!row) {
      return `<div class="kpi-pill kpi-empty">
        <div class="kpi-year">${start}-${start + 1}</div>
        <div class="kpi-main">N/A</div>
        <div class="kpi-sub">Chưa có snapshot</div>
      </div>`;
    }

    const summary = row.summary || {};
    const totalQuota = COHORT_KEYS.reduce((sum, key) => sum + Number((summary[key] && summary[key].quota) || 0), 0);
    const totalAllocated = COHORT_KEYS.reduce((sum, key) => sum + Number((summary[key] && summary[key].allocated) || 0), 0);
    const utilization = totalQuota > 0 ? Math.round((totalAllocated / totalQuota) * 100) : 0;

    return `<div class="kpi-pill">
      <div class="kpi-year">${row.academicYear}</div>
      <div class="kpi-main">${totalQuota}</div>
      <div class="kpi-sub">Thực tế ${totalAllocated} · ${utilization}%</div>
    </div>`;
  });

  const bridges = [
    `${starts[0]}→${starts[1]}`,
    `${starts[1]}→${starts[2]}`
  ].map((label, idx) => {
    const fromStart = starts[idx];
    const toStart = starts[idx + 1];
    const toRow = byStart.get(toStart);
    const fromRow = byStart.get(fromStart);

    if (!fromRow || !toRow || !toRow.comparison || toRow.comparison.previousAcademicYear !== fromRow.academicYear) {
      return `<div class="kpi-bridge"><span>${label}</span><strong>N/A</strong></div>`;
    }

    const deltaQuota = COHORT_KEYS.reduce((sum, key) => {
      const d = toRow.comparison.deltas && toRow.comparison.deltas[key];
      return sum + Number((d && d.quotaDelta) || 0);
    }, 0);

    const promoted = (toRow.comparison.shiftTransitions || []).filter(t => t.movement === 'promoted').length;
    const sign = deltaQuota > 0 ? '+' : '';

    return `<div class="kpi-bridge"><span>${label}</span><strong>${sign}${deltaQuota} quota · ${promoted} shift</strong></div>`;
  });

  wrap.innerHTML = `${cards[0]}${bridges[0]}${cards[1]}${bridges[1]}${cards[2]}`;
}

function deltaBadge(value) {
  const num = Number(value || 0);
  if (num === 0) return '<span class="flow-delta neutral">0</span>';
  const cls = num > 0 ? 'up' : 'down';
  const sign = num > 0 ? '+' : '';
  return `<span class="flow-delta ${cls}">${sign}${num}</span>`;
}

function renderShiftFlow(snapshot) {
  const panel = document.getElementById('shiftFlowPanel');
  const hint = document.getElementById('shiftFlowHint');
  if (!panel || !hint) return;

  if (!snapshot || !snapshot.academicYear) {
    hint.textContent = 'Không có dữ liệu để so sánh';
    panel.innerHTML = '<div class="flow-empty"><i class="fas fa-inbox"></i> Chưa có snapshot.</div>';
    return;
  }

  const timelineItem = TIMELINE_BY_YEAR.get(snapshot.academicYear);
  const comparison = timelineItem && timelineItem.comparison ? timelineItem.comparison : null;
  const prevYear = comparison && comparison.previousAcademicYear;
  const transitions = comparison && Array.isArray(comparison.shiftTransitions)
    ? comparison.shiftTransitions
    : [];

  if (!prevYear) {
    hint.textContent = 'Không có năm học trước để so sánh';
    panel.innerHTML = '<div class="flow-empty"><i class="fas fa-hourglass-start"></i> Đây là snapshot đầu tiên.</div>';
    return;
  }

  hint.textContent = `${prevYear} → ${snapshot.academicYear}`;

  const moveRows = transitions.length
    ? transitions.map(t => {
      const moveClass = t.movement === 'new' ? 'flow-new' : 'flow-promoted';
      const fromText = t.fromLabel || 'Mới';
      const toText = t.toLabel || '-';
      return `<div class="flow-row ${moveClass}">
        <span class="flow-code">${t.cohort}</span>
        <span class="flow-step">${fromText}</span>
        <span class="flow-arrow"><i class="fas fa-arrow-right"></i></span>
        <span class="flow-step to">${toText}</span>
      </div>`;
    }).join('')
    : '<div class="flow-empty"><i class="fas fa-circle-info"></i> Không phát hiện thay đổi cohort.</div>';

  const deltaRows = COHORT_KEYS.map(key => {
    const row = comparison && comparison.deltas ? (comparison.deltas[key] || {}) : {};
    return `<div class="flow-delta-row">
      <span class="flow-delta-label">${YEAR_LABELS[key]}</span>
      ${deltaBadge(row.quotaDelta)}
      ${deltaBadge(row.allocatedDelta)}
      ${deltaBadge(row.studentDelta)}
    </div>`;
  }).join('');

  panel.innerHTML = `<div class="flow-grid">
    <div class="flow-column">
      <div class="flow-col-title">Cohort chuyển nhóm</div>
      <div class="flow-list">${moveRows}</div>
    </div>
    <div class="flow-column flow-column-delta">
      <div class="flow-col-title">Chênh lệch theo nhóm năm</div>
      <div class="flow-delta-head">
        <span>Nhóm năm</span>
        <span>Quota</span>
        <span>Thực tế</span>
        <span>Sinh viên</span>
      </div>
      <div class="flow-delta-list">${deltaRows}</div>
    </div>
  </div>`;
}

// ─── Year switcher ────────────────────────────────────────────────────────────
function switchYear(year) {
  window.location.href = '/admin/cohort-shift?year=' + encodeURIComponent(year);
}

// ─── Load snapshot via API ────────────────────────────────────────────────────
async function loadSnapshot(year) {
  document.querySelectorAll('.tl-node').forEach(n => {
    n.classList.toggle('tl-node-active', n.dataset.year === year);
  });
  document.getElementById('detailYearBadge').textContent = year;

  const res = await fetch(`/api/cohort-shift/snapshot/${encodeURIComponent(year)}`, { credentials:'same-origin' });
  if (!res.ok) return showToast('Không tìm thấy snapshot', 'error');
  const { snapshot } = await res.json();
  activeSnapshot = snapshot || null;

  // Update cohort table
  const wrap = document.getElementById('cohortTableWrap');
  if (snapshot) {
    wrap.innerHTML = buildCohortTableHTML(snapshot);
  } else {
    wrap.innerHTML = `<div class="snap-empty"><i class="fas fa-circle-info"></i> Chưa có snapshot cho năm này.</div>`;
  }

  // Rebuild main chart
  buildMainChartFromData(activeSnapshot);
  renderShiftFlow(activeSnapshot);
}

function buildMainChartFromData(snap) {
  // Re-build using current chartType
  const ctx = document.getElementById('mainChart').getContext('2d');
  if (mainChartInst) mainChartInst.destroy();
  if (!snap) return;

  const labels    = COHORT_KEYS.map(k => YEAR_LABELS[k]);
  const quotaData = COHORT_KEYS.map(k => (snap.summary && snap.summary[k] && snap.summary[k].quota)     || 0);
  const allocData = COHORT_KEYS.map(k => (snap.summary && snap.summary[k] && snap.summary[k].allocated) || 0);
  const borders   = COHORT_KEYS.map(k => YEAR_COLORS[k].border);
  const bgs       = COHORT_KEYS.map(k => YEAR_COLORS[k].bg);

  if (chartType === 'bar') {
    mainChartInst = new Chart(ctx, { type:'bar', data:{ labels, datasets:[
      { label:'Hạn mức', data:quotaData, backgroundColor:bgs, borderColor:borders, borderWidth:2, borderRadius:6 },
      { label:'Thực tế', data:allocData, backgroundColor:borders.map(c=>c+'cc'), borderColor:borders, borderWidth:2, borderRadius:6 }
    ]}, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ position:'bottom' } }, scales:{ y:{ beginAtZero:true }, x:{ grid:{ display:false } } } }});
  } else if (chartType === 'radar') {
    mainChartInst = new Chart(ctx, { type:'radar', data:{ labels, datasets:[
      { label:'Hạn mức', data:quotaData, backgroundColor:'rgba(67,97,238,.12)', borderColor:'#4361ee', pointBackgroundColor:'#4361ee', borderWidth:2 },
      { label:'Thực tế', data:allocData, backgroundColor:'rgba(247,37,133,.12)', borderColor:'#f72585', pointBackgroundColor:'#f72585', borderWidth:2 }
    ]}, options:{ responsive:true, maintainAspectRatio:false, plugins:{ legend:{ position:'bottom' } }, scales:{ r:{ beginAtZero:true } } }});
  } else {
    mainChartInst = new Chart(ctx, { type:'doughnut', data:{ labels, datasets:[{ data:quotaData, backgroundColor:borders, borderWidth:3, borderColor:'#fff', hoverOffset:6 }]}, options:{ responsive:true, maintainAspectRatio:false, cutout:'62%', plugins:{ legend:{ position:'bottom' } } }});
  }
}

function buildCohortTableHTML(snap) {
  const colors = { year1:'#4361ee', year2:'#3a0ca3', year3:'#7209b7', year4_plus:'#f72585' };
  const labels = { year1:'Năm 1', year2:'Năm 2', year3:'Năm 3', year4_plus:'Năm 4+' };
  const rows = (snap.cohorts || []).map(c => {
    const util = c.quota > 0 ? Math.round((c.allocated / c.quota) * 100) : 0;
    return `<tr>
      <td><span class="ct-code">${c.code}</span></td>
      <td>${c.enrollmentYear}</td>
      <td><span class="ct-year-badge" style="background:${colors[c.yearGroup] || '#888'}22;color:${colors[c.yearGroup] || '#888'}">${labels[c.yearGroup] || c.yearGroup}</span></td>
      <td>${c.quota}</td>
      <td>${c.allocated}</td>
      <td>
        <div class="ct-prog-wrap">
          <div class="ct-prog-bg"><div class="ct-prog-fill" style="width:${util}%;background:${colors[c.yearGroup] || '#888'}"></div></div>
          <span>${util}%</span>
        </div>
      </td>
      <td>${c.studentCount}</td>
      ${c.yearInSchool >= 5 ? '<td><span class="edge-warn">Năm '+c.yearInSchool+'</span></td>' : '<td>—</td>'}
    </tr>`;
  }).join('');

  return `<div class="ct-scroll">
    <table class="ct-table">
      <thead>
        <tr>
          <th>Cohort</th><th>Năm nhập học</th><th>Nhóm năm</th>
          <th>Quota</th><th>Thực tế</th><th>Sử dụng</th><th>SV</th><th>Ghi chú</th>
        </tr>
      </thead>
      <tbody>${rows || '<tr><td colspan="8" style="text-align:center;padding:32px;color:#94a3b8">Không có dữ liệu</td></tr>'}</tbody>
    </table>
  </div>`;
}

// ─── Run shift modal ──────────────────────────────────────────────────────────
function runShift() {
  document.getElementById('runModal').classList.add('open');
  document.getElementById('runBackdrop').classList.add('open');
}
function closeRunModal() {
  document.getElementById('runModal').classList.remove('open');
  document.getElementById('runBackdrop').classList.remove('open');
}

async function confirmRunShift() {
  const year  = document.getElementById('runYear').value;
  const notes = document.getElementById('runNotes').value;
  const btn   = document.getElementById('runBtn');

  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang chạy...';

  try {
    const res = await fetch('/api/cohort-shift/run', {
      method:      'POST',
      headers:     { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body:        JSON.stringify({ academicYear: year, notes })
    });
    const data = await res.json();
    if (data.success) {
      showToast(`Shift thành công cho năm ${year}!`, 'success');
      closeRunModal();
      setTimeout(() => window.location.href = `/admin/cohort-shift?year=${encodeURIComponent(year)}`, 1000);
    } else {
      showToast(data.error || 'Lỗi khi chạy shift', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-play"></i> Xác nhận chạy';
    }
  } catch {
    showToast('Network error', 'error');
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-play"></i> Xác nhận chạy';
  }
}

// ─── Toast ────────────────────────────────────────────────────────────────────
let toastTimer = null;
function showToast(msg, type = 'success') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = `toast toast-${type} toast-show`;
  if (toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('toast-show'), 3500);
}

// ─── Init ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  activeSnapshot = CURRENT_SNAP;
  if (!activeSnapshot && SELECTED_YEAR && TIMELINE_BY_YEAR.has(SELECTED_YEAR)) {
    activeSnapshot = TIMELINE_BY_YEAR.get(SELECTED_YEAR);
  }
  buildMainChart(activeSnapshot);
  buildTrendChart(TIMELINE_DATA);
  renderKpiStrip(TIMELINE_DATA);
  renderShiftFlow(activeSnapshot);
});
</script>
</body>
</html>
