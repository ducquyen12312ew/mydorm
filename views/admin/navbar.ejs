<%
  const navActive = typeof activeNav !== 'undefined' ? activeNav : '';
  const navUser = typeof user !== 'undefined' && user ? user : (typeof locals !== 'undefined' && locals.user ? locals.user : null);
  const navUserName = navUser && navUser.name ? navUser.name : 'Admin';
  const navUsername = (navUser && navUser.username) || (typeof locals !== 'undefined' && locals.sessionUsername) || '';
  const navInitials = navUserName.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
  const PAGE_TITLES = {
    dashboard:'Dashboard', dormitories:'Ký túc xá', students:'Sinh viên',
    applications:'Hồ sơ đăng ký', violations:'Vi phạm', maintenance:'Bảo trì',
    logs:'Nhật ký', quotas:'Quota', academic:'Học vụ',
    registrationperiod:'Đợt đăng ký KTX',
  };
  const pageTitle = PAGE_TITLES[navActive] || '';
%>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<link rel="stylesheet" href="/css/admin.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;}
html,body{margin:0;padding:0;min-height:100vh;}

/* ─── Sidebar ────────────────────────────────────────────── */
.adm-sidebar{
  position:fixed;top:0;left:0;height:100vh;width:224px;
  background:linear-gradient(180deg,#FFFEFA 0%,#FAF5EE 100%);
  border-right:1px solid #EFE8DF;
  display:flex;flex-direction:column;z-index:200;
  transition:width .22s cubic-bezier(.4,0,.2,1);overflow:hidden;
  box-shadow:2px 0 20px rgba(43,35,32,.06);
}
.adm-sidebar.sb-collapsed{width:58px;}

.sb-hd{
  height:58px;display:flex;align-items:center;
  padding:0 12px;border-bottom:1px solid #EFE8DF;flex-shrink:0;gap:8px;
}
.sb-logo-link{
  display:flex;align-items:center;text-decoration:none;
  flex:1;overflow:hidden;transition:opacity .15s;
}
.sb-logo-link:hover{opacity:.8;}
.sb-logo-img{height:28px;width:auto;object-fit:contain;image-rendering:-webkit-optimize-contrast;}
.adm-sidebar.sb-collapsed .sb-logo-link{width:0;opacity:0;pointer-events:none;flex:0;}
.sb-toggle{
  width:32px;height:32px;border:none;background:none;cursor:pointer;
  color:#A89C8E;border-radius:8px;display:flex;align-items:center;
  justify-content:center;font-size:14px;
  transition:background .15s,color .15s;flex-shrink:0;
}
.sb-toggle:hover{background:#F0E8DF;color:#2B2320;}

.sb-nav{flex:1;overflow-y:auto;overflow-x:hidden;padding:10px 8px;scrollbar-width:none;}
.sb-nav::-webkit-scrollbar{display:none;}

.sb-group{margin-bottom:4px;}
.sb-label{
  font-size:9.5px;font-weight:700;color:#C4B4A6;letter-spacing:.1em;
  text-transform:uppercase;padding:10px 12px 5px;white-space:nowrap;
  transition:opacity .15s,height .15s,padding .15s;overflow:hidden;
}
.adm-sidebar.sb-collapsed .sb-label{opacity:0;height:0;padding:0;}

.sb-item{
  display:flex;align-items:center;gap:10px;padding:8px 12px;
  border-radius:10px;color:#6B5F58;text-decoration:none;
  font-family:'Josefin Sans',system-ui,sans-serif;
  font-size:13px;font-weight:500;white-space:nowrap;
  transition:background .14s,color .14s;position:relative;margin-bottom:2px;
}
.sb-item:hover{background:#F0E8DF;color:#2B2320;}
.sb-item.active{
  background:linear-gradient(135deg,rgba(225,29,42,.1),rgba(178,12,38,.06));
  color:#C8102E;font-weight:600;
}
.sb-item.active::before{
  content:'';position:absolute;left:0;top:7px;bottom:7px;
  width:3px;background:linear-gradient(180deg,#E11D2A,#B20C26);
  border-radius:0 3px 3px 0;
}
.sb-item i{font-size:13.5px;width:18px;text-align:center;flex-shrink:0;opacity:.65;}
.sb-item.active i{opacity:1;}
.sb-item .sb-text{transition:opacity .15s;white-space:nowrap;overflow:hidden;}
.adm-sidebar.sb-collapsed .sb-text{opacity:0;width:0;overflow:hidden;}
.adm-sidebar.sb-collapsed .sb-item{padding:8px;justify-content:center;}
.adm-sidebar.sb-collapsed .sb-item::before{top:5px;bottom:5px;}

.sb-div{height:1px;background:#EFE8DF;margin:5px 6px;}

/* Tooltip on collapse */
.adm-sidebar.sb-collapsed .sb-item:hover::after{
  content:attr(data-tip);
  position:absolute;left:calc(100% + 10px);top:50%;transform:translateY(-50%);
  background:#2B2320;color:#FBF8F3;font-size:12px;font-weight:500;
  font-family:'Josefin Sans',system-ui,sans-serif;
  padding:5px 11px;border-radius:8px;white-space:nowrap;pointer-events:none;z-index:400;
  box-shadow:0 4px 16px rgba(43,35,32,.2);
}

/* Sidebar footer */
.sb-ft{padding:10px 8px;border-top:1px solid #EFE8DF;flex-shrink:0;position:relative;}
.sb-user{
  display:flex;align-items:center;gap:10px;padding:8px 12px;
  border-radius:10px;cursor:pointer;transition:background .14s;color:#6B5F58;
}
.sb-user:hover{background:#F0E8DF;}
.sb-avatar{
  width:30px;height:30px;border-radius:50%;
  background:linear-gradient(135deg,#E11D2A,#B20C26);
  color:#fff;font-size:10.5px;font-weight:700;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  box-shadow:0 3px 10px rgba(200,16,46,.35);
}
.sb-uname{font-size:13px;font-weight:600;color:#2B2320;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-urole{font-size:10.5px;color:#A89C8E;}
.adm-sidebar.sb-collapsed .sb-user{padding:8px;justify-content:center;}
.adm-sidebar.sb-collapsed .sb-uinfo{display:none;}

.sb-usermenu{
  position:absolute;bottom:calc(100% + 6px);left:8px;right:8px;
  background:linear-gradient(180deg,#FFFFFF,#FDFAF6);
  border:1px solid #EFE8DF;border-radius:14px;
  box-shadow:0 8px 32px rgba(43,35,32,.14);display:none;z-index:300;overflow:hidden;
}
.sb-usermenu.open{display:block;}
.sb-usermenu-hd{padding:12px 16px 10px;border-bottom:1px solid #EFE8DF;}
.sb-usermenu a{
  display:flex;align-items:center;gap:10px;text-decoration:none;
  color:#6B5F58;padding:9px 16px;font-size:13px;
  font-family:'Josefin Sans',system-ui,sans-serif;
  transition:background .12s;
}
.sb-usermenu a:hover{background:#F5EFE7;}
.sb-usermenu a i{width:16px;text-align:center;font-size:12px;color:#A89C8E;}
.sb-usermenu a.danger{color:#C8102E;}
.sb-usermenu a.danger i{color:#C8102E;}
.sb-usermenu hr{border:none;border-top:1px solid #EFE8DF;margin:3px 0;}

/* ─── Topbar ─────────────────────────────────────────────── */
.adm-topbar{
  position:fixed;top:0;left:224px;right:0;height:58px;
  background:linear-gradient(180deg,rgba(255,254,250,.97),rgba(251,248,243,.96));
  border-bottom:1px solid #EFE8DF;backdrop-filter:blur(12px);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;z-index:100;gap:16px;
  transition:left .22s cubic-bezier(.4,0,.2,1);
  box-shadow:0 1px 0 #EFE8DF,0 2px 16px rgba(43,35,32,.04);
}
body.sb-collapsed .adm-topbar{left:58px;}

.tb-title{
  font-family:'Josefin Sans',sans-serif;
  font-size:1.05rem;font-weight:600;color:#2B2320;margin:0;
}

.tb-right{display:flex;align-items:center;gap:8px;}

.tb-search{
  display:flex;align-items:center;gap:8px;
  background:rgba(255,255,255,.8);border:1px solid #E7DECF;border-radius:10px;
  padding:6px 14px;font-size:13px;font-family:'Josefin Sans',system-ui,sans-serif;
  color:#A89C8E;cursor:pointer;transition:border-color .15s,box-shadow .15s;
}
.tb-search:hover{border-color:#C8102E;box-shadow:0 0 0 3px rgba(200,16,46,.08);}
.tb-search i{font-size:11px;}

.tb-iconbtn{
  width:36px;height:36px;border-radius:10px;
  border:1px solid #E7DECF;background:rgba(255,255,255,.85);
  color:#8B8178;cursor:pointer;display:flex;align-items:center;
  justify-content:center;font-size:14px;
  transition:background .15s,border-color .15s,color .15s;
  text-decoration:none;position:relative;
}
.tb-iconbtn:hover{background:#FBF8F3;border-color:#D8CABA;color:#2B2320;}
.notif-dot{
  position:absolute;top:-3px;right:-3px;width:15px;height:15px;
  background:linear-gradient(135deg,#E11D2A,#B20C26);color:#fff;
  border-radius:50%;font-size:8px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  border:2px solid #FFFEFA;
}

/* ─── Body offset ────────────────────────────────────────── */
body{padding-left:224px;padding-top:58px;transition:padding-left .22s cubic-bezier(.4,0,.2,1);}
body.sb-collapsed{padding-left:58px;}

@media(max-width:768px){
  .adm-sidebar{width:58px;}
  .adm-sidebar .sb-text{opacity:0;width:0;overflow:hidden;}
  .adm-sidebar .sb-label{opacity:0;height:0;padding:0;}
  .adm-sidebar .sb-item{padding:8px;justify-content:center;}
  .adm-sidebar .sb-user{padding:8px;justify-content:center;}
  .adm-sidebar .sb-uinfo{display:none;}
  body{padding-left:58px;}
  .adm-topbar{left:58px;}
  .tb-search span{display:none;}
}
</style>

<!-- ══ SIDEBAR ═══════════════════════════════════════════════ -->
<aside class="adm-sidebar" id="admSidebar" aria-label="Navigation">

  <div class="sb-hd">
    <button class="sb-toggle" id="sbToggle" aria-label="Đóng/mở sidebar">
      <i class="fas fa-bars"></i>
    </button>
    <a href="/admin/dashboard" class="sb-logo-link" title="eDorm">
      <img src="https://res.cloudinary.com/dysgt8t4d/image/upload/v1781114107/logo_edorm2_au54b2.png"
           alt="eDorm" class="sb-logo-img" />
    </a>
  </div>

  <nav class="sb-nav">

    <div class="sb-group">
      <div class="sb-label">Tổng quan</div>
      <a href="/admin/dashboard"
         class="sb-item <%=navActive==='dashboard'?'active':''%>"
         data-tip="Dashboard">
        <i class="fas fa-chart-line"></i><span class="sb-text">Dashboard</span>
      </a>
      <a href="/admin/registration-period"
         class="sb-item <%=navActive==='registrationperiod'?'active':''%>"
         data-tip="Đợt đăng ký KTX">
        <i class="fas fa-calendar-check"></i><span class="sb-text">Đợt đăng ký KTX</span>
      </a>
    </div>

    <div class="sb-div"></div>

    <div class="sb-group">
      <div class="sb-label">Quản lý KTX</div>
      <a href="/admin/dormitories"
         class="sb-item <%=navActive==='dormitories'?'active':''%>"
         data-tip="Ký túc xá">
        <i class="fas fa-building"></i><span class="sb-text">Ký túc xá</span>
      </a>
      <a href="/admin/students"
         class="sb-item <%=navActive==='students'?'active':''%>"
         data-tip="Sinh viên">
        <i class="fas fa-users"></i><span class="sb-text">Sinh viên</span>
      </a>
    </div>

    <div class="sb-div"></div>

    <div class="sb-group">
      <div class="sb-label">Vận hành</div>
      <a href="/admin/application"
         class="sb-item <%=navActive==='applications'?'active':''%>"
         data-tip="Hồ sơ">
        <i class="fas fa-file-alt"></i><span class="sb-text">Hồ sơ</span>
      </a>
      <a href="/admin/requests"
         class="sb-item <%=(navActive==='requests'||navActive==='maintenance'||navActive==='roomtransfer')?'active':''%>"
         data-tip="Yêu cầu">
        <i class="fas fa-inbox"></i><span class="sb-text">Yêu cầu</span>
      </a>
      <a href="/admin/violations"
         class="sb-item <%=navActive==='violations'?'active':''%>"
         data-tip="Vi phạm">
        <i class="fas fa-shield-alt"></i><span class="sb-text">Vi phạm</span>
      </a>
    </div>

    <div class="sb-div"></div>

    <div class="sb-group">
      <div class="sb-label">Thông báo</div>
      <a href="/admin/notifications"
         class="sb-item <%=navActive==='notifications'?'active':''%>"
         data-tip="Thông báo">
        <i class="fas fa-bullhorn"></i><span class="sb-text">Gửi thông báo</span>
      </a>
    </div>

    <div class="sb-div"></div>

    <% if (navUsername === 'admintest') { %>
    <div class="sb-group">
      <div class="sb-label">Công cụ</div>
      <a href="/admin/simulation"
         class="sb-item <%=navActive==='simulation'?'active':''%>"
         data-tip="Phân phòng tự động">
        <i class="fas fa-layer-group"></i><span class="sb-text">Phân phòng tự động</span>
      </a>
    </div>
    <% } %>

    <div class="sb-group">
      <div class="sb-label">Hệ thống</div>
      <a href="/admin/quotas"
         class="sb-item <%=navActive==='quotas'?'active':''%>"
         data-tip="Quota">
        <i class="fas fa-chart-pie"></i><span class="sb-text">Quota</span>
      </a>
      <a href="/admin/academic-windows"
         class="sb-item <%=navActive==='academic'?'active':''%>"
         data-tip="Học vụ">
        <i class="fas fa-calendar-alt"></i><span class="sb-text">Học vụ</span>
      </a>
      <a href="/admin/logs"
         class="sb-item <%=navActive==='logs'?'active':''%>"
         data-tip="Nhật ký">
        <i class="fas fa-history"></i><span class="sb-text">Nhật ký</span>
      </a>
    </div>

  </nav>

  <div class="sb-ft">
    <div class="sb-usermenu" id="sbUserMenu" role="menu">
      <div class="sb-usermenu-hd">
        <div style="font-family:'Josefin Sans',sans-serif;font-weight:600;font-size:13px;color:#2B2320;"><%= navUserName %></div>
        <% if (navUser && navUser.isSuperAdmin) { %>
          <div style="font-size:11px;color:#A89C8E;margin-top:1px;">Giám đốc Ký túc xá</div>
        <% } else { %>
          <div style="font-size:11px;color:#A89C8E;margin-top:1px;">Quản trị viên</div>
        <% } %>
      </div>
      <a href="/admin/priority-claims-review"><i class="fas fa-star"></i>Ưu tiên</a>
      <hr>
      <a href="/logout" class="danger"><i class="fas fa-sign-out-alt"></i>Đăng xuất</a>
    </div>
    <div class="sb-user" id="sbUserBtn" role="button" tabindex="0" aria-haspopup="true">
      <div class="sb-avatar"><%= navInitials %></div>
      <div class="sb-uinfo">
        <div class="sb-uname"><%= navUserName %></div>
        <div class="sb-urole"><%= (navUser && navUser.isSuperAdmin) ? 'Giám đốc Ký túc xá' : 'Quản trị viên' %></div>
      </div>
    </div>
  </div>

</aside>

<!-- ══ TOPBAR ════════════════════════════════════════════════ -->
<header class="adm-topbar">
  <div>
    <% if (pageTitle) { %><h1 class="tb-title"><%= pageTitle %></h1><% } %>
  </div>
  <div class="tb-right">
    <div class="tb-search">
      <i class="fas fa-search"></i><span>Tìm kiếm...</span>
    </div>
    <a href="/admin/logs" class="tb-iconbtn" title="Nhật ký hệ thống">
      <i class="fas fa-bell"></i>
      <span class="notif-dot" id="notifDot" style="display:none;"></span>
    </a>
  </div>
</header>

<script>
(function(){
  var sidebar = document.getElementById('admSidebar');
  var toggle  = document.getElementById('sbToggle');
  var userBtn = document.getElementById('sbUserBtn');
  var userMenu= document.getElementById('sbUserMenu');

  if(localStorage.getItem('sbCollapsed')==='1'){
    sidebar.classList.add('sb-collapsed');
    document.body.classList.add('sb-collapsed');
  }

  toggle.addEventListener('click',function(){
    var c = sidebar.classList.toggle('sb-collapsed');
    document.body.classList.toggle('sb-collapsed',c);
    localStorage.setItem('sbCollapsed',c?'1':'0');
  });

  if(userBtn && userMenu){
    userBtn.addEventListener('click',function(e){e.stopPropagation();userMenu.classList.toggle('open');});
    userBtn.addEventListener('keydown',function(e){if(e.key==='Enter'||e.key===' '){e.preventDefault();userMenu.classList.toggle('open');}});
    document.addEventListener('click',function(){userMenu.classList.remove('open');});
    document.addEventListener('keydown',function(e){if(e.key==='Escape')userMenu.classList.remove('open');});
  }

  fetch('/admin/applications/stats').then(r=>r.json()).then(r=>{
    if(r.success&&r.stats&&r.stats.pending>0){
      var d=document.getElementById('notifDot');
      if(d){d.style.display='flex';d.textContent=r.stats.pending>9?'9+':r.stats.pending;}
    }
  }).catch(function(){});
})();
</script>
