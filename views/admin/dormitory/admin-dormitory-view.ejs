﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= dormitory.name %> — Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary:    #C8102E;
      --primary-dk: #9E0C24;
      --primary-bg: #FFF0F2;
      --border:     #EFE8DF;
      --text:       #2B2320;
      --text-2:     #7C7166;
      --text-3:     #A89C8E;
      --success:    #0E9F6E;
      --success-bg: #E4F6EF;
      --success-bd: #A7DFC8;
      --warning:    #D9A22B;
      --warning-bg: #FBF1DC;
      --warning-bd: #EDD28A;
      --danger:     #C8102E;
      --danger-bg:  #FFF0F2;
      --shadow-card: 0 1px 2px rgba(43,35,32,.04), 0 20px 38px -26px rgba(43,35,32,.2);
      --radius-card: 16px;
      --radius-sm:   10px;
      --radius-btn:  11px;
    }

    body {
      background: linear-gradient(180deg, #FBF8F3, #F5EFE7);
      min-height: 100vh;
      font-family: 'Inter', system-ui, sans-serif;
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }

    .page {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 24px 48px;
    }

    /* ── Page header ── */
    .page-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 0 18px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 22px;
      gap: 12px;
      flex-wrap: wrap;
    }

    .page-head-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--text-2);
    }

    .breadcrumb a { color: var(--text-2); }
    .breadcrumb a:hover { color: var(--text); }
    .breadcrumb .sep { color: var(--text-3); }
    .breadcrumb .current { color: var(--text); font-weight: 700; font-family: 'Inter', sans-serif; }

    .page-head-right { display: flex; gap: 8px; flex-wrap: wrap; }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: var(--radius-btn);
      font-size: 13px;
      font-weight: 600;
      font-family: 'Inter', inherit;
      cursor: pointer;
      border: 1px solid transparent;
      transition: background 0.15s, box-shadow 0.15s, border-color 0.15s;
      white-space: nowrap;
    }

    .btn-primary {
      background: linear-gradient(135deg, #E11D2A, #B20C26);
      color: #fff;
      box-shadow: 0 10px 24px -10px rgba(200,16,46,.65);
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #C8102E, #9E0C24);
      box-shadow: 0 12px 28px -8px rgba(200,16,46,.75);
    }

    .btn-ghost { background: #fff; color: var(--text-2); border-color: var(--border); }
    .btn-ghost:hover { background: #FBF8F3; color: var(--text); border-color: #D9CFBF; }

    .btn-danger-ghost { background: transparent; color: var(--danger); border-color: transparent; }
    .btn-danger-ghost:hover { background: var(--danger-bg); border-color: #FECDD3; }

    /* ── KPI row ── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 13px;
      margin-bottom: 24px;
    }
    @media (max-width: 900px) { .kpi-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 600px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }

    .kpi-card {
      background: linear-gradient(180deg, #FFFFFF, #FCFAF6);
      border: 1px solid var(--border);
      border-top: 3px solid #C8102E;
      border-radius: var(--radius-card);
      padding: 15px 18px;
      box-shadow: var(--shadow-card);
    }

    .kpi-label {
      font-size: 10.5px;
      font-weight: 700;
      color: #9A8F84;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 5px;
      font-family: 'Inter', sans-serif;
    }

    .kpi-value {
      font-family: 'Inter', sans-serif;
      font-size: 24px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--text);
      line-height: 1;
    }

    .kpi-value.accent { color: var(--primary); }

    .kpi-sub { font-size: 11px; color: var(--text-3); margin-top: 4px; }

    /* ── Dormitory info card ── */
    .dorm-info-card {
      background: linear-gradient(180deg, #FFFFFF, #FCFAF6);
      border: 1px solid var(--border);
      border-radius: var(--radius-card);
      padding: 20px 22px;
      margin-bottom: 22px;
      display: flex;
      gap: 20px;
      align-items: flex-start;
      box-shadow: var(--shadow-card);
      flex-wrap: wrap;
    }

    .dorm-info-img {
      width: 110px;
      height: 74px;
      object-fit: cover;
      border-radius: 10px;
      flex-shrink: 0;
    }

    .dorm-info-img-placeholder {
      width: 110px;
      height: 74px;
      background: linear-gradient(135deg, #F7F1E8, #EFE8DF);
      border: 1px solid var(--border);
      border-radius: 10px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #C8B9A8;
      font-size: 28px;
    }

    .dorm-info-meta { flex: 1; }
    .dorm-info-meta h2 {
      font-family: 'Inter', sans-serif;
      font-size: 18px; font-weight: 700; color: var(--text); letter-spacing: -0.01em;
    }
    .dorm-info-meta p  { font-size: 12px; color: var(--text-2); margin-top: 5px; }

    .dorm-info-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 9px; }

    .tag {
      padding: 2px 8px;
      border-radius: 5px;
      font-size: 11px;
      font-weight: 500;
      border: 1px solid transparent;
    }
    .tag-school       { background: #F7F1E8; color: var(--text-2); border-color: var(--border); }
    .tag-private      { background: #FBF1DC; color: #92400E; border-color: #EDD28A; }
    .tag-basic        { background: var(--primary-bg); color: var(--primary); border-color: #FECDD3; }
    .tag-premium      { background: #F7F1E8; color: #7C5C2E; border-color: #DCC9A8; }
    .tag-international{ background: #FBF1DC; color: #7C4D10; border-color: #EDD28A; }
    .tag-female       { background: #F7F1E8; color: var(--text-2); border-color: var(--border); }
    .tag-male         { background: #F7F1E8; color: var(--text-2); border-color: var(--border); }
    .tag-amenity      { background: #F7F1E8; color: var(--text-2); border-color: var(--border); }

    /* ── Floors section ── */
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }

    .section-title {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .section-title i { color: var(--primary); font-size: 13px; }

    /* ── Floor block ── */
    .floor-block { margin-bottom: 20px; }

    .floor-heading {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 9px 14px;
      background: #F7F1E8;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      margin-bottom: 12px;
      font-size: 13px;
      font-weight: 700;
      color: var(--text);
    }

    .floor-heading i { color: #9A8F84; font-size: 11px; }
    .floor-badge {
      margin-left: auto;
      font-size: 11px;
      color: var(--text-3);
      font-weight: 500;
    }

    /* ── Room grid ── */
    .rooms-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }

    /* ── Room card ── */
    .room-card {
      background: linear-gradient(180deg, #FFFFFF, #FCFAF6);
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 1px 2px rgba(43,35,32,.04), 0 8px 18px -12px rgba(43,35,32,.15);
      overflow: hidden;
      transition: box-shadow 0.15s, border-color 0.15s;
    }

    .room-card:hover {
      box-shadow: 0 2px 6px rgba(43,35,32,.07), 0 14px 26px -10px rgba(43,35,32,.22);
      border-color: #D9CFBF;
    }

    .room-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 11px 14px 9px;
      border-bottom: 1px solid #F1EAE0;
      background: #F7F1E8;
    }

    .room-num {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
    }

    .room-type-label {
      font-size: 11px;
      color: var(--text-3);
      font-weight: 500;
    }

    .room-occ-badge {
      font-size: 12px;
      font-weight: 600;
      padding: 2px 9px;
      border-radius: 99px;
    }

    .occ-full  { background: var(--primary-bg); color: var(--primary); border: 1px solid #FECDD3; }
    .occ-most  { background: var(--warning-bg); color: var(--warning); border: 1px solid var(--warning-bd); }
    .occ-part  { background: #F7F1E8; color: var(--text-2); border: 1px solid var(--border); }
    .occ-empty { background: #FDFBF8; color: var(--text-3); border: 1px solid #EFE8DF; }

    .room-card-body { padding: 11px 14px 13px; }

    /* mini progress */
    .room-prog {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 10px;
    }

    .room-prog-track {
      flex: 1;
      height: 4px;
      background: #EFE8DF;
      border-radius: 99px;
      overflow: hidden;
    }

    .room-prog-fill {
      height: 100%;
      border-radius: 99px;
    }

    .room-prog-fill.occ-high { background: linear-gradient(90deg, #E11D2A, #B20C26); }
    .room-prog-fill.occ-mid  { background: linear-gradient(90deg, #D9A22B, #B8861F); }
    .room-prog-fill.occ-low  { background: #C8B9A8; }

    .room-prog-label { font-size: 11px; color: var(--text-3); white-space: nowrap; }

    /* occupants list */
    .occupants-list { display: flex; flex-direction: column; gap: 5px; }

    .occupant-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 8px;
      border-radius: 8px;
      transition: background 0.1s;
    }

    .occupant-row:hover { background: #F7F1E8; }

    .occ-avatar {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: linear-gradient(135deg, #E11D2A, #B20C26);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .occ-info { flex: 1; min-width: 0; }
    .occ-name { font-size: 12px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .occ-id   { font-size: 11px; color: var(--text-3); }

    .occ-icon { color: var(--text-3); font-size: 11px; }

    .empty-room-msg {
      font-size: 12px;
      color: var(--text-3);
      text-align: center;
      padding: 8px 0;
    }

    .more-residents {
      font-size: 11px;
      color: var(--text-3);
      text-align: center;
      padding: 4px 0;
      font-style: italic;
    }

    /* room footer */
    .room-card-foot {
      padding: 8px 12px;
      border-top: 1px solid #F1EAE0;
      background: #FDFBF8;
      display: flex;
      gap: 6px;
    }
  </style>
</head>
<body>
  <%- include('../navbar', { activeNav: 'dormitories' }) %>

  <div class="page">

    <!-- Page header -->
    <div class="page-head">
      <div class="page-head-left">
        <div class="breadcrumb">
          <a href="/admin/dormitories"><i class="fas fa-building"></i> Ký túc xá</a>
          <span class="sep">/</span>
          <span class="current"><%= dormitory.name %></span>
        </div>
      </div>
      <div class="page-head-right">
        <a href="/admin/dormitories/edit/<%= dormitory._id %>" class="btn btn-ghost">
          <i class="fas fa-pen"></i> Sửa
        </a>
        <button onclick="deleteDorm('<%= dormitory._id %>')" class="btn btn-danger-ghost">
          <i class="fas fa-trash"></i>
        </button>
        <a href="/admin/dormitories" class="btn btn-ghost">
          <i class="fas fa-arrow-left"></i> Quay lại
        </a>
      </div>
    </div>

    <%
    let dFloors = dormitory.floors ? dormitory.floors.length : 0;
    let dRooms  = 0, dCap = 0, dOcc = 0;
    let minPrice = Infinity, maxPrice = 0;

    if (dormitory.floors) {
      dormitory.floors.forEach(fl => {
        if (fl.rooms) {
          fl.rooms.forEach(rm => {
            dRooms++;
            dCap += rm.maxCapacity || 0;
            dOcc += (rm.occupants || []).filter(o => o.active).length;
            if (rm.pricePerMonth) {
              if (rm.pricePerMonth < minPrice) minPrice = rm.pricePerMonth;
              if (rm.pricePerMonth > maxPrice) maxPrice = rm.pricePerMonth;
            }
          });
        }
      });
    }
    if (minPrice === Infinity) minPrice = 0;

    const occRate = dCap > 0 ? Math.round(dOcc / dCap * 100) : 0;
    const available = dOcc < dCap;
    %>

    <!-- Dormitory info card -->
    <div class="dorm-info-card">
      <% if (dormitory.imageUrl) { %>
        <img class="dorm-info-img" src="<%= dormitory.imageUrl %>" alt="<%= dormitory.name %>" loading="lazy">
      <% } else { %>
        <div class="dorm-info-img-placeholder"><i class="fas fa-building"></i></div>
      <% } %>

      <div class="dorm-info-meta">
        <h2><%= dormitory.name %></h2>
        <p><i class="fas fa-map-marker-alt" style="color:#C8102E;margin-right:4px;"></i><%= dormitory.address || '' %></p>
        <% if (dormitory.contact && (dormitory.contact.phone || dormitory.contact.email)) { %>
        <p style="margin-top:3px;">
          <% if (dormitory.contact.phone) { %><i class="fas fa-phone" style="margin-right:4px;"></i><%= dormitory.contact.phone %><% } %>
          <% if (dormitory.contact.email) { %>&nbsp;&nbsp;<i class="fas fa-envelope" style="margin-right:4px;"></i><%= dormitory.contact.email %><% } %>
        </p>
        <% } %>
        <div class="dorm-info-tags">
          <% if (dormitory.details && dormitory.details.type) { %>
            <span class="tag tag-<%= dormitory.details.type %>">
              <%= dormitory.details.type === 'school' ? 'Trường học' : 'Tư nhân' %>
            </span>
          <% } %>
          <% if (dormitory.details && dormitory.details.category) { %>
            <span class="tag tag-<%= dormitory.details.category %>">
              <% if (dormitory.details.category === 'basic') { %>Cơ bản<% } %>
              <% if (dormitory.details.category === 'premium') { %>Cao cấp<% } %>
              <% if (dormitory.details.category === 'international') { %>Quốc tế<% } %>
            </span>
          <% } %>
          <% if (dormitory.details && dormitory.details.gender && dormitory.details.gender !== 'mixed') { %>
            <span class="tag tag-<%= dormitory.details.gender %>">
              <%= dormitory.details.gender === 'female' ? '♀ Nữ' : '♂ Nam' %>
            </span>
          <% } %>
          <% if (dormitory.details && dormitory.details.amenities) { %>
            <% dormitory.details.amenities.slice(0, 3).forEach(a => { %>
              <span class="tag tag-amenity"><%= a %></span>
            <% }); %>
            <% if (dormitory.details.amenities.length > 3) { %>
              <span class="tag tag-amenity">+<%= dormitory.details.amenities.length - 3 %></span>
            <% } %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- KPI row -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-label">Tổng tầng</div>
        <div class="kpi-value"><%= dFloors %></div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Tổng phòng</div>
        <div class="kpi-value"><%= dRooms %></div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Sức chứa</div>
        <div class="kpi-value"><%= dCap %></div>
        <div class="kpi-sub">chỗ tối đa</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Sinh viên</div>
        <div class="kpi-value"><%= dOcc %></div>
        <div class="kpi-sub"><%= dCap - dOcc %> chỗ trống</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Lấp đầy</div>
        <div class="kpi-value accent"><%= occRate %>%</div>
        <div class="kpi-sub"><%= available ? 'Còn chỗ' : 'Hết chỗ' %></div>
      </div>
    </div>

    <!-- Floors & Rooms -->
    <div>
      <div class="section-header">
        <div class="section-title">
          <i class="fas fa-layer-group"></i>
          Danh sách phòng theo tầng
        </div>
        <span style="font-size:12px;color:var(--text-3);"><%= dRooms %> phòng · <%= dOcc %>/<%= dCap %> chỗ</span>
      </div>

      <% if (dormitory.floors && dormitory.floors.length > 0) { %>
        <% dormitory.floors.forEach(function(floor) {
          let fRooms = floor.rooms ? floor.rooms.length : 0;
          let fOcc = 0, fCap = 0;
          if (floor.rooms) {
            floor.rooms.forEach(r => {
              fCap += r.maxCapacity || 0;
              fOcc += (r.occupants || []).filter(o => o.active).length;
            });
          }
        %>
        <div class="floor-block">
          <div class="floor-heading">
            <i class="fas fa-arrows-alt-v"></i>
            Tầng <%= floor.floorNumber %>
            <span class="floor-badge"><%= fRooms %> phòng · <%= fOcc %>/<%= fCap %> chỗ</span>
          </div>

          <% if (floor.rooms && floor.rooms.length > 0) { %>
          <div class="rooms-grid">
            <% floor.rooms.forEach(function(room) {
              const occ  = (room.occupants || []).filter(o => o.active);
              const occN = occ.length;
              const cap  = room.maxCapacity || 0;
              const pct  = cap > 0 ? Math.round(occN / cap * 100) : 0;
              const occClass = pct >= 90 ? 'occ-high' : pct >= 50 ? 'occ-mid' : 'occ-low';
              const badgeClass = pct >= 100 ? 'occ-full' : pct >= 70 ? 'occ-most' : pct > 0 ? 'occ-part' : 'occ-empty';

              const typeLabel = {
                '8-person': '8 người', '4-person-service': '4 người (DV)',
                '5-person': '5 người', '10-person': '10 người'
              }[room.roomType] || room.roomType || '';
            %>
            <div class="room-card">
              <div class="room-card-head">
                <div>
                  <div class="room-num">Phòng <%= room.roomNumber %></div>
                  <div class="room-type-label"><%= typeLabel %></div>
                </div>
                <span class="room-occ-badge <%= badgeClass %>"><%= occN %>/<%= cap %></span>
              </div>

              <div class="room-card-body">
                <!-- Progress -->
                <div class="room-prog">
                  <div class="room-prog-track">
                    <div class="room-prog-fill <%= occClass %>" style="width:<%= pct %>%"></div>
                  </div>
                  <span class="room-prog-label"><%= pct %>%</span>
                </div>

                <!-- Occupants -->
                <% if (occN > 0) { %>
                <div class="occupants-list">
                  <% const showOcc = occ.slice(0, 4); %>
                  <% showOcc.forEach(function(o) {
                    const initials = o.name ? o.name.split(' ').map(w => w[0]).slice(-2).join('').toUpperCase() : 'SV';
                  %>
                  <div class="occupant-row">
                    <div class="occ-avatar"><%= initials %></div>
                    <div class="occ-info">
                      <div class="occ-name"><%= o.name || 'N/A' %></div>
                      <% if (o.studentId) { %><div class="occ-id">MSSV: <%= o.studentId %></div><% } %>
                    </div>
                    <% if (o.userId) { %>
                    <a href="/admin/students/<%= o.userId %>" title="Xem hồ sơ" style="color:var(--text-3);">
                      <i class="fas fa-external-link-alt occ-icon"></i>
                    </a>
                    <% } %>
                  </div>
                  <% }); %>
                  <% if (occN > 4) { %>
                  <div class="more-residents">+<%= occN - 4 %> sinh viên khác</div>
                  <% } %>
                </div>
                <% } else { %>
                <div class="empty-room-msg">Phòng trống</div>
                <% } %>
              </div>

              <div class="room-card-foot">
                <button class="btn btn-ghost" style="font-size:12px;padding:4px 10px;"
                  onclick="viewRoom('<%= dormitory._id %>', <%= floor.floorNumber %>, '<%= room.roomNumber %>')">
                  <i class="fas fa-eye"></i> Chi tiết
                </button>
              </div>
            </div>
            <% }); %>
          </div>
          <% } %>
        </div>
        <% }); %>
      <% } else { %>
      <div style="text-align:center;padding:48px 24px;background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border:1px solid #EFE8DF;border-radius:16px;box-shadow:0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);">
        <i class="fas fa-layer-group" style="font-size:32px;color:#C8B9A8;margin-bottom:10px;display:block;"></i>
        <p style="color:#7C7166;font-weight:600;font-family:'Inter',sans-serif;">Chưa có tầng nào</p>
        <p style="color:#A89C8E;font-size:12px;margin-top:4px;">Thêm tầng và phòng vào ký túc xá này.</p>
      </div>
      <% } %>
    </div>

  </div><!-- /page -->

  <script>
    function deleteDorm(id) {
      if (!confirm('Xóa ký túc xá này?\n\nHành động này không thể hoàn tác.')) return;
      fetch('/api/dormitories/' + id, { method: 'DELETE' })
        .then(r => r.json())
        .then(res => {
          if (res.success || !res.error) {
            window.location.href = '/admin/dormitories';
          } else {
            alert('Lỗi: ' + (res.error || 'Không thể xóa'));
          }
        })
        .catch(() => alert('Lỗi hệ thống.'));
    }

    function viewRoom(dormId, floor, roomNum) {
      window.location.href = '/admin/dormitories/' + dormId + '/rooms/' + floor + '/' + roomNum;
    }
  </script>

<%- include('../footer') %>
</body>
</html>
