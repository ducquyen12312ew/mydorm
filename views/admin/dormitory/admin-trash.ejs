<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thùng rác - Ký túc xá</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/admin-priority-queue.css">
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            font-family: 'Josefin Sans', 'Segoe UI', sans-serif;
            background: linear-gradient(180deg,#FBF8F3,#F5EFE7);
            min-height: 100vh;
            color: #2B2320;
        }

        .trash-header {
            background: linear-gradient(135deg,#E11D2A,#B20C26);
            color: white;
            padding: 28px 0;
            margin-bottom: 36px;
            box-shadow: 0 10px 28px -10px rgba(200,16,46,.5);
        }

        .trash-header h1 {
            margin: 0;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .trash-header .info {
            font-size: 0.9rem;
            opacity: 0.88;
            margin-top: 8px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            border-radius: 16px;
            border: 1px solid #EFE8DF;
            margin: 36px 0;
            box-shadow: 0 1px 2px rgba(43,35,32,.04), 0 20px 38px -26px rgba(43,35,32,.15);
        }

        .empty-state i {
            font-size: 3rem;
            color: #D4C9BE;
            margin-bottom: 14px;
            display: block;
        }

        .empty-state p {
            color: #7C7166;
            font-size: 1rem;
        }

        .trash-item {
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            border: 1px solid #EFE8DF;
            border-radius: 14px;
            padding: 18px 22px;
            margin-bottom: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s ease;
            box-shadow: 0 1px 2px rgba(43,35,32,.04), 0 10px 24px -16px rgba(43,35,32,.12);
        }

        .trash-item:hover {
            border-color: #C8102E;
            box-shadow: 0 4px 16px rgba(200,16,46,.12);
            transform: translateY(-2px);
        }

        .trash-item-info { flex-grow: 1; }

        .trash-item-name {
            font-size: 1rem;
            font-weight: 700;
            color: #2B2320;
            margin-bottom: 5px;
        }

        .trash-item-detail {
            font-size: 0.85rem;
            color: #A89C8E;
        }

        .trash-item-detail span {
            display: inline-block;
            margin-right: 18px;
        }

        .trash-item-actions { display: flex; gap: 10px; }

        .btn-restore {
            background: linear-gradient(135deg,#16B880,#0A8A5A);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 11px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 8px 20px -8px rgba(14,159,110,.55);
        }

        .btn-restore:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 24px -8px rgba(14,159,110,.65);
        }

        .btn-permanent-delete {
            background: linear-gradient(135deg,#E11D2A,#B20C26);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 11px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 600;
            font-family: inherit;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 8px 20px -8px rgba(200,16,46,.55);
        }

        .btn-permanent-delete:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 24px -8px rgba(200,16,46,.65);
        }

        .restored-alert { animation: slideIn 0.3s ease; }

        @keyframes slideIn {
            from { transform: translateY(-16px); opacity: 0; }
            to   { transform: translateY(0); opacity: 1; }
        }

        @media (max-width: 768px) {
            .trash-item { flex-direction: column; align-items: flex-start; }
            .trash-item-actions { width: 100%; margin-top: 14px; }
            .btn-restore, .btn-permanent-delete { flex: 1; justify-content: center; }
            .trash-header h1 { font-size: 1.25rem; }
        }
    </style>
</head>
<body>
        <% const activeNav = 'trash'; %>
    <%- include('../navbar.ejs') %>
    
    <div class="trash-header">
        <div class="container">
            <h1>
                <i class="fas fa-trash-alt"></i>
                Thùng rác
            </h1>
            <div class="info">
                <i class="fas fa-info-circle"></i>
                <span id="trash-count"><%= deletedDormitories.length %> ký túc xá</span> trong thùng rác
            </div>
        </div>
    </div>
    
    <div class="container" style="margin-bottom: 40px;">
        <% if (message) { %>
            <div class="alert alert-success restored-alert alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> <%= message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        
        <% if (deletedDormitories.length === 0) { %>
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <p>Thùng rác trống</p>
                <small style="color: #95a5a6;">Tất cả ký túc xá đều bình thường</small>
            </div>
        <% } else { %>
            <div class="trash-list">
                <% deletedDormitories.forEach(dorm => { %>
                    <div class="trash-item">
                        <div class="trash-item-info">
                            <div class="trash-item-name"><%= dorm.name %></div>
                            <div class="trash-item-detail">
                                <span>
                                    <i class="fas fa-map-marker-alt"></i>
                                    <%= dorm.address %>
                                </span>
                                <span>
                                    <i class="fas fa-home"></i>
                                    <%= dorm.numberOfRooms || 0 %> phòng
                                </span>
                                <span>
                                    <i class="fas fa-calendar"></i>
                                    Xóa: <%= new Date(dorm.deletedAt).toLocaleString('vi-VN') %>
                                </span>
                            </div>
                        </div>
                        <div class="trash-item-actions">
                            <button class="btn-restore" onclick="restoreDormitory('<%= dorm._id %>')">
                                <i class="fas fa-undo"></i> Phục hồi
                            </button>
                            <button class="btn-permanent-delete" onclick="permanentDelete('<%= dorm._id %>', '<%= dorm.name %>')">
                                <i class="fas fa-trash"></i> Xóa vĩnh viễn
                            </button>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function restoreDormitory(id) {
            if (confirm('Bạn chắc chắn muốn phục hồi ký túc xá này?')) {
                fetch(`/dormitories/${id}/restore`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert('Phục hồi thành công!');
                        location.reload();
                    } else {
                        alert('Lỗi: ' + (data.message || 'Không thể phục hồi'));
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Lỗi kết nối');
                });
            }
        }
        
        function permanentDelete(id, name) {
            if (confirm(`Bạn chắc chắn muốn XÓA VĨN VIỄN "${name}"?\n\nHành động này không thể hoàn tác!`)) {
                fetch(`/dormitories/${id}/permanent-delete`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert('Đã xóa vĩnh viễn!');
                        location.reload();
                    } else {
                        alert('Lỗi: ' + (data.message || 'Không thể xóa'));
                    }
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Lỗi kết nối');
                });
            }
        }
    </script>
<%- include('../../shared/footer') %>
</body>
</html>
