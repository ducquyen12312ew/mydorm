<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết phòng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --red: #C8102E; --red-dark: #9E0C24;
            --bg: #FBF8F3; --card: #FFFFFF;
            --border: #EFE8DF; --text: #2B2320; --muted: #7C7166; --muted2: #A89C8E;
            --success: #0E9F6E; --radius: 16px;
            --shadow: 0 1px 2px rgba(43,35,32,.04), 0 20px 38px -26px rgba(43,35,32,.2);
        }

        body {
            font-family: 'Josefin Sans', 'Segoe UI', sans-serif;
            background: linear-gradient(180deg,#FBF8F3,#F5EFE7);
            min-height: 100vh;
            color: var(--text);
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 24px;
        }

        /* Header */
        .header {
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            padding: 20px 28px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            margin-bottom: 28px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header h1 {
            font-family: 'Josefin Sans', sans-serif;
            color: var(--text);
            font-size: 1.35rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0;
        }

        .header-actions { display: flex; gap: 10px; }

        .btn {
            padding: 9px 18px;
            border: none;
            border-radius: 11px;
            cursor: pointer;
            font-size: 13.5px;
            font-weight: 600;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: inherit;
        }

        .btn-primary {
            background: linear-gradient(135deg,#E11D2A,#B20C26);
            color: white;
            box-shadow: 0 10px 24px -10px rgba(200,16,46,.65);
        }
        .btn-primary:hover { transform: translateY(-1px); }

        .btn-secondary {
            background: #fff;
            color: var(--text);
            border: 1px solid #E7DECF;
        }
        .btn-secondary:hover { background: #FBF8F3; }

        .btn-danger {
            background: linear-gradient(135deg,#E11D2A,#B20C26);
            color: white;
            padding: 7px 14px;
            font-size: 12px;
            box-shadow: 0 8px 18px -8px rgba(200,16,46,.55);
        }
        .btn-danger:hover { transform: translateY(-1px); }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 18px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            padding: 22px 24px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            transition: transform 0.2s;
        }
        .stat-card:hover { transform: translateY(-2px); }

        .stat-card:nth-child(1) { border-left: 4px solid #A89C8E; }
        .stat-card:nth-child(2) { border-left: 4px solid var(--red); }
        .stat-card:nth-child(3) { border-left: 4px solid #0E9F6E; }

        .stat-value {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 5px;
            line-height: 1;
        }
        .stat-card:nth-child(2) .stat-value { color: var(--red); }
        .stat-card:nth-child(3) .stat-value { color: #076641; }

        .stat-label {
            font-size: 11px;
            color: var(--muted2);
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: .05em;
        }

        /* Content Cards */
        .content-card {
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            margin-bottom: 28px;
            overflow: hidden;
        }

        .content-card-header {
            background: #F7F1E8;
            color: var(--text);
            padding: 16px 24px;
            font-family: 'Josefin Sans', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid var(--border);
        }

        .content-card-body { padding: 24px; }

        /* Room Info Grid */
        .room-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 16px;
        }

        .info-group {
            background: #F5EFE7;
            padding: 16px 18px;
            border-radius: 12px;
            border-left: 4px solid #C8A882;
        }

        .info-label {
            font-size: 11px;
            color: var(--muted2);
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 6px;
            letter-spacing: 0.5px;
        }

        .info-value {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text);
        }

        /* Table */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        thead { background: #F7F1E8; }
        th {
            padding: 13px 15px;
            text-align: left;
            font-size: 10.5px;
            font-weight: 700;
            color: #9A8F84;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid var(--border);
        }
        td { padding: 14px 15px; border-bottom: 1px solid #F4EEE5; font-size: .88rem; }
        tbody tr:nth-child(even) td { background: #FDFBF8; }
        tbody tr:hover td { background: #FAF5EE; }

        .occupant-name { font-weight: 600; color: var(--text); }

        .occupant-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg,#E11D2A,#B20C26);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 15px;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .occupant-row-header { display: flex; align-items: center; }

        /* Empty State */
        .empty-state { text-align: center; padding: 56px 20px; }
        .empty-state i { font-size: 52px; color: #EFE8DF; margin-bottom: 16px; display: block; }
        .empty-state p { color: var(--muted2); font-size: 15px; }

        @media (max-width: 768px) {
            .container { padding: 12px; }
            .header { flex-direction: column; gap: 14px; }
            .stats-grid { grid-template-columns: 1fr; }
            .room-info-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <%- include('../navbar', { activeNav: 'dormitories' }) %>

    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>
                <i class="fas fa-door-open"></i>
                Phòng <span id="roomNumber">-</span>
            </h1>
            <div class="header-actions">
                <a href="/admin/dormitories" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>

        <!-- Room Info Section -->
        <div class="content-card">
            <div class="content-card-header">
                <i class="fas fa-info-circle"></i>
                Thông tin phòng
            </div>
            <div class="content-card-body">
                <div class="room-info-grid">
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-building me-1"></i>Ký túc xá</div>
                        <div class="info-value" id="dormName">-</div>
                    </div>
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-layer-group me-1"></i>Tầng</div>
                        <div class="info-value" id="floorNum">-</div>
                    </div>
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-door-open me-1"></i>Phòng số</div>
                        <div class="info-value" id="roomNum">-</div>
                    </div>
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-users me-1"></i>Sức chứa</div>
                        <div class="info-value" id="capacity">-</div>
                    </div>
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-venus-mars me-1"></i>Giới tính</div>
                        <div class="info-value" id="gender">-</div>
                    </div>
                    <div class="info-group">
                        <div class="info-label"><i class="fas fa-dollar-sign me-1"></i>Giá/tháng</div>
                        <div class="info-value" id="price">-</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label"><i class="fas fa-bed me-1"></i>Tổng chỗ</div>
                <div class="stat-value" id="statTotal">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label"><i class="fas fa-user-check me-1"></i>Đang ở</div>
                <div class="stat-value" id="statOccupied">0</div>
            </div>
            <div class="stat-card">
                <div class="stat-label"><i class="fas fa-door-open me-1"></i>Trống</div>
                <div class="stat-value" id="statEmpty">0</div>
            </div>
        </div>

        <!-- Occupants Section -->
        <div class="content-card">
            <div class="content-card-header">
                <i class="fas fa-users"></i>
                Sinh viên đang ở (<span id="occupantCount">0</span>)
            </div>
            <div class="content-card-body">
                <div id="occupantsList">
                    <!-- Will be populated by JavaScript -->
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Get URL parameters from path: /admin/dormitories/[dormId]/rooms/[floorNumber]/[roomNumber]
        const pathParts = window.location.pathname.split('/');
        const dormId = pathParts[3];
        const floorNumber = pathParts[5];
        const roomNumber = pathParts[6];

        async function loadRoomDetails() {
            try {
                const apiUrl = `/api/admin/dormitories/${dormId}/rooms/${floorNumber}/${roomNumber}`;
                const response = await fetch(apiUrl);

                if (!response.ok) {
                    throw new Error(`HTTP Error: ${response.status} ${response.statusText}`);
                }

                const data = await response.json();
                displayRoomDetails(data);
            } catch (error) {
                console.error('Error loading room details:', error);
                document.getElementById('occupantsList').innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-circle"></i>
                        <p>Lỗi khi tải dữ liệu: ${error.message}</p>
                    </div>
                `;
            }
        }

        function displayRoomDetails(data) {
            const room = data.room;
            const dorm = data.dormitory;

            // Update room number in header and breadcrumb
            document.getElementById('roomNumber').textContent = room.roomNumber;

            // Update room info
            document.getElementById('dormName').textContent = dorm ? dorm.name : 'N/A';
            document.getElementById('floorNum').textContent = floorNumber;
            document.getElementById('roomNum').textContent = room.roomNumber;
            document.getElementById('capacity').textContent = (room.maxCapacity || 0) + ' chỗ';
            document.getElementById('gender').textContent = 
                room.genderPolicy === 'male' ? 'Nam' : 
                room.genderPolicy === 'female' ? 'Nữ' : 'Chung';
            document.getElementById('price').textContent = 
                room.pricePerMonth ? room.pricePerMonth.toLocaleString('vi-VN') + ' đ' : 'N/A';

            // Calculate stats
            const occupied = room.occupants ? room.occupants.filter(o => o.active).length : 0;
            const available = (room.maxCapacity || 0) - occupied;

            document.getElementById('statTotal').textContent = room.maxCapacity || 0;
            document.getElementById('statOccupied').textContent = occupied;
            document.getElementById('statEmpty').textContent = available;
            document.getElementById('occupantCount').textContent = occupied;

            // Display occupants
            const occupantsList = document.getElementById('occupantsList');
            if (room.occupants && room.occupants.length > 0) {
                const activeOccupants = room.occupants.filter(o => o.active);
                
                if (activeOccupants.length > 0) {
                    occupantsList.innerHTML = `
                        <div class="table-responsive">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Họ và tên</th>
                                        <th>MSSV</th>
                                        <th>Email</th>
                                        <th>Năm học</th>
                                        <th style="text-align: center;">Hành động</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${activeOccupants.map(occupant => `
                                        <tr>
                                            <td>
                                                <div class="occupant-row-header">
                                                    <div class="occupant-avatar">
                                                        ${(occupant.name || 'U').charAt(0).toUpperCase()}
                                                    </div>
                                                    <span class="occupant-name">${occupant.name || 'N/A'}</span>
                                                </div>
                                            </td>
                                            <td>${occupant.studentId || 'N/A'}</td>
                                            <td>${occupant.email || 'N/A'}</td>
                                            <td>${occupant.academicYear || 'N/A'}</td>
                                            <td style="text-align: center;">
                                                <button class="btn btn-danger" onclick="removeOccupant('${dormId}', '${floorNumber}', '${roomNumber}', '${occupant._id}')">
                                                    <i class="fas fa-trash"></i> Xóa
                                                </button>
                                            </td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                } else {
                    occupantsList.innerHTML = `
                        <div class="empty-state">
                            <i class="fas fa-door-open"></i>
                            <p>Phòng này hiện không có sinh viên</p>
                        </div>
                    `;
                }
            } else {
                occupantsList.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-door-open"></i>
                        <p>Phòng này hiện không có sinh viên</p>
                    </div>
                `;
            }
        }

        async function removeOccupant(dormId, floorNumber, roomNumber, occupantId) {
            if (!confirm('Bạn chắc chắn muốn xóa sinh viên này khỏi phòng?')) {
                return;
            }

            try {
                const response = await fetch(
                    `/api/admin/dormitories/${dormId}/rooms/${floorNumber}/${roomNumber}/occupants/${occupantId}`,
                    { method: 'DELETE' }
                );

                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.error || 'Failed to remove occupant');
                }

                alert('Xóa sinh viên thành công');
                loadRoomDetails(); // Reload details
            } catch (error) {
                console.error('Error:', error);
                alert('Lỗi: ' + error.message);
            }
        }

        // Load details on page load
        document.addEventListener('DOMContentLoaded', loadRoomDetails);
    </script>
    <%- include('../../shared/footer') %>
</body>
</html>
