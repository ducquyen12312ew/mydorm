﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= action === 'add' ? 'Thêm' : 'Cập nhật' %> Ký túc xá</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css">
    <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: 'Inter', system-ui, sans-serif !important; background: linear-gradient(180deg,#FBF8F3,#F5EFE7) !important; color: #2B2320 !important; }

        /* Warm form section cards */
        .form-section {
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            border-radius: 16px;
            border: 1px solid #EFE8DF;
            box-shadow: 0 1px 2px rgba(43,35,32,.04), 0 20px 38px -26px rgba(43,35,32,.2);
            padding: 1.5rem 1.75rem;
            margin-bottom: 1.5rem;
        }
        .form-section-title {
            margin-bottom: 1.25rem;
            padding-bottom: .75rem;
            border-bottom: 1px solid #EFE8DF;
            color: #2B2320;
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            display: flex; align-items: center; gap: .5rem;
        }
        .form-section-title i { color: #C8102E; }

        /* Override Bootstrap inputs with warm styles */
        .form-control, .form-select {
            border: 1.5px solid #EFE8DF !important;
            border-radius: 10px !important;
            font-family: 'Inter', sans-serif !important;
            font-size: .9rem !important;
            color: #2B2320 !important;
            background: #fff !important;
            padding: .6rem .9rem !important;
            transition: border-color .15s, box-shadow .15s !important;
        }
        .form-control:focus, .form-select:focus {
            border-color: #C8102E !important;
            box-shadow: 0 0 0 3px rgba(200,16,46,.08) !important;
            outline: none !important;
        }
        .form-label {
            font-size: .78rem !important;
            font-weight: 700 !important;
            color: #9A8F84 !important;
            text-transform: uppercase !important;
            letter-spacing: .06em !important;
            margin-bottom: .4rem !important;
        }
        .form-text { font-size: .78rem !important; color: #A89C8E !important; }

        /* Override Bootstrap buttons */
        .btn { font-family: 'Inter', sans-serif !important; border-radius: 11px !important; font-weight: 600 !important; }
        .btn-primary { background: linear-gradient(135deg,#E11D2A,#B20C26) !important; border: none !important; box-shadow: 0 4px 12px rgba(200,16,46,.3) !important; color: #fff !important; }
        .btn-primary:hover { filter: brightness(1.05) !important; transform: translateY(-1px) !important; }
        .btn-success { background: linear-gradient(135deg,#12B981,#0E9F6E) !important; border: none !important; box-shadow: 0 4px 12px rgba(14,159,110,.3) !important; color: #fff !important; }
        .btn-success:hover { filter: brightness(1.05) !important; transform: translateY(-1px) !important; }
        .btn-outline-secondary { background: #fff !important; border: 1.5px solid #E7DECF !important; color: #7C7166 !important; }
        .btn-outline-secondary:hover { background: #FBF8F3 !important; border-color: #C8102E !important; color: #C8102E !important; }
        .btn-danger { background: linear-gradient(135deg,#E11D2A,#B20C26) !important; border: none !important; color: #fff !important; }

        /* Alert warm */
        .alert-info { background: #E9F0FE !important; border-color: #AABEF8 !important; color: #1A4FBD !important; border-radius: 12px !important; }

        /* Map */
        #map { height: 400px; width: 100%; margin-bottom: 20px; border-radius: 12px; overflow: hidden; }

        /* Media tabs */
        .media-tab-btn {
            padding: 6px 18px; border: 1.5px solid #EFE8DF; background: #fff;
            border-radius: 11px; cursor: pointer; font-weight: 600; font-size: .85rem;
            font-family: 'Inter', sans-serif; color: #7C7166; transition: all .15s;
        }
        .media-tab-btn.active { background: linear-gradient(135deg,#E11D2A,#B20C26); color: #fff; border-color: transparent; box-shadow: 0 4px 12px rgba(200,16,46,.25); }
        .media-tab-panel { display: none; }
        .media-tab-panel.active { display: block; }

        /* Room cards */
        .room-card { border: 1px solid #EFE8DF; border-radius: 12px; margin-bottom: 10px; background: #FBF8F3; overflow: hidden; }
        .room-card-header { padding: 8px 14px; background: #F7F1E8; border-bottom: 1px solid #EFE8DF; font-weight: 600; font-size: .85rem; color: #2B2320; }
        .room-card-body { padding: 12px 14px; }

        /* Image thumbs */
        .img-thumb { width: 90px; height: 70px; object-fit: cover; border-radius: 8px; border: 1px solid #EFE8DF; }
        .img-item { display: inline-flex; flex-direction: column; align-items: center; gap: 4px; margin: 4px; position: relative; }
        .img-item .cover-badge { font-size: .65rem; background: #0E9F6E; color: #fff; padding: 1px 6px; border-radius: 4px; }
        .img-remove-btn { position: absolute; top: -6px; right: -6px; background: #C8102E; color: #fff; border: none; border-radius: 50%; width: 20px; height: 20px; font-size: .7rem; cursor: pointer; display: flex; align-items: center; justify-content: center; }

        /* Page header card */
        .pg-header {
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            border: 1px solid #EFE8DF;
            border-radius: 16px;
            box-shadow: 0 1px 2px rgba(43,35,32,.04), 0 20px 38px -26px rgba(43,35,32,.2);
            padding: 1.25rem 1.5rem;
            margin-bottom: 1.5rem;
            display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
        }
        .pg-header h2 { margin: 0; font-size: 1.2rem; font-weight: 700; color: #2B2320; display: flex; align-items: center; gap: .6rem; }
        .pg-header h2 i { color: #C8102E; }
        .pg-header-actions { display: flex; gap: .75rem; }

        .form-container { max-width: 1100px; margin: 0 auto; padding: 1.25rem 1.5rem 3rem; }
    </style>
</head>
<body>
    <%- include('../navbar', { activeNav: 'dormitories', user: user }) %>

    <div class="form-container">
        <div class="pg-header">
            <h2><i class="fas fa-building"></i> <%= action === 'add' ? 'Thêm mới' : 'Cập nhật' %> Ký túc xá</h2>
            <div class="pg-header-actions">
                <a href="/admin/dormitories" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
        
        <% if (action === 'add') { %>
            <div class="alert alert-info mb-4">
                <i class="fas fa-info-circle me-2"></i>
                <strong>Lưu ý:</strong> Mỗi ký túc xá chỉ được tạo một lần duy nhất. Vui lòng kiểm tra thông tin cẩn thận trước khi tạo.
            </div>
        <% } %>
        
        <form id="dormitoryForm">
            <div class="form-section">
                <h4 class="form-section-title"><i class="fas fa-building me-2"></i>Thông tin cơ bản</h4>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="name" class="form-label">Tên ký túc xá <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="name" name="name" required
                            value="<%= dormitory ? dormitory.name : '' %>"
                            <%= action === 'edit' ? 'readonly' : '' %>>
                        <% if (action === 'edit') { %>
                            <div class="form-text">Tên ký túc xá không thể thay đổi sau khi tạo</div>
                        <% } %>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="address" class="form-label">Địa chỉ <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="address" name="address" required
                            value="<%= dormitory ? dormitory.address : '' %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="phone" class="form-label">Số điện thoại liên hệ</label>
                        <input type="text" class="form-control" id="phone" name="contact[phone]"
                            value="<%= dormitory && dormitory.contact ? dormitory.contact.phone : '' %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="email" class="form-label">Email liên hệ</label>
                        <input type="email" class="form-control" id="email" name="contact[email]"
                            value="<%= dormitory && dormitory.contact ? dormitory.contact.email : '' %>">
                    </div>
                    <div class="col-12 mb-3">
                        <label class="form-label">Hình ảnh ký túc xá</label>
                        <% if (dormitory && dormitory.imageUrl) { %>
                        <div class="mb-2">
                            <img src="<%= dormitory.imageUrl %>" style="height:80px;border-radius:6px;object-fit:cover;" alt="Ảnh hiện tại">
                            <small class="text-muted d-block mt-1">Ảnh hiện tại. Upload file mới để thay thế.</small>
                        </div>
                        <% } %>
                        <input type="file" class="form-control mb-2" id="imageFile" name="image"
                            accept="image/jpeg,image/png,image/webp">
                        <input type="text" class="form-control" id="imageUrl" name="imageUrl"
                            placeholder="Hoặc nhập URL hình ảnh trực tiếp"
                            value="<%= dormitory ? dormitory.imageUrl : '' %>">
                        <small class="text-muted">Upload file sẽ được ưu tiên hơn URL.</small>
                    </div>
                </div>
            </div>
            
            <div class="form-section">
                <h4 class="form-section-title"><i class="fas fa-info-circle me-2"></i>Thông tin chi tiết</h4>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="type" class="form-label">Loại ký túc xá <span class="text-danger">*</span></label>
                        <select class="form-select" id="type" name="details[type]" required>
                            <option value="">-- Chọn loại --</option>
                            <option value="school" <%= dormitory && dormitory.details && dormitory.details.type === 'school' ? 'selected' : '' %>>Trường học</option>
                            <option value="private" <%= dormitory && dormitory.details && dormitory.details.type === 'private' ? 'selected' : '' %>>Tư nhân</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="category" class="form-label">Danh mục <span class="text-danger">*</span></label>
                        <select class="form-select" id="category" name="details[category]" required>
                            <option value="">-- Chọn danh mục --</option>
                            <option value="basic" <%= dormitory && dormitory.details && dormitory.details.category === 'basic' ? 'selected' : '' %>>Cơ bản</option>
                            <option value="premium" <%= dormitory && dormitory.details && dormitory.details.category === 'premium' ? 'selected' : '' %>>Cao cấp</option>
                            <option value="international" <%= dormitory && dormitory.details && dormitory.details.category === 'international' ? 'selected' : '' %>>Du học sinh</option>
                        </select>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="minPrice" class="form-label">Giá tối thiểu (VNĐ/tháng) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="minPrice" name="details[priceRange][min]" required min="0"
                            value="<%= dormitory && dormitory.details && dormitory.details.priceRange ? dormitory.details.priceRange.min : '500000' %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="maxPrice" class="form-label">Giá tối đa (VNĐ/tháng) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="maxPrice" name="details[priceRange][max]" required min="0"
                            value="<%= dormitory && dormitory.details && dormitory.details.priceRange ? dormitory.details.priceRange.max : '1500000' %>">
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-12 mb-3">
                        <label class="form-label">Tiện ích</label>
                        <div class="row">
                            <% 
                            const amenities = ['Wifi', 'Điều hòa', 'Tủ lạnh', 'Bếp chung', 'Phòng giặt', 'Bảo vệ 24/7', 'Căng tin', 'Phòng học', 'TV chung', 'Giường tầng', 'Tủ cá nhân', 'Nhà vệ sinh chung'];
                            let existingAmenities = [];
                            if (dormitory && dormitory.details && dormitory.details.amenities) {
                                existingAmenities = dormitory.details.amenities;
                            }
                            %>
                            
                            <% amenities.forEach((amenity, index) => { %>
                                <div class="col-md-4 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="amenity<%= index %>" 
                                            name="details[amenities][]" value="<%= amenity %>"
                                            <%= existingAmenities.includes(amenity) ? 'checked' : '' %>>
                                        <label class="form-check-label" for="amenity<%= index %>">
                                            <%= amenity %>
                                        </label>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="available" name="details[available]" value="true"
                                <%= dormitory && dormitory.details && dormitory.details.available ? 'checked' : '' %>>
                            <label class="form-check-label" for="available">
                                Còn phòng trống
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            
            <% if (action === 'add') { %>
                <div class="form-section">
                    <h4 class="form-section-title"><i class="fas fa-layer-group me-2"></i>Cấu trúc tầng và phòng</h4>
                    
                    <div class="alert alert-warning mb-4">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Lưu ý:</strong> Số tầng và số phòng không thể thay đổi sau khi tạo. Vui lòng xác nhận cẩn thận.
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="totalFloors" class="form-label">Số tầng <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="totalFloors" name="details[totalFloors]" required min="1" max="20" value="4" onchange="generateFloorConfig()">
                            <div class="form-text">Nhập số tầng của ký túc xá</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="roomsPerFloor" class="form-label">Số phòng mỗi tầng <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="roomsPerFloor" name="details[roomsPerFloor]" required min="1" max="30" value="5" onchange="generateFloorConfig()">
                            <div class="form-text">Nhập số phòng trên mỗi tầng</div>
                        </div>
                    </div>
                    
                    <div id="floorConfigContainer" class="mt-4">
                    </div>
                    
                    <div class="mt-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="confirmStructure" required>
                            <label class="form-check-label" for="confirmStructure">
                                Tôi xác nhận thông tin về số tầng và cấu trúc phòng là chính xác
                            </label>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="form-section">
                    <h4 class="form-section-title"><i class="fas fa-layer-group me-2"></i>Cấu trúc tầng và phòng</h4>
                    
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Cấu trúc phòng và tầng không thể thay đổi sau khi đã tạo. Vui lòng truy cập vào trang quản lý phòng để cập nhật chi tiết từng phòng.
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Số tầng</label>
                            <input type="text" class="form-control" value="<%= dormitory.floors.length %>" readonly>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tổng số phòng</label>
                            <% 
                            let totalRooms = 0;
                            if (dormitory.floors && dormitory.floors.length > 0) {
                                dormitory.floors.forEach(floor => {
                                    if (floor.rooms && floor.rooms.length > 0) {
                                        totalRooms += floor.rooms.length;
                                    }
                                });
                            }
                            %>
                            <input type="text" class="form-control" value="<%= totalRooms %>" readonly>
                        </div>
                        <div class="col-12">
                            <a href="/admin/dormitories/view/<%= dormitory._id %>" class="btn btn-primary">
                                <i class="fas fa-door-open me-1"></i> Quản lý phòng
                            </a>
                        </div>
                    </div>
                </div>
            <% } %>
            
            <div class="form-section">
                <h4 class="form-section-title"><i class="fas fa-map-marker-alt me-2"></i>Vị trí trên bản đồ</h4>
                <div id="map"></div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="longitude" class="form-label">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="longitude" name="location[coordinates][0]" required
                            value="<%= dormitory && dormitory.location && dormitory.location.coordinates ? dormitory.location.coordinates[0] : '105.843220' %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="latitude" class="form-label">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="latitude" name="location[coordinates][1]" required
                            value="<%= dormitory && dormitory.location && dormitory.location.coordinates ? dormitory.location.coordinates[1] : '21.007119' %>">
                    </div>
                    <input type="hidden" name="location[type]" value="Point">
                </div>
            </div>
            
            <!-- ============================================================ -->
            <!-- MEDIA & HÌNH ẢNH SECTION -->
            <!-- ============================================================ -->
            <div class="form-section">
                <h4 class="form-section-title"><i class="fas fa-images me-2"></i>Media & Hình ảnh</h4>

                <!-- Tab nav -->
                <div class="d-flex gap-2 mb-3">
                    <button type="button" class="media-tab-btn active" onclick="switchMediaTab('images')">
                        <i class="fas fa-image me-1"></i> Ảnh
                    </button>
                    <button type="button" class="media-tab-btn" onclick="switchMediaTab('video')">
                        <i class="fab fa-youtube me-1"></i> Video
                    </button>
                    <button type="button" class="media-tab-btn" onclick="switchMediaTab('tour')">
                        <i class="fas fa-vr-cardboard me-1"></i> Virtual Tour
                    </button>
                </div>

                <!-- Images tab -->
                <div class="media-tab-panel active" id="mediaTab-images">
                    <div id="imageGallery" style="display:flex;flex-wrap:wrap;gap:4px;min-height:80px;background:#f8f9fa;border:1px dashed #dee2e6;border-radius:6px;padding:10px;margin-bottom:12px;">
                        <%
                        const existingImages = (dormitory && dormitory.images && dormitory.images.length)
                            ? dormitory.images
                            : (dormitory && dormitory.imageUrl ? [dormitory.imageUrl] : []);
                        const existingCover = (dormitory && dormitory.coverImage) || (existingImages[0] || '');
                        %>
                        <% existingImages.forEach((img, i) => { %>
                        <div class="img-item" id="imgItem_<%= i %>">
                            <% if (img === existingCover || i === 0) { %>
                                <span class="cover-badge">Bìa</span>
                            <% } %>
                            <img src="<%= img %>" class="img-thumb" alt="img">
                            <button type="button" class="img-remove-btn" onclick="removeImage('<%= img %>')" title="Xóa">×</button>
                        </div>
                        <% }); %>
                    </div>

                    <div class="input-group mb-2" style="max-width:550px;">
                        <input type="text" class="form-control form-control-sm" id="newImageUrl" placeholder="Nhập URL hình ảnh và nhấn Thêm">
                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="addImageUrl()">
                            <i class="fas fa-plus"></i> Thêm
                        </button>
                    </div>
                    <small class="text-muted">Ảnh đầu tiên sẽ được dùng làm ảnh bìa. Bạn có thể xóa từng ảnh bằng nút ×.</small>
                    <!-- Hidden inputs for images array -->
                    <div id="imageHiddenInputs">
                        <% existingImages.forEach((img) => { %>
                            <input type="hidden" name="images[]" value="<%= img %>">
                        <% }); %>
                    </div>
                </div>

                <!-- Video tab -->
                <div class="media-tab-panel" id="mediaTab-video">
                    <div class="row g-3">
                        <!-- Left: YouTube URL -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fab fa-youtube text-danger me-1"></i>Link YouTube</label>
                            <input type="text" class="form-control" id="videoUrl" name="videoUrl"
                                placeholder="https://www.youtube.com/watch?v=..."
                                value="<%= (dormitory && dormitory.videos && dormitory.videos[0] && !dormitory.videos[0].startsWith('http') === false && dormitory.videos[0].includes('you')) ? dormitory.videos[0] : '' %>">
                            <small class="text-muted">Nhập URL YouTube để nhúng video giới thiệu KTX.</small>
                            <div id="videoPreview" style="margin-top:10px;"></div>
                        </div>
                        <!-- Right: File upload -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold"><i class="fas fa-upload me-1"></i>Upload video trực tiếp</label>
                            <% if (action === 'edit' && dormitory) { %>
                            <input type="file" class="form-control" id="videoFileInput" accept="video/mp4,video/webm,video/quicktime,video/x-m4v">
                            <small class="text-muted">Hỗ trợ: MP4, WebM, MOV, M4V. Tối đa 100MB.</small>
                            <div id="videoUploadProgress" style="display:none;margin-top:8px;">
                                <div class="progress" style="height:8px;">
                                    <div class="progress-bar bg-danger" id="videoProgressBar" style="width:0%"></div>
                                </div>
                                <small class="text-muted" id="videoUploadStatus">Đang tải lên...</small>
                            </div>
                            <div id="uploadedVideos" style="margin-top:10px;">
                                <% if (dormitory && dormitory.media) { dormitory.media.filter(m => m.type === 'video').forEach(m => { %>
                                <div class="d-flex align-items-center gap-2 mb-2 p-2 border rounded" style="background:#f8f9fa;">
                                    <% if (m.thumbnail) { %><img src="<%= m.thumbnail %>" style="width:80px;height:45px;object-fit:cover;border-radius:4px;" alt="thumb"><% } %>
                                    <div style="flex:1;min-width:0;">
                                        <div style="font-size:.8rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= m.url %></div>
                                        <% if (m.duration) { %><small class="text-muted"><%= Math.floor(m.duration/60) %>:<%= String(Math.round(m.duration%60)).padStart(2,'0') %></small><% } %>
                                    </div>
                                    <video controls style="width:160px;height:90px;border-radius:4px;" src="<%= m.url %>"></video>
                                </div>
                                <% }) } %>
                            </div>
                            <% } else { %>
                            <div class="alert alert-info py-2"><small>Lưu KTX trước để có thể upload video.</small></div>
                            <% } %>
                        </div>
                    </div>
                    <script>
                    (function() {
                        // YouTube preview
                        var ytInput = document.getElementById('videoUrl');
                        if (ytInput) {
                            function updateYtPreview() {
                                var url = ytInput.value.trim();
                                var preview = document.getElementById('videoPreview');
                                if (!url) { preview.innerHTML = ''; return; }
                                var match = url.match(/(?:v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
                                if (match) {
                                    preview.innerHTML = '<iframe width="100%" height="195" src="https://www.youtube.com/embed/'+match[1]+'" frameborder="0" allowfullscreen style="border-radius:8px;max-width:420px;"></iframe>';
                                } else {
                                    preview.innerHTML = '<small class="text-danger">URL YouTube không hợp lệ</small>';
                                }
                            }
                            ytInput.addEventListener('input', updateYtPreview);
                            updateYtPreview();
                        }

                        // Video file upload
                        var videoInput = document.getElementById('videoFileInput');
                        if (videoInput) {
                            videoInput.addEventListener('change', async function() {
                                var file = this.files[0];
                                if (!file) return;
                                var dormId = '<%= dormitory ? dormitory._id : "" %>';
                                if (!dormId) { alert('Chưa có ID ký túc xá'); return; }
                                var progressWrap = document.getElementById('videoUploadProgress');
                                var progressBar  = document.getElementById('videoProgressBar');
                                var statusEl     = document.getElementById('videoUploadStatus');
                                progressWrap.style.display = 'block';
                                statusEl.textContent = 'Đang chuẩn bị tải lên...';

                                var formData = new FormData();
                                formData.append('video', file);

                                var xhr = new XMLHttpRequest();
                                xhr.open('POST', '/api/dormitories/' + dormId + '/upload-video');
                                xhr.withCredentials = true;

                                xhr.upload.onprogress = function(e) {
                                    if (e.lengthComputable) {
                                        var pct = Math.round(e.loaded / e.total * 100);
                                        progressBar.style.width = pct + '%';
                                        statusEl.textContent = 'Đang tải lên: ' + pct + '%';
                                    }
                                };
                                xhr.onload = function() {
                                    if (xhr.status === 200) {
                                        var data = JSON.parse(xhr.responseText);
                                        if (data.success) {
                                            statusEl.textContent = 'Tải lên thành công!';
                                            progressBar.style.width = '100%';
                                            // Add preview
                                            var container = document.getElementById('uploadedVideos');
                                            var div = document.createElement('div');
                                            div.className = 'd-flex align-items-center gap-2 mb-2 p-2 border rounded';
                                            div.style.background = '#f0fff4';
                                            div.innerHTML = (data.thumbnail ? '<img src="'+data.thumbnail+'" style="width:80px;height:45px;object-fit:cover;border-radius:4px;" alt="thumb">' : '') +
                                                '<div style="flex:1"><small style="color:#38A169;font-weight:700">✓ Đã tải lên</small><br><small>'+data.url.split('/').pop()+'</small></div>' +
                                                '<video controls style="width:160px;height:90px;border-radius:4px;" src="'+data.url+'"></video>';
                                            container.appendChild(div);
                                        } else {
                                            statusEl.textContent = 'Lỗi: ' + (data.error || 'Upload thất bại');
                                            progressBar.classList.add('bg-danger');
                                        }
                                    } else {
                                        statusEl.textContent = 'Lỗi server: ' + xhr.status;
                                    }
                                };
                                xhr.onerror = function() { statusEl.textContent = 'Lỗi kết nối'; };
                                xhr.send(formData);
                            });
                        }
                    })();
                    </script>
                </div>

                <!-- Virtual Tour tab -->
                <div class="media-tab-panel" id="mediaTab-tour">
                    <div class="mb-3" style="max-width:600px;">
                        <label class="form-label">URL Virtual Tour (Matterport / 360°)</label>
                        <input type="text" class="form-control" id="virtualTourUrl" name="virtualTourUrl"
                            placeholder="VD: https://my.matterport.com/show/?m=..."
                            value="<%= (dormitory && dormitory.virtualTour) ? dormitory.virtualTour : '' %>">
                        <small class="text-muted">Nhập URL iFrame từ Matterport hoặc dịch vụ tour 360° khác.</small>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <a href="/admin/dormitories" class="btn btn-secondary me-2">
                    <i class="fas fa-times me-1"></i> Hủy
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> <%= action === 'add' ? 'Tạo ký túc xá' : 'Cập nhật' %>
                </button>
            </div>
        </form>
    </div>
 
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function generateFloorConfig() {
            const totalFloors = parseInt(document.getElementById('totalFloors').value);
            const roomsPerFloor = parseInt(document.getElementById('roomsPerFloor').value);
            const container = document.getElementById('floorConfigContainer');
            
            container.innerHTML = ''; 
            
            for (let i = 1; i <= totalFloors; i++) {
                const floorDiv = document.createElement('div');
                floorDiv.className = 'card mb-3';
                
                floorDiv.innerHTML = `
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Tầng ${i}</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-2">
                            <div class="col-md-12">
                                <label class="form-label">Loại phòng mặc định cho tầng ${i}</label>
                                <select class="form-select floor-room-type" data-floor="${i}" onchange="updateRoomTypes(${i})">
                                    <option value="4-person-service">Phòng 4 người (dịch vụ)</option>
                                    <option value="8-person">Phòng 8 người</option>
                                    <option value="5-person">Phòng 5 người</option>
                                    <option value="10-person">Phòng 10 người</option>
                                </select>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="form-check">
                                <input class="form-check-input customize-rooms" type="checkbox" id="customizeRooms${i}" onchange="toggleCustomizeRooms(${i})">
                                <label class="form-check-label" for="customizeRooms${i}">
                                    Cấu hình chi tiết cho từng phòng
                                </label>
                            </div>
                        </div>
                        <div class="room-config-container" id="roomConfig${i}" style="display: none;">
                            <div class="row mt-3">
                                ${generateRoomConfig(i, roomsPerFloor)}
                            </div>
                        </div>
                    </div>
                `;
                
                container.appendChild(floorDiv);
            }
        }

        function generateRoomConfig(floorNumber, roomCount) {
            let html = '';
            for (let j = 1; j <= roomCount; j++) {
                const roomNumber = `P${floorNumber}${j.toString().padStart(2, '0')}`;
                html += `
                    <div class="col-md-4 mb-3">
                        <div class="room-card">
                            <div class="room-card-header">
                                ${roomNumber}
                            </div>
                            <div class="room-card-body">
                                <select class="form-select room-type" data-floor="${floorNumber}" data-room="${j}">
                                    <option value="4-person-service">Phòng 4 người (dịch vụ)</option>
                                    <option value="8-person">Phòng 8 người</option>
                                    <option value="5-person">Phòng 5 người</option>
                                    <option value="10-person">Phòng 10 người</option>
                                </select>
                            </div>
                        </div>
                    </div>
                `;
            }
            return html;
        }

        function toggleCustomizeRooms(floorNumber) {
            const checkbox = document.getElementById(`customizeRooms${floorNumber}`);
            const roomConfig = document.getElementById(`roomConfig${floorNumber}`);
            roomConfig.style.display = checkbox.checked ? 'block' : 'none';
        }

        function updateRoomTypes(floorNumber) {
            const floorRoomType = document.querySelector(`.floor-room-type[data-floor="${floorNumber}"]`).value;
            const roomSelects = document.querySelectorAll(`.room-type[data-floor="${floorNumber}"]`);
            
            roomSelects.forEach(select => {
                select.value = floorRoomType;
            });
        }

        function collectRoomConfigurations() {
            const totalFloors = parseInt(document.getElementById('totalFloors').value);
            const roomsPerFloor = parseInt(document.getElementById('roomsPerFloor').value);
            const floorRoomConfigs = [];
            
            for (let i = 1; i <= totalFloors; i++) {
                const floorConfig = {
                    floorNumber: i,
                    rooms: []
                };
                
                const customizeRooms = document.getElementById(`customizeRooms${i}`) && 
                                      document.getElementById(`customizeRooms${i}`).checked;
                
                if (customizeRooms) {
                    for (let j = 1; j <= roomsPerFloor; j++) {
                        const roomTypeSelect = document.querySelector(`.room-type[data-floor="${i}"][data-room="${j}"]`);
                        if (roomTypeSelect) {
                            const roomType = roomTypeSelect.value;
                            floorConfig.rooms.push({
                                roomNumber: `P${i}${j.toString().padStart(2, '0')}`,
                                roomType: roomType
                            });
                        }
                    }
                } else {
                    const floorRoomTypeSelect = document.querySelector(`.floor-room-type[data-floor="${i}"]`);
                    const floorRoomType = floorRoomTypeSelect ? floorRoomTypeSelect.value : '4-person-service';
                    
                    for (let j = 1; j <= roomsPerFloor; j++) {
                        floorConfig.rooms.push({
                            roomNumber: `P${i}${j.toString().padStart(2, '0')}`,
                            roomType: floorRoomType
                        });
                    }
                }
                
                floorRoomConfigs.push(floorConfig);
            }
            
            return floorRoomConfigs;
        }
        
        // ---- Media tabs ----
        function switchMediaTab(tab) {
            document.querySelectorAll('.media-tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.media-tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('mediaTab-' + tab).classList.add('active');
            event.target.classList.add('active');
        }

        // ---- Image management ----
        let mediaImages = <%- JSON.stringify(
            (dormitory && dormitory.images && dormitory.images.length)
                ? dormitory.images
                : (dormitory && dormitory.imageUrl ? [dormitory.imageUrl] : [])
        ) %>;

        function syncImageInputs() {
            const container = document.getElementById('imageHiddenInputs');
            container.innerHTML = '';
            mediaImages.forEach(url => {
                const inp = document.createElement('input');
                inp.type = 'hidden'; inp.name = 'images[]'; inp.value = url;
                container.appendChild(inp);
            });
        }

        function renderGallery() {
            const gallery = document.getElementById('imageGallery');
            gallery.innerHTML = '';
            mediaImages.forEach((img, i) => {
                const div = document.createElement('div');
                div.className = 'img-item';
                div.innerHTML = `
                    ${i === 0 ? '<span class="cover-badge">Bìa</span>' : ''}
                    <img src="${img}" class="img-thumb" onerror="this.src='/images/placeholder.png'">
                    <button type="button" class="img-remove-btn" onclick="removeImageByIndex(${i})" title="Xóa">×</button>`;
                gallery.appendChild(div);
            });
        }

        function addImageUrl() {
            const inp = document.getElementById('newImageUrl');
            const url = inp.value.trim();
            if (!url) return;
            if (mediaImages.includes(url)) { alert('URL này đã có trong danh sách.'); return; }
            mediaImages.push(url);
            inp.value = '';
            renderGallery();
            syncImageInputs();
        }

        function removeImage(url) {
            mediaImages = mediaImages.filter(u => u !== url);
            renderGallery();
            syncImageInputs();
        }

        function removeImageByIndex(idx) {
            mediaImages.splice(idx, 1);
            renderGallery();
            syncImageInputs();
        }

        document.addEventListener('DOMContentLoaded', function() {
            const lng = parseFloat(document.getElementById('longitude').value) || 105.843220;
            const lat = parseFloat(document.getElementById('latitude').value) || 21.007119;

            const map = new maplibregl.Map({
                container: 'map',
                style: 'https://tiles.openfreemap.org/styles/bright',
                center: [lng, lat],
                zoom: 16
            });
            const marker = new maplibregl.Marker({ draggable: true })
                .setLngLat([lng, lat])
                .addTo(map);
            function syncCoords(ll) {
                document.getElementById('latitude').value  = ll.lat.toFixed(6);
                document.getElementById('longitude').value = ll.lng.toFixed(6);
            }
            marker.on('dragend', () => syncCoords(marker.getLngLat()));
            map.on('click', e => { marker.setLngLat(e.lngLat); syncCoords(e.lngLat); });

            if ('<%= action %>' === 'add') {
                generateFloorConfig();
            }

            document.getElementById('dormitoryForm').addEventListener('submit', function(e) {
                e.preventDefault();

                if ('<%= action %>' === 'add') {
                    if (!document.getElementById('confirmStructure').checked) {
                        alert('Vui lòng xác nhận thông tin về số tầng và cấu trúc phòng');
                        return;
                    }
                }

                const formData = new FormData(this);
                const jsonData = {};
                
                formData.forEach((value, key) => {
                    if (key.includes('[')) {
                        const parts = key.split('[');
                        const mainKey = parts[0];
                        
                        if (!jsonData[mainKey]) {
                            jsonData[mainKey] = {};
                        }
                        
                        let currentObj = jsonData[mainKey];
                        
                        for (let i = 1; i < parts.length; i++) {
                            const subKey = parts[i].replace(/\]$/, '');

                            if (subKey === '') {
                                if (!Array.isArray(currentObj)) {
                                    currentObj = [];
                                    jsonData[mainKey] = currentObj;
                                }
                                currentObj.push(value);
                                break;
                            }
                            else {
                                if (i === parts.length - 1) {
                                    currentObj[subKey] = value;
                                } else {
                                    if (!currentObj[subKey]) {
                                        currentObj[subKey] = {};
                                    }
                                    currentObj = currentObj[subKey];
                                }
                            }
                        }
                    } else {
                        jsonData[key] = value;
                    }
                });
                if (jsonData.details) {
                    if (jsonData.details.totalFloors) {
                        jsonData.details.totalFloors = parseInt(jsonData.details.totalFloors);
                    }
                    if (jsonData.details.roomsPerFloor) {
                        jsonData.details.roomsPerFloor = parseInt(jsonData.details.roomsPerFloor);
                    }
                    if (jsonData.details.priceRange) {
                        if (jsonData.details.priceRange.min) {
                            jsonData.details.priceRange.min = parseInt(jsonData.details.priceRange.min);
                        }
                        if (jsonData.details.priceRange.max) {
                            jsonData.details.priceRange.max = parseInt(jsonData.details.priceRange.max);
                        }
                    }
                }

                if ('<%= action %>' === 'add') {
                    jsonData.floorRoomConfigs = collectRoomConfigurations();
                }

                // Media fields
                jsonData.images = mediaImages;
                const videoUrlVal = document.getElementById('videoUrl') ? document.getElementById('videoUrl').value.trim() : '';
                if (videoUrlVal) jsonData.videos = [videoUrlVal];
                const tourUrlVal = document.getElementById('virtualTourUrl') ? document.getElementById('virtualTourUrl').value.trim() : '';
                if (tourUrlVal) jsonData.virtualTour = tourUrlVal;

                if (jsonData.location && jsonData.location.coordinates) {
                    const lng = parseFloat(document.getElementById('longitude').value);
                    const lat = parseFloat(document.getElementById('latitude').value);
                    
                    if (!isNaN(lng) && !isNaN(lat)) {
                        jsonData.location.coordinates = [lng, lat];
                    } else {
                        jsonData.location.coordinates = [105.84322, 21.007119];
                    }
                }

                if (!jsonData.details.available) {
                    jsonData.details.available = false;
                }

                const url = '<%= action %>' === 'add'
                    ? '/api/dormitories'
                    : '/api/dormitories/<%= dormitory ? dormitory._id : "" %>';

                const method = '<%= action %>' === 'add' ? 'POST' : 'PUT';

                // Upload image first if file selected, then submit JSON
                const imageFileInput = document.getElementById('imageFile');
                const hasFile = imageFileInput && imageFileInput.files && imageFileInput.files[0];

                const doSubmit = (finalData) => fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(finalData)
                }).then(response => {
                    if (!response.ok) {
                        return response.json().then(errData => {
                            throw new Error(errData.error || 'Lỗi kết nối');
                        });
                    }
                    return response.json();
                })
                .then(data => {
                    if (data.success) {
                        alert('<%= action %>' === 'add' ? 'Thêm ký túc xá thành công!' : 'Cập nhật ký túc xá thành công!');
                        window.location.href = '/admin/dormitories';
                    } else {
                        throw new Error(data.error || 'Có lỗi xảy ra');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Lỗi: ' + error.message);
                });

                if (hasFile) {
                    const fd = new FormData();
                    fd.append('image', imageFileInput.files[0]);
                    fetch('/api/upload/dormitory-image', { method: 'POST', body: fd })
                        .then(r => r.json())
                        .then(r => {
                            if (r.success) jsonData.imageUrl = r.url;
                            doSubmit(jsonData);
                        })
                        .catch(() => doSubmit(jsonData));
                } else {
                    doSubmit(jsonData);
                }
            });
        });
    </script>
<%- include('../footer') %>
</body>
</html>