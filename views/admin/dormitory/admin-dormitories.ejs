<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ký túc xá — KTX HUST Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary:   #C8102E;
      --primary-dk:#A20D25;
      --primary-bg:#FFF0F2;
      --bg:        #F7F7F7;
      --surface:   #FFFFFF;
      --border:    #E5E7EB;
      --text:      #111827;
      --text-2:    #6B7280;
      --text-3:    #9CA3AF;
      --success:   #15803D;
      --success-bg:#F0FDF4;
      --warning:   #D97706;
      --warning-bg:#FFFBEB;
      --danger:    #DC2626;
      --danger-bg: #FEF2F2;
      --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
      --shadow:    0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.04);
      --radius:    8px;
      --radius-sm: 6px;
    }

    body {
      background: var(--bg);
      font-family: 'Inter', system-ui, sans-serif;
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }

    /* ── Page shell ── */
    .page {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 24px 48px;
    }

    /* ── Page header ── */
    .page-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 0 18px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 24px;
      gap: 12px;
      flex-wrap: wrap;
    }

    .page-head-left h1 {
      font-size: 18px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    .page-head-left p {
      font-size: 13px;
      color: var(--text-2);
      margin-top: 2px;
    }

    .page-head-right {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      border-radius: var(--radius-sm);
      font-size: 13px;
      font-weight: 500;
      font-family: inherit;
      cursor: pointer;
      border: 1px solid transparent;
      transition: background 0.15s, box-shadow 0.15s, border-color 0.15s;
      white-space: nowrap;
    }

    .btn-primary {
      background: var(--primary);
      color: #fff;
      border-color: var(--primary);
    }
    .btn-primary:hover {
      background: var(--primary-dk);
      border-color: var(--primary-dk);
      box-shadow: 0 1px 4px rgba(200,16,46,0.25);
    }

    .btn-ghost {
      background: var(--surface);
      color: var(--text-2);
      border-color: var(--border);
    }
    .btn-ghost:hover {
      background: var(--bg);
      color: var(--text);
      border-color: #D1D5DB;
    }

    .btn-icon-only {
      padding: 6px 8px;
    }

    .btn-sm { padding: 5px 10px; font-size: 12px; }

    /* ── KPI cards ── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 24px;
    }

    @media (max-width: 900px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 500px) { .kpi-grid { grid-template-columns: 1fr; } }

    .kpi-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 18px;
      box-shadow: var(--shadow-sm);
    }

    .kpi-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 6px;
    }

    .kpi-value {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--text);
      line-height: 1;
    }

    .kpi-sub {
      font-size: 12px;
      color: var(--text-3);
      margin-top: 4px;
    }

    /* occupancy bar under the last kpi */
    .kpi-bar-wrap { margin-top: 8px; }
    .kpi-bar-track {
      height: 4px;
      background: var(--border);
      border-radius: 99px;
      overflow: hidden;
    }
    .kpi-bar-fill {
      height: 100%;
      border-radius: 99px;
      background: var(--primary);
      transition: width 0.4s ease;
    }

    /* ── Toolbar ── */
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      gap: 8px;
      flex-wrap: wrap;
    }

    .toolbar-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }

    .toolbar-right { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

    /* ── Dormitory grid ── */
    .dorm-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    @media (max-width: 1100px) { .dorm-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px)  { .dorm-grid { grid-template-columns: 1fr; } }

    /* ── Dormitory card ── */
    .dorm-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.15s, border-color 0.15s;
    }

    .dorm-card:hover {
      box-shadow: var(--shadow);
      border-color: #D1D5DB;
    }

    /* image strip */
    .dorm-img {
      width: 100%;
      height: 130px;
      object-fit: cover;
      display: block;
      background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
    }

    .dorm-img-placeholder {
      height: 130px;
      background: linear-gradient(135deg, #F9FAFB 0%, #F3F4F6 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .dorm-img-placeholder i {
      font-size: 40px;
      color: #D1D5DB;
    }

    /* card body */
    .dorm-body {
      padding: 14px 16px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .dorm-name-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px;
    }

    .dorm-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
      line-height: 1.3;
    }

    .dorm-addr {
      font-size: 12px;
      color: var(--text-3);
      margin-top: 2px;
    }

    /* status badge */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      border-radius: 99px;
      font-size: 11px;
      font-weight: 600;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .badge-success  { background: var(--success-bg); color: var(--success); }
    .badge-danger   { background: var(--danger-bg);  color: var(--danger); }
    .badge-warning  { background: var(--warning-bg); color: var(--warning); }
    .badge-neutral  { background: #F3F4F6; color: var(--text-2); }

    /* meta row */
    .dorm-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 12px;
    }

    .dorm-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-2);
    }

    .dorm-meta-item i {
      color: var(--text-3);
      width: 12px;
      text-align: center;
      font-size: 11px;
    }

    /* occupancy bar */
    .occ-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 12px;
      color: var(--text-2);
      margin-bottom: 4px;
    }

    .occ-row strong { color: var(--text); font-weight: 600; }

    .occ-track {
      height: 5px;
      background: var(--border);
      border-radius: 99px;
      overflow: hidden;
    }

    .occ-fill {
      height: 100%;
      border-radius: 99px;
      transition: width 0.3s;
    }

    .occ-fill.high    { background: var(--danger); }
    .occ-fill.medium  { background: var(--warning); }
    .occ-fill.low     { background: var(--success); }

    /* category tags */
    .dorm-tags { display: flex; gap: 4px; flex-wrap: wrap; }

    .tag {
      padding: 2px 7px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 500;
      border: 1px solid transparent;
    }

    .tag-school   { background: #EFF6FF; color: #1D4ED8; border-color: #BFDBFE; }
    .tag-private  { background: #FFFBEB; color: #92400E; border-color: #FDE68A; }
    .tag-basic    { background: #F0FDF4; color: #15803D; border-color: #BBF7D0; }
    .tag-premium  { background: #FAF5FF; color: #7C3AED; border-color: #DDD6FE; }
    .tag-international { background: #FFF7ED; color: #C2410C; border-color: #FDBA74; }
    .tag-female   { background: #FDF2F8; color: #9D174D; border-color: #FBCFE8; }
    .tag-male     { background: #EFF6FF; color: #1E40AF; border-color: #BFDBFE; }

    /* card footer */
    .dorm-footer {
      padding: 10px 16px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 6px;
      background: #FAFAFA;
    }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 60px 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }

    .empty-state i {
      font-size: 40px;
      color: var(--text-3);
      margin-bottom: 12px;
      display: block;
    }

    .empty-state h3 { font-size: 15px; font-weight: 600; color: var(--text-2); }
    .empty-state p  { font-size: 13px; color: var(--text-3); margin-top: 4px; }

    /* ── Danger action inline ── */
    .btn-danger-ghost {
      background: transparent;
      color: var(--danger);
      border-color: transparent;
    }
    .btn-danger-ghost:hover {
      background: var(--danger-bg);
      border-color: #FECACA;
    }

    /* ── Bottom bar ── */
    .bottom-bar {
      margin-top: 16px;
      display: flex;
      justify-content: flex-end;
    }
  </style>
</head>
<body>
  <%- include('../navbar', { activeNav: 'dormitories' }) %>

  <div class="page">

    <!-- Page header -->
    <div class="page-head">
      <div class="page-head-left">
        <h1>Quản lý Ký túc xá</h1>
        <p>Tổng quan hệ thống ký túc xá HUST — dữ liệu thời gian thực</p>
      </div>
      <div class="page-head-right">
        <a href="/admin/dormitories/add" class="btn btn-primary">
          <i class="fas fa-plus"></i> Thêm KTX
        </a>
      </div>
    </div>

    <%
    let totalDorms    = dormitories ? dormitories.length : 0;
    let totalRoomsCnt = 0;
    let totalCapCnt   = 0;
    let totalOccCnt   = 0;

    if (dormitories && dormitories.length > 0) {
      dormitories.forEach(d => {
        if (d.floors) {
          d.floors.forEach(fl => {
            if (fl.rooms) {
              fl.rooms.forEach(rm => {
                totalRoomsCnt++;
                totalCapCnt  += rm.maxCapacity || 0;
                totalOccCnt  += (rm.occupants || []).filter(o => o.active).length;
              });
            }
          });
        }
      });
    }
    const globalOccRate = totalCapCnt > 0 ? Math.round(totalOccCnt / totalCapCnt * 100) : 0;
    %>

    <!-- KPI Cards -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-label">Tổng KTX</div>
        <div class="kpi-value"><%= totalDorms %></div>
        <div class="kpi-sub">Đang hoạt động</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Tổng phòng</div>
        <div class="kpi-value"><%= totalRoomsCnt %></div>
        <div class="kpi-sub"><%= totalCapCnt.toLocaleString('vi-VN') %> chỗ tổng cộng</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Sinh viên đang ở</div>
        <div class="kpi-value"><%= totalOccCnt.toLocaleString('vi-VN') %></div>
        <div class="kpi-sub">Trên <%= totalCapCnt.toLocaleString('vi-VN') %> chỗ</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Tỷ lệ lấp đầy</div>
        <div class="kpi-value"><%= globalOccRate %>%</div>
        <div class="kpi-sub">
          <div class="kpi-bar-wrap">
            <div class="kpi-bar-track">
              <div class="kpi-bar-fill" style="width: <%= globalOccRate %>%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
      <span class="toolbar-title"><%= totalDorms %> ký túc xá</span>
      <div class="toolbar-right">
        <a href="/admin/dormitories/trash" class="btn btn-ghost btn-sm">
          <i class="fas fa-trash-restore"></i> Thùng rác
        </a>
      </div>
    </div>

    <!-- Dormitory Grid -->
    <% if (dormitories && dormitories.length > 0) { %>
    <div class="dorm-grid">
      <% dormitories.forEach(function(dorm) {
        let dFloors = 0, dRooms = 0, dCap = 0, dOcc = 0;
        if (dorm.floors && dorm.floors.length > 0) {
          dFloors = dorm.floors.length;
          dorm.floors.forEach(fl => {
            if (fl.rooms) {
              fl.rooms.forEach(rm => {
                dRooms++;
                dCap += rm.maxCapacity || 0;
                dOcc += (rm.occupants || []).filter(o => o.active).length;
              });
            }
          });
        }
        const dRate = dCap > 0 ? Math.round(dOcc / dCap * 100) : 0;
        const isAvailable = dOcc < dCap;
        const occClass = dRate >= 85 ? 'high' : dRate >= 55 ? 'medium' : 'low';
      %>
      <div class="dorm-card">

        <!-- Image -->
        <% if (dorm.imageUrl) { %>
          <img class="dorm-img" src="<%= dorm.imageUrl %>" alt="<%= dorm.name %>" loading="lazy">
        <% } else { %>
          <div class="dorm-img-placeholder">
            <i class="fas fa-building"></i>
          </div>
        <% } %>

        <!-- Body -->
        <div class="dorm-body">

          <!-- Name + status -->
          <div class="dorm-name-row">
            <div>
              <div class="dorm-name"><%= dorm.name %></div>
              <div class="dorm-addr"><i class="fas fa-map-marker-alt" style="color:#C8102E;margin-right:3px;"></i><%= dorm.address || '' %></div>
            </div>
            <span class="badge <%= isAvailable ? 'badge-success' : 'badge-danger' %>">
              <%= isAvailable ? 'Còn chỗ' : 'Hết chỗ' %>
            </span>
          </div>

          <!-- Tags -->
          <div class="dorm-tags">
            <% if (dorm.details && dorm.details.type) { %>
              <span class="tag tag-<%= dorm.details.type %>">
                <%= dorm.details.type === 'school' ? 'Trường học' : 'Tư nhân' %>
              </span>
            <% } %>
            <% if (dorm.details && dorm.details.category) { %>
              <span class="tag tag-<%= dorm.details.category %>">
                <% if (dorm.details.category === 'basic') { %>Cơ bản<% } %>
                <% if (dorm.details.category === 'premium') { %>Cao cấp<% } %>
                <% if (dorm.details.category === 'international') { %>Quốc tế<% } %>
              </span>
            <% } %>
            <% if (dorm.details && dorm.details.gender && dorm.details.gender !== 'mixed') { %>
              <span class="tag tag-<%= dorm.details.gender %>">
                <%= dorm.details.gender === 'female' ? 'Nữ' : 'Nam' %>
              </span>
            <% } %>
          </div>

          <!-- Meta -->
          <div class="dorm-meta">
            <div class="dorm-meta-item">
              <i class="fas fa-layer-group"></i>
              <span><%= dFloors %> tầng</span>
            </div>
            <div class="dorm-meta-item">
              <i class="fas fa-door-open"></i>
              <span><%= dRooms %> phòng</span>
            </div>
            <div class="dorm-meta-item">
              <i class="fas fa-users"></i>
              <span><%= dOcc %>/<%= dCap %> sinh viên</span>
            </div>
            <% if (dorm.details && dorm.details.priceRange) { %>
            <div class="dorm-meta-item">
              <i class="fas fa-tag"></i>
              <span><%= (dorm.details.priceRange.min || 0).toLocaleString('vi-VN') %>–<%= (dorm.details.priceRange.max || 0).toLocaleString('vi-VN') %>đ</span>
            </div>
            <% } %>
          </div>

          <!-- Occupancy bar -->
          <div>
            <div class="occ-row">
              <span>Lấp đầy</span>
              <strong><%= dRate %>%</strong>
            </div>
            <div class="occ-track">
              <div class="occ-fill <%= occClass %>" style="width:<%= dRate %>%"></div>
            </div>
          </div>

        </div><!-- /dorm-body -->

        <!-- Footer actions -->
        <div class="dorm-footer">
          <a href="/admin/dormitories/view/<%= dorm._id %>" class="btn btn-ghost btn-sm">
            <i class="fas fa-eye"></i> Chi tiết
          </a>
          <a href="/admin/dormitories/edit/<%= dorm._id %>" class="btn btn-ghost btn-sm">
            <i class="fas fa-pen"></i> Sửa
          </a>
          <button
            onclick="deleteDorm('<%= dorm._id %>', '<%= dorm.name.replace(/'/g, `\\'`) %>')"
            class="btn btn-sm btn-danger-ghost" style="margin-left:auto;">
            <i class="fas fa-trash"></i>
          </button>
        </div>

      </div><!-- /dorm-card -->
      <% }); %>
    </div><!-- /dorm-grid -->

    <% } else { %>
    <div class="empty-state">
      <i class="fas fa-building"></i>
      <h3>Chưa có ký túc xá nào</h3>
      <p>Nhấn "Thêm KTX" để bắt đầu thêm ký túc xá đầu tiên.</p>
    </div>
    <% } %>

  </div><!-- /page -->

  <script>
    function deleteDorm(id, name) {
      if (!confirm('Xóa ký túc xá "' + name + '"?\n\nHành động này không thể hoàn tác.')) return;
      fetch('/api/dormitories/' + id, { method: 'DELETE' })
        .then(r => r.json())
        .then(res => {
          if (res.success || !res.error) {
            location.reload();
          } else {
            alert('Lỗi: ' + (res.error || 'Không thể xóa'));
          }
        })
        .catch(() => alert('Lỗi hệ thống. Vui lòng thử lại.'));
    }
  </script>
</body>
</html>
