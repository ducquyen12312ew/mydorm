<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ký túc xá — KTX HUST Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary:    #C8102E;
      --primary-dk: #9E0C24;
      --primary-bg: #FFF0F2;
      --border:     #EFE8DF;
      --text:       #2B2320;
      --text-2:     #7C7166;
      --text-3:     #A89C8E;
      --success:    #0E9F6E;
      --success-bg: #E4F6EF;
      --success-bd: #A7DFC8;
      --warning:    #D9A22B;
      --warning-bg: #FBF1DC;
      --warning-bd: #EDD28A;
      --danger:     #C8102E;
      --danger-bg:  #FFF0F2;
      --shadow-card: 0 1px 2px rgba(43,35,32,.04), 0 20px 38px -26px rgba(43,35,32,.2);
      --shadow-hover: 0 2px 8px rgba(43,35,32,.07), 0 24px 44px -22px rgba(43,35,32,.25);
      --radius-card: 16px;
      --radius-sm:   10px;
      --radius-btn:  11px;
    }

    body {
      background: linear-gradient(180deg, #FBF8F3, #F5EFE7);
      min-height: 100vh;
      font-family: 'Josefin Sans', system-ui, sans-serif;
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }

    /* ── Page shell ── */
    .page {
      max-width: 1440px;
      margin: 0 auto;
      padding: 0 24px 48px;
    }

    /* ── Page header ── */
    .page-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 0 20px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 24px;
      gap: 12px;
      flex-wrap: wrap;
    }

    .page-head-left h1 {
      font-family: 'Josefin Sans', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.02em;
    }

    .page-head-left p {
      font-size: 13px;
      color: var(--text-2);
      margin-top: 3px;
    }

    .page-head-right {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: var(--radius-btn);
      font-size: 13px;
      font-weight: 600;
      font-family: 'Josefin Sans', inherit;
      cursor: pointer;
      border: 1px solid transparent;
      transition: background 0.15s, box-shadow 0.15s, border-color 0.15s;
      white-space: nowrap;
    }

    .btn-primary {
      background: linear-gradient(135deg, #E11D2A, #B20C26);
      color: #fff;
      border-color: transparent;
      box-shadow: 0 10px 24px -10px rgba(200,16,46,.65);
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #C8102E, #9E0C24);
      box-shadow: 0 12px 28px -8px rgba(200,16,46,.75);
    }

    .btn-ghost {
      background: #fff;
      color: var(--text-2);
      border-color: var(--border);
    }
    .btn-ghost:hover {
      background: #FBF8F3;
      color: var(--text);
      border-color: #D9CFBF;
    }

    .btn-icon-only { padding: 6px 8px; }

    .btn-sm { padding: 5px 12px; font-size: 12px; }

    /* ── KPI cards ── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 28px;
    }

    @media (max-width: 900px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 500px) { .kpi-grid { grid-template-columns: 1fr; } }

    .kpi-card {
      background: linear-gradient(180deg, #FFFFFF, #FCFAF6);
      border: 1px solid var(--border);
      border-radius: var(--radius-card);
      padding: 18px 20px;
      box-shadow: var(--shadow-card);
      border-top: 3px solid #C8102E;
    }

    .kpi-label {
      font-size: 10.5px;
      font-weight: 700;
      color: #9A8F84;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 6px;
      font-family: 'Josefin Sans', sans-serif;
    }

    .kpi-value {
      font-family: 'Josefin Sans', sans-serif;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--text);
      line-height: 1;
    }

    .kpi-sub {
      font-size: 12px;
      color: var(--text-3);
      margin-top: 5px;
    }

    /* occupancy bar */
    .kpi-bar-wrap { margin-top: 8px; }
    .kpi-bar-track {
      height: 5px;
      background: #EFE8DF;
      border-radius: 99px;
      overflow: hidden;
    }
    .kpi-bar-fill {
      height: 100%;
      border-radius: 99px;
      background: linear-gradient(90deg, #E11D2A, #B20C26);
      transition: width 0.4s ease;
    }

    /* ── Toolbar ── */
    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      gap: 8px;
      flex-wrap: wrap;
    }

    .toolbar-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }

    .toolbar-right { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

    /* ── Dormitory grid ── */
    .dorm-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    @media (max-width: 1100px) { .dorm-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px)  { .dorm-grid { grid-template-columns: 1fr; } }

    /* ── Dormitory card ── */
    .dorm-card {
      background: linear-gradient(180deg, #FFFFFF, #FCFAF6);
      border: 1px solid var(--border);
      border-radius: var(--radius-card);
      box-shadow: var(--shadow-card);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
    }

    .dorm-card:hover {
      box-shadow: var(--shadow-hover);
      border-color: #D9CFBF;
      transform: translateY(-2px);
    }

    /* image strip */
    .dorm-img {
      width: 100%;
      height: 130px;
      object-fit: cover;
      display: block;
    }

    .dorm-img-placeholder {
      height: 130px;
      background: linear-gradient(135deg, #F7F1E8 0%, #EFE8DF 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .dorm-img-placeholder i {
      font-size: 40px;
      color: #C8B9A8;
    }

    /* card body */
    .dorm-body {
      padding: 16px 18px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .dorm-name-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px;
    }

    .dorm-name {
      font-family: 'Josefin Sans', sans-serif;
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
      line-height: 1.3;
    }

    .dorm-addr {
      font-size: 12px;
      color: var(--text-3);
      margin-top: 2px;
    }

    /* status badge */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 9px;
      border-radius: 99px;
      font-size: 11px;
      font-weight: 600;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .badge-success { background: var(--success-bg); color: var(--success); border: 1px solid var(--success-bd); }
    .badge-danger  { background: var(--danger-bg);  color: var(--danger);  border: 1px solid #FECDD3; }
    .badge-warning { background: var(--warning-bg); color: var(--warning); border: 1px solid var(--warning-bd); }
    .badge-neutral { background: #F7F1E8; color: var(--text-2); border: 1px solid var(--border); }

    /* meta row */
    .dorm-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 12px;
    }

    .dorm-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-2);
    }

    .dorm-meta-item i {
      color: var(--text-3);
      width: 12px;
      text-align: center;
      font-size: 11px;
    }

    /* occupancy bar */
    .occ-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 12px;
      color: var(--text-2);
      margin-bottom: 5px;
    }

    .occ-row strong { color: var(--text); font-weight: 700; }

    .occ-track {
      height: 5px;
      background: #EFE8DF;
      border-radius: 99px;
      overflow: hidden;
    }

    .occ-fill {
      height: 100%;
      border-radius: 99px;
      transition: width 0.3s;
    }

    .occ-fill.high    { background: linear-gradient(90deg, #E11D2A, #B20C26); }
    .occ-fill.medium  { background: linear-gradient(90deg, #D9A22B, #B8861F); }
    .occ-fill.low     { background: #C8B9A8; }

    /* category tags */
    .dorm-tags { display: flex; gap: 4px; flex-wrap: wrap; }

    .tag {
      padding: 2px 8px;
      border-radius: 5px;
      font-size: 11px;
      font-weight: 500;
      border: 1px solid transparent;
    }

    .tag-school       { background: #F7F1E8; color: var(--text-2); border-color: var(--border); }
    .tag-private      { background: #FBF1DC; color: #92400E; border-color: #EDD28A; }
    .tag-basic        { background: var(--primary-bg); color: var(--primary); border-color: #FECDD3; }
    .tag-premium      { background: #F7F1E8; color: #7C5C2E; border-color: #DCC9A8; }
    .tag-international{ background: #FBF1DC; color: #7C4D10; border-color: #EDD28A; }
    .tag-female       { background: #F7F1E8; color: var(--text-2); border-color: var(--border); }
    .tag-male         { background: #F7F1E8; color: var(--text-2); border-color: var(--border); }

    /* card footer */
    .dorm-footer {
      padding: 10px 16px;
      border-top: 1px solid var(--border);
      display: flex;
      gap: 6px;
      background: #FDFBF8;
    }

    /* ── Empty state ── */
    .empty-state {
      text-align: center;
      padding: 60px 24px;
      background: linear-gradient(180deg, #FFFFFF, #FCFAF6);
      border: 1px solid var(--border);
      border-radius: var(--radius-card);
      box-shadow: var(--shadow-card);
    }

    .empty-state i {
      font-size: 40px;
      color: #C8B9A8;
      margin-bottom: 12px;
      display: block;
    }

    .empty-state h3 { font-family: 'Josefin Sans', sans-serif; font-size: 16px; font-weight: 600; color: var(--text-2); }
    .empty-state p  { font-size: 13px; color: var(--text-3); margin-top: 4px; }

    /* ── Danger action inline ── */
    .btn-danger-ghost {
      background: transparent;
      color: #C8102E;
      border-color: transparent;
    }
    .btn-danger-ghost:hover {
      background: var(--danger-bg);
      border-color: #FECDD3;
    }

    /* ── Bottom bar ── */
    .bottom-bar {
      margin-top: 16px;
      display: flex;
      justify-content: flex-end;
    }
  </style>
</head>
<body>
  <%- include('../navbar', { activeNav: 'dormitories' }) %>

  <div class="page">

    <!-- Page header -->
    <div class="page-head">
      <div class="page-head-left">
        <h1>Quản lý Ký túc xá</h1>
        <p>Tổng quan hệ thống ký túc xá HUST — dữ liệu thời gian thực</p>
      </div>
      <div class="page-head-right">
        <a href="/admin/dormitories/add" class="btn btn-primary">
          <i class="fas fa-plus"></i> Thêm KTX
        </a>
      </div>
    </div>

    <%
    let totalDorms    = dormitories ? dormitories.length : 0;
    let totalRoomsCnt = 0;
    let totalCapCnt   = 0;
    let totalOccCnt   = 0;

    if (dormitories && dormitories.length > 0) {
      dormitories.forEach(d => {
        if (d.floors) {
          d.floors.forEach(fl => {
            if (fl.rooms) {
              fl.rooms.forEach(rm => {
                totalRoomsCnt++;
                totalCapCnt  += rm.maxCapacity || 0;
                totalOccCnt  += (rm.occupants || []).filter(o => o.active).length;
              });
            }
          });
        }
      });
    }
    let globalOccRate = totalCapCnt > 0 ? Math.round(totalOccCnt / totalCapCnt * 100) : 0;

    // admintest: override global KPIs with simulation data
    if (typeof simOverall !== 'undefined' && simOverall) {
      totalCapCnt  = simOverall.totalBeds;
      totalOccCnt  = simOverall.occupiedBeds;
      globalOccRate = simOverall.occupancyRate;
    }
    %>

    <!-- KPI Cards -->
    <div class="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-label">Tổng KTX</div>
        <div class="kpi-value"><%= totalDorms %></div>
        <div class="kpi-sub">Đang hoạt động</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Tổng phòng</div>
        <div class="kpi-value"><%= totalRoomsCnt %></div>
        <div class="kpi-sub"><%= totalCapCnt.toLocaleString('vi-VN') %> chỗ tổng cộng</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Sinh viên đang ở</div>
        <div class="kpi-value"><%= totalOccCnt.toLocaleString('vi-VN') %></div>
        <div class="kpi-sub">Trên <%= totalCapCnt.toLocaleString('vi-VN') %> chỗ</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">Tỷ lệ lấp đầy</div>
        <div class="kpi-value"><%= globalOccRate %>%</div>
        <div class="kpi-sub">
          <div class="kpi-bar-wrap">
            <div class="kpi-bar-track">
              <div class="kpi-bar-fill" style="width: <%= globalOccRate %>%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="toolbar">
      <span class="toolbar-title"><%= totalDorms %> ký túc xá</span>
      <div class="toolbar-right">
        <a href="/admin/dormitories/trash" class="btn btn-ghost btn-sm">
          <i class="fas fa-trash-restore"></i> Thùng rác
        </a>
      </div>
    </div>

    <!-- Dormitory Grid -->
    <% if (dormitories && dormitories.length > 0) { %>
    <div class="dorm-grid">
      <% dormitories.forEach(function(dorm) {
        let dFloors = 0, dRooms = 0, dCap = 0, dOcc = 0;
        if (dorm.floors && dorm.floors.length > 0) {
          dFloors = dorm.floors.length;
          dorm.floors.forEach(fl => {
            if (fl.rooms) {
              fl.rooms.forEach(rm => {
                dRooms++;
                dCap += rm.maxCapacity || 0;
                dOcc += (rm.occupants || []).filter(o => o.active).length;
              });
            }
          });
        }
        // admintest: override per-dorm occupancy with simulation data
        if (typeof simDormMap !== 'undefined' && simDormMap && simDormMap[dorm.name]) {
          const sd = simDormMap[dorm.name];
          dCap = sd.capacity;
          dOcc = sd.occupied;
        }
        const dRate = dCap > 0 ? Math.round(dOcc / dCap * 100) : 0;
        const isAvailable = dOcc < dCap;
        const occClass = dRate >= 85 ? 'high' : dRate >= 55 ? 'medium' : 'low';
      %>
      <div class="dorm-card">

        <!-- Image -->
        <% if (dorm.imageUrl) { %>
          <img class="dorm-img" src="<%= dorm.imageUrl %>" alt="<%= dorm.name %>" loading="lazy">
        <% } else { %>
          <div class="dorm-img-placeholder">
            <i class="fas fa-building"></i>
          </div>
        <% } %>

        <!-- Body -->
        <div class="dorm-body">

          <!-- Name + status -->
          <div class="dorm-name-row">
            <div>
              <div class="dorm-name"><%= dorm.name %></div>
              <div class="dorm-addr"><i class="fas fa-map-marker-alt" style="color:#C8102E;margin-right:3px;"></i><%= dorm.address || '' %></div>
            </div>
            <span class="badge <%= isAvailable ? 'badge-success' : 'badge-danger' %>">
              <%= isAvailable ? 'Còn chỗ' : 'Hết chỗ' %>
            </span>
          </div>

          <!-- Tags -->
          <div class="dorm-tags">
            <% if (dorm.details && dorm.details.type) { %>
              <span class="tag tag-<%= dorm.details.type %>">
                <%= dorm.details.type === 'school' ? 'Trường học' : 'Tư nhân' %>
              </span>
            <% } %>
            <% if (dorm.details && dorm.details.category) { %>
              <span class="tag tag-<%= dorm.details.category %>">
                <% if (dorm.details.category === 'basic') { %>Cơ bản<% } %>
                <% if (dorm.details.category === 'premium') { %>Cao cấp<% } %>
                <% if (dorm.details.category === 'international') { %>Quốc tế<% } %>
              </span>
            <% } %>
            <% if (dorm.details && dorm.details.gender && dorm.details.gender !== 'mixed') { %>
              <span class="tag tag-<%= dorm.details.gender %>">
                <%= dorm.details.gender === 'female' ? 'Nữ' : 'Nam' %>
              </span>
            <% } %>
          </div>

          <!-- Meta -->
          <div class="dorm-meta">
            <div class="dorm-meta-item">
              <i class="fas fa-layer-group"></i>
              <span><%= dFloors %> tầng</span>
            </div>
            <div class="dorm-meta-item">
              <i class="fas fa-door-open"></i>
              <span><%= dRooms %> phòng</span>
            </div>
            <div class="dorm-meta-item">
              <i class="fas fa-users"></i>
              <span><%= dOcc %>/<%= dCap %> sinh viên</span>
            </div>
            <% if (dorm.details && dorm.details.priceRange) { %>
            <div class="dorm-meta-item">
              <i class="fas fa-tag"></i>
              <span><%= (dorm.details.priceRange.min || 0).toLocaleString('vi-VN') %>–<%= (dorm.details.priceRange.max || 0).toLocaleString('vi-VN') %>đ</span>
            </div>
            <% } %>
          </div>

          <!-- Occupancy bar -->
          <div>
            <div class="occ-row">
              <span>Lấp đầy</span>
              <strong><%= dRate %>%</strong>
            </div>
            <div class="occ-track">
              <div class="occ-fill <%= occClass %>" style="width:<%= dRate %>%"></div>
            </div>
          </div>

        </div><!-- /dorm-body -->

        <!-- Footer actions -->
        <div class="dorm-footer">
          <a href="/admin/dormitories/view/<%= dorm._id %>" class="btn btn-ghost btn-sm">
            <i class="fas fa-eye"></i> Chi tiết
          </a>
          <a href="/admin/dormitories/edit/<%= dorm._id %>" class="btn btn-ghost btn-sm">
            <i class="fas fa-pen"></i> Sửa
          </a>
          <button
            onclick="deleteDorm('<%= dorm._id %>', '<%= dorm.name.replace(/'/g, `\\'`) %>')"
            class="btn btn-sm btn-danger-ghost" style="margin-left:auto;">
            <i class="fas fa-trash"></i>
          </button>
        </div>

      </div><!-- /dorm-card -->
      <% }); %>
    </div><!-- /dorm-grid -->

    <% } else { %>
    <div class="empty-state">
      <i class="fas fa-building"></i>
      <h3>Chưa có ký túc xá nào</h3>
      <p>Nhấn "Thêm KTX" để bắt đầu thêm ký túc xá đầu tiên.</p>
    </div>
    <% } %>

  </div><!-- /page -->

  <script>
    function deleteDorm(id, name) {
      if (!confirm('Xóa ký túc xá "' + name + '"?\n\nHành động này không thể hoàn tác.')) return;
      fetch('/api/dormitories/' + id, { method: 'DELETE' })
        .then(r => r.json())
        .then(res => {
          if (res.success || !res.error) {
            location.reload();
          } else {
            alert('Lỗi: ' + (res.error || 'Không thể xóa'));
          }
        })
        .catch(() => alert('Lỗi hệ thống. Vui lòng thử lại.'));
    }
  </script>

<%- include('../../shared/footer') %>
</body>
</html>
