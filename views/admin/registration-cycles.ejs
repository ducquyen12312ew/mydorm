<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Đợt Đăng Ký - Admin KTX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --red: #C8102E;
            --red-grad: linear-gradient(135deg,#E11D2A,#B20C26);
            --red-dark: #9E0C24;
            --body-bg: linear-gradient(180deg,#FBF8F3,#F5EFE7);
            --card-bg: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            --card-border: #EFE8DF;
            --card-shadow: 0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);
            --text: #2B2320; --muted: #7C7166; --muted2: #A89C8E;
            --th-bg: #F7F1E8; --th-color: #9A8F84;
            --row-border: #F4EEE5;
        }

        body { font-family: 'Josefin Sans', 'Segoe UI', sans-serif; background: var(--body-bg); color: var(--text); }

        /* Container */
        .container { max-width: 1400px; margin: 0 auto; padding: 0 2rem; }

        /* Page header */
        .page-header {
            background: var(--card-bg);
            padding: 1.5rem 2rem; border-radius: 17px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow);
            margin-bottom: 2rem;
            display: flex; justify-content: space-between; align-items: center;
        }
        .page-header h1 {
            font-family: 'Josefin Sans', sans-serif;
            font-size: 1.3rem; font-weight: 700; color: var(--text);
        }

        /* Buttons */
        .btn {
            padding: 10px 22px; border: none; border-radius: 11px;
            cursor: pointer; font-weight: 600; transition: all .2s;
            text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
            font-family: 'Josefin Sans', sans-serif; font-size: 13.5px;
        }
        .btn-primary { background: var(--red-grad); color: #fff; box-shadow: 0 10px 24px -10px rgba(200,16,46,.65); }
        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 14px 28px -10px rgba(200,16,46,.75); }
        .btn-sm { padding: 7px 14px; font-size: .85rem; border-radius: 9px; }
        .btn-success { background: linear-gradient(135deg,#0E9F6E,#087A55); color: #fff; box-shadow: 0 8px 20px -8px rgba(14,159,110,.55); }
        .btn-success:hover { transform: translateY(-1px); }
        .btn-danger { background: var(--red-grad); color: #fff; box-shadow: 0 8px 20px -8px rgba(200,16,46,.5); }
        .btn-danger:hover { transform: translateY(-1px); }
        .btn-secondary { background: #fff; border: 1px solid #E7DECF; color: var(--text); }
        .btn-secondary:hover { background: #FBF8F3; border-color: #D4C9BC; }

        /* Registration cards */
        .windows-grid { display: grid; gap: 1.5rem; }
        .window-card {
            background: var(--card-bg); border-radius: 17px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow);
            padding: 1.5rem; transition: transform .25s, box-shadow .25s;
        }
        .window-card:hover { transform: translateY(-2px); box-shadow: 0 1px 2px rgba(43,35,32,.04),0 28px 44px -22px rgba(43,35,32,.28); }

        .window-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; }
        .window-title { font-family: 'Josefin Sans', sans-serif; font-size: 1.4rem; color: var(--text); font-weight: 700; }

        /* Status badges */
        .window-status { padding: 5px 13px; border-radius: 20px; font-size: .78rem; font-weight: 700; }
        .status-active   { background: #E4F6EF; color: #0E9F6E; border: 1px solid #A7DFC8; }
        .status-upcoming { background: #FBF1DC; color: #B07D1A; border: 1px solid #EDD28A; }
        .status-closed   { background: #FCEDEF; color: var(--red); border: 1px solid #F5C2C7; }

        .window-info { margin-bottom: 1rem; }
        .info-row { display: flex; padding: .7rem 0; border-bottom: 1px solid var(--row-border); }
        .info-row:last-child { border-bottom: none; }
        .info-label { flex: 0 0 200px; font-weight: 600; color: var(--muted); font-size: 13px; }
        .info-value { flex: 1; color: var(--text); font-size: 13px; }

        .window-actions { display: flex; gap: .75rem; margin-top: 1.25rem; flex-wrap: wrap; }

        /* Modal */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(43,35,32,.45); z-index: 1000; align-items: center; justify-content: center; }
        .modal.show { display: flex; }
        .modal-content { background: #fff; border-radius: 17px; border-top: 3px solid var(--red); width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; box-shadow: 0 24px 60px rgba(43,35,32,.2); }
        .modal-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--card-border); display: flex; justify-content: space-between; align-items: center; background: linear-gradient(180deg,#fff,#FCFAF6); border-radius: 14px 14px 0 0; }
        .modal-title { font-family: 'Josefin Sans', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--text); }
        .modal-close { background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--muted); transition: color .18s; }
        .modal-close:hover { color: var(--red); }
        .modal-body { padding: 1.5rem; }

        .form-group { margin-bottom: 1.25rem; }
        .form-label { display: block; margin-bottom: .4rem; font-size: 12.5px; font-weight: 700; color: var(--text); }
        .form-control {
            width: 100%; padding: 10px 14px; border: 1px solid var(--card-border);
            border-radius: 10px; font-size: 13px; color: var(--text);
            font-family: 'Josefin Sans', sans-serif; outline: none; transition: border .18s;
        }
        .form-control:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(200,16,46,.08); }

        /* Alerts */
        .alert { padding: .9rem 1.1rem; border-radius: 10px; margin-bottom: 1rem; font-size: 13px; }
        .alert-info    { background: #E9F0FE; color: #2563EB; border: 1px solid #AABEF8; }
        .alert-success { background: #E4F6EF; color: #0E9F6E; border: 1px solid #A7DFC8; }
        .alert-warning { background: #FBF1DC; color: #B07D1A; border: 1px solid #EDD28A; }

        .empty-state { text-align: center; padding: 3rem; color: var(--muted2); }
        .empty-state i { font-size: 4rem; margin-bottom: 1rem; opacity: .35; display: block; }
    </style>
</head>
<body>
    <%- include('navbar', { activeNav: 'allocation' }) %>

    <!-- Main content -->
    <div class="container">
        <div class="page-header">
            <h1><i class="fas fa-calendar-alt"></i> Quản Lý Đợt Đăng Ký</h1>
            <button class="btn btn-primary" onclick="showCreateModal()">
                <i class="fas fa-plus"></i> Tạo đợt mới
            </button>
        </div>

        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            Đợt đăng ký xác định thời gian sinh viên có thể đăng ký KTX. Chỉ có đợt đang "active" mới cho phép đăng ký. <strong>Hệ thống sẽ tự động tính điểm ưu tiên</strong> dựa trên diện ưu tiên, năm học và học lực của sinh viên.
        </div>

        <div id="windowsList" class="windows-grid"></div>
    </div>

    <!-- Create/Edit Modal -->
    <div id="windowModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="modalTitle">Tạo Đợt Đăng Ký Mới</h2>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="windowForm">
                    <div class="form-group">
                        <label class="form-label">Năm học <span style="color: red;">*</span></label>
                        <input type="text" class="form-control" id="academicYear"
                               placeholder="VD: 2025-2026" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Chính sách phân bổ</label>
                        <div id="activePolicyInfo" style="padding:10px 14px;background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;font-size:.9rem;color:#0369a1;">
                            <i class="fas fa-spinner fa-spin"></i> Đang tải chính sách hiện hành...
                        </div>
                        <small style="color:#6b7280;display:block;margin-top:6px;">
                            <i class="fas fa-info-circle"></i> Chính sách phân bổ được tự động lấy từ Quota đang ban hành. Để thay đổi, hãy ban hành Quota mới tại <a href="/admin/quotas">Quản lý Quota</a>.
                        </small>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Ngày bắt đầu <span style="color: red;">*</span></label>
                        <input type="datetime-local" class="form-control" id="startDate" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Ngày kết thúc <span style="color: red;">*</span></label>
                        <input type="datetime-local" class="form-control" id="endDate" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Trạng thái</label>
                        <select class="form-control" id="status">
                            <option value="PENDING">Sắp diễn ra</option>
                            <option value="RUNNING">Đang mở</option>
                            <option value="COMPLETED">Đã đóng</option>
                            <option value="CANCELLED">Đã hủy</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" id="description" rows="3"
                                  placeholder="Mô tả về đợt đăng ký..."></textarea>
                    </div>

                    <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                        <button type="button" class="btn btn-secondary" onclick="closeModal()">
                            Hủy
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Lưu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let windows = [];
        let editingWindowId = null;

        // Load windows on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadWindows();
            loadPublishedPolicy();

            // Handle form submission
            document.getElementById('windowForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                await saveWindow();
            });
        });

        // Load current published quota / active policy info
        async function loadPublishedPolicy() {
            try {
                const res = await fetch('/api/admin/published-quota');
                const data = await res.json();
                const el = document.getElementById('activePolicyInfo');
                if (!el) return;
                if (data.policy) {
                    el.innerHTML = `<i class="fas fa-check-circle" style="color:#16a34a"></i>
                        <strong>Chính sách hiện hành:</strong> Năm học ${data.policy.academicYear}
                        ${data.quota ? `(từ Quota <strong>${data.quota.academicYear}</strong> v${data.quota.version || ''})` : ''}
                        — <span style="color:#16a34a">Đang áp dụng</span>`;
                    el.style.background = '#f0fdf4';
                    el.style.borderColor = '#86efac';
                    el.style.color = '#15803d';
                } else {
                    el.innerHTML = `<i class="fas fa-exclamation-triangle" style="color:#d97706"></i>
                        <strong>Chưa có chính sách nào!</strong> Vui lòng <a href="/admin/quotas">ban hành Quota</a> trước khi tạo đợt đăng ký.`;
                    el.style.background = '#fffbeb';
                    el.style.borderColor = '#fcd34d';
                    el.style.color = '#92400e';
                }
            } catch (e) {
                const el = document.getElementById('activePolicyInfo');
                if (el) {
                    el.innerHTML = `<i class="fas fa-times-circle" style="color:#dc2626"></i> Không tải được chính sách`;
                    el.style.color = '#dc2626';
                }
            }
        }

        // Load academic windows
        async function loadWindows() {
            try {
                const response = await fetch('/api/admin/academic-windows');
                
                if (!response.ok) {
                    console.error('🔴 Response not OK:', response.status, response.statusText);
                    throw new Error('Failed to fetch windows');
                }
                
                const data = await response.json();
                
                windows = Array.isArray(data) ? data : (data.windows || data.data || []);
                
                renderWindows();
            } catch (error) {
                console.error('🔴 Error loading windows:', error);
                const container = document.getElementById('windowsList');
                if (container) {
                    container.innerHTML = `
                        <div class="empty-state">
                            <i class="fas fa-exclamation-circle"></i>
                            <h3>Lỗi tải dữ liệu</h3>
                            <p>${error.message}</p>
                            <p style="color: red; font-size: 12px;">Kiểm tra console để xem chi tiết lỗi</p>
                        </div>
                    `;
                }
            }
        }

        // Render windows list
        function renderWindows() {
            const container = document.getElementById('windowsList');
            
            if (!container) {
                console.error('🔴 Container not found');
                return;
            }
            
            try {
                
                if (!windows || windows.length === 0) {
                    container.innerHTML = `
                        <div class="empty-state">
                            <i class="fas fa-calendar-times"></i>
                            <h3>Chưa có đợt đăng ký nào</h3>
                            <p>Tạo đợt đăng ký mới để sinh viên có thể đăng ký KTX</p>
                        </div>
                    `;
                    return;
                }

                const html = windows.map((window, idx) => {
                    try {
                        const startDate = new Date(window.registrationStart);
                        const endDate = new Date(window.registrationEnd);
                        const now = new Date();

                        let statusClass = 'status-upcoming';
                        let statusText = 'Sắp diễn ra';

                        if (window.status === 'RUNNING') {
                            statusClass = 'status-active';
                            statusText = 'Đang mở';
                        } else if (window.status === 'COMPLETED' || window.status === 'CANCELLED' || endDate < now) {
                            statusClass = 'status-closed';
                            statusText = window.status === 'CANCELLED' ? 'Đã hủy' : 'Đã đóng';
                        }

                        // Priority statistics
                        const priorityStats = window.priorityStats || { dantoc: 0, hongho: 0, khuyettat: 0, mocoι: 0, total: 0 };
                        const priorityHtml = priorityStats.total > 0
                            ? `<div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                ${priorityStats.dantoc > 0 ? `<span class="badge bg-success">Dân tộc: ${priorityStats.dantoc}</span>` : ''}
                                ${priorityStats.hongho > 0 ? `<span class="badge bg-info">Hộ nghèo: ${priorityStats.hongho}</span>` : ''}
                                ${priorityStats.khuyettat > 0 ? `<span class="badge bg-warning">Khuyết tật: ${priorityStats.khuyettat}</span>` : ''}
                                ${priorityStats.mocoι > 0 ? `<span class="badge bg-danger">Mồ côi: ${priorityStats.mocoι}</span>` : ''}
                            </div>`
                            : '<span class="text-muted">-</span>';

                        return `
                            <div class="window-card">
                                <div class="window-header">
                                    <div class="window-title">${window.academicYear || 'N/A'}</div>
                                    <span class="window-status ${statusClass}">${statusText}</span>
                                </div>
                                <div class="window-info">
                                    <div class="info-row">
                                        <div class="info-label">Thời gian bắt đầu:</div>
                                        <div class="info-value">${formatDate(startDate)}</div>
                                    </div>
                                    <div class="info-row">
                                        <div class="info-label">Thời gian kết thúc:</div>
                                        <div class="info-value">${formatDate(endDate)}</div>
                                    </div>
                                    <div class="info-row">
                                        <div class="info-label">Diện ưu tiên:</div>
                                        <div class="info-value">${priorityHtml}</div>
                                    </div>
                                    <div class="info-row">
                                        <div class="info-label">Chính sách áp dụng:</div>
                                        <div class="info-value">${
                                            window.currentPolicy
                                                ? `<span style="color:#16a34a"><i class="fas fa-check-circle"></i> Năm học ${window.currentPolicy.academicYear}</span>`
                                                : '<span style="color:#d97706"><i class="fas fa-exclamation-triangle"></i> Chưa có chính sách</span>'
                                        }</div>
                                    </div>
                                    ${window.description ? `
                                        <div class="info-row">
                                            <div class="info-label">Mô tả:</div>
                                            <div class="info-value">${window.description}</div>
                                        </div>
                                    ` : ''}
                                </div>
                                <div class="window-actions">
                                    ${window.status !== 'RUNNING' ? `
                                        <button class="btn btn-sm btn-success" onclick="activateWindow('${window._id}')">
                                            <i class="fas fa-check-circle"></i> Kích hoạt
                                        </button>
                                    ` : `
                                        <button class="btn btn-sm btn-danger" onclick="deactivateWindow('${window._id}')">
                                            <i class="fas fa-times-circle"></i> Đóng đăng ký
                                        </button>
                                    `}
                                    <button class="btn btn-sm btn-secondary" onclick="editWindow('${window._id}')">
                                        <i class="fas fa-edit"></i> Sửa
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteWindow('${window._id}')">
                                        <i class="fas fa-trash"></i> Xóa
                                    </button>
                                </div>
                            </div>
                        `;
                    } catch (itemError) {
                        console.error('🔴 Error rendering window item:', itemError, window);
                        return `
                            <div class="window-card" style="background: #fef2f2; border: 2px solid #fecaca;">
                                <div style="padding: 1rem; color: #991b1b;">
                                    <i class="fas fa-exclamation-circle"></i> Lỗi hiển thị dữ liệu
                                    <br><small>${itemError.message}</small>
                                </div>
                            </div>
                        `;
                    }
                }).join('');
                
                container.innerHTML = html;
            } catch (error) {
                console.error('🔴 Error rendering windows:', error);
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-circle"></i>
                        <h3>Lỗi hiển thị</h3>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        // Format date
        function formatDate(date) {
            try {
                if (!date) return 'Không xác định';
                const d = new Date(date);
                if (isNaN(d.getTime())) return 'Không xác định';
                const options = { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                };
                return d.toLocaleDateString('vi-VN', options);
            } catch (e) {
                return 'Không xác định';
            }
        }

        // Show create modal
        function showCreateModal() {
            editingWindowId = null;
            document.getElementById('modalTitle').textContent = 'Tạo Đợt Đăng Ký Mới';
            document.getElementById('windowForm').reset();
            
            // Set default values
            const now = new Date();
            const later = new Date(now.getTime() + (90 * 24 * 60 * 60 * 1000)); // 3 months later
            
            document.getElementById('startDate').value = formatDateTimeLocal(now);
            document.getElementById('endDate').value = formatDateTimeLocal(later);
            document.getElementById('status').value = 'PENDING';
            
            document.getElementById('windowModal').classList.add('show');
        }

        // Edit window
        function editWindow(id) {
            const window = windows.find(w => w._id === id);
            if (!window) return;

            editingWindowId = id;
            document.getElementById('modalTitle').textContent = 'Chỉnh Sửa Đợt Đăng Ký';

            document.getElementById('academicYear').value = window.academicYear;
            document.getElementById('startDate').value = formatDateTimeLocal(new Date(window.registrationStart));
            document.getElementById('endDate').value = formatDateTimeLocal(new Date(window.registrationEnd));
            document.getElementById('status').value = window.status;
            document.getElementById('description').value = window.description || '';
            
            document.getElementById('windowModal').classList.add('show');
        }

        // Close modal
        function closeModal() {
            document.getElementById('windowModal').classList.remove('show');
            editingWindowId = null;
        }

        // Save window
        async function saveWindow() {
            // policyId is auto-assigned on the backend from the active AllocationPolicy
            const data = {
                academicYear: document.getElementById('academicYear').value,
                startDate: document.getElementById('startDate').value,
                endDate: document.getElementById('endDate').value,
                status: document.getElementById('status').value,
                description: document.getElementById('description').value
            };

            try {
                const url = editingWindowId 
                    ? `/api/admin/academic-windows/${editingWindowId}`
                    : '/api/admin/academic-windows';
                    
                const method = editingWindowId ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (!response.ok) throw new Error('Failed to save window');

                closeModal();
                await loadWindows();
                
                alert(editingWindowId ? 'Cập nhật thành công!' : 'Tạo đợt mới thành công!');
            } catch (error) {
                console.error('Error saving window:', error);
                alert('Có lỗi xảy ra khi lưu dữ liệu');
            }
        }

        // Activate window
        async function activateWindow(id) {
            if (!confirm('Kích hoạt đợt đăng ký này?')) return;

            try {
                const response = await fetch(`/api/admin/academic-windows/${id}/activate`, {
                    method: 'POST'
                });

                const data = await response.json();
                
                if (!response.ok) {
                    if (response.status === 400 && data.error) {
                        alert(data.error);
                    } else {
                        throw new Error('Failed to activate');
                    }
                    return;
                }

                await loadWindows();
                alert('Đã kích hoạt đợt đăng ký!');
            } catch (error) {
                console.error('Error activating window:', error);
                alert('Có lỗi xảy ra');
            }
        }

        // Deactivate window
        async function deactivateWindow(id) {
            if (!confirm('Đóng đợt đăng ký này?')) return;

            try {
                const response = await fetch(`/api/admin/academic-windows/${id}/deactivate`, {
                    method: 'POST'
                });

                if (!response.ok) throw new Error('Failed to deactivate');

                await loadWindows();
                alert('Đã đóng đợt đăng ký!');
            } catch (error) {
                console.error('Error deactivating window:', error);
                alert('Có lỗi xảy ra');
            }
        }

        // Delete window
        async function deleteWindow(id) {
            if (!confirm('Xóa đợt đăng ký này? Thao tác không thể hoàn tác!')) return;

            try {
                const response = await fetch(`/api/admin/academic-windows/${id}`, {
                    method: 'DELETE'
                });

                if (!response.ok) throw new Error('Failed to delete');

                await loadWindows();
                alert('Đã xóa đợt đăng ký!');
            } catch (error) {
                console.error('Error deleting window:', error);
                alert('Có lỗi xảy ra');
            }
        }

        // Format datetime for input
        function formatDateTimeLocal(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');
            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }
    </script>
    <%- include('footer') %>
</body>
</html>
