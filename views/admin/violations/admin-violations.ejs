﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Vi phạm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --red: #C8102E;
            --red-grad: linear-gradient(135deg,#E11D2A,#B20C26);
            --body-bg: linear-gradient(180deg,#FBF8F3,#F5EFE7);
            --card-bg: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            --card-border: #EFE8DF;
            --card-shadow: 0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);
            --text: #2B2320; --muted: #7C7166; --muted2: #A89C8E;
            --th-bg: #F7F1E8; --th-color: #9A8F84;
            --row-alt: #FDFBF8; --row-border: #F4EEE5; --row-hover: #FAF5EE;
        }

        body { font-family: 'Inter', system-ui, sans-serif; background: var(--body-bg); color: var(--text); margin: 0; padding: 0; }
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }

        /* ── Header ── */
        .header {
            background: var(--card-bg);
            padding: 20px 28px; border-radius: 17px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow);
            margin-bottom: 28px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .header h1 {
            font-family: 'Inter', sans-serif;
            font-size: 1.3rem; font-weight: 700; color: var(--text);
            display: flex; align-items: center; gap: 10px; margin: 0;
        }
        .header-actions { display: flex; gap: 10px; }

        /* ── Buttons ── */
        .btn {
            padding: 9px 20px; border: none; border-radius: 11px;
            cursor: pointer; font-size: 13.5px; font-weight: 600;
            transition: all .2s; text-decoration: none;
            display: inline-flex; align-items: center; gap: 8px;
            font-family: 'Inter', sans-serif;
        }
        .btn-primary {
            background: var(--red-grad) !important; color: #fff !important;
            box-shadow: 0 10px 24px -10px rgba(200,16,46,.65) !important;
            border: none !important;
        }
        .btn-primary:hover { transform: translateY(-1px) !important; box-shadow: 0 14px 28px -10px rgba(200,16,46,.75) !important; background: var(--red-grad) !important; }
        .btn-secondary { background: #fff !important; border: 1px solid #E7DECF !important; color: var(--text) !important; }
        .btn-secondary:hover { background: #FBF8F3 !important; border-color: #D4C9BC !important; }

        /* ── Stats ── */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(240px,1fr)); gap: 20px; margin-bottom: 28px; }
        .stat-card {
            background: var(--card-bg); padding: 22px 26px;
            border-radius: 17px; border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow); transition: transform .25s, box-shadow .25s;
        }
        .stat-card:hover { transform: translateY(-2px); box-shadow: 0 1px 2px rgba(43,35,32,.04),0 28px 44px -22px rgba(43,35,32,.28); }
        .stat-card:nth-child(1) { border-top: 3px solid #D9A22B; }
        .stat-card:nth-child(2) { border-top: 3px solid #0E9F6E; }
        .stat-card:nth-child(3) { border-top: 3px solid #C8102E; }
        .stat-value { font-family: 'Inter', sans-serif; font-size: 36px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
        .stat-card:nth-child(1) .stat-value { color: #D9A22B; }
        .stat-card:nth-child(2) .stat-value { color: #0E9F6E; }
        .stat-card:nth-child(3) .stat-value { color: #C8102E; }
        .stat-label { font-size: 10.5px; color: var(--th-color); text-transform: uppercase; letter-spacing: .08em; font-weight: 700; }

        /* ── Filters ── */
        .filters-card {
            background: var(--card-bg); padding: 18px 24px;
            border-radius: 16px; border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow); margin-bottom: 20px;
        }
        .filters-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap: 14px; }

        .form-select, .form-control {
            padding: 9px 14px; border: 1px solid var(--card-border) !important;
            border-radius: 10px !important; font-size: 13px !important;
            color: var(--text) !important; transition: all .18s !important;
            box-shadow: none !important; font-family: 'Inter', sans-serif !important;
        }
        .form-select:focus, .form-control:focus {
            border-color: var(--red) !important;
            box-shadow: 0 0 0 3px rgba(200,16,46,.08) !important;
            outline: none !important;
        }

        /* ── Table ── */
        .table-container {
            background: var(--card-bg); border-radius: 17px;
            border: 1px solid var(--card-border);
            box-shadow: var(--card-shadow); overflow: hidden; margin-bottom: 28px;
        }
        .custom-table { width: 100%; border-collapse: collapse; font-family: 'Inter', sans-serif; font-size: 13.5px; }
        .custom-table thead { background: var(--th-bg); }
        .custom-table thead th {
            padding: 13px 15px; text-align: left;
            font-weight: 700; color: var(--th-color);
            font-size: 10.5px; text-transform: uppercase; letter-spacing: .07em;
            border-bottom: 1px solid var(--row-border);
        }
        .custom-table tbody tr { border-bottom: 1px solid var(--row-border); transition: background .15s; }
        .custom-table tbody tr:nth-child(even) { background: var(--row-alt); }
        .custom-table tbody tr:hover { background: var(--row-hover); }
        .custom-table tbody td { padding: 13px 15px; vertical-align: middle; color: var(--text); }

        .user-cell { display: flex; align-items: center; gap: 12px; }
        .avatar-placeholder {
            width: 38px; height: 38px; border-radius: 50%;
            background: var(--red-grad); color: #fff;
            font-weight: 700; font-size: .88rem;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .user-info { display: flex; flex-direction: column; }
        .user-name { font-weight: 600; color: var(--text); margin-bottom: 2px; }
        .user-id { font-size: .82rem; color: var(--muted); }

        /* ── Severity/Status badges ── */
        .badge-custom { padding: 3px 11px; border-radius: 20px; font-size: .75rem; font-weight: 700; display: inline-block; }
        .severity-low      { background: #F4EFE8; color: #7C7166; border: 1px solid #E0D8CF; }
        .severity-medium   { background: #E9F0FE; color: #2563EB; border: 1px solid #AABEF8; }
        .severity-high     { background: #FBF1DC; color: #B07D1A; border: 1px solid #EDD28A; }
        .severity-critical { background: var(--red-grad); color: #fff; box-shadow: 0 4px 10px -4px rgba(200,16,46,.45); }
        .status-pending    { background: #FBF1DC; color: #B07D1A; border: 1px solid #EDD28A; }
        .status-resolved   { background: #E4F6EF; color: #0E9F6E; border: 1px solid #A7DFC8; }
        .status-dismissed  { background: #F4EFE8; color: #7C7166; border: 1px solid #E0D8CF; }

        /* ── Action buttons ── */
        .action-btns { display: flex; gap: 8px; }
        .btn-icon { width: 34px; height: 34px; border-radius: 9px; border: none; display: flex; align-items: center; justify-content: center; transition: all .2s; cursor: pointer; font-size: .88rem; }
        .btn-view { background: #F4EFE8; color: var(--muted); }
        .btn-view:hover { background: #EFE8DF; color: var(--text); transform: scale(1.08); }
        .btn-delete { background: #FCEDEF; color: #C8102E; }
        .btn-delete:hover { background: var(--red-grad); color: #fff; transform: scale(1.08); }

        /* ── Pagination ── */
        .pagination { margin-top: 20px; gap: 6px; }
        .page-item .page-link { border: 1px solid var(--card-border) !important; border-radius: 8px !important; padding: 7px 14px; color: var(--text) !important; font-weight: 500; transition: all .2s; background: #fff !important; font-size: 13px !important; }
        .page-item.active .page-link { background: var(--red-grad) !important; border-color: var(--red) !important; color: #fff !important; box-shadow: 0 6px 14px -6px rgba(200,16,46,.55) !important; }
        .page-item .page-link:hover { background: #FBF8F3 !important; color: var(--text) !important; }

        /* ── Loading ── */
        .loading-spinner { text-align: center; padding: 40px; }
        .spinner-border { color: var(--red) !important; }

        /* ── Modal ── */
        .modal-content { border-radius: 17px !important; border: 1px solid var(--card-border) !important; border-top: 3px solid var(--red) !important; box-shadow: 0 24px 60px rgba(43,35,32,.18) !important; }
        .modal-header { background: linear-gradient(180deg,#fff,#FCFAF6) !important; border-bottom: 1px solid var(--card-border) !important; border-radius: 14px 14px 0 0 !important; padding: 18px 24px !important; }
        .modal-title { font-family: 'Inter', sans-serif !important; font-weight: 700 !important; color: var(--text) !important; }
        .modal-body { padding: 22px 24px !important; }
        .modal-footer { border-top: 1px solid var(--card-border) !important; padding: 14px 24px !important; }

        @media (max-width: 768px) {
            .container { padding: 10px; }
            .header { flex-direction: column; gap: 15px; }
            .stats-grid { grid-template-columns: 1fr; }
            .filters-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <%- include('../navbar', { activeNav: 'violations' }) %>

    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>
                <i class="fas fa-shield-alt" style="color: #e74c3c;"></i>
                Quản lý Vi phạm
            </h1>
            <div class="header-actions">
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addViolationModal">
                    <i class="fas fa-plus"></i>
                    Báo cáo vi phạm
                </button>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value" id="statPending">0</div>
                <div class="stat-label">Chờ xử lý</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="statResolved">0</div>
                <div class="stat-label">Đã xử lý</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="statCritical">0</div>
                <div class="stat-label">Vi phạm nghiêm trọng</div>
            </div>
        </div>

        <!-- Filters -->
        <div class="filters-card">
            <div class="filters-grid">
                <select class="form-select" id="filterStatus">
                    <option value="">Tất cả trạng thái</option>
                    <option value="pending">Chờ xử lý</option>
                    <option value="resolved">Đã xử lý</option>
                    <option value="dismissed">Đã bỏ qua</option>
                </select>
                <select class="form-select" id="filterSeverity">
                    <option value="">Tất cả mức độ</option>
                    <option value="low">Nhẹ</option>
                    <option value="medium">Trung bình</option>
                    <option value="high">Nghiêm trọng</option>
                    <option value="critical">Rất nghiêm trọng</option>
                </select>
                <select class="form-select" id="filterType">
                    <option value="">Tất cả loại</option>
                    <option value="noise">Ồn ào</option>
                    <option value="alcohol">Rượu bia</option>
                    <option value="smoking">Hút thuốc</option>
                    <option value="late_return">Về muộn</option>
                    <option value="unauthorized_guest">Khách không phép</option>
                    <option value="damage">Hư hỏng tài sản</option>
                    <option value="hygiene">Vi phạm vệ sinh</option>
                    <option value="theft">Trộm cắp</option>
                    <option value="violence">Bạo lực</option>
                    <option value="other">Khác</option>
                </select>
                <input type="text" class="form-control" id="filterSearch" placeholder="Tìm theo MSSV hoặc tên...">
            </div>
        </div>

        <!-- Table -->
        <div class="table-container">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Sinh viên</th>
                        <th>Loại vi phạm</th>
                        <th>Mức độ</th>
                        <th>Trạng thái</th>
                        <th>Ngày báo cáo</th>
                        <th style="width: 120px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="violationsTable">
                    <tr>
                        <td colspan="6" class="loading-spinner">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <nav>
            <ul class="pagination justify-content-center" id="pagination"></ul>
        </nav>
    </div>

    <!-- Add Violation Modal -->
    <div class="modal fade" id="addViolationModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Báo cáo vi phạm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addViolationForm">
                        <div class="mb-3">
                            <label class="form-label">Mã sinh viên *</label>
                            <input type="text" class="form-control" name="studentId" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Loại vi phạm *</label>
                            <select class="form-select" name="type" required>
                                <option value="">-- Chọn loại vi phạm --</option>
                                <option value="noise">Ồn ào</option>
                                <option value="alcohol">Rượu bia</option>
                                <option value="smoking">Hút thuốc</option>
                                <option value="late_return">Về muộn</option>
                                <option value="unauthorized_guest">Khách không phép</option>
                                <option value="damage">Hư hỏng tài sản</option>
                                <option value="hygiene">Vi phạm vệ sinh</option>
                                <option value="theft">Trộm cắp</option>
                                <option value="violence">Bạo lực</option>
                                <option value="other">Khác</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mức độ nghiêm trọng *</label>
                            <select class="form-select" name="severity" required>
                                <option value="low">Nhẹ</option>
                                <option value="medium" selected>Trung bình</option>
                                <option value="high">Nghiêm trọng</option>
                                <option value="critical">Rất nghiêm trọng</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mô tả chi tiết *</label>
                            <textarea class="form-control" name="description" rows="4" required></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" onclick="submitViolation()">Báo cáo</button>
                </div>
            </div>
        </div>
    </div>

    <!-- View/Resolve Modal -->
    <div class="modal fade" id="viewViolationModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Chi tiết vi phạm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="violationDetails">
                    <!-- Content loaded via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Resolve Violation Modal -->
    <div class="modal fade" id="resolveViolationModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Xử lý vi phạm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="resolveViolationForm">
                        <div class="mb-3">
                            <label class="form-label">Hành động xử lý *</label>
                            <select class="form-select" name="action" required>
                                <option value="">-- Chọn hành động --</option>
                                <option value="warning">Cảnh cáo</option>
                                <option value="suspension">Tạm đình chỉ</option>
                                <option value="expulsion">Khai trừ</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Ghi chú</label>
                            <textarea class="form-control" name="notes" rows="4" placeholder="Ghi chú chi tiết về xử lý..."></textarea>
                        </div>
                        <input type="hidden" name="violationId" id="resolveViolationId">
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" onclick="submitResolution()">Xác nhận xử lý</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let currentPage = 1;
        let currentFilters = {};

        async function loadViolations() {
            const params = new URLSearchParams({
                page: currentPage,
                limit: 20,
                ...currentFilters
            });

            try {
                const response = await fetch(`/api/admin/violations?${params}`);
                const data = await response.json();

                if (data.success) {
                    renderTable(data.violations);
                    renderPagination(data.pagination);
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        async function loadStats() {
            try {
                const response = await fetch('/api/admin/violations/stats/summary');
                const data = await response.json();
                

                if (data.success) {
                    const stats = data.stats;
                    
                    
                    const statusMap = stats.byStatus.reduce((acc, item) => {
                        acc[item._id] = item.count;
                        return acc;
                    }, {});
                    
                    const severityMap = stats.bySeverity.reduce((acc, item) => {
                        acc[item._id] = item.count;
                        return acc;
                    }, {});


                    document.getElementById('statPending').textContent = statusMap.pending || 0;
                    document.getElementById('statResolved').textContent = statusMap.resolved || 0;
                    document.getElementById('statCritical').textContent = severityMap.critical || 0;
                    
                } else {
                    console.error('Stats error:', data);
                }
            } catch (error) {
                console.error('Error loading stats:', error);
            }
        }

        function getInitials(name) {
            return name
                .split(' ')
                .map(word => word[0])
                .join('')
                .toUpperCase()
                .slice(0, 2);
        }

        function renderTable(violations) {
            const tbody = document.getElementById('violationsTable');
            
            if (violations.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="loading-spinner" style="padding: 3rem; color: #999;">Không có dữ liệu</td></tr>';
                return;
            }

            tbody.innerHTML = violations.map(v => `
                <tr>
                    <td>
                        <div class="user-cell">
                            <div class="avatar-placeholder">${getInitials(v.studentName)}</div>
                            <div class="user-info">
                                <span class="user-name">${v.studentName}</span>
                                <span class="user-id">${v.studentId}</span>
                            </div>
                        </div>
                    </td>
                    <td>${getTypeLabel(v.type)}</td>
                    <td><span class="badge-custom severity-${v.severity}">${getSeverityLabel(v.severity)}</span></td>
                    <td><span class="badge-custom status-${v.status}">${getStatusLabel(v.status)}</span></td>
                    <td>${new Date(v.reportedAt).toLocaleDateString('vi-VN')}</td>
                    <td>
                        <div class="action-btns">
                            <button class="btn-icon btn-view" onclick="viewViolation('${v._id}')" title="Xem chi tiết">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button class="btn-icon btn-delete" onclick="deleteViolation('${v._id}')" title="Xóa">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function renderPagination(pagination) {
            const nav = document.getElementById('pagination');
            let html = '';

            for (let i = 1; i <= pagination.pages; i++) {
                html += `
                    <li class="page-item ${i === pagination.page ? 'active' : ''}">
                        <a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>
                    </li>
                `;
            }

            nav.innerHTML = html;
        }

        function changePage(page) {
            currentPage = page;
            loadViolations();
        }

        function getTypeLabel(type) {
            const labels = {
                noise: 'Ồn ào', alcohol: 'Rượu bia', smoking: 'Hút thuốc',
                late_return: 'Về muộn', unauthorized_guest: 'Khách không phép',
                damage: 'Hư hỏng', hygiene: 'Vệ sinh', theft: 'Trộm cắp',
                violence: 'Bạo lực', other: 'Khác'
            };
            return labels[type] || type;
        }

        function getSeverityLabel(severity) {
            const labels = { low: 'Nhẹ', medium: 'TB', high: 'Nghiêm trọng', critical: 'Rất nghiêm trọng' };
            return labels[severity] || severity;
        }

        function getStatusLabel(status) {
            const labels = { pending: 'Chờ xử lý', resolved: 'Đã xử lý', dismissed: 'Bỏ qua' };
            return labels[status] || status;
        }

        async function submitViolation() {
            const form = document.getElementById('addViolationForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);


            try {
                const response = await fetch('/api/admin/violations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    alert('✓ Đã báo cáo vi phạm thành công');
                    bootstrap.Modal.getInstance(document.getElementById('addViolationModal')).hide();
                    form.reset();
                    loadViolations();
                    loadStats();
                } else {
                    let errorMsg = result.error || 'Lỗi không xác định';
                    if (result.errors && Array.isArray(result.errors)) {
                        errorMsg = result.errors.map(e => `${e.field}: ${e.message}`).join('\n');
                    }
                    console.error('Validation errors:', errorMsg);
                    alert('✗ Lỗi:\n' + errorMsg);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('✗ Lỗi hệ thống: ' + error.message);
            }
        }

        async function viewViolation(id) {
            try {
                const response = await fetch(`/api/admin/violations/${id}`);
                const data = await response.json();

                if (data.success) {
                    const v = data.violation;
                    document.getElementById('violationDetails').innerHTML = `
                        <div class="user-cell mb-4">
                            <div class="avatar-placeholder" style="width: 60px; height: 60px; font-size: 1.3rem;">${getInitials(v.studentName)}</div>
                            <div class="user-info">
                                <h5 class="mb-1">${v.studentName}</h5>
                                <span class="user-id">${v.studentId} • Phòng ${v.roomNumber || 'N/A'}</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <strong>Loại:</strong> ${getTypeLabel(v.type)}<br>
                            <strong>Mức độ:</strong> <span class="badge-custom severity-${v.severity}">${getSeverityLabel(v.severity)}</span><br>
                            <strong>Trạng thái:</strong> <span class="badge-custom status-${v.status}">${getStatusLabel(v.status)}</span>
                        </div>
                        <div class="mb-3">
                            <strong>Mô tả:</strong><br>
                            <p style="margin-top: 0.5rem; line-height: 1.6;">${v.description}</p>
                        </div>
                        <div class="mb-3">
                            <strong>Báo cáo bởi:</strong> ${v.reportedBy.name}<br>
                            <strong>Thời gian:</strong> ${new Date(v.reportedAt).toLocaleString('vi-VN')}
                        </div>
                        ${v.status === 'pending' ? `
                            <div style="display: flex; gap: 10px; margin-top: 20px;">
                                <button class="btn btn-primary" onclick="resolveViolation('${v._id}')">
                                    <i class="fas fa-check"></i> Xử lý
                                </button>
                                <button class="btn btn-secondary" onclick="updateStatus('${v._id}', 'dismissed')">
                                    <i class="fas fa-times"></i> Bỏ qua
                                </button>
                            </div>
                        ` : ''}
                    `;

                    new bootstrap.Modal(document.getElementById('viewViolationModal')).show();
                }
            } catch (error) {
                console.error('Error:', error);
                alert('✗ Lỗi khi tải chi tiết vi phạm');
            }
        }

        async function updateStatus(id, status) {
            try {
                
                const response = await fetch(`/api/admin/violations/${id}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });

                const data = await response.json();

                if (data.success) {
                    alert('✓ Đã cập nhật trạng thái thành công');
                    bootstrap.Modal.getInstance(document.getElementById('viewViolationModal')).hide();
                    loadViolations();
                    loadStats();
                } else {
                    let errorMsg = data.error || 'Lỗi không xác định';
                    if (data.errors && Array.isArray(data.errors)) {
                        errorMsg = data.errors.map(e => `${e.field}: ${e.message}`).join('\n');
                    }
                    console.error('Error response:', errorMsg);
                    alert('✗ Lỗi:\n' + errorMsg);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('✗ Lỗi hệ thống: ' + error.message);
            }
        }

        async function resolveViolation(id) {
            document.getElementById('resolveViolationId').value = id;
            bootstrap.Modal.getInstance(document.getElementById('viewViolationModal')).hide();
            new bootstrap.Modal(document.getElementById('resolveViolationModal')).show();
        }

        async function submitResolution() {
            const form = document.getElementById('resolveViolationForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);
            const violationId = data.violationId;

            try {
                const response = await fetch(`/api/admin/violations/${violationId}/resolve`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        action: data.action, 
                        notes: data.notes 
                    })
                });

                const result = await response.json();

                if (result.success) {
                    alert('✓ Đã xử lý vi phạm thành công');
                    bootstrap.Modal.getInstance(document.getElementById('resolveViolationModal')).hide();
                    form.reset();
                    loadViolations();
                    loadStats();
                } else {
                    let errorMsg = result.error || 'Lỗi không xác định';
                    if (result.errors && Array.isArray(result.errors)) {
                        errorMsg = result.errors.map(e => `${e.field}: ${e.message}`).join('\n');
                    }
                    alert('✗ Lỗi:\n' + errorMsg);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('✗ Lỗi hệ thống: ' + error.message);
            }
        }

        async function deleteViolation(id) {
            if (!confirm('⚠️ Bạn chắc chắn muốn xóa vi phạm này?\n\nHành động này không thể hoàn tác.')) {
                return;
            }

            try {
                
                const response = await fetch(`/api/admin/violations/${id}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });

                const data = await response.json();

                if (data.success) {
                    alert('✓ Đã xóa vi phạm thành công');
                    loadViolations();
                    loadStats();
                } else {
                    alert('✗ Lỗi: ' + (data.error || 'Không thể xóa vi phạm'));
                }
            } catch (error) {
                console.error('Error:', error);
                alert('✗ Lỗi hệ thống: ' + error.message);
            }
        }

        // Event listeners for filters
        document.getElementById('filterStatus').addEventListener('change', (e) => {
            currentFilters.status = e.target.value;
            currentPage = 1;
            loadViolations();
        });

        document.getElementById('filterSeverity').addEventListener('change', (e) => {
            currentFilters.severity = e.target.value;
            currentPage = 1;
            loadViolations();
        });

        document.getElementById('filterType').addEventListener('change', (e) => {
            currentFilters.type = e.target.value;
            currentPage = 1;
            loadViolations();
        });

        document.getElementById('filterSearch').addEventListener('input', (e) => {
            currentFilters.studentId = e.target.value;
            currentPage = 1;
            loadViolations();
        });

        // Load initial data
        loadViolations();
        loadStats();
    </script>
    <%- include('../footer') %>
</body>
</html>
