<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quota - Quản trị</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;}
    body{font-family:'Josefin Sans',system-ui,sans-serif;background:linear-gradient(180deg,#FBF8F3,#F5EFE7);min-height:100vh;margin:0;color:#2B2320;}
    body::before{content:'';position:fixed;inset:0;background:radial-gradient(1100px 560px at 88% -8%,rgba(225,29,42,.07),transparent 58%),radial-gradient(820px 480px at -8% 6%,rgba(185,138,42,.09),transparent 56%);pointer-events:none;z-index:0;}
    .container{max-width:1240px;margin:0 auto;padding:0 18px 28px;position:relative;z-index:1;}
    .toolbar{display:flex;justify-content:space-between;align-items:center;margin:20px 0 16px;gap:12px;background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border:1px solid #EFE8DF;border-radius:16px;padding:16px 20px;box-shadow:0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);}
    .toolbar h1{margin:0;font-family:'Josefin Sans',sans-serif;font-size:1.5rem;font-weight:600;color:#2B2320;}
    .toolbar-actions{display:flex;gap:8px;flex-wrap:wrap;}
    .btn{border:none;border-radius:11px;padding:9px 14px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;font-size:.84rem;font-family:'Josefin Sans',sans-serif;font-weight:600;transition:all .18s;}
    .btn-primary{background:linear-gradient(135deg,#E11D2A,#B20C26);color:#fff;box-shadow:0 4px 12px rgba(200,16,46,.25);}
    .btn-primary:hover{filter:brightness(1.05);transform:translateY(-1px);}
    .btn-secondary{background:#fff;color:#7C7166;border:1.5px solid #E7DECF;}
    .btn-secondary:hover{background:#FBF8F3;border-color:#C8102E;color:#C8102E;}
    .btn-warning{background:linear-gradient(135deg,#E8A320,#C8102E);color:#fff;box-shadow:0 4px 12px rgba(216,162,43,.25);}
    .btn-warning:hover{filter:brightness(1.05);transform:translateY(-1px);}
    .btn-success{background:linear-gradient(135deg,#12B981,#0E9F6E);color:#fff;box-shadow:0 4px 12px rgba(14,159,110,.25);}
    .btn-success:hover{filter:brightness(1.05);transform:translateY(-1px);}
    .btn-soft{background:#FBF8F3;color:#7C7166;border:1.5px solid #EFE8DF;}
    .btn-soft:hover{background:#F7F1E8;border-color:#C8102E;color:#C8102E;}
    .message{padding:12px 16px;border-radius:12px;margin-bottom:16px;font-size:.875rem;}
    .message.success{background:#F7F1E8;color:#2B2320;border:1px solid #EFE8DF;}
    .message.error{background:#FDE8EA;color:#9E0C24;border:1px solid #F4ABAF;}
    .card{background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border:1px solid #EFE8DF;border-radius:16px;overflow:hidden;box-shadow:0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);}
    table{width:100%;border-collapse:collapse;}
    th,td{padding:11px 14px;border-bottom:1px solid #F4EEE5;text-align:left;vertical-align:top;}
    th{background:#F7F1E8;font-size:.655rem;color:#9A8F84;font-weight:700;text-transform:uppercase;letter-spacing:.06em;}
    tr:nth-child(even) td{background:#FDFBF8;}
    tr:hover td{background:#FAF5EE;}
    .status{padding:4px 10px;border-radius:999px;font-size:.73rem;font-weight:700;}
    .status.draft{background:#FBF1DC;color:#D9A22B;}
    .status.published{background:#FDE8EA;color:#C8102E;}
    .quota-line{font-size:.82rem;color:#7C7166;line-height:1.6;}
    .actions{display:flex;flex-wrap:wrap;gap:6px;margin-top:2px;}
    .small{font-size:.75rem;color:#A89C8E;margin-top:4px;}
    details.advanced{margin-top:10px;}
    details.advanced summary{cursor:pointer;font-size:.8rem;color:#C8102E;font-weight:600;}
    .advanced-links{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}
  </style>
</head>
<body>
  <%- include('../navbar', { activeNav: activeNav }) %>

  <div class="container">
    <div class="toolbar">
      <h1>Quota ký túc xá</h1>
      <div class="toolbar-actions">
        <a class="btn btn-secondary" href="/admin/quotas/audit"><i class="fas fa-history"></i> Lịch sử thao tác</a>
      <% if (canManage) { %>
          <a class="btn btn-primary" href="/admin/quotas/create"><i class="fas fa-plus"></i> Tạo bản nháp</a>
      <% } %>
      </div>
    </div>

    <% if (!canManage) { %>
      <div class="message" style="background:#fffbeb;border:1px solid #fcd34d;color:#92400e;margin-bottom:14px">
        <i class="fas fa-shield-alt"></i> <strong>Chế độ xem:</strong> Bạn đang xem với quyền Admin thường. Để tạo, sửa hoặc ban hành quota, đăng nhập bằng tài khoản <strong>Giám đốc Ký túc xá</strong> (username: <code>admin</code>).
      </div>
    <% } else { %>
      <div class="message" style="background:#f0fdf4;border:1px solid #86efac;color:#15803d;margin-bottom:14px">
        <i class="fas fa-crown"></i> <strong>Giám đốc Ký túc xá:</strong> Bạn có toàn quyền tạo, sửa, ban hành và thu hồi quota.
      </div>
    <% } %>

    <% if (message) { %>
      <div class="message <%= message.type === 'error' ? 'error' : 'success' %>"><%= message.text %></div>
    <% } %>

    <div class="card">
      <table>
        <thead>
          <tr>
            <th>Năm học</th>
            <th>Phiên bản</th>
            <th>Trạng thái</th>
            <th>Tổng sức chứa</th>
            <th>Quota</th>
            <th>Hiệu lực</th>
            <th>Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% const yearGroupLabels = { year1: 'Năm 1', year2: 'Năm 2', year3: 'Năm 3', year4_plus: 'Năm 4 và các năm còn lại' }; %>
          <% const publishedYears = new Set((quotas || []).filter((q) => q.isPublished).map((q) => q.academicYear)); %>
          <% if (!quotas || quotas.length === 0) { %>
            <tr><td colspan="7">Chưa có cấu hình quota.</td></tr>
          <% } %>
          <% (quotas || []).forEach(function(item){ %>
            <tr>
              <td><strong><%= item.academicYear %></strong></td>
              <td>#<%= item.version %></td>
              <td>
                <% if (item.isDraft) { %>
                  <span class="status draft">Nháp</span>
                <% } else if (item.isPublished) { %>
                  <span class="status" style="background:#dcfce7;color:#166534">&#x2605; Đang áp dụng</span>
                <% } else { %>
                  <span class="status published">Đã lưu trữ</span>
                <% } %>
              </td>
              <td><%= item.totalCapacity %></td>
              <td>
                <% (item.quotas || []).forEach(function(q){ %>
                  <div class="quota-line"><%= yearGroupLabels[q.yearGroup] || q.yearGroup %>: <%= q.percentage %>% - <strong><%= q.slot %></strong> chỗ</div>
                <% }) %>
              </td>
              <td>
                <div class="small">Từ: <%- (function(d){ if(!d) return '—'; var dt=new Date(d); return isNaN(dt)?'—':dt.toLocaleDateString('vi-VN'); })(item.effectiveFrom) %></div>
                <div class="small">Đến: <%- (function(d){ if(!d) return '—'; var dt=new Date(d); return isNaN(dt)?'—':dt.toLocaleDateString('vi-VN'); })(item.effectiveTo) %></div>
              </td>
              <td>
                <% if (canManage) { %>
                  <div class="actions">
                    <% if (item.isDraft) { %>
                      <a class="btn btn-warning" href="/admin/quotas/<%= item._id %>/edit">Kế hoạch</a>
                    <% } %>
                    <a class="btn btn-secondary" href="/admin/quotas/<%= item._id %>/dashboard">Thực tế</a>
                    <a class="btn btn-secondary" href="/admin/quotas/<%= item._id %>/preview">Mô phỏng</a>
                    <% if (item.isDraft) { %>
                      <% if (publishedYears.has(item.academicYear)) { %>
                        <button class="btn btn-success" type="button" disabled title="Năm học này đã có quota ban hành">Ban hành</button>
                      <% } else { %>
                        <button class="btn btn-success" onclick="publishQuota('<%= item._id %>')">Ban hành</button>
                      <% } %>
                    <% } else if (item.isPublished) { %>
                      <button onclick="archiveQuota('<%= item._id %>')"
                        style="padding:.3rem .75rem;border:1px solid #9CA3AF;background:#fff;color:#6B7280;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;">
                        Lưu trữ
                      </button>
                    <% } else if (!item.isDraft && !item.isPublished) { %>
                      <button onclick="reactivateQuota('<%= item._id %>')"
                        style="padding:.3rem .75rem;border:1px solid #C8102E;background:#fff;color:#C8102E;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;">
                        Ban hành lại
                      </button>
                    <% } %>
                    <% if (!item.isPublished) { %>
                      <button onclick="deleteQuota('<%= item._id %>', '<%= item.academicYear %> v<%= item.version %>')"
                        style="padding:.3rem .75rem;border:1px solid #EF4444;background:#fff;color:#EF4444;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;">
                        <i class="fas fa-trash"></i> Xóa
                      </button>
                    <% } %>
                  </div>
                  <% if (item.isDraft && publishedYears.has(item.academicYear)) { %>
                    <div class="small">Năm học này đã có bản quota ban hành, không thể ban hành thêm.</div>
                  <% } %>
                <% } else { %>
                  <div class="actions">
                    <a class="btn btn-secondary" href="/admin/quotas/<%= item._id %>/dashboard">Thực tế</a>
                    <a class="btn btn-secondary" href="/admin/quotas/<%= item._id %>/preview">Mô phỏng</a>
                  </div>
                  <div class="small" style="margin-top:6px;color:#d97706"><i class="fas fa-lock"></i> Chỉ Giám đốc Ký túc xá mới có thể tạo, sửa hoặc ban hành quota.</div>
                <% } %>

                <details class="advanced">
                  <summary>Chi tiết nâng cao</summary>
                  <div class="advanced-links">
                    <a class="btn btn-soft" href="/admin/quotas/<%= item._id %>/workflow">Lịch triển khai</a>
                    <a class="btn btn-soft" href="/admin/quotas/leadership/dashboard">Bảng điều hành</a>
                    <a class="btn btn-soft" href="/admin/quotas/audit">Lịch sử thao tác</a>
                  </div>
                </details>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <script>
    async function publishQuota(id) {
      if (!confirm('Ban hành quota này thành phiên bản mới?')) return;
      const response = await fetch('/admin/quotas/' + id + '/publish', { method: 'POST' });
      const data = await response.json();
      if (!response.ok || !data.success) {
        alert(data.error || 'Ban hành thất bại');
        return;
      }
      window.location.href = '/admin/quotas?message=' + encodeURIComponent(data.message || 'Ban hành thành công') + '&type=success';
    }

    async function archiveQuota(id) {
      if (!confirm('Lưu trữ quota này? Sẽ không có quota nào đang áp dụng cho đến khi ban hành mới.')) return;
      const res = await fetch('/admin/quotas/' + id + '/archive', { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        window.location.href = '/admin/quotas?message=' + encodeURIComponent(data.message) + '&type=success';
      } else {
        alert('Lỗi: ' + data.error);
      }
    }

    async function reactivateQuota(id) {
      if (!confirm('Ban hành lại quota này? Quota đang áp dụng sẽ bị lưu trữ.')) return;
      const res = await fetch('/admin/quotas/' + id + '/reactivate', { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        window.location.href = '/admin/quotas?message=' + encodeURIComponent(data.message) + '&type=success';
      } else {
        alert('Lỗi: ' + data.error);
      }
    }

    async function deleteQuota(id, label) {
      if (!confirm('Xóa vĩnh viễn quota "' + label + '"? Thao tác này không thể hoàn tác.')) return;
      const res = await fetch('/admin/quotas/' + id, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) {
        window.location.href = '/admin/quotas?message=' + encodeURIComponent(data.message) + '&type=success';
      } else {
        alert('Lỗi: ' + data.error);
      }
    }
  </script>
  <%- include('../../shared/footer') %>
</body>
</html>
