<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thực tế quota</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;}
    body{font-family:'Josefin Sans',system-ui,sans-serif;background:linear-gradient(180deg,#FBF8F3,#F5EFE7);min-height:100vh;margin:0;color:#2B2320;}
    body::before{content:'';position:fixed;inset:0;background:radial-gradient(1100px 560px at 88% -8%,rgba(225,29,42,.07),transparent 58%),radial-gradient(820px 480px at -8% 6%,rgba(185,138,42,.09),transparent 56%);pointer-events:none;z-index:0;}
    .container{max-width:1200px;margin:0 auto;padding:0 16px 24px;position:relative;z-index:1;}
    .header{display:flex;justify-content:space-between;align-items:center;margin:20px 0;}
    .header h1{margin:0;font-family:'Josefin Sans',sans-serif;font-size:1.5rem;font-weight:600;color:#2B2320;}
    .meta{color:#7C7166;font-size:.84rem;margin-top:4px;}
    .card{background:linear-gradient(180deg,#FFFFFF,#FCFAF6);border:1px solid #EFE8DF;border-radius:16px;padding:18px;margin-bottom:16px;box-shadow:0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);}
    .tabs{display:flex;gap:8px;flex-wrap:wrap;margin:16px 0 12px;}
    .tab{border-radius:11px;padding:8px 16px;text-decoration:none;font-size:.83rem;font-weight:700;font-family:'Josefin Sans',sans-serif;transition:all .15s;}
    .tab.active{background:linear-gradient(135deg,#E11D2A,#B20C26);color:#fff;box-shadow:0 4px 12px rgba(200,16,46,.25);}
    .tab.inactive{background:#fff;color:#7C7166;border:1.5px solid #E7DECF;}
    .tab.inactive:hover{background:#FBF8F3;border-color:#C8102E;color:#C8102E;}
    .kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;}
    .kpi{border:1px solid #EFE8DF;border-radius:12px;padding:16px;background:linear-gradient(180deg,#FFFFFF,#FCFAF6);}
    .kpi .label{font-size:.78rem;color:#A89C8E;font-weight:600;text-transform:uppercase;letter-spacing:.04em;}
    .kpi .value{font-family:'Josefin Sans',sans-serif;font-size:1.6rem;font-weight:700;margin-top:6px;color:#2B2320;}
    h3{font-family:'Josefin Sans',sans-serif;font-weight:600;color:#2B2320;font-size:1.05rem;margin-bottom:14px;}
    h4{font-family:'Josefin Sans',sans-serif;font-weight:600;color:#2B2320;font-size:.95rem;}
    table{width:100%;border-collapse:collapse;}
    th,td{padding:10px 12px;border-bottom:1px solid #F4EEE5;text-align:left;}
    th{background:#F7F1E8;font-size:.655rem;color:#9A8F84;font-weight:700;text-transform:uppercase;letter-spacing:.06em;}
    tr:nth-child(even) td{background:#FDFBF8;}
    tr:hover td{background:#FAF5EE;}
    .status{font-weight:700;text-transform:uppercase;font-size:.72rem;}
    .status.over_quota{color:#C8102E;}
    .status.under_quota{color:#2563EB;}
    .status.on_target{color:#0E9F6E;}
    .actions{display:flex;gap:8px;margin-top:12px;}
    .btn{border:none;border-radius:11px;padding:9px 14px;cursor:pointer;text-decoration:none;font-size:.84rem;font-family:'Josefin Sans',sans-serif;font-weight:600;transition:all .18s;display:inline-flex;align-items:center;gap:6px;}
    .btn-primary{background:linear-gradient(135deg,#E11D2A,#B20C26);color:#fff;box-shadow:0 4px 12px rgba(200,16,46,.25);}
    .btn-primary:hover{filter:brightness(1.05);transform:translateY(-1px);}
    .btn-secondary{background:#fff;color:#7C7166;border:1.5px solid #E7DECF;}
    .btn-secondary:hover{background:#FBF8F3;border-color:#C8102E;color:#C8102E;}
    .btn-warning{background:linear-gradient(135deg,#E8A320,#D9A22B);color:#fff;box-shadow:0 4px 12px rgba(217,162,43,.25);}
    .btn-warning:hover{filter:brightness(1.05);transform:translateY(-1px);}
    .muted{color:#A89C8E;font-size:.82rem;}
    .stat-ok{color:#0E9F6E;font-weight:700;}
    .stat-bad{color:#C8102E;font-weight:700;}
    details.advanced{margin-top:12px;}
    details.advanced summary{cursor:pointer;font-size:.82rem;color:#C8102E;font-weight:700;}
  </style>
</head>
<body>
  <%- include('../navbar', { activeNav: activeNav }) %>

  <div class="container">
    <div class="tabs">
      <a class="tab inactive" href="/admin/quotas/<%= quota._id %>/edit">Kế hoạch</a>
      <span class="tab active">Thực tế</span>
      <a class="tab inactive" href="/admin/quotas/<%= quota._id %>/preview">Mô phỏng</a>
    </div>

    <div class="header">
      <div>
        <h1>Thực tế</h1>
        <div class="meta">Năm học: <strong><%= quota.academicYear %></strong> | Phiên bản: <strong>#<%= quota.version %></strong> | <%= quota.isDraft ? 'Nháp' : 'Đã ban hành' %></div>
      </div>
      <div class="actions">
        <a class="btn btn-secondary" href="/admin/quotas/<%= quota._id %>/preview">Mô phỏng</a>
        <a class="btn btn-secondary" href="/admin/quotas">Quota</a>
      </div>
    </div>

    <div class="card">
      <div class="kpi-grid">
        <div class="kpi">
          <div class="label">Tổng chỗ</div>
          <div class="value"><%= capacity.totalSlots %></div>
        </div>
        <div class="kpi">
          <div class="label">Đang sử dụng</div>
          <div class="value"><%= capacity.occupiedSlots %></div>
        </div>
        <div class="kpi">
          <div class="label">Còn trống</div>
          <div class="value"><%= capacity.availableSlots %></div>
        </div>
        <div class="kpi">
          <div class="label">Dự kiến còn trống</div>
          <div class="value"><%= capacity.projectedAvailableSlots %></div>
        </div>
      </div>
    </div>

    <div class="card">
      <h3>So sánh quota và thực tế</h3>
      <% const yearGroupLabels = { year1: 'Năm 1', year2: 'Năm 2', year3: 'Năm 3', year4_plus: 'Năm 4 và các năm còn lại' }; %>
      <table>
        <thead>
          <tr>
            <th>Nhóm năm học</th>
            <th>Quota %</th>
            <th>Thực tế %</th>
            <th>Quota (chỗ)</th>
            <th>Thực tế (SV)</th>
            <th>Sử dụng %</th>
            <th>Còn lại</th>
            <th>Kết luận</th>
          </tr>
        </thead>
        <tbody>
          <% (rows || []).forEach(function(row){ %>
            <% const normalizedQuotaSlot = Number(row.quotaSlot) > 0 ? Number(row.quotaSlot) : Math.round((Number(row.quotaPercentage || 0) * Number(quota.totalCapacity || 0)) / 100); %>
            <% const normalizedRemaining = normalizedQuotaSlot - Number(row.actual || 0); %>
            <tr>
              <td><%= yearGroupLabels[row.yearGroup] || row.yearGroup %></td>
              <td><%= row.quotaPercentage %>%</td>
              <td><%= row.actualPercentage %>%</td>
              <td><%= normalizedQuotaSlot %></td>
              <td><%= row.actual %></td>
              <td><%= normalizedQuotaSlot > 0 ? Math.round((Number(row.actual || 0) / normalizedQuotaSlot) * 10000) / 100 + '%' : '-' %></td>
              <td class="<%= normalizedRemaining < 0 ? 'stat-bad' : 'stat-ok' %>"><%= normalizedRemaining %></td>
              <td>
                <% if (normalizedRemaining < 0) { %>
                  <span class="status over_quota">Vượt quota</span>
                <% } else if (normalizedRemaining > 0) { %>
                  <span class="status under_quota">Dư quota</span>
                <% } else { %>
                  <span class="status on_target">Đúng quota</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <details class="advanced">
        <summary>Chi tiết nâng cao</summary>
        <div style="margin-top: 10px;">
          <h4 style="margin: 0 0 10px;">Kiểm tra cho phép vượt trần</h4>
          <% if (!overCapEvaluation || !overCapEvaluation.enabled) { %>
            <p class="muted">Chưa bật chính sách cho phép vượt trần cho phiên bản quota này.</p>
          <% } else if (!overCapEvaluation.violations || overCapEvaluation.violations.length === 0) { %>
            <p class="muted">Không có nhóm năm nào vi phạm ngưỡng vượt trần đã cấu hình.</p>
          <% } else { %>
            <table>
              <thead>
                <tr>
                  <th>Nhóm năm học</th>
                  <th>Quota</th>
                  <th>Thực tế</th>
                  <th>Cho phép tối đa</th>
                  <th>Mức vượt trần %</th>
                  <th>Vượt</th>
                </tr>
              </thead>
              <tbody>
                <% overCapEvaluation.violations.forEach(function(item){ %>
                  <tr>
                    <td><%= yearGroupLabels[item.yearGroup] || item.yearGroup %></td>
                    <td><%= item.quotaSlot %></td>
                    <td><%= item.actual %></td>
                    <td><%= item.maxAllowed %></td>
                    <td><%= item.overCapPercent %>%</td>
                    <td><%= item.excess %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </details>
    </div>

  </div>
  <%- include('../../shared/footer') %>
</body>
</html>
