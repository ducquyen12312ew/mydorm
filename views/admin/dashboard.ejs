<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — Admin KTX HUST</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        .admin-content { min-height: 100vh; }
        .dash-container { max-width: 1440px; margin: 0 auto; padding: 1.5rem 1.5rem 3rem; }

        /* PAGE HEADER */
        .dash-header {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 1.75rem; flex-wrap: wrap; gap: .75rem;
        }
        .dash-header h1 { font-family: 'Lora', Georgia, serif; font-size: 1.5rem; font-weight: 600; color: var(--adm-text); }
        .dash-header h1 span { color: var(--adm-primary); }
        .header-right { display: flex; align-items: center; gap: .75rem; }
        .refresh-btn {
            display: flex; align-items: center; gap: .4rem; padding: .5rem 1rem;
            border: 1px solid var(--adm-border); border-radius: 11px;
            background: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            font-size: .82rem; font-weight: 600; color: var(--adm-text-soft);
            cursor: pointer; transition: all .2s; box-shadow: var(--adm-shadow-sm);
        }
        .refresh-btn:hover { border-color: var(--adm-primary); color: var(--adm-primary); background: #fff; }
        .live-badge { display: flex; align-items: center; gap: .35rem; font-size: .75rem; color: var(--adm-green); font-weight: 600; }
        .live-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--adm-green); animation: blink 1.5s ease infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

        /* KPI CARDS */
        .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.25rem; }
        .kpi-card {
            background: var(--adm-surface); border-radius: var(--adm-radius); padding: 1.35rem 1.5rem;
            box-shadow: var(--adm-shadow); border: 1px solid var(--adm-border);
            display: flex; align-items: flex-start; gap: 1rem;
            position: relative; overflow: hidden; transition: box-shadow .22s, transform .22s;
        }
        .kpi-card:hover { box-shadow: var(--adm-shadow-md); transform: translateY(-2px); }
        .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; }
        .kpi-card.red::before   { background: linear-gradient(90deg,#E11D2A,#B20C26); }
        .kpi-card.green::before { background: linear-gradient(90deg,#0E9F6E,#059669); }
        .kpi-card.blue::before  { background: linear-gradient(90deg,#2563EB,#1D4ED8); }
        .kpi-card.gold::before  { background: linear-gradient(90deg,#D9A22B,#B8891E); }
        .kpi-icon { width: 46px; height: 46px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
        .kpi-icon.red   { background: var(--adm-primary-light); color: var(--adm-primary); }
        .kpi-icon.green { background: var(--adm-green-bg); color: var(--adm-green); }
        .kpi-icon.blue  { background: var(--adm-blue-bg); color: var(--adm-blue); }
        .kpi-icon.gold  { background: var(--adm-yellow-bg); color: var(--adm-yellow); }
        .kpi-body { flex: 1; min-width: 0; }
        .kpi-label { font-size: 10.5px; color: #9A8F84; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; margin-bottom: .3rem; }
        .kpi-value { font-family: 'Lora', Georgia, serif; font-size: 2rem; font-weight: 600; line-height: 1; color: var(--adm-text); }
        .kpi-sub   { font-size: .75rem; color: var(--adm-text-muted); margin-top: .25rem; }
        .kpi-trend { font-size: .75rem; font-weight: 600; }
        .kpi-trend.up   { color: var(--adm-green); }
        .kpi-trend.down { color: var(--adm-primary); }

        /* STATUS CARDS */
        .status-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: .75rem; margin-bottom: 1.5rem; }
        .status-card {
            background: var(--adm-surface); border-radius: var(--adm-radius-sm); padding: 1rem 1.25rem;
            box-shadow: var(--adm-shadow-sm); border: 1px solid var(--adm-border);
            display: flex; flex-direction: column; gap: .3rem; transition: box-shadow .2s, transform .2s;
        }
        .status-card:hover { box-shadow: var(--adm-shadow); transform: translateY(-1px); }
        .status-card .sc-label { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .10em; }
        .status-card .sc-value { font-family: 'Lora', Georgia, serif; font-size: 1.75rem; font-weight: 600; line-height: 1; }
        .status-card.pending  .sc-label { color: var(--adm-yellow); }
        .status-card.pending  .sc-value { color: var(--adm-yellow); }
        .status-card.approved .sc-label, .status-card.allocated .sc-label { color: var(--adm-green); }
        .status-card.approved .sc-value, .status-card.allocated .sc-value { color: var(--adm-green); }
        .status-card.rejected .sc-label { color: var(--adm-primary); }
        .status-card.rejected .sc-value { color: var(--adm-primary); }
        .status-card.waitlist .sc-label { color: var(--adm-blue); }
        .status-card.waitlist .sc-value { color: var(--adm-blue); }
        .status-card .sc-sub { font-size: .7rem; color: var(--adm-text-muted); }

        /* MAIN GRID */
        .main-grid { display: grid; grid-template-columns: 1fr 380px; gap: 1.25rem; align-items: start; }

        /* SECTION CARD */
        .section-card {
            background: var(--adm-surface); border-radius: var(--adm-radius);
            box-shadow: var(--adm-shadow); border: 1px solid var(--adm-border);
            margin-bottom: 1.25rem; overflow: hidden;
        }
        .section-head {
            padding: 1rem 1.4rem; display: flex; align-items: center; justify-content: space-between;
            border-bottom: 1px solid var(--adm-border); background: var(--adm-surface-raised);
        }
        .section-head h2 { font-family: 'Lora', Georgia, serif; font-size: .95rem; font-weight: 600; display: flex; align-items: center; gap: .5rem; color: var(--adm-text); }
        .section-head a { font-size: .78rem; color: var(--adm-primary); text-decoration: none; font-weight: 600; }
        .section-head a:hover { text-decoration: underline; }
        .section-head select { font-size: .8rem; padding: .35rem .7rem; border: 1px solid var(--adm-border); border-radius: 8px; background: #fff; color: var(--adm-text); cursor: pointer; }
        .section-body { padding: 1.4rem; }

        /* DOUGHNUT CHART */
        .chart-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: center; }
        .chart-canvas-wrap { position: relative; max-width: 220px; margin: 0 auto; }
        .chart-legend .legend-item { display: flex; align-items: center; gap: .5rem; margin-bottom: .6rem; font-size: .83rem; }
        .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
        .legend-label { color: var(--adm-text-soft); flex: 1; }
        .legend-val   { font-family: 'Lora', Georgia, serif; font-weight: 600; color: var(--adm-text); }

        /* RECENT REGISTRATIONS TABLE */
        .reg-table { width: 100%; border-collapse: collapse; }
        .reg-table th { font-size: 10.5px; text-transform: uppercase; letter-spacing: .08em; color: #9A8F84; font-weight: 700; padding: .6rem .9rem; border-bottom: 1px solid var(--adm-border); background: #F7F1E8; text-align: left; }
        .reg-table td { padding: .7rem .9rem; border-bottom: 1px solid var(--adm-border-table); font-size: .83rem; vertical-align: middle; color: var(--adm-text); }
        .reg-table tr:last-child td { border-bottom: none; }
        .reg-table tbody tr:nth-child(even) td { background: #FDFBF8; }
        .reg-table tr:hover td { background: #FAF5EE !important; }
        .stu-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--adm-primary-grad); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: .7rem; font-weight: 700; flex-shrink: 0; }
        .stu-info   { display: flex; align-items: center; gap: .5rem; }
        .stu-name   { font-weight: 600; font-size: .85rem; color: var(--adm-text); }
        .stu-sid    { font-size: .72rem; color: var(--adm-text-muted); }

        /* BADGES */
        .badge { display: inline-flex; align-items: center; gap: .3rem; padding: .22rem .65rem; border-radius: 999px; font-size: .72rem; font-weight: 700; white-space: nowrap; border: 1px solid transparent; }
        .badge::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
        .badge-pending   { background: var(--adm-yellow-bg); color: #A07010; border-color: var(--adm-yellow-bdr); }
        .badge-allocated { background: var(--adm-green-bg);  color: #0B7A54; border-color: var(--adm-green-bdr); }
        .badge-waitlist  { background: var(--adm-blue-bg);   color: #1A4FBD; border-color: var(--adm-blue-bdr); }
        .badge-rejected  { background: var(--adm-red-bg);    color: #9B1C30; border-color: var(--adm-red-bdr); }
        .badge-approved  { background: var(--adm-green-bg);  color: #0B7A54; border-color: var(--adm-green-bdr); }
        .badge-approved-wp { background: #F1EEF9; color: #5B3DA8; border-color: #CCC0EE; }

        /* NOTIFICATION PANEL */
        .notif-panel { background: var(--adm-surface); border-radius: var(--adm-radius); box-shadow: var(--adm-shadow); border: 1px solid var(--adm-border); overflow: hidden; }
        .notif-head  { padding: 1rem 1.4rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--adm-border); background: var(--adm-surface-raised); }
        .notif-head h2 { font-family: 'Lora', Georgia, serif; font-size: .95rem; font-weight: 600; display: flex; align-items: center; gap: .5rem; color: var(--adm-text); }
        .notif-badge { background: var(--adm-primary-grad); color: #fff; font-size: .65rem; font-weight: 700; padding: .18rem .5rem; border-radius: 999px; min-width: 20px; text-align: center; }
        .notif-list  { max-height: 340px; overflow-y: auto; padding: .4rem 0; }
        .notif-item  { padding: .75rem 1.4rem; border-bottom: 1px solid var(--adm-border-soft); cursor: pointer; transition: background .15s; }
        .notif-item:last-child { border-bottom: none; }
        .notif-item:hover { background: var(--adm-surface-hover); }
        .notif-item.unread { background: #FBF5F6; }
        .notif-item.unread:hover { background: #F6ECEE; }
        .notif-item-icon { float: left; margin-right: .6rem; font-size: 1rem; margin-top: .1rem; }
        .notif-item-title { font-size: .83rem; font-weight: 600; color: var(--adm-text); }
        .notif-item-msg   { font-size: .75rem; color: var(--adm-text-soft); margin-top: .1rem; line-height: 1.4; }
        .notif-item-time  { font-size: .7rem; color: var(--adm-text-muted); margin-top: .25rem; }
        .notif-empty { text-align: center; padding: 2rem 1rem; color: var(--adm-text-muted); font-size: .85rem; }
        .notif-empty i { font-size: 2rem; margin-bottom: .5rem; display: block; opacity: .35; }

        /* QUICK ACTIONS */
        .qa-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
        .qa-btn {
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: .35rem;
            padding: .95rem .5rem; border-radius: 11px; background: #fff;
            border: 1px solid var(--adm-border); cursor: pointer; text-decoration: none;
            font-size: .8rem; font-weight: 600; color: var(--adm-text-soft); transition: all .2s;
        }
        .qa-btn i    { font-size: 1.3rem; }
        .qa-btn:hover { background: var(--adm-primary-grad); color: #fff; border-color: var(--adm-primary); transform: translateY(-2px); box-shadow: var(--adm-shadow-btn); }
        .qa-btn.qa-run { background: var(--adm-primary-grad); color: #fff; border-color: var(--adm-primary); box-shadow: var(--adm-shadow-btn); }
        .qa-btn.qa-run:hover { filter: brightness(1.06); transform: translateY(-1px); }

        /* DORM TABLE */
        .dorm-table { width: 100%; border-collapse: collapse; }
        .dorm-table th { font-size: 10.5px; text-transform: uppercase; letter-spacing: .08em; color: #9A8F84; font-weight: 700; padding: .6rem .9rem; border-bottom: 1px solid var(--adm-border); background: #F7F1E8; text-align: left; }
        .dorm-table td { padding: .7rem .9rem; border-bottom: 1px solid var(--adm-border-table); font-size: .83rem; color: var(--adm-text); }
        .dorm-table tr:last-child td { border-bottom: none; }
        .dorm-table tbody tr:nth-child(even) td { background: #FDFBF8; }
        .dorm-table tr:hover td { background: #FAF5EE !important; }
        .occ-bar-bg { background: var(--adm-border); border-radius: 4px; height: 6px; overflow: hidden; min-width: 80px; }
        .occ-bar    { height: 100%; border-radius: 4px; transition: width .6s ease; }
        .occ-high   { background: linear-gradient(90deg,#E11D2A,#B20C26); }
        .occ-mid    { background: linear-gradient(90deg,#D9A22B,#B8891E); }
        .occ-low    { background: linear-gradient(90deg,#0E9F6E,#059669); }

        /* LOADING SKELETON */
        .skel { background: linear-gradient(90deg,#F0E8DE 25%,#F9F4EE 50%,#F0E8DE 75%); background-size: 400% 100%; animation: skelAnim 1.4s ease infinite; border-radius: 6px; }
        @keyframes skelAnim { 0%{background-position:100% 50%} 100%{background-position:0% 50%} }

        @media (max-width: 1100px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } .main-grid { grid-template-columns: 1fr; } }
        @media (max-width: 640px)  { .kpi-grid { grid-template-columns: 1fr 1fr; } .dash-container { padding: 1rem .875rem 2rem; } }
    </style>
</head>
<body>
    <%- include('navbar', { activeNav: 'dashboard' }) %>

    <div class="admin-content">
    <div class="dash-container">

        <!-- PAGE HEADER -->
        <div class="dash-header">
            <div>
                <h1>Dashboard <span>Quản lý KTX</span></h1>
                <p style="font-size:.82rem;color:var(--muted);margin-top:.2rem">Tổng quan hệ thống — cập nhật realtime</p>
            </div>
            <div class="header-right">
                <div class="live-badge"><div class="live-dot"></div> Realtime</div>
                <button class="refresh-btn" onclick="loadAll()"><i class="fa-solid fa-rotate-right"></i> Làm mới</button>
            </div>
        </div>

        <!-- KPI CARDS -->
        <div class="kpi-grid" id="kpiGrid">
            <div class="kpi-card red">
                <div class="kpi-icon red"><i class="fa-solid fa-file-alt"></i></div>
                <div class="kpi-body">
                    <div class="kpi-label">Tổng đơn đăng ký</div>
                    <div class="kpi-value" id="kpiTotalApps">—</div>
                    <div class="kpi-sub">Tất cả đợt + legacy</div>
                </div>
            </div>
            <div class="kpi-card green">
                <div class="kpi-icon green"><i class="fa-solid fa-door-open"></i></div>
                <div class="kpi-body">
                    <div class="kpi-label">Phòng trống</div>
                    <div class="kpi-value" id="kpiAvailRooms">—</div>
                    <div class="kpi-sub" id="kpiAvailSub">—</div>
                </div>
            </div>
            <div class="kpi-card blue">
                <div class="kpi-icon blue"><i class="fa-solid fa-clock"></i></div>
                <div class="kpi-body">
                    <div class="kpi-label">Đơn chờ xử lý</div>
                    <div class="kpi-value" id="kpiPending">—</div>
                    <div class="kpi-sub">Cần xét duyệt</div>
                </div>
            </div>
            <div class="kpi-card gold">
                <div class="kpi-icon gold"><i class="fa-solid fa-percent"></i></div>
                <div class="kpi-body">
                    <div class="kpi-label">Tỷ lệ lấp đầy</div>
                    <div class="kpi-value" id="kpiOccRate">—</div>
                    <div class="kpi-sub" id="kpiOccSub">—</div>
                </div>
            </div>
        </div>

        <!-- STATUS CARDS — HORIZONTAL GRID -->
        <div class="status-grid" id="statusGrid">
            <div class="status-card pending">
                <div class="sc-label">Đang chờ xử lý</div>
                <div class="sc-value" id="scPending">—</div>
                <div class="sc-sub">Chưa xét duyệt</div>
            </div>
            <div class="status-card approved">
                <div class="sc-label">Đã duyệt</div>
                <div class="sc-value" id="scApproved">—</div>
                <div class="sc-sub">Legacy + duyệt thủ công</div>
            </div>
            <div class="status-card allocated">
                <div class="sc-label">Đã phân phòng</div>
                <div class="sc-value" id="scAllocated">—</div>
                <div class="sc-sub">Phân bổ tự động</div>
            </div>
            <div class="status-card waitlist">
                <div class="sc-label">Danh sách chờ</div>
                <div class="sc-value" id="scWaitlist">—</div>
                <div class="sc-sub">Chờ có phòng trống</div>
            </div>
            <div class="status-card rejected">
                <div class="sc-label">Đã từ chối</div>
                <div class="sc-value" id="scRejected">—</div>
                <div class="sc-sub">Không đủ tiêu chí</div>
            </div>
        </div>

        <!-- MAIN GRID: LEFT + RIGHT -->
        <div class="main-grid">

            <!-- LEFT COLUMN -->
            <div>

                <!-- Doughnut Chart -->
                <div class="section-card">
                    <div class="section-head">
                        <h2><i class="fa-solid fa-chart-pie" style="color:var(--red)"></i> Trạng thái phòng theo tòa</h2>
                        <select id="dormSelect" style="font-size:.8rem;padding:.3rem .6rem;border:1px solid var(--border);border-radius:6px;cursor:pointer" onchange="updateDoughnut()">
                            <option value="all">Tất cả tòa</option>
                        </select>
                    </div>
                    <div class="section-body">
                        <div class="chart-layout">
                            <div class="chart-canvas-wrap">
                                <canvas id="doughnutChart" width="220" height="220"></canvas>
                            </div>
                            <div class="chart-legend" id="doughnutLegend">
                                <div class="legend-item"><span class="legend-dot" style="background:#DFA8A8"></span><span class="legend-label">Đã sử dụng</span><span class="legend-val" id="lgOccupied">—</span></div>
                                <div class="legend-item"><span class="legend-dot" style="background:#A8CCC0"></span><span class="legend-label">Còn trống</span><span class="legend-val" id="lgAvailable">—</span></div>
                                <div class="legend-item"><span class="legend-dot" style="background:#C0C8D0"></span><span class="legend-label">Bảo trì</span><span class="legend-val" id="lgMaint">—</span></div>
                                <div style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid var(--border)">
                                    <div style="font-size:.75rem;color:var(--muted)">Tổng chỗ</div>
                                    <div style="font-size:1.3rem;font-weight:900" id="lgTotal">—</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Recent Registrations -->
                <div class="section-card">
                    <div class="section-head">
                        <h2><i class="fa-solid fa-list-check" style="color:var(--red)"></i> Đơn đăng ký gần đây</h2>
                        <a href="/admin/allocation/dashboard">Xem tất cả →</a>
                    </div>
                    <div style="overflow-x:auto">
                        <table class="reg-table">
                            <thead>
                                <tr>
                                    <th>Sinh viên</th>
                                    <th>Khoa</th>
                                    <th style="text-align:center">Điểm ưu tiên</th>
                                    <th>Thời gian</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody id="regTableBody">
                                <tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--muted)">
                                    <div class="skel" style="height:14px;width:60%;margin:auto"></div>
                                </td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Dorm occupancy table -->
                <div class="section-card">
                    <div class="section-head">
                        <h2><i class="fa-solid fa-building" style="color:var(--red)"></i> Thống kê lấp đầy KTX</h2>
                    </div>
                    <div style="overflow-x:auto">
                        <table class="dorm-table">
                            <thead>
                                <tr>
                                    <th>Tòa nhà</th>
                                    <th style="text-align:center">Tổng phòng</th>
                                    <th style="text-align:center">Còn trống</th>
                                    <th>Lấp đầy</th>
                                    <th style="text-align:right">Tỷ lệ</th>
                                </tr>
                            </thead>
                            <tbody id="dormTableBody">
                                <tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--muted)">Đang tải...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div><!-- /left -->

            <!-- RIGHT COLUMN -->
            <div>

                <!-- NOTIFICATION PANEL -->
                <div class="notif-panel" style="margin-bottom:1.25rem">
                    <div class="notif-head">
                        <h2><i class="fa-solid fa-bell" style="color:var(--red)"></i> Thông báo
                            <span class="notif-badge" id="notifCount">0</span>
                        </h2>
                        <button onclick="clearNotifs()" style="background:none;border:none;font-size:.75rem;color:var(--muted);cursor:pointer">Xóa tất cả</button>
                    </div>
                    <div class="notif-list" id="notifList">
                        <div class="notif-empty"><i class="fa-solid fa-bell-slash"></i>Chưa có thông báo mới</div>
                    </div>
                </div>

                <!-- QUICK ACTIONS -->
                <div class="section-card">
                    <div class="section-head">
                        <h2><i class="fa-solid fa-bolt" style="color:var(--red)"></i> Thao tác nhanh</h2>
                    </div>
                    <div class="section-body">
                        <div class="qa-grid">
                            <a href="/admin/allocation/dashboard" class="qa-btn qa-run">
                                <i class="fa-solid fa-play"></i> Chạy phân bổ
                            </a>
                            <a href="/admin/applications" class="qa-btn">
                                <i class="fa-solid fa-file-lines"></i> Xem đơn
                            </a>
                            <a href="/admin/master-dashboard" class="qa-btn">
                                <i class="fa-solid fa-chart-line"></i> Báo cáo
                            </a>
                            <a href="/admin/master-dashboard/export" class="qa-btn">
                                <i class="fa-solid fa-file-excel"></i> Xuất Excel
                            </a>
                        </div>
                    </div>
                </div>

            </div><!-- /right -->

        </div><!-- /main-grid -->

    </div><!-- /dash-container -->
    </div><!-- /admin-content -->

<script src="/socket.io/socket.io.js"></script>
<script>
// ── GLOBALS ─────────────────────────────────────────────
let doughnutChart = null;
let dormRoomData  = [];
let notifList = [];
let unreadCount = 0;

// ── BOOT ─────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    loadAll();
    initSocket();
    // Auto-refresh every 60s
    setInterval(loadAll, 60000);
});

async function loadAll() {
    await Promise.all([loadKPI(), loadRecentRegs()]);
}

// ── KPI ──────────────────────────────────────────────────
async function loadKPI() {
    try {
        const r = await fetch('/api/admin/kpi', { credentials: 'include' });
        const d = await r.json();
        if (!d.success) return;

        const kpi = d.kpi || {};
        document.getElementById('kpiTotalApps').textContent = fmt(kpi.totalApplications);
        document.getElementById('kpiAvailRooms').textContent = fmt(kpi.availableRooms);
        document.getElementById('kpiAvailSub').textContent  = `Trên tổng ${fmt(kpi.totalCapacity)} chỗ`;
        document.getElementById('kpiPending').textContent   = fmt(kpi.pendingApplications);
        document.getElementById('kpiOccRate').textContent   = (kpi.occupancyRate || 0) + '%';
        document.getElementById('kpiOccSub').textContent    = `${fmt(kpi.occupiedSpots)}/${fmt(kpi.totalCapacity)} chỗ`;

        // Status grid — combine reg + app stats
        const rs = d.registrationStats || {};
        const as = d.applicationStats  || {};
        document.getElementById('scPending').textContent  = fmt((rs.PENDING||0)+(as.pending||0));
        document.getElementById('scApproved').textContent = fmt(as.approved||0);
        document.getElementById('scAllocated').textContent= fmt(rs.ALLOCATED||0);
        document.getElementById('scWaitlist').textContent = fmt(rs.WAITLIST||0);
        document.getElementById('scRejected').textContent = fmt((rs.REJECTED||0)+(as.rejected||0));

        // Doughnut
        dormRoomData = d.dormRoomStatus || [];
        buildDormSelect(dormRoomData);
        updateDoughnut();

        // Dorm table
        renderDormTable(dormRoomData);

    } catch(e) { console.error('KPI load error', e); }
}

// ── DORM SELECT & DOUGHNUT ─────────────────────────────
function buildDormSelect(data) {
    const sel = document.getElementById('dormSelect');
    const cur = sel.value;
    // Keep 'all' option, add dorm options
    while (sel.options.length > 1) sel.remove(1);
    data.forEach(d => {
        const o = document.createElement('option');
        o.value = d.name; o.textContent = d.name;
        sel.appendChild(o);
    });
    sel.value = cur || 'all';
}

function updateDoughnut() {
    const val = document.getElementById('dormSelect').value;
    let occupied=0, available=0, maintenance=0;

    if (val === 'all') {
        dormRoomData.forEach(d => {
            occupied    += d.occupied    || 0;
            available   += d.available  || 0;
            maintenance += d.maintenance|| 0;
        });
    } else {
        const d = dormRoomData.find(x => x.name === val) || {};
        occupied    = d.occupied    || 0;
        available   = d.available  || 0;
        maintenance = d.maintenance|| 0;
    }

    const total = occupied + available + maintenance;
    document.getElementById('lgOccupied').textContent  = occupied;
    document.getElementById('lgAvailable').textContent = available;
    document.getElementById('lgMaint').textContent     = maintenance;
    document.getElementById('lgTotal').textContent     = total;

    const chartData = [occupied, available, maintenance];
    const colors    = ['#DFA8A8','#A8CCC0','#C0C8D0'];

    if (doughnutChart) {
        doughnutChart.data.datasets[0].data = chartData;
        doughnutChart.update('active');
        return;
    }

    const ctx = document.getElementById('doughnutChart').getContext('2d');
    doughnutChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['Đã sử dụng','Còn trống','Bảo trì'],
            datasets: [{ data: chartData, backgroundColor: colors, borderWidth: 2, borderColor: '#fff', hoverOffset: 6 }]
        },
        options: {
            responsive: true, cutout: '68%',
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.label}: ${ctx.parsed} (${total ? Math.round(ctx.parsed/total*100) : 0}%)`
                    }
                }
            }
        }
    });
}

// ── DORM TABLE ───────────────────────────────────────────
function renderDormTable(data) {
    const tbody = document.getElementById('dormTableBody');
    if (!data.length) { tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:1.5rem;color:var(--muted)">Không có dữ liệu</td></tr>'; return; }
    tbody.innerHTML = data.map(d => {
        const total = d.total || (d.occupied + d.available);
        const occ   = total > 0 ? Math.round((d.occupied / total) * 100) : 0;
        const barCls = occ >= 80 ? 'occ-high' : occ >= 50 ? 'occ-mid' : 'occ-low';
        return `<tr>
            <td style="font-weight:600">${esc(d.name)}</td>
            <td style="text-align:center">${d.available+d.occupied}</td>
            <td style="text-align:center;color:var(--success);font-weight:600">${d.available}</td>
            <td style="min-width:100px">
                <div class="occ-bar-bg"><div class="occ-bar ${barCls}" style="width:${occ}%"></div></div>
            </td>
            <td style="text-align:right;font-weight:700">${occ}%</td>
        </tr>`;
    }).join('');
}

// ── RECENT REGISTRATIONS ─────────────────────────────────
async function loadRecentRegs() {
    try {
        const r = await fetch('/api/admin/recent-registrations?limit=15', { credentials: 'include' });
        const d = await r.json();
        renderRegTable(d.registrations || []);
    } catch(e) {
        document.getElementById('regTableBody').innerHTML = `<tr><td colspan="5" style="text-align:center;color:var(--muted);padding:1.5rem">Không thể tải dữ liệu</td></tr>`;
    }
}

function renderRegTable(regs) {
    const tbody = document.getElementById('regTableBody');
    if (!regs.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--muted)">Chưa có đơn đăng ký nào</td></tr>';
        return;
    }
    tbody.innerHTML = regs.map(reg => {
        const initials = (reg.studentName||'?').split(' ').map(w=>w[0]).slice(-2).join('').toUpperCase();
        const badgeCls = { PENDING:'badge-pending', ALLOCATED:'badge-allocated', WAITLIST:'badge-waitlist', REJECTED:'badge-rejected', WITHDRAWN:'badge-rejected' };
        const statusVN  = { PENDING:'Đang chờ', ALLOCATED:'Đã phân phòng', WAITLIST:'Danh sách chờ', REJECTED:'Đã từ chối', WITHDRAWN:'Đã rút' };
        const bdge = `<span class="badge ${badgeCls[reg.status]||'badge-pending'}">${statusVN[reg.status]||reg.status||'—'}</span>`;
        const timeAgo = relTime(reg.createdAt);
        return `<tr>
            <td>
                <div class="stu-info">
                    <div class="stu-avatar">${initials}</div>
                    <div>
                        <div class="stu-name">${esc(reg.studentName||'—')}</div>
                        <div class="stu-sid">${esc(reg.studentId||'')}</div>
                    </div>
                </div>
            </td>
            <td style="color:var(--muted);font-size:.78rem">${esc(reg.faculty||'—')}</td>
            <td style="text-align:center;font-weight:700;color:var(--red)">${reg.priority||0}</td>
            <td style="color:var(--muted);font-size:.78rem;white-space:nowrap">${timeAgo}</td>
            <td>${bdge}</td>
        </tr>`;
    }).join('');
}

// ── NOTIFICATIONS ─────────────────────────────────────────
function addNotif(icon, title, msg, color) {
    const now = new Date();
    notifList.unshift({ icon, title, msg, color, time: now, read: false });
    if (notifList.length > 50) notifList.pop();
    unreadCount++;
    renderNotifList();
    document.getElementById('notifCount').textContent = unreadCount;
}

function renderNotifList() {
    const el = document.getElementById('notifList');
    if (!notifList.length) {
        el.innerHTML = '<div class="notif-empty"><i class="fa-solid fa-bell-slash"></i>Chưa có thông báo mới</div>';
        return;
    }
    el.innerHTML = notifList.map((n,i) => `
        <div class="notif-item${n.read ? '' : ' unread'}" onclick="markRead(${i})">
            <span class="notif-item-icon" style="color:${n.color||'var(--red)'}">${n.icon}</span>
            <div style="overflow:hidden">
                <div class="notif-item-title">${esc(n.title)}</div>
                <div class="notif-item-msg">${esc(n.msg)}</div>
                <div class="notif-item-time">${relTime(n.time)}</div>
            </div>
        </div>`).join('');
}

function markRead(i) { notifList[i].read = true; unreadCount = Math.max(0, notifList.filter(n=>!n.read).length); document.getElementById('notifCount').textContent = unreadCount; renderNotifList(); }
function clearNotifs() { notifList=[]; unreadCount=0; document.getElementById('notifCount').textContent=0; renderNotifList(); }

// ── SOCKET.IO ─────────────────────────────────────────────
function initSocket() {
    try {
        const socket = io({ withCredentials: true });
        socket.on('connect', () => {
            socket.emit('admin:dashboard:subscribe');
        });
        socket.on('admin:new-registration', data => {
            addNotif('📋', 'Đơn đăng ký mới',
                `${data.studentName || '—'} (${data.studentFaculty||''}) vừa đăng ký`,
                'var(--red)');
            // Refresh data
            setTimeout(loadAll, 800);
        });
        socket.on('admin:dashboard:refresh', () => {
            loadAll();
        });
        socket.on('student:assigned', data => {
            addNotif('✅', 'Sinh viên được phân bổ',
                `Đơn ${data.registrationId ? data.registrationId.toString().slice(-6) : ''} đã được phân bổ phòng`,
                'var(--success)');
            setTimeout(loadAll, 800);
        });
        socket.on('application:updated', data => {
            addNotif('🔄', 'Đơn cập nhật trạng thái',
                `Đơn đăng ký vừa được cập nhật`,
                'var(--info)');
            setTimeout(loadAll, 800);
        });
    } catch(e) { console.warn('Socket init failed:', e.message); }
}

// ── UTILS ─────────────────────────────────────────────────
function fmt(n) { return typeof n === 'number' ? n.toLocaleString('vi-VN') : (n || '0'); }
function esc(t) { if(!t) return ''; return String(t).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c])); }
function relTime(ts) {
    if (!ts) return '—';
    const ms  = Date.now() - new Date(ts).getTime();
    const sec = Math.floor(ms/1000);
    if (sec < 60) return 'Vừa xong';
    const min = Math.floor(sec/60);
    if (min < 60) return `${min} phút trước`;
    const hr = Math.floor(min/60);
    if (hr < 24) return `${hr} giờ trước`;
    const day = Math.floor(hr/24);
    return `${day} ngày trước`;
}
</script>
<%- include('footer') %>
</body>
</html>
