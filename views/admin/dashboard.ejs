<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bảng Điều Khiển - Admin KTX</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        .admin-content {
            padding-top: 0;
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 1.5rem 2rem;
        }

        /* Stats grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        /* Progress bar */
        .progress-bar {
            width: 100%;
            height: 6px;
            background: var(--adm-border);
            border-radius: 3px;
            overflow: hidden;
            margin-top: 0.4rem;
        }

        .progress-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.4s ease;
        }

        .progress-fill.high   { background: #dc2626; }
        .progress-fill.medium { background: #f59e0b; }
        .progress-fill.low    { background: #10b981; }

        /* Chart section (inside grid) */
        .chart-section {
            background: var(--adm-surface);
            border-radius: var(--adm-radius);
            border: 1px solid var(--adm-border);
            box-shadow: var(--adm-shadow-sm);
            padding: 1.5rem;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.25rem;
        }

        .chart-header h2 {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--adm-text);
            margin: 0;
        }

        /* Activity section (inside grid) */
        .activity-section {
            background: var(--adm-surface);
            border-radius: var(--adm-radius);
            border: 1px solid var(--adm-border);
            box-shadow: var(--adm-shadow-sm);
            overflow: hidden;
        }

        .activity-list {
            max-height: 380px;
            overflow-y: auto;
        }

        /* Loading state */
        .loading {
            text-align: center;
            padding: 3rem;
            color: var(--adm-text-muted);
        }

        /* 2-column bottom grid */
        .dashboard-bottom-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        @media (max-width: 1024px) {
            .dashboard-bottom-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .container  { padding: 0 1rem 1.5rem; }
        }

        @media (max-width: 480px) {
            .stats-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <%- include('navbar', { activeNav: 'dashboard' }) %>


    <!-- MAIN CONTENT -->
    <div class="admin-content">
        <div class="container">
            <div class="page-header">
                <div>
                    <h1><i class="fas fa-chart-line"></i> Bảng Điều Khiển</h1>
                    <p class="page-subtitle">Tổng quan về hệ thống quản lý ký túc xá</p>
                </div>
            </div>

            <div id="loading" class="loading">
                <div class="spinner"></div>
                <p>Đang tải dữ liệu...</p>
            </div>

            <div id="dashboard-content" style="display: none;">
                <div class="stats-grid" id="stats-grid"></div>

                <!-- Application stats row -->
                <div class="dormitory-table" style="padding: 0; margin-bottom: 1.5rem;">
                    <h2 class="section-heading"><i class="fas fa-file-alt"></i> Tình Trạng Đơn Đăng Ký</h2>
                    <div style="padding: 1.25rem 1.5rem;" id="application-stats-container">
                        <div class="loading-state" style="padding: 1.5rem;">
                            <div class="spinner"></div>
                        </div>
                    </div>
                </div>

                <!-- Dormitory occupancy table -->
                <div class="dormitory-table" style="padding: 0; margin-bottom: 1.5rem;">
                    <h2 class="section-heading"><i class="fas fa-building"></i> Thống Kê Theo Ký Túc Xá</h2>
                    <div style="overflow-x: auto;">
                        <table class="admin-table" id="dormitory-stats-table">
                            <thead>
                                <tr>
                                    <th>Tên KTX</th>
                                    <th style="text-align:center">Tổng phòng</th>
                                    <th style="text-align:center">Phòng trống</th>
                                    <th style="text-align:center">Sức chứa</th>
                                    <th style="text-align:center">Đã sử dụng</th>
                                    <th>Tỷ lệ lấp đầy</th>
                                </tr>
                            </thead>
                            <tbody id="dormitory-stats-body"></tbody>
                        </table>
                    </div>
                </div>

                <!-- Chart + Activity 2-column layout on wide screens -->
                <div class="dashboard-bottom-grid">
                    <div class="chart-section" style="margin-bottom: 0;">
                        <div class="chart-header">
                            <h2>Phân Bố Sinh Viên Theo Năm</h2>
                        </div>
                        <div style="position: relative; height: 380px;">
                            <canvas id="year-distribution-chart"></canvas>
                        </div>
                    </div>

                    <div class="activity-section" style="margin-bottom: 0;">
                        <h2 class="section-heading" style="margin-bottom: 0;"><i class="fas fa-history"></i> Hoạt Động Gần Đây</h2>
                        <div class="activity-list" id="activity-list" style="padding: 0.5rem 1.5rem 1rem;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        let yearDistributionChart = null;

        // Load dashboard stats on page load
        window.addEventListener('load', function() {
            loadDashboardStats();
            // Auto refresh every 60 seconds
            setInterval(loadDashboardStats, 60000);
        });

        // Main function to load dashboard statistics
        async function loadDashboardStats() {
            const loadingEl = document.getElementById('loading');
            const dashboardContent = document.getElementById('dashboard-content');
            
            if (loadingEl) loadingEl.style.display = 'block';
            if (dashboardContent) dashboardContent.style.display = 'none';
            
            try {
                const response = await fetch('/admin/dashboard/stats');
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const data = await response.json();

                if (data.success && data.stats) {
                    // Render all dashboard components
                    renderStats(data.stats.summary || {});
                    renderDormitoryTable(data.stats.dormitories || []);
                    renderActivities(data.stats.recentActivity || []);
                    renderApplicationStats(data.stats.applications || {});
                    
                    // Load year distribution chart
                    await loadYearDistributionChart();

                    if (loadingEl) loadingEl.style.display = 'none';
                    if (dashboardContent) dashboardContent.style.display = 'block';
                } else {
                    throw new Error(data.error || 'Invalid response format');
                }
            } catch (error) {
                console.error('Error loading dashboard:', error);
                if (loadingEl) {
                    loadingEl.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle"></i>
                            <p>Không thể tải dữ liệu. Vui lòng thử lại.</p>
                            <button onclick="loadDashboardStats()" class="btn btn-primary mt-2">
                                <i class="fas fa-redo"></i> Thử lại
                            </button>
                        </div>
                    `;
                }
                
                // Show default empty state
                renderStats({});
                renderDormitoryTable([]);
                renderActivities([]);
            }
        }

        // Render summary statistics cards
        function renderStats(stats) {
            const statsGrid = document.getElementById('stats-grid');
            if (!statsGrid) return;
            
            // Extract stats with default values
            const totalStudents = stats.totalStudents || 0;
            const totalRooms = stats.totalRooms || 0;
            const availableRooms = stats.availableRooms || 0;
            const totalCapacity = stats.totalCapacity || 0;
            const occupiedSpots = stats.occupiedSpots || 0;
            const occupancyRate = stats.overallOccupancyRate || 0;
            const pendingApplications = stats.pendingApplications || 0;
            
            const statsCards = [
                {
                    title: 'Sinh viên đang ở KTX',
                    value: totalStudents.toLocaleString('vi-VN'),
                    label: 'Tổng số sinh viên',
                    color: 'blue',
                    icon: 'fas fa-users'
                },
                {
                    title: 'Phòng trống',
                    value: availableRooms.toLocaleString('vi-VN'),
                    label: `Trên tổng ${totalRooms.toLocaleString('vi-VN')} phòng`,
                    color: 'green',
                    icon: 'fas fa-door-open'
                },
                {
                    title: 'Đơn chờ duyệt',
                    value: pendingApplications.toLocaleString('vi-VN'),
                    label: 'Cần xử lý',
                    color: 'orange',
                    icon: 'fas fa-clock'
                },
                {
                    title: 'Tỷ lệ sử dụng',
                    value: `${occupancyRate}%`,
                    label: `${occupiedSpots.toLocaleString('vi-VN')}/${totalCapacity.toLocaleString('vi-VN')} chỗ`,
                    color: occupancyRate > 80 ? 'red' : (occupancyRate > 50 ? 'orange' : 'blue'),
                    icon: 'fas fa-chart-pie'
                }
            ];

            statsGrid.innerHTML = statsCards.map(card => `
                <div class="stat-card ${card.color}">
                    <div class="stat-icon">
                        <i class="${card.icon}"></i>
                    </div>
                    <h3>${escapeHtml(card.title)}</h3>
                    <div class="value">${card.value}</div>
                    <div class="label">${escapeHtml(card.label)}</div>
                </div>
            `).join('');
        }

        // Render dormitory statistics table
        function renderDormitoryTable(dormitories) {
            const tbody = document.getElementById('dormitory-stats-body');
            if (!tbody) return;
            
            if (!dormitories || dormitories.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="text-center py-4">
                            <i class="fas fa-inbox fa-2x text-muted mb-2"></i>
                            <p class="text-muted">Chưa có dữ liệu ký túc xá</p>
                        </td>
                    </tr>
                `;
                return;
            }
            
            tbody.innerHTML = dormitories.map(dorm => {
                const name = dorm.name || 'N/A';
                const totalRooms = dorm.totalRooms || 0;
                const availableRooms = dorm.availableRooms || 0;
                const capacity = dorm.totalCapacity || 0;
                const occupied = dorm.occupiedSpots || 0;
                const rate = dorm.occupancyRate || 0;
                
                let progressClass = 'low';
                if (rate > 80) progressClass = 'high';
                else if (rate > 50) progressClass = 'medium';

                return `
                    <tr>
                        <td><strong>${escapeHtml(name)}</strong></td>
                        <td class="text-center">${totalRooms.toLocaleString('vi-VN')}</td>
                        <td class="text-center">${availableRooms.toLocaleString('vi-VN')}</td>
                        <td class="text-center">${capacity.toLocaleString('vi-VN')}</td>
                        <td class="text-center">${occupied.toLocaleString('vi-VN')}</td>
                        <td>
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span><strong>${rate}%</strong></span>
                                <small class="text-muted">${occupied}/${capacity}</small>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill ${progressClass}" 
                                     style="width: ${rate}%" 
                                     title="${rate}% lấp đầy">
                                </div>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        // Render application statistics
        function renderApplicationStats(applications) {
            const container = document.getElementById('application-stats-container');
            if (!container) return;
            
            const pending = applications.pending || 0;
            const approved = applications.approved || 0;
            const rejected = applications.rejected || 0;
            const total = applications.total || (pending + approved + rejected);
            
            container.innerHTML = `
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="app-stat-card pending">
                            <div class="icon"><i class="fas fa-clock"></i></div>
                            <div class="number">${pending.toLocaleString('vi-VN')}</div>
                            <div class="label">Đang chờ</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="app-stat-card approved">
                            <div class="icon"><i class="fas fa-check-circle"></i></div>
                            <div class="number">${approved.toLocaleString('vi-VN')}</div>
                            <div class="label">Đã duyệt</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="app-stat-card rejected">
                            <div class="icon"><i class="fas fa-times-circle"></i></div>
                            <div class="number">${rejected.toLocaleString('vi-VN')}</div>
                            <div class="label">Đã từ chối</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="app-stat-card total">
                            <div class="icon"><i class="fas fa-file-alt"></i></div>
                            <div class="number">${total.toLocaleString('vi-VN')}</div>
                            <div class="label">Tổng cộng</div>
                        </div>
                    </div>
                </div>
            `;
        }

        // Load and render year distribution chart
        async function loadYearDistributionChart() {
            try {
                const response = await fetch('/admin/dashboard/year-distribution');
                
                if (!response.ok) return; // Silently fail if endpoint not available
                
                const result = await response.json();

                if (result.success && result.data) {
                    renderYearDistributionChart(result.data);
                }
            } catch (error) {
                console.warn('Year distribution chart not available:', error);
            }
        }

        // Render year distribution chart using vertical bars
        function renderYearDistributionChart(data) {
            const canvas = document.getElementById('year-distribution-chart');
            if (!canvas) return;
            
            // Destroy existing chart
            if (yearDistributionChart) {
                yearDistributionChart.destroy();
            }

            const yearColors = {
                'Năm 1': '#FF6B6B',
                'Năm 2': '#9E9E9E',
                'Năm 3': '#FFC107',
                'Năm 4': '#FF9800',
                'Năm 5': '#9C27B0',
                'Năm 6': '#4CAF50',
                'Sau đại học': '#2196F3'
            };

            const ctx = canvas.getContext('2d');
            yearDistributionChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.labels || [],
                    datasets: [{
                        label: 'Số sinh viên',
                        data: data.values || [],
                        backgroundColor: data.labels?.map(label => yearColors[label] || '#95a5a6') || [],
                        borderColor: data.labels?.map(label => yearColors[label] || '#95a5a6') || [],
                        borderWidth: 0,
                        borderRadius: 8
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.parsed.x || 0;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                    return `${value} sinh viên (${percentage}%)`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value;
                                }
                            },
                            grid: {
                                color: '#f0f0f0'
                            }
                        },
                        y: {
                            grid: {
                                display: false
                            }
                        }
                    }
                },
                plugins: [{
                    id: 'dataLabels',
                    afterDatasetsDraw(chart) {
                        const { ctx, data, scales } = chart;
                        ctx.font = 'bold 13px Arial';
                        ctx.fillStyle = '#2c3e50';
                        ctx.textAlign = 'start';
                        ctx.textBaseline = 'middle';

                        data.datasets.forEach((dataset) => {
                            const xScale = scales.x;
                            const yScale = scales.y;
                            const total = dataset.data.reduce((a, b) => a + b, 0);

                            dataset.data.forEach((value, index) => {
                                const x = xScale.getPixelForValue(value);
                                const y = yScale.getPixelForValue(index);
                                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                ctx.fillText(`${percentage}%`, x + 8, y);
                            });
                        });
                    }
                }]
            });
        }

        // Render recent activities
        function renderActivities(activities) {
            const activityList = document.getElementById('activity-list');
            if (!activityList) return;
            
            if (!activities || activities.length === 0) {
                activityList.innerHTML = `
                    <div class="text-center py-4">
                        <i class="fas fa-history fa-2x text-muted mb-2"></i>
                        <p class="text-muted">Chưa có hoạt động nào</p>
                    </div>
                `;
                return;
            }

            activityList.innerHTML = activities.map(activity => {
                const actionLabels = {
                    'login': 'đã đăng nhập',
                    'logout': 'đã đăng xuất',
                    'register_success': 'đã đăng ký thành công',
                    'register_failed': 'đăng ký thất bại',
                    'checked_in': 'đã nhận phòng',
                    'checked_out': 'đã trả phòng',
                    'room_assigned': 'được phân phòng',
                    'room_changed': 'đã đổi phòng',
                    'application_approved': 'được duyệt đơn',
                    'application_rejected': 'bị từ chối đơn',
                    'profile_updated': 'đã cập nhật hồ sơ',
                    'payment_success': 'thanh toán thành công',
                    'payment_failed': 'thanh toán thất bại',
                    'registration_approved': 'đăng ký được duyệt',
                    'registration_rejected': 'đăng ký bị từ chối'
                };

                const actionIcons = {
                    'login': 'fas fa-sign-in-alt',
                    'logout': 'fas fa-sign-out-alt',
                    'register_success': 'fas fa-check-circle',
                    'register_failed': 'fas fa-times-circle',
                    'checked_in': 'fas fa-door-open',
                    'checked_out': 'fas fa-door-closed',
                    'room_assigned': 'fas fa-home',
                    'room_changed': 'fas fa-exchange-alt',
                    'application_approved': 'fas fa-thumbs-up',
                    'application_rejected': 'fas fa-thumbs-down',
                    'profile_updated': 'fas fa-user-edit',
                    'payment_success': 'fas fa-dollar-sign',
                    'payment_failed': 'fas fa-exclamation-triangle'
                };

                const userName = activity.userId?.name || activity.actor || 'Người dùng';
                const studentId = activity.userId?.studentId || '';
                const timestamp = activity.createdAt || activity.timestamp;
                const time = timestamp ? new Date(timestamp).toLocaleString('vi-VN') : 'N/A';
                const action = actionLabels[activity.action] || activity.action || 'thực hiện hành động';
                const icon = actionIcons[activity.action] || 'fas fa-info-circle';
                const description = activity.description || '';

                return `
                    <div class="activity-item">
                        <div class="activity-icon">
                            <i class="${icon}"></i>
                        </div>
                        <div class="activity-content">
                            <div class="activity-header">
                                <span class="actor">
                                    <strong>${escapeHtml(userName)}</strong>
                                    ${studentId ? `<small class="text-muted">(${escapeHtml(studentId)})</small>` : ''}
                                </span>
                                <span class="time">${time}</span>
                            </div>
                            <div class="activity-text">
                                ${action}
                                ${description ? `<div class="text-muted small mt-1">${escapeHtml(description)}</div>` : ''}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // Utility function to escape HTML
        function escapeHtml(text) {
            if (!text) return '';
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.toString().replace(/[&<>"']/g, m => map[m]);
        }

        // Export for external use
        window.loadDashboardStats = loadDashboardStats;
    </script>
</body>
</html>
