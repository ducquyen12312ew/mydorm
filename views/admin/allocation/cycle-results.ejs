<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kết quả chu kỳ - <%= cycle.name %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background: #f5f5f5;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            padding: 30px;
        }
        
        .header {
            border-bottom: 2px solid #007bff;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }
        
        .header h1 {
            color: #333;
            font-size: 28px;
            margin-bottom: 10px;
        }
        
        .header .info {
            color: #666;
            font-size: 14px;
        }
        
        .back-btn {
            display: inline-block;
            padding: 8px 16px;
            background: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            margin-bottom: 20px;
        }
        
        .back-btn:hover {
            background: #5a6268;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        .stat-card.success {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        }
        
        .stat-card.warning {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }
        
        .stat-card.info {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }
        
        .stat-card .label {
            font-size: 14px;
            opacity: 0.9;
            margin-bottom: 8px;
        }
        
        .stat-card .value {
            font-size: 32px;
            font-weight: bold;
        }
        
        .section {
            margin-bottom: 40px;
        }
        
        .section h2 {
            color: #333;
            font-size: 20px;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e0e0e0;
        }
        
        .quota-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        
        .quota-table th,
        .quota-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #e0e0e0;
        }
        
        .quota-table th {
            background: #f8f9fa;
            font-weight: bold;
            color: #495057;
        }
        
        .quota-table tr:hover {
            background: #f8f9fa;
        }
        
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
        }
        
        .status-badge.sufficient {
            background: #d4edda;
            color: #155724;
        }
        
        .status-badge.deficit {
            background: #f8d7da;
            color: #721c24;
        }
        
        .status-badge.surplus {
            background: #d1ecf1;
            color: #0c5460;
        }
        
        .status-badge.available {
            background: #fff3cd;
            color: #856404;
        }
        
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e0e0e0;
            border-radius: 4px;
            overflow: hidden;
            margin-top: 8px;
        }
        
        .progress-fill {
            height: 100%;
            background: #007bff;
            transition: width 0.3s ease;
        }
        
        .progress-fill.full {
            background: #28a745;
        }
        
        .progress-fill.over {
            background: #dc3545;
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="/admin/allocation/policies" class="back-btn">← Quay lại danh sách</a>
        
        <div class="header">
            <h1>Kết quả chu kỳ: <%= cycle.name %></h1>
            <div class="info">
                <p><strong>Năm học:</strong> <%= cycle.academicYear %></p>
                <p><strong>Trạng thái:</strong> <%= cycle.status %></p>
                <p><strong>Đăng ký:</strong> <%= new Date(cycle.registrationStart).toLocaleDateString('vi-VN') %> - <%= new Date(cycle.registrationEnd).toLocaleDateString('vi-VN') %></p>
                <% if (cycle.executedAt) { %>
                <p><strong>Thực thi:</strong> <%= new Date(cycle.executedAt).toLocaleString('vi-VN') %></p>
                <% } %>
            </div>
        </div>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="label">Tổng đăng ký</div>
                <div class="value"><%= cycle.stats?.totalRegistrations || 0 %></div>
            </div>
            <div class="stat-card success">
                <div class="label">Đã phân bổ</div>
                <div class="value"><%= cycle.stats?.totalAllocated || 0 %></div>
            </div>
            <div class="stat-card warning">
                <div class="label">Đang chờ</div>
                <div class="value"><%= cycle.stats?.totalWaitlisted || 0 %></div>
            </div>
            <div class="stat-card info">
                <div class="label">Quota</div>
                <div class="value"><%= cycle.quotaSnapshot?.total || 0 %></div>
            </div>
        </div>
        
        <% if (status && status.categories) { %>
        <div class="section">
            <h2>Chi tiết theo nhóm năm</h2>
            <table class="quota-table">
                <thead>
                    <tr>
                        <th>Nhóm năm</th>
                        <th>Trạng thái</th>
                        <th>Đã đăng ký</th>
                        <th>Đã phân bổ</th>
                        <th>Quota</th>
                        <th>Tỷ lệ lấp đầy</th>
                    </tr>
                </thead>
                <tbody>
                    <% Object.keys(status.categories).forEach(category => { 
                        const cat = status.categories[category];
                        const fillPercent = cat.quota > 0 ? (cat.allocated / cat.quota * 100).toFixed(1) : 0;
                        const progressClass = fillPercent >= 100 ? 'over' : (fillPercent >= 90 ? 'full' : '');
                    %>
                    <tr>
                        <td><strong><%= category %></strong></td>
                        <td>
                            <span class="status-badge <%= cat.status.toLowerCase() %>">
                                <%= cat.status %>
                            </span>
                        </td>
                        <td><%= cat.registered %></td>
                        <td><%= cat.allocated %></td>
                        <td><%= cat.quota %></td>
                        <td>
                            <%= fillPercent %>%
                            <div class="progress-bar">
                                <div class="progress-fill <%= progressClass %>" 
                                     style="width: <%= Math.min(fillPercent, 100) %>%">
                                </div>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
        <% } %>
        
        <% if (cycle.quotaSnapshot) { %>
        <div class="section">
            <h2>Quota Snapshot (Lúc tạo chu kỳ)</h2>
            <table class="quota-table">
                <thead>
                    <tr>
                        <th>Loại</th>
                        <th>Giá trị</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Năm 1</td>
                        <td><%= cycle.quotaSnapshot.year1 || 0 %></td>
                    </tr>
                    <tr>
                        <td>Năm 2-3</td>
                        <td><%= cycle.quotaSnapshot.year2_3 || 0 %></td>
                    </tr>
                    <tr>
                        <td>Năm 4+</td>
                        <td><%= cycle.quotaSnapshot.year4_plus || 0 %></td>
                    </tr>
                    <tr>
                        <td>Dự trữ</td>
                        <td><%= cycle.quotaSnapshot.reserved || 0 %></td>
                    </tr>
                    <tr>
                        <td><strong>Tổng</strong></td>
                        <td><strong><%= cycle.quotaSnapshot.total || 0 %></strong></td>
                    </tr>
                </tbody>
            </table>
        </div>
        <% } %>
        
        <% if (status && status.summary) { %>
        <div class="section">
            <h2>Tóm tắt</h2>
            <table class="quota-table">
                <tbody>
                    <tr>
                        <td><strong>Tổng phòng có sẵn:</strong></td>
                        <td><%= status.summary.totalAvailableRooms || 0 %></td>
                    </tr>
                    <tr>
                        <td><strong>Phòng đã phân bổ:</strong></td>
                        <td><%= status.summary.totalAllocated || 0 %></td>
                    </tr>
                    <tr>
                        <td><strong>Sinh viên chờ:</strong></td>
                        <td><%= status.summary.totalWaitlisted || 0 %></td>
                    </tr>
                    <tr>
                        <td><strong>Tỷ lệ lấp đầy tổng:</strong></td>
                        <td>
                            <% const totalFill = status.summary.totalAvailableRooms > 0 
                                ? (status.summary.totalAllocated / status.summary.totalAvailableRooms * 100).toFixed(1) 
                                : 0; 
                            %>
                            <%= totalFill %>%
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
</body>
</html>
