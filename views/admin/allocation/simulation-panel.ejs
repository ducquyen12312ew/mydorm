<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Allocation Simulation - Dormitory Management</title>
    <link rel="stylesheet" href="/css/admin-dashboard-modern.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <style>
        .simulation-split {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-top: 2rem;
        }

        .simulation-panel {
            background: var(--color-bg-card);
            border: 1px solid var(--color-border);
            border-radius: 12px;
            padding: 2rem;
        }

        .simulation-results {
            background: var(--color-bg-card);
            border: 1px solid var(--color-border);
            border-radius: 12px;
            padding: 2rem;
        }

        .year-group-allocation {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .year-group-card {
            padding: 1.5rem;
            background: var(--color-bg-light);
            border-radius: 8px;
            border-left: 4px solid var(--color-info);
        }

        .year-group-card.year1 { border-left-color: #C8102E; }
        .year-group-card.year2 { border-left-color: #A20D25; }
        .year-group-card.year3 { border-left-color: #6B7280; }
        .year-group-card.year4 { border-left-color: #9CA3AF; }

        .year-group-name {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--color-text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .year-group-number {
            font-size: 2rem;
            font-weight: 700;
            margin: 0.5rem 0;
            color: var(--color-text-primary);
        }

        .year-group-percentage {
            font-size: 0.95rem;
            color: var(--color-text-secondary);
        }

        .allocation-comparison {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1rem;
        }

        .comparison-item {
            text-align: center;
            padding: 1rem;
            background: var(--color-bg-light);
            border-radius: 6px;
        }

        .comparison-label {
            font-size: 0.75rem;
            color: var(--color-text-secondary);
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .comparison-value {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .warning-list {
            margin-top: 1rem;
        }

        .warning-item {
            padding: 0.75rem;
            background: var(--color-bg-light);
            border-left: 3px solid var(--color-warning);
            border-radius: 4px;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .warning-item.error {
            border-left-color: var(--color-danger);
        }

        .warning-item.success {
            border-left-color: var(--color-success);
        }

        .policy-selector {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .comparison-mode {
            display: flex;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .comparison-mode input[type="checkbox"] {
            width: auto;
        }

        @media (max-width: 1024px) {
            .simulation-split {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Header -->
        <div class="dashboard-header">
            <div>
                <h1>🧪 Allocation Simulation</h1>
                <p style="color: var(--color-text-secondary); margin-top: 0.5rem;">Test policies before applying them</p>
            </div>
            <div style="text-align: right;">
                <div class="badge active">
                    <span style="width: 8px; height: 8px; background: #6B7280; border-radius: 50%; display: inline-block;"></span>
                    Simulation Ready
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="grid-2">
            <!-- Simulation Panel -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">⚙️ Simulation Configuration</h2>
                </div>

                <div class="form-group">
                    <label for="cycle-select">Select Allocation Cycle</label>
                    <select id="cycle-select" style="width: 100%;">
                        <option value="">-- Loading cycles --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="policy-select">Select Policy to Simulate</label>
                    <select id="policy-select" style="width: 100%;">
                        <option value="">-- Loading policies --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>
                        <input type="checkbox" id="compare-mode"> 
                        Compare Two Policies
                    </label>
                </div>

                <div id="policy-selector-2" class="policy-selector hidden">
                    <div class="form-group">
                        <label for="policy-select-2">Policy 2</label>
                        <select id="policy-select-2"></select>
                    </div>
                </div>

                <div class="btn-group">
                    <button class="btn btn-primary" id="btn-run-simulation">
                        📊 Run Simulation
                    </button>
                    <button class="btn btn-secondary" id="btn-reset">
                        🔄 Reset
                    </button>
                </div>

                <!-- Loading State -->
                <div id="loading-state" class="hidden" style="margin-top: 1rem; text-align: center;">
                    <div class="loading" style="display: inline-block;"></div>
                    <p style="margin-top: 1rem; color: var(--color-text-secondary);">Running simulation...</p>
                </div>
            </div>

            <!-- Results Panel -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">📈 Simulation Results</h2>
                    <span id="result-status" class="status-badge info hidden">
                        <span class="status-indicator"></span>
                        Results Ready
                    </span>
                </div>

                <div id="results-placeholder" style="text-align: center; color: var(--color-text-secondary); padding: 2rem;">
                    Run a simulation to see results
                </div>

                <div id="results-content" class="hidden">
                    <!-- Allocated vs Waitlisted -->
                    <div class="metric-group">
                        <div class="metric">
                            <div class="metric-number" id="result-allocated">0</div>
                            <div class="metric-label">Allocated</div>
                        </div>
                        <div class="metric">
                            <div class="metric-number" id="result-waitlisted">0</div>
                            <div class="metric-label">Waitlisted</div>
                        </div>
                        <div class="metric">
                            <div class="metric-number" id="result-efficiency">0%</div>
                            <div class="metric-label">Efficiency</div>
                        </div>
                    </div>

                    <!-- Year Group Breakdown -->
                    <div style="margin-top: 1.5rem;">
                        <h3 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 1rem;">📋 By Year Group</h3>
                        <div class="year-group-allocation" id="year-group-results"></div>
                    </div>

                    <!-- Fairness Score -->
                    <div style="margin-top: 1.5rem;">
                        <h3 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 0.5rem;">⚖️ Fairness Score</h3>
                        <div class="progress-bar">
                            <div class="progress-fill" id="fairness-bar" style="width: 80%;"></div>
                        </div>
                        <div class="progress-text">
                            <span>Max Deviation</span>
                            <span id="fairness-value">0%</span>
                        </div>
                    </div>

                    <!-- Warnings -->
                    <div id="warnings-section" class="hidden" style="margin-top: 1.5rem;">
                        <h3 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 1rem;">⚠️ Warnings & Notes</h3>
                        <div class="warning-list" id="warnings-list"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Comparison Results (if comparing) -->
        <div id="comparison-results" class="hidden" style="margin-top: 2rem;">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">🔄 Policy Comparison Results</h2>
                </div>

                <div class="grid-2">
                    <div>
                        <h3 style="font-weight: 600; margin-bottom: 1rem;" id="policy1-name">Policy 1</h3>
                        <div class="metric-group">
                            <div class="metric">
                                <div class="metric-number" id="policy1-allocated">0</div>
                                <div class="metric-label">Allocated</div>
                            </div>
                            <div class="metric">
                                <div class="metric-number" id="policy1-efficiency">0%</div>
                                <div class="metric-label">Efficiency</div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h3 style="font-weight: 600; margin-bottom: 1rem;" id="policy2-name">Policy 2</h3>
                        <div class="metric-group">
                            <div class="metric">
                                <div class="metric-number" id="policy2-allocated">0</div>
                                <div class="metric-label">Allocated</div>
                            </div>
                            <div class="metric">
                                <div class="metric-number" id="policy2-efficiency">0%</div>
                                <div class="metric-label">Efficiency</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="margin-top: 2rem; padding: 1.5rem; background: var(--color-bg-light); border-radius: 8px;">
                    <h3 style="font-weight: 600; margin-bottom: 0.5rem;">✅ Recommendation</h3>
                    <p id="comparison-recommendation" style="color: var(--color-text-secondary);"></p>
                </div>
            </div>
        </div>

        <!-- Execution Section -->
        <div class="card" style="margin-top: 2rem;">
            <div class="card-header">
                <h2 class="card-title">🚀 Apply Simulation Results</h2>
            </div>

            <div class="alert info">
                <div class="alert-icon">ℹ️</div>
                <div class="alert-content">
                    <div class="alert-title">Simulation Complete</div>
                    <p>Review the results above. If satisfied, apply this allocation to the system.</p>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem;">
                <button class="btn btn-secondary" id="btn-back-to-sim">
                    ← Back to Simulation
                </button>
                <button class="btn btn-success" id="btn-apply-allocation" disabled>
                    ✓ Apply Now
                </button>
            </div>
        </div>
    </div>

    <script>
        // ========== SIMULATION CONTROLLER ==========
        
        const SimulationController = {
            cycleId: null,
            policyId: null,
            policyId2: null,
            compareMode: false,
            lastResults: null,

            async init() {
                this.setupEventListeners();
                await this.loadCycles();
                await this.loadPolicies();
            },

            setupEventListeners() {
                document.getElementById('btn-run-simulation').addEventListener('click', () => this.runSimulation());
                document.getElementById('btn-reset').addEventListener('click', () => this.reset());
                document.getElementById('cycle-select').addEventListener('change', (e) => this.cycleId = e.target.value);
                document.getElementById('policy-select').addEventListener('change', (e) => this.policyId = e.target.value);
                document.getElementById('policy-select-2').addEventListener('change', (e) => this.policyId2 = e.target.value);
                document.getElementById('compare-mode').addEventListener('change', (e) => {
                    this.compareMode = e.target.checked;
                    document.getElementById('policy-selector-2').classList.toggle('hidden', !this.compareMode);
                });
                document.getElementById('btn-apply-allocation').addEventListener('click', () => this.applyAllocation());
                document.getElementById('btn-back-to-sim').addEventListener('click', () => this.reset());
            },

            async loadCycles() {
                try {
                    const response = await fetch('/api/allocation/simulate');
                    const data = await response.json();
                    
                    const select = document.getElementById('cycle-select');
                    select.innerHTML = data.policies ? '-- Ready --' : '-- No cycles available --';
                } catch (error) {
                    console.error('Failed to load cycles', error);
                }
            },

            async loadPolicies() {
                try {
                    const response = await fetch('/api/allocation/simulate');
                    const data = await response.json();
                    
                    const selects = [
                        document.getElementById('policy-select'),
                        document.getElementById('policy-select-2')
                    ];

                    selects.forEach(select => {
                        select.innerHTML = '<option value="">-- Select Policy --</option>';
                        data.policies?.forEach(policy => {
                            const option = document.createElement('option');
                            option.value = policy.id;
                            option.textContent = policy.name;
                            select.appendChild(option);
                        });
                    });
                } catch (error) {
                    console.error('Failed to load policies', error);
                }
            },

            async runSimulation() {
                if (!this.cycleId) {
                    alert('Please select a cycle');
                    return;
                }

                if (!this.policyId) {
                    alert('Please select a policy');
                    return;
                }

                document.getElementById('loading-state').classList.remove('hidden');
                document.getElementById('results-placeholder').classList.add('hidden');
                document.getElementById('results-content').classList.add('hidden');

                try {
                    if (this.compareMode && this.policyId2) {
                        // Comparison mode
                        const response = await fetch('/api/allocation/simulate/compare', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                cycleId: this.cycleId,
                                policyId1: this.policyId,
                                policyId2: this.policyId2
                            })
                        });

                        const data = await response.json();
                        this.displayComparisonResults(data);
                    } else {
                        // Single policy simulation
                        const response = await fetch('/api/allocation/simulate/run', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                cycleId: this.cycleId,
                                policyId: this.policyId
                            })
                        });

                        const data = await response.json();
                        if (data.success) {
                            this.lastResults = data;
                            this.displayResults(data);
                        } else {
                            alert('Simulation failed: ' + data.error);
                        }
                    }
                } catch (error) {
                    console.error('Simulation error', error);
                    alert('Simulation failed: ' + error.message);
                } finally {
                    document.getElementById('loading-state').classList.add('hidden');
                }
            },

            displayResults(data) {
                const sim = data.simulation;
                const stats = sim.stats;

                // Update metrics
                document.getElementById('result-allocated').textContent = stats.totalAllocated;
                document.getElementById('result-waitlisted').textContent = stats.totalWaitlisted;
                
                const efficiency = ((stats.totalAllocated / (stats.totalAllocated + stats.totalWaitlisted)) * 100).toFixed(1);
                document.getElementById('result-efficiency').textContent = efficiency + '%';

                // Update fairness
                const fairnessPercent = (100 - sim.fairness.maxDeviationPercent);
                document.getElementById('fairness-bar').style.width = fairnessPercent + '%';
                document.getElementById('fairness-value').textContent = sim.fairness.maxDeviationPercent.toFixed(1) + '%';

                // Year group breakdown
                const ygContainer = document.getElementById('year-group-results');
                ygContainer.innerHTML = '';
                Object.entries(stats.byYearGroup).forEach(([yg, counts]) => {
                    const card = document.createElement('div');
                    card.className = `year-group-card ${yg}`;
                    card.innerHTML = `
                        <div class="year-group-name">${yg.replace(/_/g, ' ')}</div>
                        <div class="year-group-number">${counts.allocated}</div>
                        <div class="year-group-percentage">Allocated: ${(((counts.allocated) / (counts.allocated + counts.waitlisted)) * 100) || 0}%</div>
                        <div class="year-group-percentage">Waitlisted: ${counts.waitlisted}</div>
                    `;
                    ygContainer.appendChild(card);
                });

                // Warnings
                if (sim.warnings && sim.warnings.length > 0) {
                    document.getElementById('warnings-section').classList.remove('hidden');
                    const warningsList = document.getElementById('warnings-list');
                    warningsList.innerHTML = '';
                    sim.warnings.forEach(warning => {
                        const item = document.createElement('div');
                        item.className = `warning-item ${warning.level.toLowerCase()}`;
                        item.innerHTML = `<strong>${warning.message}</strong><br><small>${warning.suggestion || ''}</small>`;
                        warningsList.appendChild(item);
                    });
                } else {
                    document.getElementById('warnings-section').classList.add('hidden');
                }

                // Show results
                document.getElementById('results-content').classList.remove('hidden');
                document.getElementById('result-status').classList.remove('hidden');
                document.getElementById('btn-apply-allocation').disabled = false;
            },

            displayComparisonResults(data) {
                document.getElementById('comparison-results').classList.remove('hidden');
                
                const comp = data.comparison;
                document.getElementById('policy1-name').textContent = comp.policy1.name;
                document.getElementById('policy1-allocated').textContent = comp.policy1.allocation;
                document.getElementById('policy1-efficiency').textContent = comp.policy1.efficiency;

                document.getElementById('policy2-name').textContent = comp.policy2.name;
                document.getElementById('policy2-allocated').textContent = comp.policy2.allocation;
                document.getElementById('policy2-efficiency').textContent = comp.policy2.efficiency;

                const rec = data.recommendation;
                document.getElementById('comparison-recommendation').textContent = rec.reason;
            },

            async applyAllocation() {
                if (!confirm('Apply this allocation to the system? This action cannot be undone.')) {
                    return;
                }

                try {
                    // TODO: Call actual apply API
                    alert('Allocation applied successfully!');
                    this.reset();
                } catch (error) {
                    alert('Failed to apply allocation: ' + error.message);
                }
            },

            reset() {
                this.cycleId = null;
                this.policyId = null;
                this.policyId2 = null;
                this.compareMode = false;
                this.lastResults = null;

                document.getElementById('cycle-select').value = '';
                document.getElementById('policy-select').value = '';
                document.getElementById('policy-select-2').value = '';
                document.getElementById('compare-mode').checked = false;
                document.getElementById('policy-selector-2').classList.add('hidden');
                document.getElementById('results-content').classList.add('hidden');
                document.getElementById('results-placeholder').classList.remove('hidden');
                document.getElementById('comparison-results').classList.add('hidden');
                document.getElementById('btn-apply-allocation').disabled = true;
            }
        };

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', () => SimulationController.init());
    </script>
</body>
</html>
