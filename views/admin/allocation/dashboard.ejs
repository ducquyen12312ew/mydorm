﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <link rel="icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="shortcut icon" type="image/png" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <link rel="apple-touch-icon" href="https://res.cloudinary.com/dysgt8t4d/image/upload/v1782017194/logoedorm_c33vj5_obiwxk.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Phân Bổ - <%= academicYear %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --red: #C8102E; --red-grad: linear-gradient(135deg,#E11D2A,#B20C26); --red-dark: #9E0C24;
            --body-bg: linear-gradient(180deg,#FBF8F3,#F5EFE7);
            --card-bg: linear-gradient(180deg,#FFFFFF,#FCFAF6);
            --card-border: #EFE8DF;
            --shadow: 0 1px 2px rgba(43,35,32,.04),0 20px 38px -26px rgba(43,35,32,.2);
            --text: #2B2320; --muted: #7C7166; --muted2: #A89C8E;
            --th-bg: #F7F1E8; --th-color: #9A8F84;
            --row-border: #F4EEE5; --row-alt: #FDFBF8; --row-hover: #FAF5EE;
        }
        body { font-family: 'Josefin Sans', system-ui, sans-serif; background: var(--body-bg); color: var(--text); }
        .container { max-width: 1400px; margin: 0 auto; padding: 0 1.5rem 3rem; }

        .header {
            background: var(--card-bg); padding: 1.2rem 1.5rem;
            border-radius: 17px; border: 1px solid var(--card-border);
            box-shadow: var(--shadow); margin-bottom: 1.25rem;
            display: flex; justify-content: space-between; align-items: center;
        }
        .header h1 { font-family: 'Josefin Sans', sans-serif; color: var(--text); font-size: 1.25rem; font-weight: 600; }

        .back-btn {
            padding: .45rem 1rem; background: #fff; color: var(--text);
            text-decoration: none; border-radius: 11px;
            border: 1px solid #E7DECF; font-size: .82rem; font-weight: 600;
            transition: all .18s;
        }
        .back-btn:hover { background: #FBF8F3; border-color: #D4C9BC; color: var(--text); }

        .filter-bar {
            background: var(--card-bg); padding: .9rem 1.25rem;
            border-radius: 14px; border: 1px solid var(--card-border);
            box-shadow: var(--shadow); margin-bottom: 1.25rem;
            display: flex; align-items: center; gap: 1rem;
        }
        .filter-bar label { font-size: .82rem; font-weight: 700; color: var(--muted); }
        .filter-bar select {
            padding: .45rem .85rem; border: 1px solid var(--card-border);
            border-radius: 9px; font-size: .84rem; color: var(--text);
            background: #fff; font-family: 'Josefin Sans', sans-serif; cursor: pointer;
        }
        .filter-bar select:focus { border-color: var(--red); outline: none; box-shadow: 0 0 0 3px rgba(200,16,46,.08); }

        .rebalance-alert {
            background: #FBF1DC; border: 1px solid #EDD28A;
            padding: .875rem 1.25rem; border-radius: 12px;
            margin-bottom: 1.25rem; display: flex;
            justify-content: space-between; align-items: center; gap: 1rem;
        }
        .rebalance-alert .text { color: #A07010; font-size: .84rem; }
        .rebalance-btn {
            padding: .45rem 1rem; background: linear-gradient(135deg,#D9A22B,#B8891E);
            color: #fff; border: none; border-radius: 10px;
            cursor: pointer; font-weight: 600; font-size: .82rem;
            box-shadow: 0 6px 14px -6px rgba(185,138,42,.5);
            transition: all .18s; white-space: nowrap;
        }
        .rebalance-btn:hover { filter: brightness(1.06); transform: translateY(-1px); }

        .categories-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 1.25rem; }

        .category-card {
            background: var(--card-bg); border-radius: 17px;
            border: 1px solid var(--card-border); box-shadow: var(--shadow); overflow: hidden;
        }
        .category-header { padding: 1rem 1.25rem; color: #fff; font-size: .95rem; font-weight: 700; font-family: 'Josefin Sans', sans-serif; }
        .category-header.year1    { background: linear-gradient(135deg,#E11D2A,#B20C26); }
        .category-header.year2_3  { background: linear-gradient(135deg,#C8102E,#8E0B22); }
        .category-header.year4_plus { background: linear-gradient(135deg,#7C7166,#5C534E); }

        .category-body { padding: 1.25rem; }

        .status-badge {
            display: inline-block; padding: .28rem .75rem;
            border-radius: 20px; font-size: .72rem; font-weight: 700;
            text-transform: uppercase; margin-bottom: 1rem; border: 1px solid transparent;
        }
        .status-badge.sufficient     { background: #E4F6EF; color: #0B7A54; border-color: #A7DFC8; }
        .status-badge.deficit        { background: #FCEDEF; color: #9B1C30; border-color: #F5C2C7; }
        .status-badge.surplus        { background: #E9F0FE; color: #1A4FBD; border-color: #AABEF8; }
        .status-badge.available_capacity { background: #FBF1DC; color: #A07010; border-color: #EDD28A; }

        .stat-row { display: flex; justify-content: space-between; padding: .55rem 0; border-bottom: 1px solid var(--row-border); }
        .stat-row:last-child { border-bottom: none; }
        .stat-label { color: var(--muted); font-size: .83rem; }
        .stat-value { color: var(--text); font-weight: 600; font-size: .87rem; }

        .progress-bar { width: 100%; height: 6px; background: #EFE8DF; border-radius: 4px; overflow: hidden; margin-top: .75rem; }
        .progress-fill { height: 100%; background: linear-gradient(90deg,#E11D2A,#B20C26); transition: width 0.4s ease; border-radius: 4px; }
        .progress-fill.warning { background: linear-gradient(90deg,#D9A22B,#B8891E); }
        .progress-fill.danger  { background: linear-gradient(90deg,#E11D2A,#B20C26); }

        .buildings-list { margin-top: 1rem; }

        .smart-panel {
            background: var(--card-bg); padding: 1.25rem 1.5rem;
            border-radius: 17px; border: 1px solid var(--card-border);
            box-shadow: var(--shadow); margin-bottom: 1.25rem;
        }
        .smart-header { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
        .smart-header h2 { font-family: 'Josefin Sans', sans-serif; font-size: 1.1rem; font-weight: 600; color: var(--text); }
        .smart-controls { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; }
        .smart-controls label { font-size: .82rem; color: var(--muted); }
        .smart-controls input { width: 90px; padding: .45rem .75rem; border: 1px solid var(--card-border); border-radius: 9px; font-size: .84rem; font-family: 'Josefin Sans', sans-serif; }
        .smart-controls input:focus { border-color: var(--red); outline: none; }

        .btn-primary {
            background: var(--red-grad); color: #fff; border: none;
            border-radius: 11px; padding: .45rem 1rem; cursor: pointer;
            font-size: .82rem; font-weight: 600; font-family: 'Josefin Sans', sans-serif;
            box-shadow: 0 8px 20px -8px rgba(200,16,46,.55);
            transition: all .18s;
        }
        .btn-primary:hover { filter: brightness(1.06); transform: translateY(-1px); }
        .btn-accent {
            background: #fff; color: var(--text); border: 1px solid #E7DECF;
            border-radius: 11px; padding: .45rem 1rem; cursor: pointer;
            font-size: .82rem; font-weight: 600; font-family: 'Josefin Sans', sans-serif;
            transition: all .18s;
        }
        .btn-accent:hover { background: #FBF8F3; border-color: #D4C9BC; }

        .smart-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: .75rem; margin-bottom: 1rem; }
        .smart-stat { background: #FAF6F0; border: 1px solid var(--card-border); border-radius: 11px; padding: .875rem 1rem; }
        .smart-stat .label { font-size: 10.5px; color: var(--th-color); margin-bottom: .35rem; text-transform: uppercase; letter-spacing: .08em; font-weight: 700; }
        .smart-stat .value { font-family: 'Josefin Sans', sans-serif; font-size: 1.4rem; font-weight: 600; color: var(--text); }

        .smart-lists { display: grid; grid-template-columns: 1fr 1fr; gap: .875rem; }
        .smart-list { border: 1px solid var(--card-border); border-radius: 12px; overflow: hidden; background: #fff; }
        .smart-list h3 { background: var(--th-bg); padding: .65rem 1rem; font-size: .82rem; font-weight: 700; border-bottom: 1px solid var(--row-border); color: var(--text); }

        .smart-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
        .smart-table th,
        .smart-table td { padding: .55rem .875rem; border-bottom: 1px solid var(--row-border); text-align: left; color: var(--text); }
        .smart-table th { color: var(--th-color); background: var(--th-bg); font-size: 10.5px; text-transform: uppercase; font-weight: 700; letter-spacing: .06em; }
        .smart-table tbody tr:nth-child(even) td { background: var(--row-alt); }
        .smart-table tbody tr:hover td { background: var(--row-hover); }

        .fairness-line { margin: .75rem 0 0; padding: .6rem 1rem; border-radius: 9px; font-size: .82rem; }
        .fairness-line.balanced   { background: #E4F6EF; color: #0B7A54; border: 1px solid #A7DFC8; }
        .fairness-line.needs-review { background: #FBF1DC; color: #A07010; border: 1px solid #EDD28A; }

        .empty-note { padding: 1rem; color: var(--muted); font-size: .84rem; }

        @media (max-width: 980px) { .smart-lists { grid-template-columns: 1fr; } }

        .building-item { background: #FAF6F0; padding: .75rem; border-radius: 9px; border: 1px solid var(--card-border); margin-bottom: .5rem; }
        .building-item .name { font-weight: 600; color: var(--text); font-size: .84rem; margin-bottom: .25rem; }
        .building-item .stats { font-size: .78rem; color: var(--muted); }
        .building-item .rooms-bar { margin-top: .5rem; }
    </style>
</head>
<body>
    <%- include('../navbar', { activeNav: 'allocation' }) %>
    <div class="container">
        <div class="header">
            <h1>Dashboard Phân Bổ Phòng - <%= academicYear %></h1>
            <a href="/admin/allocation/policies" class="back-btn">← Quay lại</a>
        </div>
        
        <div class="filter-bar">
            <label for="yearGroupFilter">Lọc theo nhóm năm:</label>
            <select id="yearGroupFilter" onchange="filterYearGroup(this.value)">
                <option value="">Tất cả</option>
                <option value="year1" <%= selectedYearGroup === 'year1' ? 'selected' : '' %>>Năm 1</option>
                <option value="year2_3" <%= selectedYearGroup === 'year2_3' ? 'selected' : '' %>>Năm 2-3</option>
                <option value="year4_plus" <%= selectedYearGroup === 'year4_plus' ? 'selected' : '' %>>Năm 4+</option>
            </select>
        </div>
        
        <% if (rebalancingNeeded) { %>
        <div class="rebalance-alert">
            <div class="text">
                <strong>⚠️ Cần tái cân bằng!</strong> Có sự mất cân bằng giữa các nhóm năm. Nhấn để xem đề xuất.
            </div>
            <button class="rebalance-btn" onclick="viewRebalanceSuggestions()">
                Xem đề xuất tái cân bằng
            </button>
        </div>
        <% } %>

        <div class="smart-panel">
            <div class="smart-header">
                <div>
                    <h2 style="font-size: 20px; color: #0f172a; margin-bottom: 4px;">Approval Dashboard</h2>
                    <% if (selectedCycle) { %>
                    <div style="font-size: 13px; color: #475569;">Chu kỳ: <strong><%= selectedCycle.name %></strong> (<%= selectedCycle.status %>)</div>
                    <% } else { %>
                    <div style="font-size: 13px; color: #b45309;">Không tìm thấy chu kỳ PENDING/RUNNING để tự động duyệt.</div>
                    <% } %>
                </div>
                <div class="smart-controls">
                    <label for="autoPercentInput" style="font-size: 13px; color: #475569;">Auto approve %</label>
                    <input id="autoPercentInput" type="number" min="50" max="60" value="55" />
                    <button class="btn-primary" onclick="refreshApprovalDashboard()">Refresh Ranking</button>
                    <button class="btn-accent" onclick="runAutoAssignment()">Auto Assign Top</button>
                </div>
            </div>

            <div id="smartSummary" class="smart-summary"></div>
            <div id="fairnessLine"></div>

            <div class="smart-lists">
                <div class="smart-list">
                    <h3>Quick Approve List</h3>
                    <div id="quickApproveContainer" class="empty-note">Chưa có dữ liệu</div>
                </div>
                <div class="smart-list">
                    <h3>Manual Review List</h3>
                    <div id="manualReviewContainer" class="empty-note">Chưa có dữ liệu</div>
                </div>
            </div>
        </div>
        
        <div class="categories-grid">
            <% if (dashboard && dashboard.categories) { 
                Object.keys(dashboard.categories).forEach(categoryKey => {
                    const category = dashboard.categories[categoryKey];
                    const fillPercent = category.quota > 0 
                        ? (category.allocated / category.quota * 100).toFixed(1) 
                        : 0;
                    const progressClass = fillPercent >= 100 ? 'danger' : (fillPercent >= 80 ? 'warning' : '');
            %>
            <div class="category-card">
                <div class="category-header <%= categoryKey %>">
                    <%= categoryKey === 'year1' ? 'Sinh viên Năm 1' : 
                        categoryKey === 'year2_3' ? 'Sinh viên Năm 2-3' : 
                        'Sinh viên Năm 4+' %>
                </div>
                
                <div class="category-body">
                    <span class="status-badge <%= category.status.toLowerCase().replace('_', '') %>">
                        <%= category.status %>
                    </span>
                    
                    <div class="stat-row">
                        <span class="stat-label">Đã đăng ký</span>
                        <span class="stat-value"><%= category.registered %></span>
                    </div>
                    
                    <div class="stat-row">
                        <span class="stat-label">Đã phân bổ</span>
                        <span class="stat-value"><%= category.allocated %></span>
                    </div>
                    
                    <div class="stat-row">
                        <span class="stat-label">Quota</span>
                        <span class="stat-value"><%= category.quota %></span>
                    </div>
                    
                    <div class="stat-row">
                        <span class="stat-label">Phòng trống</span>
                        <span class="stat-value"><%= category.available %></span>
                    </div>
                    
                    <% if (category.waitlisted > 0) { %>
                    <div class="stat-row">
                        <span class="stat-label">Đang chờ</span>
                        <span class="stat-value" style="color: #dc3545;"><%= category.waitlisted %></span>
                    </div>
                    <% } %>
                    
                    <div class="progress-bar">
                        <div class="progress-fill <%= progressClass %>" 
                             style="width: <%= Math.min(fillPercent, 100) %>%">
                        </div>
                    </div>
                    <div style="text-align: center; margin-top: 8px; font-size: 14px; color: #666;">
                        <%= fillPercent %>% lấp đầy
                    </div>
                    
                    <% if (category.buildings && category.buildings.length > 0) { %>
                    <div class="buildings-list">
                        <strong style="display: block; margin-bottom: 10px;">Tòa nhà:</strong>
                        <% category.buildings.forEach(building => { 
                            const buildingFill = building.totalRooms > 0 
                                ? (building.allocatedRooms / building.totalRooms * 100).toFixed(0) 
                                : 0;
                        %>
                        <div class="building-item">
                            <div class="name"><%= building.name %></div>
                            <div class="stats">
                                Phân bổ: <%= building.allocatedRooms %>/<%= building.totalRooms %> 
                                (<%= buildingFill %>%)
                            </div>
                            <div class="rooms-bar">
                                <div class="progress-bar" style="height: 6px;">
                                    <div class="progress-fill" style="width: <%= buildingFill %>%;"></div>
                                </div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }); %>
            <% } %>
        </div>
    </div>
    
    <script>
        const selectedCycleId = '<%= selectedCycle ? selectedCycle._id : "" %>';

        function getAutoPercent() {
            const input = document.getElementById('autoPercentInput');
            const value = Number(input.value || 55);
            if (!Number.isFinite(value)) return 55;
            if (value < 50) return 50;
            if (value > 60) return 60;
            return Math.round(value);
        }

        function renderSmartSummary(data) {
            const summary = document.getElementById('smartSummary');
            const totals = data.totals || {};
            const settings = data.settings || {};

            summary.innerHTML = `
                <div class="smart-stat"><div class="label">Applications</div><div class="value">${totals.applications || 0}</div></div>
                <div class="smart-stat"><div class="label">Auto %</div><div class="value">${settings.autoApprovePercent || 0}%</div></div>
                <div class="smart-stat"><div class="label">Auto Slots</div><div class="value">${settings.autoSlots || 0}</div></div>
                <div class="smart-stat"><div class="label">Quick Approve</div><div class="value">${totals.quickApprove || 0}</div></div>
                <div class="smart-stat"><div class="label">Manual Review</div><div class="value">${totals.manualReview || 0}</div></div>
            `;

            const fairness = data.fairness || {};
            const fairnessLine = document.getElementById('fairnessLine');
            const fairnessClass = (fairness.fairnessStatus || '') === 'BALANCED'
                ? 'fairness-line balanced'
                : 'fairness-line needs-review';
            fairnessLine.className = fairnessClass;
            fairnessLine.textContent = `Fairness: ${(fairness.fairnessStatus || 'UNKNOWN')} | Max deviation ${fairness.maxDeviationPercent || 0}%`;
        }

        function renderStudentTable(items) {
            if (!items || items.length === 0) {
                return '<div class="empty-note">Không có dữ liệu.</div>';
            }

            const rows = items.slice(0, 50).map(item => {
                const score = Number(item.smartScore || 0).toFixed(2);
                const distance = item.criteria?.distanceFromHomeKm ?? 0;
                const fin = item.criteria?.financialDifficultyScore ?? 0;
                const pri = item.criteria?.priorityLevelScore ?? 0;
                return `
                    <tr>
                        <td>#${item.rank}</td>
                        <td>${item.studentName || 'N/A'}</td>
                        <td>${item.yearGroup || '-'}</td>
                        <td>${score}</td>
                        <td>${distance}km / ${fin} / ${pri}</td>
                    </tr>
                `;
            }).join('');

            return `
                <table class="smart-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Student</th>
                            <th>Year</th>
                            <th>Score</th>
                            <th>Criteria (D/F/P)</th>
                        </tr>
                    </thead>
                    <tbody>${rows}</tbody>
                </table>
            `;
        }

        async function refreshApprovalDashboard() {
            if (!selectedCycleId) return;
            const autoApprovePercent = getAutoPercent();

            try {
                const response = await fetch(`/api/allocation/cycles/${selectedCycleId}/approval-dashboard?autoApprovePercent=${autoApprovePercent}`);
                const payload = await response.json();
                if (!response.ok) {
                    throw new Error(payload.error || 'Không tải được approval dashboard');
                }

                const data = payload.data || {};
                renderSmartSummary(data);
                document.getElementById('quickApproveContainer').innerHTML = renderStudentTable(data.quickApproveList || []);
                document.getElementById('manualReviewContainer').innerHTML = renderStudentTable(data.manualReviewList || []);
            } catch (error) {
                alert(error.message || 'Đã xảy ra lỗi khi tải ranking');
            }
        }

        async function runAutoAssignment() {
            if (!selectedCycleId) return;
            const autoApprovePercent = getAutoPercent();

            try {
                const response = await fetch(`/api/allocation/cycles/${selectedCycleId}/auto-assign`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ autoApprovePercent })
                });
                const payload = await response.json();
                if (!response.ok) {
                    throw new Error(payload.error || 'Auto assign thất bại');
                }

                const assigned = payload.results?.assigned?.length || 0;
                const failed = payload.results?.failed?.length || 0;
                alert(`Auto assign hoàn tất. Assigned: ${assigned}, Failed: ${failed}`);
                await refreshApprovalDashboard();
            } catch (error) {
                alert(error.message || 'Đã xảy ra lỗi khi auto assign');
            }
        }

        function filterYearGroup(yearGroup) {
            const url = new URL(window.location);
            if (yearGroup) {
                url.searchParams.set('yearGroup', yearGroup);
            } else {
                url.searchParams.delete('yearGroup');
            }
            window.location.href = url.toString();
        }
        
        function viewRebalanceSuggestions() {
            // Get current cycle ID (you might need to pass this from backend)
            alert('Chức năng xem đề xuất tái cân bằng đang được phát triển. Sử dụng API để xem chi tiết.');
            // window.location.href = '/admin/allocation/rebalance/' + cycleId;
        }

        if (selectedCycleId) {
            refreshApprovalDashboard();
        }
    </script>
    <%- include('../footer') %>
</body>
</html>
