<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đề xuất Chính sách - Kế hoạch Năm Next</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #3b82f6;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
      --gray-900: #111827;
      --gray-800: #1f2937;
      --gray-700: #374151;
      --gray-600: #4b5563;
      --gray-500: #6b7280;
      --gray-200: #e5e7eb;
      --gray-100: #f3f4f6;
      --gray-50: #f9fafb;
      
      --shadow-sm: 0 1px 2px 0 rgba(0,0,0,0.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.1);
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
      background: var(--gray-50);
      color: var(--gray-900);
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
    }

    .header {
      margin-bottom: 2rem;
    }

    .header-title {
      font-size: 2rem;
      font-weight: 700;
      color: var(--gray-900);
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .header-title i {
      color: var(--primary);
    }

    .header-subtitle {
      color: var(--gray-600);
      font-size: 0.95rem;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* CARD COMPONENT */
    /* ═══════════════════════════════════════════════════════════════════════ */

    .card {
      background: white;
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--gray-200);
      transition: all 0.3s ease;
    }

    .card:hover {
      box-shadow: var(--shadow-lg);
    }

    .card-header {
      border-bottom: 1px solid var(--gray-100);
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
    }

    .card-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--gray-900);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .card-title i {
      color: var(--primary);
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* ALERT COMPONENT */
    /* ═══════════════════════════════════════════════════════════════════════ */

    .alert {
      padding: 1rem;
      border-radius: 8px;
      border-left: 4px solid;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .alert-info {
      background: #eff6ff;
      border-color: var(--primary);
      color: #1e3a8a;
    }

    .alert-success {
      background: #f0fdf4;
      border-color: var(--success);
      color: #166534;
    }

    .alert-warning {
      background: #fef3c7;
      border-color: var(--warning);
      color: #92400e;
    }

    .alert-danger {
      background: #fee2e2;
      border-color: var(--danger);
      color: #991b1b;
    }

    .alert-icon {
      font-size: 1.25rem;
      flex-shrink: 0;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* GRID LAYOUT */
    /* ═══════════════════════════════════════════════════════════════════════ */

    .grid {
      display: grid;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .grid-2 {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }

    .grid-3 {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }

    .grid-4 {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* STAT CARD */
    /* ═══════════════════════════════════════════════════════════════════════ */

    .stat-card {
      background: white;
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--gray-200);
    }

    .stat-card.primary {
      border-left: 4px solid var(--primary);
    }

    .stat-card.success {
      border-left: 4px solid var(--success);
    }

    .stat-card.warning {
      border-left: 4px solid var(--warning);
    }

    .stat-label {
      font-size: 0.875rem;
      color: var(--gray-600);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .stat-value {
      font-size: 2rem;
      font-weight: 700;
      color: var(--gray-900);
      margin-bottom: 0.25rem;
    }

    .stat-meta {
      font-size: 0.875rem;
      color: var(--gray-500);
    }

    .stat-trend {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      font-size: 0.875rem;
      font-weight: 600;
      margin-top: 0.5rem;
    }

    .stat-trend.up {
      color: var(--success);
    }

    .stat-trend.down {
      color: var(--danger);
    }

    .stat-trend.stable {
      color: var(--gray-500);
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* COMPARISON TABLE */
    /* ═══════════════════════════════════════════════════════════════════════ */

    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
    }

    .comparison-table thead {
      background: var(--gray-50);
      border-bottom: 1px solid var(--gray-200);
    }

    .comparison-table th {
      padding: 1rem;
      text-align: left;
      font-weight: 600;
      color: var(--gray-700);
      border: 1px solid var(--gray-200);
    }

    .comparison-table td {
      padding: 1rem;
      border: 1px solid var(--gray-200);
    }

    .comparison-table tbody tr {
      transition: background 0.2s ease;
    }

    .comparison-table tbody tr:hover {
      background: var(--gray-50);
    }

    .comparison-label {
      font-weight: 600;
      color: var(--gray-900);
    }

    .comparison-current {
      color: var(--gray-600);
    }

    .comparison-suggested {
      color: var(--primary);
      font-weight: 600;
    }

    .delta-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 6px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .delta-badge.increase {
      background: #dcfce7;
      color: #166534;
    }

    .delta-badge.decrease {
      background: #fee2e2;
      color: #991b1b;
    }

    .delta-badge.neutral {
      background: var(--gray-100);
      color: var(--gray-600);
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* BUTTON */
    /* ═══════════════════════════════════════════════════════════════════════ */

    .btn {
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: #2563eb;
      transform: translateY(-1px);
      box-shadow: var(--shadow-lg);
    }

    .btn-success {
      background: var(--success);
      color: white;
    }

    .btn-success:hover {
      background: #059669;
      transform: translateY(-1px);
      box-shadow: var(--shadow-lg);
    }

    .btn-secondary {
      background: var(--gray-200);
      color: var(--gray-700);
    }

    .btn-secondary:hover {
      background: var(--gray-300);
    }

    .btn-outline {
      background: transparent;
      color: var(--primary);
      border: 2px solid var(--primary);
    }

    .btn-outline:hover {
      background: var(--primary);
      color: white;
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    .button-group {
      display: flex;
      gap: 1rem;
      margin-top: 1.5rem;
      flex-wrap: wrap;
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* LOADING STATE */
    /* ═══════════════════════════════════════════════════════════════════════ */

    .loading {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 3px solid var(--gray-200);
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .skeleton {
      background: linear-gradient(90deg, var(--gray-200) 25%, var(--gray-100) 50%, var(--gray-200) 75%);
      background-size: 200% 100%;
      animation: loading 1.5s infinite;
    }

    @keyframes loading {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    /* ═══════════════════════════════════════════════════════════════════════ */
    /* RESPONSIVE */
    /* ═══════════════════════════════════════════════════════════════════════ */

    @media (max-width: 768px) {
      .container {
        padding: 1rem;
      }

      .header-title {
        font-size: 1.5rem;
      }

      .grid-2,
      .grid-3,
      .grid-4 {
        grid-template-columns: 1fr;
      }

      .comparison-table {
        font-size: 0.85rem;
      }

      .comparison-table th,
      .comparison-table td {
        padding: 0.75rem;
      }

      .button-group {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</head>
<body>

<div class="container">
  <!-- Header -->
  <div class="header">
    <h1 class="header-title">
      <i class="fas fa-wand-magic-sparkles"></i>
      Đề xuất Chính sách Năm Tới
    </h1>
    <p class="header-subtitle">Dựa trên phân tích dữ liệu lịch sử, hệ thống gợi ý cấu hình phòng tối ưu</p>
  </div>

  <!-- Info Alert -->
  <div class="alert alert-info">
    <div class="alert-icon">
      <i class="fas fa-circle-info"></i>
    </div>
    <div>
      <strong>Cách thức hoạt động:</strong> Hệ thống phân tích dữ liệu từ 5 năm quá khứ, tính toán tỷ lệ giữ chân, nhu cầu nhập học và đưa ra đề xuất cấu hình phòng tối ưu.
    </div>
  </div>

  <!-- Analysis Tab -->
  <div class="card" style="margin-bottom: 2rem;">
    <div class="card-header">
      <div class="card-title">
        <i class="fas fa-chart-bar"></i>
        Thông tin phân tích
      </div>
    </div>

    <!-- Controls -->
    <div style="margin-bottom: 1.5rem;">
      <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Chọn năm học:</label>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <select id="yearSelector" style="padding: 0.75rem; border: 1px solid var(--gray-200); border-radius: 8px; font-size: 0.95rem;">
          <option value="">-- Chọn năm học --</option>
          <option value="2025-2026">2025-2026</option>
          <option value="2026-2027">2026-2027</option>
          <option value="2027-2028">2027-2028</option>
          <option value="2028-2029">2028-2029</option>
        </select>
        <button class="btn btn-primary" onclick="generateAnalysis()">
          <i class="fas fa-play"></i>
          Tạo phân tích
        </button>
      </div>
    </div>

    <!-- Loading -->
    <div id="loadingState" style="display: none; text-align: center; padding: 2rem;">
      <div class="loading"></div>
      <p style="color: var(--gray-600); margin-top: 1rem;">Đang phân tích dữ liệu...</p>
    </div>

    <!-- Content -->
    <div id="analysisContent" style="display: none;">
      <!-- Key Metrics -->
      <div class="grid grid-4">
        <div class="stat-card primary">
          <div class="stat-label">Độ tin cậy</div>
          <div class="stat-value"><span id="confidenceScore">--</span>%</div>
          <div class="stat-meta">Độ chính xác của đề xuất</div>
        </div>
        <div class="stat-card success">
          <div class="stat-label">Tỷ lệ giữ chân</div>
          <div class="stat-value"><span id="retentionRate">--</span>%</div>
          <div class="stat-meta">Trung bình qua các năm</div>
        </div>
        <div class="stat-card warning">
          <div class="stat-label">Nhu cầu Năm 1</div>
          <div class="stat-value"><span id="year1Demand">--</span></div>
          <div class="stat-meta">Sinh viên năm 1 hiện tại</div>
        </div>
        <div class="stat-card primary">
          <div class="stat-label">Xu hướng</div>
          <div class="stat-value" id="trendIndicator">---</div>
          <div class="stat-meta">Nhu cầu NĂNG CAO/THẤP</div>
        </div>
      </div>

      <!-- Comparison Table -->
      <div style="margin-top: 2rem;">
        <h3 style="margin-bottom: 1rem; font-size: 1.1rem; font-weight: 600;">So sánh Chính sách</h3>
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Cohort</th>
              <th style="text-align: center;">Chính sách Hiện tại</th>
              <th style="text-align: center;">Đề xuất</th>
              <th style="text-align: center;">Thay đổi</th>
              <th style="text-align: center;">% Thay đổi</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="comparison-label">Năm 1 (50%)</td>
              <td style="text-align: center;" class="comparison-current"><span id="current-year1">--</span></td>
              <td style="text-align: center;" class="comparison-suggested"><span id="suggested-year1">--</span></td>
              <td style="text-align: center;">
                <span class="delta-badge neutral" id="delta-year1">0</span>
              </td>
              <td style="text-align: center;" id="pct-delta-year1">0%</td>
            </tr>
            <tr>
              <td class="comparison-label">Năm 2 (25%)</td>
              <td style="text-align: center;" class="comparison-current"><span id="current-year2">--</span></td>
              <td style="text-align: center;" class="comparison-suggested"><span id="suggested-year2">--</span></td>
              <td style="text-align: center;">
                <span class="delta-badge neutral" id="delta-year2">0</span>
              </td>
              <td style="text-align: center;" id="pct-delta-year2">0%</td>
            </tr>
            <tr>
              <td class="comparison-label">Năm 3 (15%)</td>
              <td style="text-align: center;" class="comparison-current"><span id="current-year3">--</span></td>
              <td style="text-align: center;" class="comparison-suggested"><span id="suggested-year3">--</span></td>
              <td style="text-align: center;">
                <span class="delta-badge neutral" id="delta-year3">0</span>
              </td>
              <td style="text-align: center;" id="pct-delta-year3">0%</td>
            </tr>
            <tr>
              <td class="comparison-label">Năm 4+ (10%)</td>
              <td style="text-align: center;" class="comparison-current"><span id="current-year4">--</span></td>
              <td style="text-align: center;" class="comparison-suggested"><span id="suggested-year4">--</span></td>
              <td style="text-align: center;">
                <span class="delta-badge neutral" id="delta-year4">0</span>
              </td>
              <td style="text-align: center;" id="pct-delta-year4">0%</td>
            </tr>
            <tr style="background: var(--gray-50); font-weight: 600;">
              <td class="comparison-label">Tổng cộng</td>
              <td style="text-align: center;" id="current-total">--</td>
              <td style="text-align: center; color: var(--primary);" id="suggested-total">--</td>
              <td style="text-align: center; border-top: 2px solid var(--gray-300); border-bottom: 2px solid var(--gray-300);">—</td>
              <td style="text-align: center; border-top: 2px solid var(--gray-300); border-bottom: 2px solid var(--gray-300);">—</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Retention Analysis -->
      <div style="margin-top: 2rem; padding: 1.5rem; background: var(--gray-50); border-radius: 8px;">
        <h3 style="margin-bottom: 1rem; font-size: 1.1rem; font-weight: 600;">Phân tích Giữ chân</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
          <div>
            <div style="font-size: 0.85rem; color: var(--gray-600); font-weight: 600; margin-bottom: 0.5rem;">Năm 1 → Năm 2</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><span id="retention-1-2">--</span>%</div>
          </div>
          <div>
            <div style="font-size: 0.85rem; color: var(--gray-600); font-weight: 600; margin-bottom: 0.5rem;">Năm 2 → Năm 3</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><span id="retention-2-3">--</span>%</div>
          </div>
          <div>
            <div style="font-size: 0.85rem; color: var(--gray-600); font-weight: 600; margin-bottom: 0.5rem;">Năm 3 → Năm 4</div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><span id="retention-3-4">--</span>%</div>
          </div>
        </div>
      </div>

      <!-- Recommendations -->
      <div style="margin-top: 2rem; padding: 1.5rem; background: #f0fdf4; border-left: 4px solid var(--success); border-radius: 8px;">
        <h3 style="margin-bottom: 1rem; font-size: 1.1rem; font-weight: 600; color: #166534;">Khuyến nghị</h3>
        <div id="recommendationsText" style="color: #166534; line-height: 1.8; white-space: pre-wrap; font-size: 0.95rem;">
          Đang chường...
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="button-group">
        <button class="btn btn-success" onclick="applySuggestion()">
          <i class="fas fa-check"></i>
          Áp dụng đề xuất
        </button>
        <button class="btn btn-secondary" onclick="downloadReport()">
          <i class="fas fa-download"></i>
          Tải báo cáo
        </button>
        <button class="btn btn-outline" onclick="resetAnalysis()">
          <i class="fas fa-redo"></i>
          Tạo lại
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
let currentAnalysis = null;
let selectedYear = null;

function generateAnalysis() {
  selectedYear = document.getElementById('yearSelector').value;
  
  if (!selectedYear) {
    alert('Vui lòng chọn năm học');
    return;
  }

  showLoading(true);

  fetch(`/api/planning/analyze/${selectedYear}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      currentAnalysis = d.analysis;
      displayAnalysis();
    } else {
      alert('Lỗi: ' + (d.message || 'Không thể tạo phân tích'));
    }
  })
  .catch(e => alert('Lỗi kết nối: ' + e.message))
  .finally(() => showLoading(false));
}

function displayAnalysis() {
  if (!currentAnalysis) return;

  const analysis = currentAnalysis;
  const retention = analysis.retention;
  const admission = analysis.admission;
  const policy = analysis.suggestedPolicy;

  // Update confidence
  document.getElementById('confidenceScore').textContent = analysis.confidence;

  // Update retention
  const avgRetention = Math.round(
    (retention.year1To2.rate + retention.year2To3.rate + retention.year3To4.rate) / 3
  );
  document.getElementById('retentionRate').textContent = avgRetention;

  // Update demand
  document.getElementById('year1Demand').textContent = admission.year1Demand;
  document.getElementById('trendIndicator').textContent = 
    admission.trend === 'increasing' ? '📈 TĂNG' :
    admission.trend === 'decreasing' ? '📉 GIẢM' :
    '➡️ ỔNDEF';

  // Update retention rates
  document.getElementById('retention-1-2').textContent = retention.year1To2.rate.toFixed(1);
  document.getElementById('retention-2-3').textContent = retention.year2To3.rate.toFixed(1);
  document.getElementById('retention-3-4').textContent = retention.year3To4.rate.toFixed(1);

  // Update policy comparison
  const dist = policy.distribution;
  document.getElementById('suggested-year1').textContent = dist.year1.students;
  document.getElementById('suggested-year2').textContent = dist.year2.students;
  document.getElementById('suggested-year3').textContent = dist.year3.students;
  document.getElementById('suggested-year4').textContent = dist.year4_plus.students;
  document.getElementById('suggested-total').textContent = policy.totalStudents;

  // Update recommendations
  document.getElementById('recommendationsText').textContent = analysis.recommendations;

  // Show content
  document.getElementById('analysisContent').style.display = 'block';
}

function applySuggestion() {
  if (!selectedYear || !currentAnalysis) {
    alert('Vui lòng tạo phân tích trước');
    return;
  }

  const totalRooms = prompt('Nhập tổng số phòng/giường:', '100');
  if (!totalRooms) return;

  fetch(`/api/planning/apply-suggestion/${selectedYear}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      totalRooms: parseInt(totalRooms),
      notes: 'Áp dụng từ đề xuất tự động'
    })
  })
  .then(r => r.json())
  .then(d => {
    if (d.success) {
      alert('✅ Chính sách đã được áp dụng thành công!');
      window.location.href = '/admin/allocation/policies';
    } else {
      alert('Lỗi: ' + (d.message || 'Không thể áp dụng'));
    }
  })
  .catch(e => alert('Lỗi kết nối: ' + e.message));
}

function downloadReport() {
  if (!currentAnalysis) {
    alert('Vui lòng tạo phân tích trước');
    return;
  }

  const report = JSON.stringify(currentAnalysis, null, 2);
  const blob = new Blob([report], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `planning-${selectedYear}.json`;
  a.click();
}

function resetAnalysis() {
  document.getElementById('analysisContent').style.display = 'none';
  document.getElementById('yearSelector').value = '';
  currentAnalysis = null;
}

function showLoading(show) {
  document.getElementById('loadingState').style.display = show ? 'block' : 'none';
  document.getElementById('analysisContent').style.display = show ? 'none' : 'block';
}
</script>

</body>
</html>
