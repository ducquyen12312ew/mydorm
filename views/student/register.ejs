    <!-- Scripts -->
    <script>
        let selectedDormitory = null;
        let selectedRoom = null;
        let priorityPolicies = [];
        let dormitories = [];

        const policies = [
            { id: 'ethnic', label: 'DĂ¢n tá»™c thiá»ƒu sá»‘', hasInput: true, inputLabel: 'Nháº­p dĂ¢n tá»™c' },
            { id: 'poor', label: 'Há»™ nghĂ¨o/Cáº­n nghĂ¨o', hasInput: false },
            { id: 'disability', label: 'NgÆ°á»i khuyáº¿t táº­t', hasInput: false },
            { id: 'orphan', label: 'Tráº» má»“ cĂ´i/HoĂ n cáº£nh khĂ³ khÄƒn', hasInput: false }
        ];

        document.addEventListener('DOMContentLoaded', function() {
            setupHeader();
            loadStudentInfo();
            loadDormitories();
            renderPolicies();
        });

        function setupHeader() {
            const menuToggle = document.getElementById('menuToggle');
            const navContainer = document.getElementById('navContainer');
            
            if (menuToggle && navContainer) {
                menuToggle.addEventListener('click', function() {
                    navContainer.classList.toggle('active');
                });

                const navLinks = navContainer.querySelectorAll('.nav-link');
                navLinks.forEach(link => {
                    link.addEventListener('click', function() {
                        navContainer.classList.remove('active');
                    });
                });
            }

            const dropdownMenu = document.getElementById('dropdownMenu');
            const userProfile = document.querySelector('.user-profile');
            const avatarContainer = document.querySelector('.avatar-container');

            if (avatarContainer && dropdownMenu) {
                avatarContainer.addEventListener('click', function(e) {
                    e.preventDefault();
                    dropdownMenu.classList.toggle('show');
                });

                document.addEventListener('click', function(e) {
                    if (!userProfile.contains(e.target)) {
                        dropdownMenu.classList.remove('show');
                    }
                });
            }
        }

        function loadStudentInfo() {
            fetch('/api/student/profile')
                .then(res => res.json())
                .then(data => {
                    console.log('[DEBUG] Student profile data:', data);
                    if (data.success && data.student) {
                        console.log('[DEBUG] Setting student info:', data.student);
                        document.getElementById('studentId').value = data.student.studentId || 'N/A';
                        document.getElementById('fullName').value = data.student.name || 'N/A';
                        document.getElementById('email').value = data.student.email || '';
                        document.getElementById('phone').value = data.student.phone || '';
                        
                        // Pre-fill major and cohort if available, but allow manual edit
                        const majorField = document.getElementById('major');
                        const cohortField = document.getElementById('cohort');
                        
                        if (majorField && data.student.major) majorField.value = data.student.major;
                        if (cohortField && data.student.cohort) cohortField.value = data.student.cohort;
                        
                        console.log('[DEBUG] Major set to:', majorField ? majorField.value : 'field not found');
                        console.log('[DEBUG] Cohort set to:', cohortField ? cohortField.value : 'field not found');
                    } else {
                        showAlert('Lá»—i: ' + (data.error || 'KhĂ´ng thá»ƒ láº¥y thĂ´ng tin sinh viĂªn'), 'error');
                    }
                })
                .catch(err => {
                    console.error('[ERROR] Fetching student profile:', err);
                    showAlert('Lá»—i: ' + err.message, 'error');
                });
        }

        function loadDormitories() {
            fetch('/api/dormitories')
                .then(res => res.json())
                .then(data => {
                    console.log('[DEBUG] Dormitories data:', data);
                    if (data.success && data.dormitories) {
                        dormitories = data.dormitories;
                        console.log(`[DEBUG] Found ${dormitories.length} dormitories`);
                        dormitories.forEach(d => {
                            console.log(`[DEBUG] Dormitory: ${d.name} - Rooms: ${d.rooms ? d.rooms.length : 0}`);
                        });
                        
                        const select = document.getElementById('dormitory');
                        dormitories.forEach(dorm => {
                            const option = document.createElement('option');
                            option.value = dorm._id;
                            option.textContent = dorm.name;
                            select.appendChild(option);
                        });
                    } else {
                        showAlert('Lá»—i: ' + (data.error || 'KhĂ´ng thá»ƒ táº£i kĂ½ tĂºc xĂ¡'), 'error');
                    }
                })
                .catch(err => {
                    console.error('[ERROR] Fetching dormitories:', err);
                    showAlert('Lá»—i táº£i kĂ½ tĂºc xĂ¡: ' + err.message, 'error');
                });
        }

        function onDormitoryChange() {
            const dormId = document.getElementById('dormitory').value;
            const dormStatus = document.getElementById('dormStatus');
            
            if (!dormId) {
                document.getElementById('roomSelectionCard').classList.add('section-hidden');
                document.getElementById('policiesCard').classList.add('section-hidden');
                document.getElementById('submitBtn').disabled = true;
                dormStatus.textContent = '';
                selectedDormitory = null;
                selectedRoom = null;
                return;
            }

            const dorm = dormitories.find(d => d._id === dormId);
            if (dorm) {
                const totalCapacity = dorm.rooms ? dorm.rooms.reduce((sum, r) => sum + r.maxCapacity, 0) : 0;
                const totalOccupants = dorm.rooms ? dorm.rooms.reduce((sum, r) => sum + r.currentOccupants, 0) : 0;
                
                if (totalOccupants >= totalCapacity && totalCapacity > 0) {
                    dormStatus.className = 'dorm-status full';
                    dormStatus.textContent = 'âŒ ÄĂ£ háº¿t chá»—';
                    document.getElementById('roomSelectionCard').classList.add('section-hidden');
                    document.getElementById('policiesCard').classList.add('section-hidden');
                    document.getElementById('submitBtn').disabled = true;
                    selectedDormitory = null;
                    selectedRoom = null;
                    return;
                } else {
                    dormStatus.className = 'dorm-status available';
                    dormStatus.textContent = 'âœ“ CĂ²n chá»—';
                }
            }

            selectedDormitory = dormId;
            loadRooms();
            document.getElementById('roomSelectionCard').classList.remove('section-hidden');
            document.getElementById('policiesCard').classList.remove('section-hidden');
        }

        function loadRooms() {
            if (!selectedDormitory) return;

            fetch(`/api/dormitories/${selectedDormitory}/rooms`)
                .then(res => res.json())
                .then(data => {
                    console.log('Room data:', data);
                    if (data.success && data.rooms) {
                        renderRooms(data.rooms);
                    } else {
                        showAlert('Lá»—i: ' + (data.error || 'KhĂ´ng thá»ƒ táº£i phĂ²ng'), 'error');
                    }
                })
                .catch(err => {
                    console.error('Error loading rooms:', err);
                    showAlert('Lá»—i táº£i phĂ²ng: ' + err.message, 'error');
                });
        }

        function renderRooms(rooms) {
            const container = document.getElementById('roomsContainer');
            if (!rooms || rooms.length === 0) {
                container.innerHTML = '<p style="text-align: center; color: #999;">KhĂ´ng cĂ³ phĂ²ng nĂ o</p>';
                return;
            }
            
            // Group rooms by floor
            const roomsByFloor = {};
            rooms.forEach(room => {
                const floor = room.floor || 1;
                if (!roomsByFloor[floor]) {
                    roomsByFloor[floor] = [];
                }
                roomsByFloor[floor].push(room);
            });
            
            // Sort floors and render
            const sortedFloors = Object.keys(roomsByFloor).sort((a, b) => a - b);
            let html = '';
            
            sortedFloors.forEach(floor => {
                const floorRooms = roomsByFloor[floor];
                html += `<div class="floor-section">
                    <div class="floor-title">Táº§ng ${floor}</div>
                    <div class="room-grid">`;
                
                floorRooms.forEach(room => {
                    let status, statusClass;
                    const currentOccupants = room.occupants ? room.occupants.filter(o => o.active).length : 0;
                    const maxCapacity = room.maxCapacity || 4;
                    
                    if (currentOccupants >= maxCapacity) {
                        status = `${currentOccupants}/${maxCapacity}`;
                        statusClass = 'full';
                    } else if (currentOccupants > 0) {
                        status = `${currentOccupants}/${maxCapacity}`;
                        statusClass = 'pending';
                    } else {
                        status = 'CĂ²n trá»‘ng';
                        statusClass = 'available';
                    }

                    html += `
                        <div class="room-card ${statusClass}" id="room_${room._id}"
                             ${statusClass === 'full' ? 'style="cursor: not-allowed"' : `onclick="selectRoom('${room._id}', '${room.roomNumber}')" style="cursor: pointer"`}>
                            <div><strong>${room.roomNumber || 'P' + room._id.substring(0, 4)}</strong></div>
                            <div style="font-size: 0.9rem; margin-top: 0.5rem;">${status}</div>
                        </div>
                    `;
                });
                
                html += `</div></div>`;
            });
            
            container.innerHTML = html;
        }

        function selectRoom(roomId, roomNumber) {
            document.querySelectorAll('.room-card.selected').forEach(el => el.classList.remove('selected'));
            document.getElementById(`room_${roomId}`).classList.add('selected');
            selectedRoom = { id: roomId, number: roomNumber };
            document.getElementById('submitBtn').disabled = false;
        }

        function renderPolicies() {
            const container = document.getElementById('policiesContainer');
            container.innerHTML = policies.map(policy => `
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="policy_${policy.id}" 
                           onchange="togglePolicyFile('${policy.id}')">
                    <label class="form-check-label" for="policy_${policy.id}">
                        ${policy.label}
                    </label>
                    ${policy.hasInput ? `
                        <div id="input_${policy.id}" style="display: none; margin-top: 0.8rem; flex: 100%;">
                            <input type="text" class="form-control" id="text_${policy.id}" 
                                   placeholder="${policy.inputLabel}">
                        </div>
                    ` : ''}
                </div>
                <div id="file_${policy.id}" style="display: none; margin-bottom: 1.5rem;">
                    <div class="upload-area" onclick="document.getElementById('upload_${policy.id}').click()">
                        <i class="fas fa-cloud-upload-alt fa-2x"></i>
                        <p>KĂ©o tháº£ file hoáº·c click Ä‘á»ƒ chá»n</p>
                        <p style="font-size: 0.85rem; color: #666;">PDF, JPG, PNG (tá»‘i Ä‘a 5MB)</p>
                    </div>
                    <input type="file" id="upload_${policy.id}" style="display: none;" 
                           accept=".pdf,.jpg,.jpeg,.png" onchange="updateFileName('${policy.id}')">
                    <div id="fileName_${policy.id}" style="margin-top: 0.5rem; font-size: 0.9rem; color: #666;"></div>
                </div>
            `).join('');
        }

        function togglePolicyFile(policyId) {
            const checkbox = document.getElementById(`policy_${policyId}`);
            const fileDiv = document.getElementById(`file_${policyId}`);
            const inputDiv = document.getElementById(`input_${policyId}`);
            
            if (checkbox.checked) {
                fileDiv.style.display = 'block';
                if (inputDiv) inputDiv.style.display = 'block';
            } else {
                fileDiv.style.display = 'none';
                if (inputDiv) inputDiv.style.display = 'none';
            }
        }

        function updateFileName(policyId) {
            const file = document.getElementById(`upload_${policyId}`).files[0];
            const nameDiv = document.getElementById(`fileName_${policyId}`);
            if (file) {
                nameDiv.textContent = 'âœ“ ' + file.name;
            }
        }

        function submitRegistration() {
            if (!selectedRoom) {
                showAlert('Vui lĂ²ng chá»n phĂ²ng', 'error');
                return;
            }
            
            // Validate required fields
            const studentId = document.getElementById('studentId').value.trim();
            const fullName = document.getElementById('fullName').value.trim();
            const email = document.getElementById('email').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const major = document.getElementById('major').value.trim();
            const cohort = document.getElementById('cohort').value.trim();
            const studentClass = document.getElementById('class').value.trim();
            
            if (!studentId || !fullName) {
                showAlert('ThĂ´ng tin sinh viĂªn khĂ´ng há»£p lá»‡', 'error');
                return;
            }
            if (!email || !phone) {
                showAlert('Vui lĂ²ng nháº­p email vĂ  sá»‘ Ä‘iá»‡n thoáº¡i', 'error');
                return;
            }
            if (!major) {
                showAlert('Vui lĂ²ng nháº­p ngĂ nh há»c', 'error');
                return;
            }
            if (!cohort) {
                showAlert('Vui lĂ²ng nháº­p khĂ³a há»c', 'error');
                return;
            }
            if (!studentClass) {
                showAlert('Vui lĂ²ng nháº­p lá»›p', 'error');
                return;
            }

            const formData = new FormData();
            // Required fields that backend expects
            formData.append('studentId', studentId);
            formData.append('fullName', fullName);
            formData.append('email', email);
            formData.append('phone', phone);
            formData.append('faculty', major); // Using major as faculty
            formData.append('class', studentClass);
            formData.append('dormitoryId', selectedDormitory);
            formData.append('roomNumber', selectedRoom.number); // Backend expects roomNumber, not roomId

            // Process priority policies
            const priorityPoliciesArray = [];
            policies.forEach(policy => {
                const checkbox = document.getElementById(`policy_${policy.id}`);
                if (checkbox.checked) {
                    const policyObj = {
                        type: policy.id,
                        description: policy.label
                    };
                    
                    // Add additional input if applicable
                    if (policy.hasInput) {
                        const textInput = document.getElementById(`text_${policy.id}`);
                        if (textInput && textInput.value) {
                            policyObj.details = textInput.value;
                        }
                    }
                    
                    priorityPoliciesArray.push(policyObj);
                    
                    // Add file with correct field name expected by backend
                    const file = document.getElementById(`upload_${policy.id}`).files[0];
                    if (file) {
                        // Backend expects: fileEthnic, filePoor, fileDisability, fileOrphan
                        const fieldName = 'file' + policy.id.charAt(0).toUpperCase() + policy.id.slice(1);
                        formData.append(fieldName, file);
                    }
                }
            });

            formData.append('priorityPolicies', JSON.stringify(priorityPoliciesArray));

            // Debug logging
            console.log('[SUBMIT] Sending registration data:');
            console.log('- Student ID:', studentId);
            console.log('- Full Name:', fullName);
            console.log('- Dormitory ID:', selectedDormitory);
            console.log('- Room Number:', selectedRoom.number);
            console.log('- Priority Policies:', priorityPoliciesArray);

            document.getElementById('submitBtn').disabled = true;
            document.getElementById('submitBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Äang xá»­ lĂ½...';

            fetch('/api/registration', {
                method: 'POST',
                body: formData
            })
            .then(res => {
                console.log('[SUBMIT] Response status:', res.status);
                return res.json().then(data => ({ status: res.status, data }));
            })
            .then(({ status, data }) => {
                console.log('[SUBMIT] Response data:', data);
                document.getElementById('submitBtn').disabled = false;
                document.getElementById('submitBtn').innerHTML = '<i class="fas fa-check"></i> XĂ¡c nháº­n Ä‘Äƒng kĂ½';

                if (status === 200 && data.success) {
                    showAlert('ÄÄƒng kĂ½ thĂ nh cĂ´ng! ÄÆ¡n cá»§a báº¡n Ä‘ang chá» xĂ©t duyá»‡t.', 'success');
                    document.getElementById('resetBtn').style.display = 'inline-flex';
                    document.getElementById('submitBtn').style.display = 'none';
                    setTimeout(() => location.href = '/room-status', 2000);
                } else {
                    showAlert(data.error || 'ÄÄƒng kĂ½ khĂ´ng thĂ nh cĂ´ng', 'error');
                }
            })
            .catch(err => {
                console.error('[SUBMIT] Error:', err);
                document.getElementById('submitBtn').disabled = false;
                document.getElementById('submitBtn').innerHTML = '<i class="fas fa-check"></i> XĂ¡c nháº­n Ä‘Äƒng kĂ½';
                showAlert('Lá»—i káº¿t ná»‘i: ' + err.message, 'error');
            });
        }

        function resetForm() {
            location.reload();
        }

        function showAlert(message, type) {
            const container = document.getElementById('alertContainer');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type}`;
            alert.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}"></i> ${message}`;
            container.innerHTML = '';
            container.appendChild(alert);

            if (type === 'success') {
                setTimeout(() => alert.remove(), 3000);
            }
        }
    </script>
</body>
</html>
