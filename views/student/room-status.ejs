<script src="/socket.io/socket.io.js"></script>
<script>
// ═══════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════
const esc  = t => t==null?'':String(t).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
const dateFmt = ts => { if(!ts) return '—'; const d=new Date(ts); return isNaN(d)?'—':`${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/${d.getFullYear()}`; };
const relTime = ts => { if(!ts) return ''; const s=Math.floor((Date.now()-new Date(ts))/1000); if(s<60) return 'Vừa xong'; if(s<3600) return Math.floor(s/60)+'p trước'; if(s<86400) return Math.floor(s/3600)+'h trước'; return dateFmt(ts); };
const toAscii = s => (s||'').replace(/[^\x20-\x7E]/g,'').trim();
const PALETTE = ['#4F46E5','#0891B2','#059669','#D97706','#7C3AED','#DC2626','#2563EB','#0D9488'];
const colorOf = str => PALETTE[str.split('').reduce((a,c)=>a+c.charCodeAt(0),0)%PALETTE.length];
function validityDate(yr) {
    if (!yr) return '—';
    const m = String(yr).match(/\d{4}-(\d{4})/);
    if (m) return '31/08/'+m[1];
    const m2 = String(yr).match(/(\d{4})/);
    return m2 ? '31/08/'+m2[1] : '—';
}

// ═══════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════
const RS = { data:null, qrPayload:'', leaflet:null, mapInited:false, roommates:[] };

// ═══════════════════════════════════════════════════
// VIEW SWITCH
// ═══════════════════════════════════════════════════
function showView(name) {
    ['Loading','Allocated','Waitlist','Pending','None','Error'].forEach(v => {
        const el = document.getElementById('view'+v);
        if (el) el.style.display = v.toLowerCase()===name ? '' : 'none';
    });
}

// ═══════════════════════════════════════════════════
// BOOT
// ═══════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', loadStatus);

async function loadStatus() {
    showView('loading');
    try {
        const [rr, wr] = await Promise.all([
            fetch('/api/student/allocation-result', { credentials:'include' }),
            fetch('/api/dormitories/registration',  { credentials:'include' }).catch(()=>null)
        ]);
        const rd = await rr.json();
        let wd = null;
        if (wr?.ok) wd = await wr.json().catch(()=>null);
        renderRegBtn(wd===null ? null : wd.openForRegistration===true);

        if (!rd.success || !rd.data?.registration) { setChip('NONE'); showView('none'); return; }
        const data = rd.data;
        RS.data = data;
        const { flow, registration:reg, roomAllocation:ra, room, dormitory:dorm } = data;

        if (flow === 'allocation') {
            setChipAlloc(reg, dorm, room, ra);
            if (reg.status==='ALLOCATED')  { showView('allocated'); renderAllocated(data); }
            else if (reg.status==='WAITLIST') { showView('waitlist'); renderWaitlist(reg,data); loadWLPos(); initSocket(reg); }
            else if (reg.status==='PENDING')  { showView('pending'); renderPending(reg); }
            else { setChip('NONE'); showView('none'); }
        } else {
            setChipLegacy(reg);
            const ms = reg.status;
            if (['approved','assigned_room','approved_waiting_payment'].includes(ms)) { showView('allocated'); renderAllocatedLegacy(data); }
            else if (['pending','pending_review','waitlist'].includes(ms)) { showView('pending'); renderPending(reg); }
            else { setChip('NONE'); showView('none'); }
        }
    } catch(e) {
        console.error(e); showView('error');
    }
}

// ═══════════════════════════════════════════════════
// CHIPS
// ═══════════════════════════════════════════════════
function setChip(s) {
    const m = { NONE:{c:'spill-gray',i:'fa-house-chimney',l:'Chưa đăng ký'} };
    const x = m[s]||{c:'spill-gray',i:'fa-circle',l:s};
    document.getElementById('rsChipWrap').innerHTML = `<span class="spill ${x.c}"><i class="fa-solid ${x.i}"></i> ${x.l}</span>`;
}
function setChipAlloc(reg,dorm,room,ra) {
    const m = {
        ALLOCATED:{c:'spill-green',i:'fa-circle-check',  l:'Đã được phân phòng'},
        WAITLIST: {c:'spill-blue', i:'fa-list-ol',       l:'Danh sách chờ'},
        PENDING:  {c:'spill-amber',i:'fa-hourglass-half',l:'Đang xét duyệt'},
        REJECTED: {c:'spill-red',  i:'fa-circle-xmark',  l:'Không được duyệt'},
    };
    const x = m[reg.status]||{c:'spill-gray',i:'fa-circle',l:reg.status};
    const rn = room?.roomNumber||ra?.roomNumber||'';
    const dn = dorm?.name||'';
    document.getElementById('rsChipWrap').innerHTML =
        `<span class="spill ${x.c}"><i class="fa-solid ${x.i}"></i> ${x.l}</span>`+
        (rn?`<span class="room-tag"><i class="fa-solid fa-location-dot" style="color:var(--red);font-size:.65rem"></i> ${esc(dn)} · Phòng <strong>${esc(rn)}</strong></span>`:'');
}
function setChipLegacy(reg) {
    const m = {
        pending:{c:'spill-amber',i:'fa-hourglass-half',l:'Chờ duyệt'},
        pending_review:{c:'spill-amber',i:'fa-hourglass-half',l:'Đang xét duyệt'},
        approved:{c:'spill-green',i:'fa-circle-check',l:'Đã phân phòng'},
        assigned_room:{c:'spill-green',i:'fa-circle-check',l:'Đã phân phòng'},
        approved_waiting_payment:{c:'spill-green',i:'fa-circle-check',l:'Đã phân phòng'},
        rejected:{c:'spill-red',i:'fa-circle-xmark',l:'Không được duyệt'},
    };
    const x = m[reg.status]||{c:'spill-gray',i:'fa-circle',l:reg.status};
    document.getElementById('rsChipWrap').innerHTML = `<span class="spill ${x.c}"><i class="fa-solid ${x.i}"></i> ${x.l}</span>`;
}

// ═══════════════════════════════════════════════════
// REGISTER BUTTON
// ═══════════════════════════════════════════════════
function renderRegBtn(isOpen) {
    ['rsBtnWrap','noneBtn'].map(id=>document.getElementById(id)).filter(Boolean).forEach(el => {
        if (isOpen===true)  el.innerHTML = `<a href="/register" class="reg-btn"><i class="fa-solid fa-pen-to-square"></i> Đăng ký ngay</a>`;
        else if (isOpen===false) el.innerHTML = `<span class="reg-btn-off"><i class="fa-solid fa-lock"></i> Chưa mở đợt đăng ký</span>`;
    });
}

// ═══════════════════════════════════════════════════
// ALLOCATED (allocation engine)
// ═══════════════════════════════════════════════════
async function renderAllocated(data) {
    const { registration:reg, roomAllocation:ra, room, dormitory:dormRaw } = data;
    const sid   = '<%= student && student.studentId ? student.studentId : "" %>';
    const sname = '<%= student && student.name ? student.name : (user && user.name ? user.name : "") %>';
    const rn = room?.roomNumber || ra?.roomNumber  || '—';
    const yr = reg?.academicYear || '—';
    RS.roommates  = data.roommates || [];

    // Fallback: nếu populate dorm thất bại, tự fetch
    let dorm = dormRaw;
    if (!dorm) dorm = await resolveDorm(ra?.buildingCode, ra?.dormitoryId || null);

    const dn = dorm?.name || '—';
    RS.qrPayload  = 'HUST-KTX|'+sid+'|'+toAscii(rn)+'|'+toAscii(dn)+'|'+toAscii(yr);

    setHeroImage(dorm);
    setHeroText(dorm, rn);
    renderQRCard(sname, sid);
    setRoomNum(rn);
    loadNotifications();
    renderResidentCard(dn, rn, yr);
    renderAmenities(room, dorm);
    buildDrawers(data, RS.roommates);
}

// ═══════════════════════════════════════════════════
// ALLOCATED (legacy manual)
// ═══════════════════════════════════════════════════
async function renderAllocatedLegacy(data) {
    const { registration:reg, room, dormitory:dormRaw } = data;
    const sid   = '<%= student && student.studentId ? student.studentId : "" %>';
    const sname = '<%= student && student.name ? student.name : (user && user.name ? user.name : "") %>';
    const rn = room?.roomNumber || reg?.roomNumber  || '—';
    const yr = reg?.academicYear || '—';
    RS.roommates = data.roommates || (Array.isArray(room?.occupants) ? room.occupants : []);

    let dorm = dormRaw;
    if (!dorm) dorm = await resolveDorm(null, reg?.dormitoryId || null);

    const dn = dorm?.name || reg?.dormitoryName || '—';
    RS.qrPayload = 'HUST-KTX|'+sid+'|'+toAscii(rn)+'|'+toAscii(dn)+'|'+toAscii(yr);

    setHeroImage(dorm);
    setHeroText(dorm, rn);
    renderQRCard(sname, sid);
    setRoomNum(rn);
    loadNotifications();
    renderResidentCard(dn, rn, yr);
    renderAmenities(room, dorm);
    buildDrawersLegacy(data, RS.roommates);
}

// ═══════════════════════════════════════════════════
// QR CARD
// ═══════════════════════════════════════════════════
function renderQRCard(name, sid) {
    document.getElementById('qrName').textContent = name || '—';
    document.getElementById('qrSub').textContent  = (sid||'') + (sid ? ' · ' : '') + 'Sinh viên';
    setTimeout(() => {
        const el = document.getElementById('qrCodeEl');
        el.innerHTML = '';
        if (typeof QRCode !== 'undefined' && RS.qrPayload) {
            try { new QRCode(el, { text:RS.qrPayload, width:160, height:160, colorDark:'#111827', colorLight:'#FFFFFF', correctLevel:QRCode.CorrectLevel.M }); }
            catch(e) { console.error('QR:', e); }
        }
        document.getElementById('qrSkeleton').style.display = 'none';
        document.getElementById('qrCodeEl').style.display = '';
    }, 200);
}
function setRoomNum(rn) {
    const el = document.getElementById('qaRoomNum');
    if (el) el.textContent = (rn && rn !== '—') ? rn : '?';
}

// ═══════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════
const NOTIF_ICON = {
    allocation:'fa-house-chimney',room_assigned:'fa-door-open',
    application:'fa-file-lines',announcement:'fa-bullhorn',
    maintenance:'fa-screwdriver-wrench',violation:'fa-triangle-exclamation',
    alert:'fa-bell',system:'fa-circle-info','2fa':'fa-shield-halved',
};
const NOTIF_CLS = {
    allocation:'ni-home2',room_assigned:'ni-home2',
    application:'ni-info',announcement:'ni-info',
    maintenance:'ni-fix',violation:'ni-warn',
    alert:'ni-fix',system:'ni-info','2fa':'ni-info',
};

async function loadNotifications() {
    const row = document.getElementById('notifRow');
    try {
        const r = await fetch('/api/notifications?limit=3', { credentials:'include' });
        if (!r.ok) throw new Error('HTTP '+r.status);
        const d = await r.json();
        const notifs = (d.notifications||[]).slice(0,3);
        if (!notifs.length) {
            row.innerHTML = `<div class="notif-empty-band"><i class="fa-regular fa-bell-slash"></i> Chưa có thông báo mới</div>`;
            return;
        }
        row.innerHTML = notifs.map(n => {
            const ic  = NOTIF_ICON[n.type]  || 'fa-circle-info';
            const cls = NOTIF_CLS[n.type]   || 'ni-info';
            const ts  = relTime(n.createdAt);
            return `<div class="ni" data-id="${esc(n._id)}">
                <div class="ni-ico ${cls}"><i class="fa-solid ${ic}"></i></div>
                <div style="flex:1;min-width:0">
                    <div class="ni-title">${esc(n.title||'Thông báo')}</div>
                    ${ts?`<div class="ni-sub">${esc(ts)}</div>`:''}
                </div>
            </div>`;
        }).join('');
        row.querySelectorAll('.ni').forEach(el => {
            el.addEventListener('click', () => {
                const id = el.dataset.id;
                if (id) fetch('/api/notifications/'+id+'/read',{method:'POST',credentials:'include'}).catch(()=>{});
                window.location = '/notifications';
            });
        });
    } catch(e) {
        row.innerHTML = `<div class="notif-empty-band" style="color:var(--t3)"><i class="fa-regular fa-bell-slash"></i> Không tải được thông báo</div>`;
    }
}

// ═══════════════════════════════════════════════════
// RESIDENT CARD
// ═══════════════════════════════════════════════════
function renderResidentCard(dn, rn, yr) {
    // Render QR into resident card
    setTimeout(() => {
        const el = document.getElementById('resQrEl');
        if (!el) return;
        el.innerHTML = '';
        if (typeof QRCode !== 'undefined' && RS.qrPayload) {
            try { new QRCode(el, { text:RS.qrPayload, width:130, height:130, colorDark:'#111827', colorLight:'#FFFFFF', correctLevel:QRCode.CorrectLevel.M }); }
            catch(e) {}
        }
        const skel = document.getElementById('resQrSkel');
        if (skel) skel.style.display = 'none';
        el.style.display = '';
    }, 350);
}

// ═══════════════════════════════════════════════════
// RESOLVE DORMITORY (fallback when populate fails)
// ═══════════════════════════════════════════════════
let _dormCache = null;
async function resolveDorm(buildingCode, dormitoryId) {
    try {
        if (!_dormCache) {
            const r = await fetch('/api/dormitories', { credentials:'include' });
            if (!r.ok) return null;
            const d = await r.json();
            _dormCache = d.dormitories || [];
        }
        if (buildingCode) {
            const hit = _dormCache.find(x => x.buildingCode === buildingCode || x.code === buildingCode);
            if (hit) return hit;
        }
        if (dormitoryId) {
            const sid = String(dormitoryId);
            const hit = _dormCache.find(x => String(x._id) === sid);
            if (hit) return hit;
        }
        // Last resort: first dormitory
        return _dormCache[0] || null;
    } catch(e) { return null; }
}

// ═══════════════════════════════════════════════════
// HERO CLIP PATH
// ═══════════════════════════════════════════════════
function setHeroImage(dorm) {
    const img = document.getElementById('heroBgImg');
    if (!img || !dorm) return;
    const candidates = [
        dorm?.imageUrl,
        dorm?.image,
        dorm?.details?.exteriorImages?.[0],
        dorm?.details?.images?.[0],
        dorm?.details?.coverImage,
        dorm?.details?.photo,
        dorm?.images?.[0],
        dorm?.thumbnail,
        dorm?.photo,
        dorm?.coverImage,
    ].filter(Boolean);
    if (!candidates.length) return;
    let idx = 0;
    function tryNext() {
        if (idx >= candidates.length) return;
        img.onerror = () => { idx++; tryNext(); };
        img.onload  = () => { img.style.opacity = '1'; };
        img.src = candidates[idx];
    }
    tryNext();
}
function setHeroText(dorm, rn) {
    const h1 = document.getElementById('heroTitle');
    if (h1 && dorm?.name) {
        // Strip leading "KTX " prefix — eyebrow already says "KÝ TÚC XÁ"
        h1.textContent = dorm.name.replace(/^KTX\s+/i, '').trim() || dorm.name;
    }
}

// ═══════════════════════════════════════════════════
// AMENITIES GRID
// ═══════════════════════════════════════════════════
const AMENITIES_DEF = [
    {icon:'fa-wifi',       bg:'#EEF2FF',color:'#4F46E5',name:'WiFi tốc độ cao',   desc:'Kết nối toàn khu KTX'},
    {icon:'fa-motorcycle', bg:'#ECFDF5',color:'#059669',name:'Bãi gửi xe',         desc:'Xe máy, xe đạp an toàn'},
    {icon:'fa-shield-halved',bg:'#FFF7ED',color:'#EA580C',name:'Bảo vệ 24/7',     desc:'An ninh liên tục'},
    {icon:'fa-book-open',  bg:'#F5F3FF',color:'#7C3AED',name:'Phòng đọc sách',     desc:'Học tập, yên tĩnh'},
    {icon:'fa-shirt',      bg:'#ECFEFF',color:'#0891B2',name:'Khu giặt đồ',        desc:'Máy giặt tự động'},
    {icon:'fa-droplet',    bg:'#EFF6FF',color:'#2563EB',name:'Nước nóng',           desc:'Bình nóng lạnh 24/7'},
    {icon:'fa-users',      bg:'#FFF1F3',color:'#C8102E',name:'Sinh hoạt chung',     desc:'Khu vui chơi, thư giãn'},
    {icon:'fa-bolt',       bg:'#FEFCE8',color:'#CA8A04',name:'Điện ổn định',        desc:'Hệ thống UPS dự phòng'},
];
const FAC_ICON = {'air conditioning':'fa-snowflake','điều hòa':'fa-snowflake','wifi':'fa-wifi','study desk':'fa-desktop','bàn học':'fa-desktop','wardrobe':'fa-shirt','tủ':'fa-shirt','bathroom':'fa-bath','toilet':'fa-bath','balcony':'fa-archway','ban công':'fa-archway','kitchen':'fa-utensils','bếp':'fa-utensils'};
const FAC_BG   = ['#EEF2FF','#ECFDF5','#FFF7ED','#F5F3FF','#ECFEFF','#EFF6FF','#FFF1F3','#FEFCE8'];
const FAC_COL  = ['#4F46E5','#059669','#EA580C','#7C3AED','#0891B2','#2563EB','#C8102E','#CA8A04'];

function renderAmenities(room, dorm) {
    const grid = document.getElementById('amenGrid');
    const facs = Array.isArray(room?.facilities) ? room.facilities : [];
    const dAms = Array.isArray(dorm?.details?.amenities) ? dorm.details.amenities : [];
    const all  = [...new Set([...facs,...dAms])];

    let items;
    if (all.length >= 4) {
        items = all.slice(0,10).map((f,i) => {
            const k = Object.keys(FAC_ICON).find(k => f.toLowerCase().includes(k));
            return { icon:k?FAC_ICON[k]:'fa-star', color:FAC_COL[i%FAC_COL.length], name:f, maint:false };
        });
        while (items.length < 4) { const d=AMENITIES_DEF[items.length]; items.push({icon:d.icon,color:d.color,name:d.name,maint:false}); }
    } else {
        items = AMENITIES_DEF.map(a => ({icon:a.icon,color:a.color,name:a.name,maint:false}));
    }
    items.push({icon:'fa-screwdriver-wrench',color:'#92400E',name:'Bảo trì',maint:true,href:'/student/maintenance-requests'});

    grid.innerHTML = items.map(a => {
        const tag = a.href ? 'a' : 'span';
        const href = a.href ? ` href="${a.href}"` : '';
        const cls = 'am-chip-item' + (a.maint?' am-chip-maint':'');
        const style = a.maint ? '' : `style="color:${a.color}"`;
        return `<${tag}${href} class="${cls}"><i class="fa-solid ${a.icon} am-chip-ico" ${style}></i>${esc(a.name)}</${tag}>`;
    }).join('');
}

// ═══════════════════════════════════════════════════
// DRAW DRAWERS
// ═══════════════════════════════════════════════════
function buildDrawers(data, roommates) {
    fillRoomDrawer(data.room, data.dormitory, data.roomAllocation, data.registration);
    fillRmDrawer(roommates);
    fillMapDrawer(data.dormitory);
}
function buildDrawersLegacy(data, roommates) {
    fillRoomDrawer(data.room, data.dormitory, null, data.registration);
    fillRmDrawer(roommates);
    fillMapDrawer(data.dormitory);
}

function fillRoomDrawer(room, dorm, ra, reg) {
    const r=room||{}, d=dorm||{};
    const rn  = r.roomNumber||ra?.roomNumber||reg?.roomNumber||'—';
    const tmap= {Single:'Phòng đơn',Double:'2 người',Triple:'3 người','8-person':'8 người','4-person-service':'4 người (dịch vụ)','5-person':'5 người','10-person':'10 người'};
    const rt  = tmap[r.type||r.roomType]||r.type||'—';
    const cap = r.maxCapacity||r.capacity||ra?.roomCapacity||'—';
    const fl  = r.floorNumber?'Tầng '+r.floorNumber:(r.floor?'Tầng '+r.floor:'—');
    const facs= Array.isArray(r.facilities)?r.facilities:[];
    const dAms= Array.isArray(d.details?.amenities)?d.details.amenities:[];
    const allF= [...new Set([...facs,...dAms])];
    const chips= allF.map(f=>{const k=Object.keys(FAC_ICON).find(k=>f.toLowerCase().includes(k));return `<span class="am-chip">${k?`<i class="fa-solid ${FAC_ICON[k]}"></i>`:'<i class="fa-solid fa-check" style="font-size:.6rem"></i>'} ${esc(f)}</span>`;}).join('');
    const catMap={premium:'Cao cấp',basic:'Tiêu chuẩn',international:'Quốc tế'};
    const brows=[
        {i:'fa-building',    l:'Tên tòa',   v:d.name||''},
        {i:'fa-location-dot',l:'Địa chỉ',   v:d.address||''},
        {i:'fa-tag',         l:'Phân loại', v:catMap[d.details?.category]||d.details?.category||''},
        {i:'fa-layer-group', l:'Số tầng',   v:d.details?.totalFloors?d.details.totalFloors+' tầng':''},
        {i:'fa-phone',       l:'Điện thoại',v:d.contact?.phone||''},
        {i:'fa-envelope',    l:'Email',      v:d.contact?.email||''},
    ].filter(x=>x.v);
    document.getElementById('roomBody').innerHTML = `
        <div class="dw-s">
            <div class="dw-hero">
                <div><div class="dw-rn">${esc(rn)}</div><div class="dw-rt">${esc(rt)}</div></div>
                <div class="dw-bg">Đang ở</div>
            </div>
            <div class="dw-grid">
                <div class="dw-item"><div class="dw-item-lbl">Tầng</div><div class="dw-item-val">${esc(String(fl))}</div></div>
                <div class="dw-item"><div class="dw-item-lbl">Sức chứa</div><div class="dw-item-val">${esc(String(cap))} người</div></div>
            </div>
        </div>
        ${allF.length?`<div class="dw-s"><div class="dw-s-title">Tiện ích phòng</div><div class="am-chips">${chips}</div></div>`:''}
        ${brows.length?`<div class="dw-s"><div class="dw-s-title">Tòa nhà</div>${brows.map(x=>`<div class="dw-info-row"><i class="fa-solid ${x.i} dw-ii"></i><div><div class="dw-il">${x.l}</div><div class="dw-iv">${esc(String(x.v))}</div></div></div>`).join('')}</div>`:''}`;
}

function fillRmDrawer(roommates) {
    if (!roommates.length) {
        document.getElementById('rmBody').innerHTML = `<div class="rm-empty"><i class="fa-solid fa-user-slash" style="font-size:2rem;display:block;margin-bottom:.75rem;opacity:.3"></i>Chưa có bạn cùng phòng</div>`;
        return;
    }
    document.getElementById('rmBody').innerHTML = roommates.map((r,i) => {
        const name=r.name||r.studentName||'Sinh viên', sid=r.studentId||'', fac=r.faculty||r.major||'';
        const init=name.trim().split(' ').pop().charAt(0).toUpperCase();
        return `<div class="rm-item"><div class="rm-av" style="background:${colorOf(name+i)}">${esc(init)}</div><div style="flex:1;min-width:0"><div class="rm-name">${esc(name)}</div><div class="rm-meta">${[sid,fac].filter(Boolean).map(esc).join(' · ')}</div><span class="rm-tag">Đang cư trú</span></div></div>`;
    }).join('');
}

function fillMapDrawer(dorm) {
    const addr = dorm?.address || 'Số 1 Đại Cồ Việt, Hai Bà Trưng, Hà Nội';
    const name = dorm?.name    || 'KTX HUST';
    RS.mapAddr = addr; RS.mapDorm = name;
    document.getElementById('mapBody').innerHTML = `
        <div class="map-wrap" id="mapLeaflet"></div>
        <div class="map-addr">
            <i class="fa-solid fa-location-dot map-addr-icon"></i>
            <div><div class="map-addr-main">${esc(name)}</div><div class="map-addr-sub">${esc(addr)}</div></div>
        </div>`;
}

// ═══════════════════════════════════════════════════
// WAITLIST
// ═══════════════════════════════════════════════════
function renderWaitlist(reg) {
    const total = calcScore(reg);
    document.getElementById('wlStats').innerHTML =
        `<div style="text-align:center"><div class="wl-sn" id="wlPos">—</div><div class="wl-sl">Vị trí chờ</div></div>`+
        (total!=null?`<div style="text-align:center"><div class="wl-sn">${Math.round(total)}</div><div class="wl-sl">Điểm ưu tiên</div></div>`:'');
}
function calcScore(reg) {
    if (!reg) return null;
    const s=reg.priorityScore;
    if (s==null) return null;
    if (typeof s==='number') return s;
    const vs=Object.values(s).filter(v=>typeof v==='number');
    return vs.length?vs.reduce((a,b)=>a+b,0):null;
}
async function loadWLPos() {
    try {
        const r=await fetch('/api/student/waitlist-position',{credentials:'include'});
        if(!r.ok) return;
        const d=await r.json().catch(()=>null);
        if(!d) return;
        const pos=d.position||d.data?.position, tot=d.total||d.data?.total;
        if (pos) {
            document.getElementById('wlTitle').textContent='Vị trí #'+pos;
            const ring=document.getElementById('wlRing');
            if(ring) ring.innerHTML=`<span style="font-size:1.3rem;font-weight:900">#${pos}</span>`;
            const pe=document.getElementById('wlPos');
            if(pe) pe.textContent=pos+(tot?'/'+tot:'');
        }
        const msg=document.getElementById('wlMsg');
        if(msg&&tot) msg.textContent='Có '+tot+' sinh viên đang trong hàng chờ';
    } catch(e) {}
}
function initSocket(reg) {
    if(typeof io==='undefined') return;
    try {
        const s=io({transports:['websocket','polling']});
        s.on('waitlist-update',d=>{
            if(d.position){document.getElementById('wlTitle').textContent='Vị trí #'+d.position;const rg=document.getElementById('wlRing');if(rg)rg.innerHTML=`<span style="font-size:1.3rem;font-weight:900">#${d.position}</span>`;}
            const m=document.getElementById('wlMsg');if(m&&d.message)m.textContent=d.message;
        });
        s.on('registration-status-change',d=>{if(d.status!=='WAITLIST')location.reload();});
    } catch(e){}
}

// ═══════════════════════════════════════════════════
// PENDING
// ═══════════════════════════════════════════════════
function renderPending(reg) {
    const yr={year1:'Năm 1',year2_3:'Năm 2–3',year4_plus:'Năm 4+'};
    document.getElementById('pendingChips').innerHTML=[
        reg?.academicYear?`<span class="p-chip"><i class="fa-solid fa-calendar" style="font-size:.68rem"></i> ${esc(reg.academicYear)}</span>`:'',
        reg?.createdAt?`<span class="p-chip"><i class="fa-solid fa-clock" style="font-size:.68rem"></i> ${dateFmt(reg.createdAt)}</span>`:'',
        reg?.yearGroup?`<span class="p-chip">${esc(yr[reg.yearGroup]||reg.yearGroup)}</span>`:'',
    ].filter(Boolean).join('');
}

// ═══════════════════════════════════════════════════
// MODAL / DRAWER CONTROLLERS
// ═══════════════════════════════════════════════════
function openOv(id) {
    const el=document.getElementById(id); if(!el) return;
    el.classList.add('open'); document.body.style.overflow='hidden';
    if (id==='mapOv' && !RS.mapInited) setTimeout(initLeaflet,80);
}
function closeOv(id) {
    const el=document.getElementById(id); if(!el) return;
    el.classList.remove('open'); document.body.style.overflow='';
}
function initLeaflet() {
    if (RS.mapInited) return;
    const c=document.getElementById('mapLeaflet');
    if (!c||typeof L==='undefined') return;
    RS.leaflet=L.map(c,{zoomControl:true}).setView([21.0048,105.8432],16);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{
        attribution:'© OpenStreetMap © CARTO',subdomains:'abcd',maxZoom:20
    }).addTo(RS.leaflet);
    L.marker([21.0048,105.8432]).addTo(RS.leaflet)
        .bindPopup(`<b>${RS.mapDorm||'KTX HUST'}</b><br>${RS.mapAddr||''}`).openPopup();
    RS.mapInited=true;
    setTimeout(()=>RS.leaflet.invalidateSize(),120);
}

function openQRModal() {
    openOv('qrModal');
    const el=document.getElementById('modalQrEl');
    el.innerHTML='';
    if (typeof QRCode!=='undefined'&&RS.qrPayload) {
        try{new QRCode(el,{text:RS.qrPayload,width:240,height:240,colorDark:'#111827',colorLight:'#FFFFFF',correctLevel:QRCode.CorrectLevel.M});}
        catch(e){}
    }
    document.getElementById('modalName').textContent=document.getElementById('qrName')?.textContent||'';
    const rn=RS.data?.room?.roomNumber||RS.data?.roomAllocation?.roomNumber||'';
    const dn=RS.data?.dormitory?.name||'';
    document.getElementById('modalTags').innerHTML=[
        rn?`<span class="modal-tag">Phòng <span>${esc(rn)}</span></span>`:'',
        dn?`<span class="modal-tag"><span>${esc(dn)}</span></span>`:'',
    ].filter(Boolean).join('');
}

// ═══════════════════════════════════════════════════
// EVENT LISTENERS
// ═══════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
    const qrCard=document.getElementById('qrCard');
    qrCard.addEventListener('click', openQRModal);
    qrCard.addEventListener('keydown', e=>{if(e.key==='Enter'||e.key===' ')openQRModal();});

    document.getElementById('qrModalClose').addEventListener('click',()=>closeOv('qrModal'));
    document.getElementById('qrModal').addEventListener('click',e=>{if(e.target.id==='qrModal')closeOv('qrModal');});

    document.getElementById('qaRoom').addEventListener('click',()=>openOv('roomOv'));
    document.getElementById('qaRoommates').addEventListener('click',()=>openOv('rmOv'));
    document.getElementById('qaMap').addEventListener('click',()=>openOv('mapOv'));
    ['qaRoom','qaRoommates','qaMap'].forEach(id=>{
        document.getElementById(id)?.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' ')document.getElementById(id).click();});
    });

    document.querySelectorAll('[data-close]').forEach(btn=>{
        btn.addEventListener('click',()=>closeOv(btn.dataset.close));
    });
    ['roomOv','rmOv','mapOv'].forEach(id=>{
        const ov=document.getElementById(id); if(!ov) return;
        ov.addEventListener('click',e=>{
            const dw=ov.querySelector('.drawer');
            if(dw&&!dw.contains(e.target))closeOv(id);
        });
    });
    document.addEventListener('keydown',e=>{
        if(e.key!=='Escape') return;
        ['qrModal','roomOv','rmOv','mapOv'].forEach(closeOv);
    });
});
</script>
</body>
</html>
