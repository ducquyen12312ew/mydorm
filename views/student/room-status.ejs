<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trạng thái phòng - KTX HUST</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/student-premium-shell.css">
    <link rel="stylesheet" href="/css/premium-home.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --red:       #C8102E;
        --red-l:     #FFF1F3;
        --red-m:     rgba(200,16,46,.1);
        --green:     #059669;
        --green-l:   #ECFDF5;
        --blue:      #4F46E5;
        --blue-l:    #EEF2FF;
        --teal:      #0891B2;
        --amber:     #D97706;
        --amber-l:   #FFFBEB;
        --bg:        #F4F6FB;
        --surface:   #FFFFFF;
        --border:    #EEF0F5;
        --border2:   #E5E7EB;
        --t1:        #111827;
        --t2:        #6B7280;
        --t3:        #9CA3AF;
        --r18:       18px;
        --r12:       12px;
        --sh0:       0 1px 3px rgba(0,0,0,.04);
        --sh1:       0 2px 12px rgba(0,0,0,.06);
        --sh2:       0 6px 28px rgba(0,0,0,.09);
        --sh3:       0 16px 56px rgba(0,0,0,.13);
    }

    body { font-family:'Inter','Segoe UI',sans-serif; background:var(--bg); color:var(--t1); }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp  { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }
    @keyframes fadeIn  { from{opacity:0} to{opacity:1} }
    @keyframes slideR  { from{transform:translateX(110%)} to{transform:translateX(0)} }
    @keyframes scaleIn { from{opacity:0;transform:scale(.94)} to{opacity:1;transform:scale(1)} }
    @keyframes spin    { to{transform:rotate(360deg)} }
    @keyframes blink   { 0%,100%{opacity:1} 50%{opacity:.25} }
    @keyframes shimmer { 0%{background-position:-400% 0} 100%{background-position:400% 0} }

    .au1{animation:fadeUp .5s cubic-bezier(.22,1,.36,1) both}
    .au2{animation:fadeUp .5s .08s cubic-bezier(.22,1,.36,1) both}
    .au3{animation:fadeUp .5s .16s cubic-bezier(.22,1,.36,1) both}
    .au4{animation:fadeUp .5s .24s cubic-bezier(.22,1,.36,1) both}
    .au5{animation:fadeUp .5s .32s cubic-bezier(.22,1,.36,1) both}

    /* ─── PAGE ─── */
    .rs-page { max-width:1040px; margin:0 auto; padding:1.75rem 1.25rem 5rem; }

    /* ─── STATUS BAR ─── */
    .rs-bar { display:flex; align-items:center; gap:.65rem; flex-wrap:wrap; margin-bottom:1.75rem; }
    .spill { display:inline-flex; align-items:center; gap:.4rem; padding:.35rem .85rem; border-radius:999px; font-size:.76rem; font-weight:700; letter-spacing:.02em; }
    .spill-green { background:var(--green-l); color:#065F46; }
    .spill-blue  { background:var(--blue-l);  color:#3730A3; }
    .spill-amber { background:var(--amber-l); color:#92400E; }
    .spill-red   { background:var(--red-l);   color:#991B1B; }
    .spill-gray  { background:#F3F4F6; color:#6B7280; }
    .room-tag { display:inline-flex; align-items:center; gap:.3rem; padding:.32rem .8rem; border-radius:999px; background:var(--surface); border:1.5px solid var(--border2); font-size:.75rem; font-weight:600; color:var(--t2); }
    .room-tag strong { color:var(--t1); }
    .reg-btn { display:inline-flex; align-items:center; gap:.4rem; padding:.4rem 1.1rem; border-radius:8px; background:var(--red); color:#fff; font-size:.78rem; font-weight:700; text-decoration:none; transition:opacity .15s,transform .15s; }
    .reg-btn:hover { opacity:.88; transform:translateY(-1px); }
    .reg-btn-off { display:inline-flex; align-items:center; gap:.4rem; padding:.4rem 1.1rem; border-radius:8px; background:#F3F4F6; color:var(--t3); font-size:.78rem; font-weight:700; border:1.5px solid var(--border2); cursor:not-allowed; }

    /* ─── LAYOUT ─── */
    .rs-sec { margin-bottom:1.25rem; }
    .g-65-35 { display:grid; grid-template-columns:65fr 35fr; gap:1.25rem; }

    /* ══════════════════════════════════════
       QR CARD — white, clean, sáng
    ══════════════════════════════════════ */
    .qr-card {
        background:var(--surface);
        border-radius:var(--r18);
        border:1.5px solid var(--border);
        box-shadow:var(--sh1);
        padding:2.5rem 2rem 2rem;
        text-align:center;
        position:relative; overflow:hidden;
        cursor:pointer; user-select:none;
        transition:transform .28s cubic-bezier(.22,1,.36,1), box-shadow .28s;
    }
    .qr-card:hover { transform:translateY(-5px); box-shadow:var(--sh3); }
    /* dot pattern top-right */
    .qr-card::before {
        content:''; position:absolute; top:0; right:0;
        width:150px; height:150px; pointer-events:none;
        background-image:radial-gradient(circle,#D1D5DB 1.3px,transparent 1.3px);
        background-size:14px 14px; opacity:.5;
    }
    /* soft glow bottom-left */
    .qr-card::after {
        content:''; position:absolute; bottom:-40px; left:-40px;
        width:130px; height:130px; border-radius:50%;
        background:radial-gradient(circle,rgba(200,16,46,.06) 0%,transparent 70%);
        pointer-events:none;
    }
    .qr-eyebrow { font-size:.66rem; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:var(--t3); margin-bottom:1.5rem; position:relative; z-index:1; }
    .qr-code-wrap { display:inline-block; background:#fff; border-radius:14px; padding:10px; box-shadow:0 4px 20px rgba(0,0,0,.09),0 1px 4px rgba(0,0,0,.05); margin-bottom:1.5rem; position:relative; z-index:1; transition:transform .28s cubic-bezier(.22,1,.36,1); }
    .qr-card:hover .qr-code-wrap { transform:scale(1.04); }
    .qr-code-wrap canvas,.qr-code-wrap img { display:block; border-radius:6px; }
    .qr-skeleton { width:160px; height:160px; border-radius:8px; background:linear-gradient(90deg,#F3F4F6 25%,#E5E7EB 50%,#F3F4F6 75%); background-size:400% 100%; animation:shimmer 1.8s infinite; }
    .qr-name { font-size:1.2rem; font-weight:800; color:var(--t1); letter-spacing:-.02em; margin-bottom:.25rem; position:relative; z-index:1; }
    .qr-sub  { font-size:.8rem; color:var(--t3); font-weight:500; margin-bottom:1.1rem; position:relative; z-index:1; }
    .qr-badge { display:inline-flex; align-items:center; gap:.4rem; padding:.38rem 1rem; border-radius:999px; background:var(--green-l); color:#065F46; font-size:.76rem; font-weight:700; position:relative; z-index:1; }
    .qr-expand-hint { display:block; margin-top:.85rem; font-size:.7rem; color:var(--t3); font-weight:600; position:relative; z-index:1; transition:color .2s; }
    .qr-card:hover .qr-expand-hint { color:var(--red); }

    /* ══════════════════════════════════════
       QUICK ACTION CARDS
    ══════════════════════════════════════ */
    .qa-stack { display:flex; flex-direction:column; gap:.85rem; }
    .qa-card {
        background:var(--surface); border-radius:var(--r18);
        border:1.5px solid var(--border); padding:1.3rem 1.2rem;
        display:flex; align-items:center; gap:1rem;
        cursor:pointer; box-shadow:var(--sh0); user-select:none;
        transition:transform .25s cubic-bezier(.22,1,.36,1), box-shadow .25s, border-color .25s;
    }
    .qa-card:hover { transform:translateY(-4px); box-shadow:var(--sh2); border-color:transparent; }
    .qa-card:hover .qa-arrow  { transform:translateX(5px); color:var(--t1); }
    .qa-card:hover .qa-iw svg { transform:scale(1.1); }
    .qa-card:hover .qa-iw .qa-num { transform:scale(1.08); }
    .qa-iw {
        width:54px; height:54px; border-radius:14px; flex-shrink:0;
        display:flex; align-items:center; justify-content:center;
    }
    .qa-iw svg { transition:transform .25s; }
    .qa-iw-red   { background:var(--red-l); }
    .qa-iw-blue  { background:var(--blue-l); }
    .qa-iw-green { background:#ECFDF5; }
    .qa-num { font-size:1.35rem; font-weight:900; letter-spacing:-.04em; color:var(--red); font-style:italic; line-height:1; transition:transform .25s; }
    .qa-text { flex:1; min-width:0; }
    .qa-title { font-size:.92rem; font-weight:800; color:var(--t1); margin-bottom:.18rem; }
    .qa-desc  { font-size:.73rem; color:var(--t2); line-height:1.5; }
    .qa-arrow { color:var(--t3); flex-shrink:0; font-size:.85rem; transition:transform .25s cubic-bezier(.22,1,.36,1), color .2s; }

    /* ══════════════════════════════════════
       NOTIFICATION BAND
    ══════════════════════════════════════ */
    .notif-band {
        background:var(--surface); border-radius:var(--r18);
        border:1.5px solid var(--border); box-shadow:var(--sh0);
        display:flex; align-items:stretch; overflow:hidden;
    }
    .notif-hd-col {
        display:flex; align-items:center; gap:.6rem; flex-shrink:0;
        padding:.95rem 1.25rem; border-right:1.5px solid var(--border);
        min-width:160px;
    }
    .bell-wrap { width:34px; height:34px; border-radius:10px; background:var(--red-l); color:var(--red); display:flex; align-items:center; justify-content:center; font-size:.82rem; flex-shrink:0; }
    .notif-hd-lbl { font-size:.8rem; font-weight:800; color:var(--t1); line-height:1.3; }
    .notif-row { display:flex; align-items:stretch; flex:1; min-width:0; overflow:hidden; }
    .ni {
        display:flex; align-items:flex-start; gap:.65rem;
        padding:.9rem 1.1rem; border-right:1.5px solid var(--border);
        flex:1; min-width:0; cursor:pointer; transition:background .15s;
    }
    .ni:last-child { border-right:none; }
    .ni:hover { background:#FAFBFF; }
    .ni-ico { width:30px; height:30px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:.76rem; flex-shrink:0; margin-top:.05rem; }
    .ni-cal   { background:#FFF1F3; color:#C8102E; }
    .ni-fix   { background:#FFFBEB; color:#D97706; }
    .ni-info  { background:#EEF2FF; color:#4F46E5; }
    .ni-home2 { background:#ECFDF5; color:#059669; }
    .ni-warn  { background:#FFF7ED; color:#EA580C; }
    .ni-title { font-size:.78rem; font-weight:700; color:var(--t1); margin-bottom:.15rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .ni-sub   { font-size:.7rem; color:var(--t3); }
    .ni-link  { font-size:.7rem; color:var(--blue); font-weight:600; }
    .notif-all { flex-shrink:0; display:flex; align-items:center; padding:0 .95rem; color:var(--t3); cursor:pointer; font-size:.8rem; transition:color .15s; border-left:1.5px solid var(--border); }
    .notif-all:hover { color:var(--t1); }
    .notif-empty-band { flex:1; display:flex; align-items:center; padding:.9rem 1.1rem; font-size:.8rem; color:var(--t3); gap:.45rem; }

    /* ══════════════════════════════════════
       RESIDENT CARD — pastel light gradient
    ══════════════════════════════════════ */
    .res-eyebrow { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.12em; color:var(--t3); margin-bottom:.75rem; }
    .res-card {
        border-radius:var(--r18); overflow:hidden; box-shadow:var(--sh2);
        background:linear-gradient(130deg,#FDE8ED 0%,#EDE7F6 38%,#E3F2FD 65%,#E8F5E9 100%);
        position:relative;
    }
    .res-card::before {
        content:''; position:absolute; inset:0; pointer-events:none;
        background:linear-gradient(140deg,rgba(255,255,255,.6) 0%,rgba(255,255,255,.15) 100%);
    }
    /* 2-col: QR left, description right */
    .res-inner { display:grid; grid-template-columns:auto 1fr; gap:0; position:relative; z-index:1; }
    .res-qr-side {
        padding:2rem 1.75rem;
        display:flex; flex-direction:column; align-items:center; justify-content:center; gap:.65rem;
        border-right:1px solid rgba(0,0,0,.07);
    }
    .res-qr-box { background:#fff; border-radius:14px; padding:10px; box-shadow:0 4px 16px rgba(0,0,0,.1); }
    .res-qr-box canvas,.res-qr-box img { display:block; border-radius:6px; }
    .res-qr-skel { width:130px; height:130px; border-radius:8px; background:linear-gradient(90deg,rgba(0,0,0,.06) 25%,rgba(0,0,0,.1) 50%,rgba(0,0,0,.06) 75%); background-size:400% 100%; animation:shimmer 1.8s infinite; }
    .res-qr-lbl { font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--t2); }
    .res-desc-side {
        padding:2rem 2rem;
        display:flex; flex-direction:column; justify-content:center; gap:1.1rem;
        position:relative;
    }
    .res-wm { position:absolute; bottom:.5rem; right:.75rem; width:110px; height:110px; opacity:.07; pointer-events:none; }
    .res-wm img { width:100%; height:100%; object-fit:contain; }
    .res-card-tag { font-size:.62rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:var(--t2); display:flex; align-items:center; gap:.4rem; }
    .res-card-title { font-size:1.1rem; font-weight:900; color:var(--t1); letter-spacing:-.02em; line-height:1.2; }
    .res-card-desc { font-size:.76rem; color:var(--t2); line-height:1.6; max-width:480px; }
    .res-badges { display:flex; flex-wrap:wrap; gap:.5rem; }
    .res-badge {
        display:inline-flex; align-items:center; gap:.35rem;
        padding:.3rem .7rem; border-radius:8px;
        font-size:.7rem; font-weight:700;
        background:rgba(255,255,255,.7); color:var(--t1);
        border:1px solid rgba(0,0,0,.07);
    }
    .res-badge i { font-size:.65rem; }

    /* ══════════════════════════════════════
       AMENITIES GRID
    ══════════════════════════════════════ */
    .am-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:.85rem; }
    .am-head-title { font-size:.88rem; font-weight:800; color:var(--t1); }
    .am-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:.8rem; }
    .am-card { background:var(--surface); border-radius:var(--r12); border:1.5px solid var(--border); padding:1.1rem .95rem .9rem; transition:transform .22s cubic-bezier(.22,1,.36,1), box-shadow .22s; box-shadow:var(--sh0); }
    .am-card:hover { transform:translateY(-4px); box-shadow:var(--sh2); border-color:transparent; }
    .am-ico  { width:38px; height:38px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:.95rem; margin-bottom:.6rem; }
    .am-name { font-size:.79rem; font-weight:700; color:var(--t1); margin-bottom:.12rem; }
    .am-desc { font-size:.68rem; color:var(--t3); line-height:1.4; }

    /* ══════════════════════════════════════
       STATE CARDS
    ══════════════════════════════════════ */
    .state-wrap { display:flex; justify-content:center; }
    .state-card { background:var(--surface); border-radius:var(--r18); border:1.5px solid var(--border); box-shadow:var(--sh1); max-width:540px; width:100%; }
    .state-inner { padding:3rem 2.5rem; text-align:center; }
    .state-ico { width:78px; height:78px; border-radius:50%; margin:0 auto 1.5rem; display:flex; align-items:center; justify-content:center; font-size:1.9rem; }
    .state-title { font-size:1.25rem; font-weight:900; margin-bottom:.5rem; }
    .state-sub { font-size:.88rem; color:var(--t2); line-height:1.65; margin-bottom:1.75rem; }
    .wl-ring { width:96px; height:96px; border-radius:50%; margin:0 auto 1.5rem; background:var(--blue-l); color:var(--blue); display:flex; align-items:center; justify-content:center; font-size:1.9rem; font-weight:900; box-shadow:0 0 0 10px rgba(79,70,229,.07); }
    .wl-stats { display:flex; justify-content:center; gap:2rem; padding:1.2rem; background:var(--bg); border-radius:var(--r12); margin-bottom:1.5rem; }
    .wl-sn { font-size:1.45rem; font-weight:900; color:var(--t1); }
    .wl-sl { font-size:.7rem; color:var(--t3); font-weight:600; margin-top:.12rem; }
    .live-dot { display:inline-block; width:7px; height:7px; border-radius:50%; background:var(--green); animation:blink 2s infinite; margin-right:.35rem; vertical-align:middle; }
    .pending-chips { display:flex; gap:.55rem; justify-content:center; flex-wrap:wrap; }
    .p-chip { padding:.38rem .9rem; border-radius:999px; background:var(--bg); border:1.5px solid var(--border2); font-size:.76rem; font-weight:600; color:var(--t2); }
    .empty-card { background:var(--surface); border-radius:var(--r18); border:1.5px solid var(--border); padding:4rem 2rem; text-align:center; max-width:460px; margin:0 auto; }
    .empty-ico { width:70px; height:70px; border-radius:50%; background:var(--bg); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; font-size:1.75rem; color:var(--t3); }
    .empty-card h2 { font-size:1.15rem; font-weight:800; margin-bottom:.5rem; }
    .empty-card p  { font-size:.85rem; color:var(--t2); line-height:1.65; margin-bottom:1.75rem; }

    /* ─── LOADING ─── */
    .loading-c { display:flex; align-items:center; justify-content:center; padding:5rem 0; }
    .loading-c i { font-size:1.6rem; animation:spin 1.2s linear infinite; display:block; margin-bottom:.55rem; color:var(--t3); }
    .loading-c span { font-size:.82rem; color:var(--t3); font-weight:600; }

    /* ══════════════════════════════════════
       MODAL
    ══════════════════════════════════════ */
    .modal-ov { position:fixed; inset:0; z-index:9000; background:rgba(0,0,0,.6); backdrop-filter:blur(8px); display:none; align-items:center; justify-content:center; padding:1.5rem; }
    .modal-ov.open { display:flex; animation:fadeIn .2s ease; }
    .modal-box { background:#0F172A; border-radius:24px; padding:2.5rem 2rem; max-width:350px; width:100%; position:relative; text-align:center; box-shadow:0 32px 80px rgba(0,0,0,.4); animation:scaleIn .3s cubic-bezier(.22,1,.36,1); }
    .modal-close { position:absolute; top:.9rem; right:.9rem; background:rgba(255,255,255,.1); border:none; cursor:pointer; width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,.6); font-size:.8rem; transition:background .15s; }
    .modal-close:hover { background:rgba(255,255,255,.2); }
    .modal-qr-wrap { background:#fff; border-radius:16px; padding:12px; display:inline-block; margin-bottom:1.25rem; box-shadow:0 8px 32px rgba(0,0,0,.4); }
    .modal-qr-wrap canvas,.modal-qr-wrap img { display:block; border-radius:8px; }
    .modal-name { font-size:1.1rem; font-weight:800; color:#fff; margin-bottom:.5rem; }
    .modal-tags { display:flex; gap:.5rem; justify-content:center; flex-wrap:wrap; }
    .modal-tag  { padding:.28rem .7rem; border-radius:7px; background:rgba(255,255,255,.09); color:rgba(255,255,255,.6); font-size:.7rem; font-weight:600; }
    .modal-tag span { color:#fff; }

    /* ══════════════════════════════════════
       DRAWER
    ══════════════════════════════════════ */
    .drawer-ov { position:fixed; inset:0; z-index:8000; background:rgba(0,0,0,.35); backdrop-filter:blur(3px); display:none; }
    .drawer-ov.open { display:block; animation:fadeIn .2s ease; }
    .drawer { position:fixed; top:0; right:0; bottom:0; width:430px; max-width:100vw; background:var(--surface); z-index:8001; display:flex; flex-direction:column; box-shadow:-4px 0 40px rgba(0,0,0,.14); animation:slideR .3s cubic-bezier(.22,1,.36,1); }
    .drawer-w { width:520px; }
    .drawer-hd { display:flex; align-items:center; justify-content:space-between; padding:1.1rem 1.4rem; border-bottom:1px solid var(--border); flex-shrink:0; }
    .drawer-hd-title { font-size:.95rem; font-weight:800; color:var(--t1); }
    .drawer-close { background:var(--bg); border:none; cursor:pointer; width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; color:var(--t2); font-size:.8rem; transition:background .15s; }
    .drawer-close:hover { background:var(--border2); }
    .drawer-body { flex:1; overflow-y:auto; padding:1.4rem; }

    /* Drawer components */
    .dw-s { margin-bottom:1.75rem; }
    .dw-s-title { font-size:.66rem; text-transform:uppercase; letter-spacing:.1em; color:var(--t3); font-weight:700; margin-bottom:.8rem; }
    .dw-hero { background:linear-gradient(135deg,#0F172A 0%,#334155 100%); border-radius:var(--r12); padding:1.4rem 1.5rem; display:flex; align-items:flex-start; gap:1rem; margin-bottom:1.1rem; position:relative; overflow:hidden; }
    .dw-hero::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse at 85% 20%,rgba(200,16,46,.18),transparent 55%); pointer-events:none; }
    .dw-rn { font-size:2.4rem; font-weight:900; color:#fff; letter-spacing:-.04em; line-height:1; }
    .dw-rt { font-size:.74rem; color:rgba(255,255,255,.45); margin-top:.25rem; font-weight:600; }
    .dw-bg { margin-left:auto; padding:.28rem .7rem; border-radius:7px; background:rgba(74,222,128,.15); border:1px solid rgba(74,222,128,.25); color:#4ADE80; font-size:.7rem; font-weight:700; }
    .dw-grid { display:grid; grid-template-columns:1fr 1fr; gap:.55rem; }
    .dw-item { background:var(--bg); border-radius:10px; padding:.65rem .85rem; }
    .dw-item-lbl { font-size:.62rem; text-transform:uppercase; letter-spacing:.07em; color:var(--t3); font-weight:700; margin-bottom:.18rem; }
    .dw-item-val { font-size:.86rem; font-weight:700; color:var(--t1); }
    .am-chips { display:flex; flex-wrap:wrap; gap:.45rem; }
    .am-chip  { display:inline-flex; align-items:center; gap:.3rem; padding:.3rem .7rem; border-radius:7px; background:var(--bg); border:1px solid var(--border2); font-size:.74rem; font-weight:600; color:var(--t2); }
    .dw-info-row { display:flex; align-items:flex-start; gap:.6rem; padding:.5rem 0; border-bottom:1px solid var(--border); }
    .dw-info-row:last-child { border-bottom:none; }
    .dw-ii  { color:var(--t3); font-size:.78rem; margin-top:.14rem; min-width:14px; }
    .dw-il  { font-size:.7rem; color:var(--t3); font-weight:600; }
    .dw-iv  { font-size:.8rem; color:var(--t1); font-weight:600; }
    .rm-item { display:flex; align-items:center; gap:.9rem; padding:.85rem .95rem; border-radius:var(--r12); background:var(--bg); margin-bottom:.6rem; transition:background .15s; }
    .rm-item:hover { background:#EEF2FF; }
    .rm-av  { width:42px; height:42px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:.95rem; font-weight:800; color:#fff; }
    .rm-name{ font-size:.86rem; font-weight:700; color:var(--t1); }
    .rm-meta{ font-size:.72rem; color:var(--t3); margin-top:.08rem; }
    .rm-tag { display:inline-block; margin-top:.2rem; font-size:.63rem; font-weight:700; padding:.12rem .45rem; border-radius:6px; background:var(--green-l); color:var(--green); }
    .rm-empty { text-align:center; padding:2.5rem 1rem; color:var(--t3); font-size:.82rem; }
    .map-wrap { border-radius:var(--r12); overflow:hidden; height:330px; }
    .map-addr { display:flex; align-items:center; gap:.55rem; margin-top:.9rem; padding:.85rem .95rem; border-radius:var(--r12); background:var(--bg); }
    .map-addr-icon { color:var(--red); font-size:.9rem; }
    .map-addr-main { font-size:.82rem; font-weight:700; color:var(--t1); }
    .map-addr-sub  { font-size:.72rem; color:var(--t3); margin-top:.08rem; }

    /* ─── RESPONSIVE ─── */
    @media(max-width:860px){
        .g-65-35 { grid-template-columns:1fr; }
        .am-grid { grid-template-columns:repeat(2,1fr); }
        .notif-row { flex-direction:column; }
        .ni { border-right:none; border-bottom:1.5px solid var(--border); padding:.75rem 0; }
        .ni:last-child { border-bottom:none; }
        .notif-band { flex-direction:column; }
        .notif-hd-col { border-right:none; border-bottom:1.5px solid var(--border); min-width:0; }
        .notif-all { border-left:none; border-top:1.5px solid var(--border); justify-content:center; padding:.7rem; }
        .res-inner { grid-template-columns:1fr; }
        .res-vdiv { display:none; }
        .drawer { width:100%; }
        .drawer-w { width:100%; }
        .rs-page { padding:1.1rem .9rem 4rem; }
    }
    @media(max-width:480px){
        .am-grid { grid-template-columns:repeat(2,1fr); }
        .wl-stats { flex-direction:column; gap:1rem; }
    }

    /* misc */
    .btn-primary { display:inline-flex; align-items:center; gap:.45rem; padding:.55rem 1.3rem; border-radius:10px; background:var(--red); color:#fff; border:none; cursor:pointer; font-size:.84rem; font-weight:700; transition:opacity .15s; }
    .btn-primary:hover { opacity:.88; }

    /* ══════════════════════════════════════
       HERO SECTION
    ══════════════════════════════════════ */
    .rs-hero {
        position:relative; height:300px; margin-bottom:1.25rem;
        border-radius:20px; overflow:hidden;
        background:linear-gradient(135deg,#1a1a2e 0%,#16213e 55%,#0f3460 100%);
    }
    .hero-img {
        position:absolute; inset:0; width:100%; height:100%;
        object-fit:cover; object-position:center 40%;
        transition:opacity .45s ease;
    }
    .hero-ov {
        position:absolute; inset:0;
        background:linear-gradient(90deg,rgba(10,10,20,.82) 0%,rgba(10,10,20,.52) 40%,rgba(10,10,20,.12) 75%,transparent 100%);
    }
    .hero-body {
        position:absolute; left:2.5rem; bottom:2.25rem; z-index:1;
        max-width:540px;
    }
    .hero-eyebrow {
        font-size:.62rem; font-weight:700; letter-spacing:.2em;
        text-transform:uppercase; color:rgba(255,255,255,.55);
        margin-bottom:.55rem;
    }
    .hero-h1 {
        font-size:2.5rem; font-weight:900; color:#fff;
        letter-spacing:-.035em; line-height:1.08;
        margin-bottom:.55rem;
        text-shadow:0 2px 24px rgba(0,0,0,.45);
    }
    .hero-h2 {
        font-size:.84rem; color:rgba(255,255,255,.68);
        line-height:1.6; font-weight:400;
        margin-bottom:1.25rem; max-width:400px;
    }
    .hero-btn {
        display:inline-flex; align-items:center; gap:.65rem;
        background:#fff; color:#111827;
        border:none; cursor:pointer; font-family:inherit;
        padding:.58rem 1rem .58rem 1.3rem;
        border-radius:999px; font-size:.82rem; font-weight:700;
        box-shadow:0 4px 18px rgba(0,0,0,.22);
        transition:transform .2s cubic-bezier(.22,1,.36,1), box-shadow .2s;
        text-decoration:none; white-space:nowrap;
    }
    .hero-btn:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(0,0,0,.28); }
    .hero-btn-arr {
        width:26px; height:26px; border-radius:50%; flex-shrink:0;
        background:#111827; color:#fff;
        display:flex; align-items:center; justify-content:center;
        font-size:.7rem;
    }
    @media(max-width:640px) {
        .rs-hero { height:230px; }
        .hero-body { left:1.25rem; bottom:1.5rem; }
        .hero-h1 { font-size:1.65rem; }
        .hero-h2 { display:none; }
    }

    /* ══════════════════════════════════════
       AMENITIES CHIP SCROLL
    ══════════════════════════════════════ */
    .am-scroll {
        display:flex; gap:.6rem;
        overflow-x:auto; padding:.2rem .05rem .85rem;
        scrollbar-width:none; -webkit-overflow-scrolling:touch;
    }
    .am-scroll::-webkit-scrollbar { display:none; }
    .am-chip-item {
        display:inline-flex; align-items:center; gap:.45rem;
        padding:.48rem 1rem; border-radius:999px;
        background:var(--surface); border:1.5px solid var(--border);
        white-space:nowrap; font-size:.78rem; font-weight:600; color:var(--t1);
        flex-shrink:0; box-shadow:var(--sh0);
        transition:transform .2s cubic-bezier(.22,1,.36,1), box-shadow .2s, border-color .2s;
        text-decoration:none; cursor:default;
    }
    .am-chip-item:hover { transform:translateY(-2px); box-shadow:var(--sh1); border-color:transparent; }
    .am-chip-item .am-chip-ico { font-size:.82rem; }
    .am-chip-maint {
        background:var(--amber-l); border-color:transparent; color:#92400E; cursor:pointer;
    }
    .am-chip-maint:hover { box-shadow:0 4px 14px rgba(217,119,6,.22); }

    /* ══════════════════════════════════════
       FOOTER
    ══════════════════════════════════════ */
    .rs-footer { background:#1a1a2e; margin-top:2.5rem; padding:2.5rem 1.25rem 1.5rem; }
    .footer-inner {
        max-width:1040px; margin:0 auto;
        display:grid; grid-template-columns:1fr 2fr; gap:2.5rem; align-items:start;
        padding-bottom:1.75rem; border-bottom:1px solid rgba(255,255,255,.08);
    }
    .footer-logo-txt { font-size:1.6rem; font-weight:900; color:#fff; letter-spacing:-.03em; line-height:1; margin-bottom:.4rem; }
    .footer-tagline  { font-size:.78rem; color:rgba(255,255,255,.4); line-height:1.5; }
    .footer-cols { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
    .footer-col-title { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.1em; color:rgba(255,255,255,.35); margin-bottom:.85rem; }
    .footer-info-row { font-size:.79rem; color:rgba(255,255,255,.55); margin-bottom:.5rem; display:flex; align-items:flex-start; gap:.5rem; line-height:1.45; }
    .footer-info-row i { flex-shrink:0; margin-top:.15rem; color:rgba(255,255,255,.28); font-size:.72rem; }
    .footer-link { display:block; font-size:.81rem; color:rgba(255,255,255,.5); text-decoration:none; margin-bottom:.45rem; transition:color .15s; }
    .footer-link:hover { color:#fff; }
    .footer-copy { max-width:1040px; margin:1.2rem auto 0; font-size:.72rem; color:rgba(255,255,255,.25); text-align:center; }
    @media(max-width:640px) {
        .footer-inner { grid-template-columns:1fr; gap:1.5rem; }
    }
    </style>
</head>
<body class="student-shell-page">
<%- include('navbar', { currentPage: 'room-status', user: user, student: student }) %>

<div class="rs-page" id="rsPage">

    <!-- STATUS BAR -->
    <div class="rs-bar au1" id="rsBar">
        <div id="rsChipWrap"><span class="spill spill-gray"><i class="fa-solid fa-circle-notch" style="animation:spin 1s linear infinite"></i> <span data-i18n="rs.loading">Đang tải...</span></span></div>
        <div id="rsBtnWrap"></div>
    </div>

    <!-- LOADING -->
    <div id="viewLoading" class="loading-c">
        <div style="text-align:center">
            <i class="fa-solid fa-circle-notch"></i>
            <span data-i18n="rs.loadingInfo">Đang tải thông tin...</span>
        </div>
    </div>

    <!-- ═══════ ALLOCATED VIEW ═══════ -->
    <div id="viewAllocated" style="display:none">

        <!-- HERO SECTION -->
        <div class="rs-hero au1" id="rsHero">
            <img class="hero-img" id="heroBgImg" src="" alt="" style="opacity:0" onerror="this.style.opacity=0">
            <div class="hero-ov"></div>
            <div class="hero-body">
                <div class="hero-eyebrow">KÝ TÚC XÁ</div>
                <div class="hero-h1" id="heroTitle">Ký túc xá HUST</div>
                <div class="hero-h2" id="heroSub">Không gian sống hiện đại, an toàn và tiện nghi dành cho sinh viên Đại học Bách Khoa Hà Nội.</div>
                <button class="hero-btn" onclick="openOv('roomOv')">
                    <span data-i18n="rs.viewMyRoom">Xem phòng của tôi</span>
                    <span class="hero-btn-arr"><i class="fa-solid fa-arrow-right"></i></span>
                </button>
            </div>
        </div>

        <!-- SECTION 1: QR + QUICK ACTIONS -->
        <div class="rs-sec g-65-35 au2">

            <!-- QR CARD -->
            <div class="qr-card" id="qrCard" role="button" tabindex="0" aria-label="Phóng to mã QR">
                <div class="qr-eyebrow" data-i18n="rs.qrEyebrow">Mã xác minh cư trú</div>
                <div class="qr-code-wrap">
                    <div class="qr-skeleton" id="qrSkeleton"></div>
                    <div id="qrCodeEl" style="display:none"></div>
                </div>
                <div class="qr-name" id="qrName"></div>
                <div class="qr-sub"  id="qrSub"></div>
                <div class="qr-badge" id="qrBadge"><i class="fa-solid fa-circle-check"></i> <span data-i18n="rs.qrBadge">Đã được phân phòng</span></div>
                <span class="qr-expand-hint"><i class="fa-solid fa-expand" style="font-size:.64rem"></i> <span data-i18n="rs.qrExpand">Nhấn để phóng to QR</span></span>
            </div>

            <!-- QUICK ACTIONS -->
            <div class="qa-stack au3">
                <div class="qa-card" id="qaRoom" role="button" tabindex="0">
                    <div class="qa-iw qa-iw-red">
                        <span class="qa-num" id="qaRoomNum">104</span>
                    </div>
                    <div class="qa-text">
                        <div class="qa-title" data-i18n="rs.qaRoomTitle">Phòng của bạn</div>
                        <div class="qa-desc" data-i18n="rs.qaRoomDesc">Xem thông tin phòng, tiện ích và trạng thái hiện tại.</div>
                    </div>
                    <i class="fa-solid fa-arrow-right qa-arrow"></i>
                </div>
                <div class="qa-card" id="qaRoommates" role="button" tabindex="0">
                    <div class="qa-iw qa-iw-blue">
                        <svg width="32" height="27" viewBox="0 0 32 27" fill="none">
                            <circle cx="10" cy="7.5" r="5" fill="#4F46E5" opacity=".65"/>
                            <path d="M1 25c0-4.97 4.03-9 9-9 .83 0 1.64.11 2.42.31" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" opacity=".65" fill="none"/>
                            <circle cx="20.5" cy="7.5" r="6" fill="#4F46E5"/>
                            <path d="M10 25c0-5.52 4.48-10 10.5-10s10.5 4.48 10.5 10" stroke="#4F46E5" stroke-width="2" stroke-linecap="round" fill="none"/>
                        </svg>
                    </div>
                    <div class="qa-text">
                        <div class="qa-title" data-i18n="rs.qaRoommatesTitle">Bạn cùng phòng</div>
                        <div class="qa-desc" data-i18n="rs.qaRoommatesDesc">Xem danh sách thành viên và thông tin chi tiết.</div>
                    </div>
                    <i class="fa-solid fa-arrow-right qa-arrow"></i>
                </div>
                <div class="qa-card" id="qaMap" role="button" tabindex="0">
                    <div class="qa-iw qa-iw-green">
                        <svg width="24" height="32" viewBox="0 0 24 32" fill="none">
                            <path d="M12 0C5.373 0 0 5.373 0 12c0 9.333 12 20 12 20s12-10.667 12-20C24 5.373 18.627 0 12 0z" fill="#059669"/>
                            <circle cx="12" cy="12" r="5" fill="white"/>
                        </svg>
                    </div>
                    <div class="qa-text">
                        <div class="qa-title" data-i18n="rs.qaMapTitle">Bản đồ</div>
                        <div class="qa-desc" data-i18n="rs.qaMapDesc">Xem vị trí KTX và chỉ đường tới phòng của bạn.</div>
                    </div>
                    <i class="fa-solid fa-arrow-right qa-arrow"></i>
                </div>
            </div>
        </div>

        <!-- SECTION 2: NOTIFICATIONS -->
        <div class="rs-sec au3">
            <div class="notif-band">
                <div class="notif-hd-col">
                    <div class="bell-wrap"><i class="fa-regular fa-bell"></i></div>
                    <div class="notif-hd-lbl" data-i18n="rs.notifLatest">Thông báo<br>mới nhất</div>
                </div>
                <div class="notif-row" id="notifRow">
                    <div class="notif-empty-band"><i class="fa-solid fa-circle-notch" style="animation:spin 1s linear infinite;font-size:.78rem"></i> Đang tải...</div>
                </div>
                <div class="notif-all" onclick="window.location='/notifications'" title="Xem tất cả thông báo">
                    <i class="fa-solid fa-chevron-right"></i>
                </div>
            </div>
        </div>

        <!-- SECTION 3: RESIDENT CARD -->
        <div class="rs-sec au4">
            <div class="res-eyebrow"><i class="fa-solid fa-id-card" style="margin-right:.3rem;color:var(--t3)"></i><span data-i18n="rs.resEyebrow">Thẻ cư trú điện tử</span></div>
            <div class="res-card">
                <div class="res-inner">
                    <!-- LEFT: QR Code -->
                    <div class="res-qr-side">
                        <div class="res-qr-box">
                            <div class="res-qr-skel" id="resQrSkel"></div>
                            <div id="resQrEl" style="display:none"></div>
                        </div>
                        <div class="res-qr-lbl" data-i18n="rs.resScanQr">Quét mã</div>
                    </div>
                    <!-- RIGHT: Description -->
                    <div class="res-desc-side">
                        <div class="res-wm"><img src="https://res.cloudinary.com/dysgt8t4d/image/upload/v1781114107/logo_edorm2_au54b2.png" alt="eDorm" style="max-height:32px;width:auto;object-fit:contain;"></div>
                        <div class="res-card-tag" data-i18n="rs.resCardTag"><i class="fa-solid fa-id-card"></i> Thẻ cư trú · KTX HUST</div>
                        <div class="res-card-title" data-i18n="rs.resCardTitle">Mã xác minh cư trú</div>
                        <div class="res-card-desc">Quét mã QR để xác minh thông tin cư trú của sinh viên tại ký túc xá. Mã này có thể được sử dụng bởi Ban quản lý KTX để kiểm tra tình trạng cư trú, xác thực danh tính khi nhận phòng, xử lý thủ tục hành chính hoặc đối chiếu thông tin nội bộ.</div>
                        <div class="res-badges">
                            <span class="res-badge"><i class="fa-solid fa-user-check"></i> Xác thực danh tính</span>
                            <span class="res-badge"><i class="fa-solid fa-house-circle-check"></i> Kiểm tra cư trú</span>
                            <span class="res-badge"><i class="fa-solid fa-file-lines"></i> Thủ tục hành chính</span>
                            <span class="res-badge"><i class="fa-solid fa-shield-halved"></i> Quản lý nội bộ</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SECTION 4: AMENITIES -->
        <div class="rs-sec au5">
            <div class="am-head"><span class="am-head-title" data-i18n="rs.amenities">Tiện ích ký túc xá</span></div>
            <div class="am-scroll" id="amenGrid"></div>
        </div>

    </div><!-- /viewAllocated -->

    <!-- ═══════ WAITLIST ═══════ -->
    <div id="viewWaitlist" style="display:none" class="au2">
        <div class="state-wrap">
            <div class="state-card">
                <div class="state-inner">
                    <div class="wl-ring" id="wlRing"><i class="fa-solid fa-list-ol"></i></div>
                    <div class="state-title" id="wlTitle" data-i18n="rs.wlTitle">Danh sách chờ</div>
                    <div class="state-sub" data-i18n="rs.wlSub">Đơn đăng ký của bạn đang trong hàng đợi.<br>Hệ thống thông báo ngay khi có phòng trống.</div>
                    <div class="wl-stats" id="wlStats"></div>
                    <div id="wlMsg" style="font-size:.8rem;color:var(--t2);margin-bottom:1rem"></div>
                    <div><span class="live-dot"></span><span style="font-size:.77rem;color:var(--t3);font-weight:600" data-i18n="rs.wlLive">Cập nhật theo thời gian thực</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════ PENDING ═══════ -->
    <div id="viewPending" style="display:none" class="au2">
        <div class="state-wrap">
            <div class="state-card">
                <div class="state-inner">
                    <div class="state-ico" style="background:var(--amber-l);color:var(--amber)"><i class="fa-solid fa-hourglass-half"></i></div>
                    <div class="state-title" data-i18n="rs.pendingTitle">Đơn đang xét duyệt</div>
                    <div class="state-sub" data-i18n="rs.pendingSub">Bộ phận quản lý đang xem xét đơn của bạn.<br>Kết quả sẽ được thông báo sớm.</div>
                    <div class="pending-chips" id="pendingChips"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════ NONE ═══════ -->
    <div id="viewNone" style="display:none" class="au2">
        <div class="empty-card">
            <div class="empty-ico"><i class="fa-solid fa-house-chimney-crack"></i></div>
            <h2 data-i18n="rs.noneTitle">Chưa có đăng ký ký túc xá</h2>
            <p data-i18n="rs.noneSub">Bạn chưa có đơn đăng ký nào. Hãy tạo đơn trong đợt đăng ký đang mở.</p>
            <div id="noneBtn"></div>
        </div>
    </div>

    <!-- ═══════ ERROR ═══════ -->
    <div id="viewError" style="display:none" class="au2">
        <div class="empty-card">
            <div class="empty-ico"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <h2 data-i18n="rs.errorTitle">Không tải được dữ liệu</h2>
            <p data-i18n="rs.errorSub">Đã xảy ra lỗi khi tải thông tin. Vui lòng thử lại.</p>
            <button class="btn-primary" onclick="location.reload()"><i class="fa-solid fa-rotate-right"></i> <span data-i18n="rs.retryBtn">Thử lại</span></button>
        </div>
    </div>

</div><!-- /rs-page -->

<%- include('../shared/footer') %>

<!-- ═══════ QR MODAL ═══════ -->
<div class="modal-ov" id="qrModal">
    <div class="modal-box">
        <button class="modal-close" id="qrModalClose"><i class="fa-solid fa-xmark"></i></button>
        <div class="modal-qr-wrap"><div id="modalQrEl"></div></div>
        <div class="modal-name" id="modalName"></div>
        <div class="modal-tags" id="modalTags"></div>
    </div>
</div>

<!-- ═══════ ROOM DRAWER ═══════ -->
<div class="drawer-ov" id="roomOv">
    <div class="drawer" id="roomDw">
        <div class="drawer-hd">
            <span class="drawer-hd-title" data-i18n="rs.drawerRoom">Phòng của bạn</span>
            <button class="drawer-close" data-close="roomOv"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="drawer-body" id="roomBody"></div>
    </div>
</div>

<!-- ═══════ ROOMMATES DRAWER ═══════ -->
<div class="drawer-ov" id="rmOv">
    <div class="drawer" id="rmDw">
        <div class="drawer-hd">
            <span class="drawer-hd-title" data-i18n="rs.drawerRoommates">Bạn cùng phòng</span>
            <button class="drawer-close" data-close="rmOv"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="drawer-body" id="rmBody"></div>
    </div>
</div>

