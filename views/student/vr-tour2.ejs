/* ── ENVIRONMENT MAP (indoor studio, không cần file HDR ngoài) ── */
function setupEnvironment() {
    try {
        const pmrem = new THREE.PMREMGenerator(renderer);
        pmrem.compileEquirectangularShader();

        // Tạo equirectangular gradient giả lập ánh sáng phòng ở
        const ec = document.createElement('canvas');
        ec.width = 512; ec.height = 256;
        const ectx = ec.getContext('2d');

        // Trần/bầu trời — trắng ấm dịu
        const top = ectx.createLinearGradient(0, 0, 0, 128);
        top.addColorStop(0,   '#cde0f5');
        top.addColorStop(0.5, '#e6e0d6');
        top.addColorStop(1,   '#f0ece5');
        ectx.fillStyle = top;
        ectx.fillRect(0, 0, 512, 128);

        // Sàn/tường dưới — nâu ấm
        const bot = ectx.createLinearGradient(0, 128, 0, 256);
        bot.addColorStop(0,   '#d8ccb8');
        bot.addColorStop(0.6, '#b79f82');
        bot.addColorStop(1,   '#8a7860');
        ectx.fillStyle = bot;
        ectx.fillRect(0, 128, 512, 128);

        // Highlight cửa sổ nhỏ
        ectx.fillStyle = 'rgba(255,248,220,0.25)';
        ectx.fillRect(40, 50, 120, 80);

        const envTex = new THREE.CanvasTexture(ec);
        envTex.mapping  = THREE.EquirectangularReflectionMapping;
        envTex.encoding = THREE.sRGBEncoding;

        const rt = pmrem.fromEquirectangular(envTex);
        scene.environment = rt.texture;

        envTex.dispose();
        pmrem.dispose();
        console.log('[B2] HDR loaded (procedural indoor studio)');
        console.log('[B2] Environment map enabled');
    } catch (e) {
        console.warn('[B2] Environment setup failed:', e.message);
    }
}
setupEnvironment();

