        + '<button onclick="history.back()" style="background:#d63031;color:#fff;border:none;padding:12px 24px;border-radius:8px;font-size:15px;cursor:pointer">Quay lại</button>';
    document.body.appendChild(fallback);
}

const glbTimeout = setTimeout(showGlbFallback, 90000);

gltfLoader.load(
    MODEL_URL,
    onGLBLoaded,
    (xhr) => {
        if (xhr.total > 0) {
            const pct = 5 + xhr.loaded / xhr.total * 70;
            setLd(pct, 'Đang tải mô hình 3D... ' + Math.round(pct - 5) + '%');
        }
    },
    (err) => { console.error('[B2] GLB load error:', err); clearTimeout(glbTimeout); showGlbFallback(); }
);

function onGLBLoaded(gltf) {
    clearTimeout(glbTimeout);
    setLd(85, 'Đang xử lý mô hình...');
    console.log('[B2] roomm.glb loaded OK');

    const model = gltf.scene;
    const maxAniso = renderer.capabilities.getMaxAnisotropy();

    model.traverse(child => {
        if (!child.isMesh) return;
        child.castShadow    = true;
        child.receiveShadow = true;

        if (!child.material) return;

        const mats = Array.isArray(child.material) ? child.material : [child.material];
        mats.forEach(mat => {
            /* Chuyển BasicMaterial → StandardMaterial để nhận ánh sáng */
            if (mat.isMeshBasicMaterial) {
                // Phát hiện vật liệu màu trắng/sáng — tăng roughness để giữ chi tiết
                const c = mat.color;
                const isBright = c && (c.r + c.g + c.b) > 2.2;
                const upgraded = new THREE.MeshStandardMaterial({
                    map:         mat.map         || null,
                    color:       mat.color,
                    side:        mat.side,
                    transparent: mat.transparent,
                    opacity:     mat.opacity,
                    roughness:   isBright ? 0.92 : 0.82,
                    metalness:   0.0,
                });
                if (mat.map) mat.map.encoding = THREE.sRGBEncoding;
                mat.dispose();
                child.material = upgraded;
                return;
            }

            /* StandardMaterial / PhysicalMaterial — nâng cấp chất lượng */
            if (mat.isMeshStandardMaterial || mat.isMeshPhysicalMaterial) {
                mat.envMapIntensity = 0.35;

                // Vật liệu màu trắng/sáng: tăng roughness để không bị clamp
                const c = mat.color;
                if (c && (c.r + c.g + c.b) > 2.2) {
                    if (mat.roughness < 0.85) mat.roughness = 0.90;
                    mat.metalness = Math.min(mat.metalness, 0.02);
                }

                /* Anisotropy cho tất cả texture — sắc nét khi nhìn chéo */
                const texSlots = [
                    'map', 'normalMap', 'roughnessMap',
                    'metalnessMap', 'aoMap', 'emissiveMap', 'bumpMap'
                ];
                texSlots.forEach(slot => {
                    if (mat[slot]) {
                        mat[slot].anisotropy = maxAniso;
                        if (slot === 'map' || slot === 'emissiveMap') {
                            mat[slot].encoding = THREE.sRGBEncoding;
                        }
                        mat[slot].needsUpdate = true;
                    }
                });
                mat.needsUpdate = true;
            }
        });
    });
    scene.add(model);

    const bbox = new THREE.Box3().setFromObject(model);
    const m = 0.4;
    exRoomBounds = { minX: bbox.min.x + m, maxX: bbox.max.x - m, minZ: bbox.min.z + m, maxZ: bbox.max.z - m };
    console.log('[B2] Room bounds:', exRoomBounds);

    /* Thu thập collision meshes để raycast va chạm tường */
    model.traverse(child => { if (child.isMesh) collisionMeshes.push(child); });
    console.log('[B2] Collision meshes:', collisionMeshes.length);

    createExWaypoints();
    exSpawnAtDefault();
    glbReady = true;
    maybeHideLd();
}

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — WAYPOINT MARKERS (2 hotspot điều hướng)
   ═══════════════════════════════════════════════════════════════ */

function createExWaypoints() {
    EX_WAYPOINTS.forEach((wp, idx) => {
        const grp = new THREE.Group();

        /* Vòng tròn fill mờ */
        grp.add(new THREE.Mesh(
            new THREE.CircleGeometry(0.22, 40),
            new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.12, side: THREE.DoubleSide, depthWrite: false })
        ));
        /* Ring chính */
        grp.add(new THREE.Mesh(
            new THREE.RingGeometry(0.22, 0.30, 40),
            new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.85, side: THREE.DoubleSide, depthWrite: false })
        ));
        /* Glow ring ngoài */
        grp.add(new THREE.Mesh(
            new THREE.RingGeometry(0.32, 0.42, 40),
            new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.18, side: THREE.DoubleSide, depthWrite: false })
        ));
        /* Hit area vô hình */
        grp.add(new THREE.Mesh(
            new THREE.CircleGeometry(0.55, 16),
            new THREE.MeshBasicMaterial({ visible: false, side: THREE.DoubleSide })
        ));

        grp.position.set(wp.hotspotPos.x, GROUND_Y + 0.02, wp.hotspotPos.z);
        grp.renderOrder = 2;
        scene.add(grp);

        exWaypoints.push({ grp, wp, phase: idx * Math.PI, hovered: false });
    });
    console.log('[B2] Waypoints created:', exWaypoints.length);
}

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — SPAWN / RESET
   ═══════════════════════════════════════════════════════════════ */

function exSpawnAtDefault() {
    camera.position.set(SPAWN_POS.x, SPAWN_POS.y, SPAWN_POS.z);
    camera.quaternion.setFromEuler(new THREE.Euler(SPAWN_POS.rotX, SPAWN_POS.rotY, SPAWN_POS.rotZ, 'YXZ'));
    syncExAngles();
    console.log('=== SPAWN POSITION ===', JSON.stringify(SPAWN_POS, null, 2));
}

function syncExAngles() {
    const e = new THREE.Euler().setFromQuaternion(camera.quaternion, 'YXZ');
    exYaw   = e.y;
    exPitch = Math.max(EX_MIN_PITCH, Math.min(EX_MAX_PITCH, e.x));
}

function applyExRotation() {
    camera.quaternion.setFromEuler(new THREE.Euler(exPitch, exYaw, 0, 'YXZ'));
}

document.getElementById('reset-btn').addEventListener('click', () => {
    exFlyActive = false;
    exSpawnAtDefault();
});

document.getElementById('overview-btn').addEventListener('click', () => {
    const cx   = (exRoomBounds.minX + exRoomBounds.maxX) * .5;
    const cz   = (exRoomBounds.minZ + exRoomBounds.maxZ) * .5;
    const quat = new THREE.Quaternion().setFromEuler(new THREE.Euler(-Math.PI / 2, 0, 0, 'XYZ'));
    exFlyTo(new THREE.Vector3(cx, 5.5, cz), quat, OVR_DUR, null);
});

