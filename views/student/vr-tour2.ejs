<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>VR Tour B2 – Ký túc xá HUST</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --brand:       #e63946;
            --brand-glow:  rgba(230,57,70,.35);
            --glass-bg:    rgba(10,12,18,.72);
            --glass-bd:    rgba(255,255,255,.12);
            --surface:     rgba(15,17,25,.90);
            --text:        #f0f2f7;
            --muted:       rgba(240,242,247,.6);
            --accent:      #4fc3f7;
            --radius:      14px;
        }

        body { font-family:'Inter',sans-serif; background:#0a0c12; color:var(--text); overflow:hidden; width:100vw; height:100vh; }

        /* ── Loading ──────────────────────────────────────── */
        #loading-screen {
            position:fixed; inset:0; z-index:2000; background:#0a0c12;
            display:flex; flex-direction:column; align-items:center; justify-content:center; gap:20px;
        }
        .ld-logo   { font-size:2rem; font-weight:800; color:var(--brand); letter-spacing:-1px; }
        .ld-logo span { color:var(--text); }
        .ld-bar-wrap { width:280px; height:4px; background:rgba(255,255,255,.1); border-radius:2px; overflow:hidden; }
        .ld-bar  { height:100%; width:0; background:var(--brand); border-radius:2px; transition:width .15s; }
        .ld-msg  { font-size:.8rem; color:var(--muted); }

        /* ── Mode Toggle (bottom-left) ──────────────────── */
        #mode-toggle {
            position:fixed; bottom:20px; left:20px; z-index:500;
            background:rgba(20,20,20,.78);
            border:1px solid rgba(255,255,255,.08);
            backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
            border-radius:18px; padding:10px;
            display:flex; flex-direction:column; gap:4px;
            box-shadow:0 10px 40px rgba(0,0,0,.38);
        }
        .mode-opt {
            display:flex; align-items:center; gap:11px;
            padding:11px 16px; border-radius:11px;
            background:none; border:1px solid transparent; cursor:pointer;
            color:rgba(255,255,255,.55); font-size:.83rem; font-weight:600;
            font-family:'Inter',sans-serif; transition:all .2s ease;
            white-space:nowrap; text-align:left;
        }
        .mode-opt:hover {
            color:rgba(255,255,255,.85);
            background:rgba(255,255,255,.06);
            border-color:rgba(255,255,255,.1);
        }
        .mode-opt.active {
            color:#fff;
            background:rgba(255,255,255,.1);
            border-color:rgba(255,255,255,.18);
        }
        .mode-icon {
            width:30px; height:30px; border-radius:8px; flex-shrink:0;
            background:rgba(255,255,255,.07); display:flex;
            align-items:center; justify-content:center;
            font-size:.95rem; transition:background .2s;
        }
        .mode-opt.active .mode-icon { background:rgba(255,255,255,.14); }
        .mode-opt-text { display:flex; flex-direction:column; gap:1px; }
        .mode-opt-name { font-size:.83rem; font-weight:700; line-height:1.1; }
        .mode-opt-desc { font-size:.66rem; font-weight:400; opacity:.55; line-height:1.2; }

        /* ── Back Button ─────────────────────────────────── */
        #back-btn {
            position:fixed; top:20px; left:20px; z-index:500;
            background:var(--glass-bg); border:1px solid var(--glass-bd);
            backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
            color:var(--text); padding:10px 18px; border-radius:var(--radius);
            cursor:pointer; font-size:.82rem; font-weight:600;
            display:flex; align-items:center; gap:8px; font-family:'Inter',sans-serif;
            transition:background .2s, border-color .2s;
        }
        #back-btn:hover { background:rgba(230,57,70,.15); border-color:var(--brand); }

        /* ══════════════════════════════════════════════════
           MATTERPORT PANEL
           ══════════════════════════════════════════════════ */
        #mp-panel { position:fixed; inset:0; z-index:10; }

        #mp-bg {
            position:absolute; inset:-10%;
            background-size:cover; background-position:center; background-repeat:no-repeat;
            will-change:transform;
        }

        #mp-vignette {
            position:absolute; inset:0; pointer-events:none;
            background: radial-gradient(ellipse 90% 80% at 50% 50%, transparent 55%, rgba(0,0,0,.55) 100%);
        }

        #mp-fade {
            position:absolute; inset:0; background:#000; opacity:0;
            pointer-events:none; transition:opacity .28s ease;
        }

        #mp-hotspots { position:absolute; inset:0; pointer-events:none; }

        .mp-hs {
            position:absolute; transform:translate(-50%,-50%);
            width:40px; height:40px; cursor:pointer; pointer-events:all;
        }
        .mp-hs-ring {
            position:absolute; inset:0; border-radius:50%;
            background:rgba(255,255,255,.18);
            border:2px solid rgba(255,255,255,.82);
            box-shadow:0 0 14px rgba(255,255,255,.35), 0 3px 10px rgba(0,0,0,.45);
            transition:transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s;
            animation:mpPulse 2.8s ease-in-out infinite;
        }
        .mp-hs:hover .mp-hs-ring {
            transform:scale(1.32);
            box-shadow:0 0 24px rgba(255,255,255,.65), 0 3px 14px rgba(0,0,0,.55);
        }
        .mp-hs-glow {
            position:absolute; inset:-6px; border-radius:50%;
            border:1px solid rgba(255,255,255,.22);
            animation:mpPulse 2.8s ease-in-out infinite .4s;
            pointer-events:none;
        }
        @keyframes mpPulse {
            0%,100% { box-shadow:0 0 12px rgba(255,255,255,.28); }
            50%      { box-shadow:0 0 22px rgba(255,255,255,.60); }
        }

        /* ── Hotspot Debug Overlay ───────────────────────── */
        #mp-hs-dbg {
            position:fixed; bottom:80px; left:20px; z-index:600;
            background:rgba(0,0,0,.85); border:1px solid rgba(0,255,100,.4);
            border-radius:10px; padding:12px 16px;
            font-family:'Courier New',monospace; font-size:.73rem;
            color:#0f0; line-height:1.9; min-width:230px;
            pointer-events:none; display:none;
        }
        #mp-hs-dbg.show { display:block; }
        #mp-hs-dbg .dbh-title  { color:#fff; font-weight:700; margin-bottom:4px; }
        #mp-hs-dbg .dbh-hint   { color:rgba(255,255,255,.5); font-size:.65rem; }
        #mp-hs-dbg .dbh-sep    { border-top:1px solid rgba(0,255,100,.2); margin:5px 0; }
        /* Crosshair lines */
        #mp-hs-cx { position:fixed; top:0; bottom:0; width:1px; background:rgba(255,60,60,.6); pointer-events:none; z-index:601; display:none; }
        #mp-hs-cy { position:fixed; left:0; right:0; height:1px; background:rgba(255,60,60,.6); pointer-events:none; z-index:601; display:none; }

        #mp-node-strip {
            position:fixed; bottom:20px; left:50%; transform:translateX(-50%);
            z-index:500; display:flex; gap:8px; align-items:center;
        }
        .mp-node-dot {
            width:8px; height:8px; border-radius:50%;
            background:rgba(255,255,255,.35); border:1px solid rgba(255,255,255,.5);
            cursor:pointer; transition:all .2s;
        }
        .mp-node-dot.active { background:#fff; width:10px; height:10px; }

        /* ══════════════════════════════════════════════════
           EXPLORE PANEL (Three.js)
           ══════════════════════════════════════════════════ */
        #ex-panel { position:fixed; inset:0; z-index:10; display:none; }

        #three-canvas {
            position:absolute; inset:0;
            display:block; width:100%!important; height:100%!important;
            cursor:none;
        }

        /* Crosshair */
        #crosshair {
            position:fixed; top:50%; left:50%;
            transform:translate(-50%,-50%);
            width:20px; height:20px; pointer-events:none; z-index:200; display:none;
        }
        #crosshair::before, #crosshair::after {
            content:''; position:absolute; background:rgba(255,255,255,.85);
        }
        #crosshair::before { left:50%; top:4px; bottom:4px; width:1.5px; transform:translateX(-50%); }
        #crosshair::after  { top:50%; left:4px; right:4px; height:1.5px; transform:translateY(-50%); }

        /* Pointer Lock Prompt */
        #lock-prompt {
            position:fixed; inset:0; z-index:400; display:none;
            flex-direction:column; align-items:center; justify-content:center; gap:16px;
            background:rgba(10,12,18,.88); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px);
        }
        #lock-prompt.show { display:flex; }
        .lp-icon {
            width:60px; height:60px;
            background:rgba(230,57,70,.12); border:2px solid var(--brand); border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            font-size:1.6rem; color:var(--brand);
            animation:lpPulse 2s ease-in-out infinite;
        }
        @keyframes lpPulse {
            0%,100% { box-shadow:0 0 0 0 var(--brand-glow); }
            50%      { box-shadow:0 0 0 14px transparent; }
        }
        .lp-title { font-size:1.2rem; font-weight:800; }
        .lp-sub   { font-size:.84rem; color:var(--muted); max-width:300px; text-align:center; }
        .lp-cta {
            background:var(--brand); color:#fff; border:none;
            border-radius:var(--radius); padding:12px 32px;
            font-size:.92rem; font-weight:700; cursor:pointer;
            box-shadow:0 4px 20px var(--brand-glow); font-family:'Inter',sans-serif;
            transition:transform .15s, box-shadow .15s;
        }
        .lp-cta:hover { transform:translateY(-2px); box-shadow:0 8px 28px var(--brand-glow); }

        /* ── Shared HUD (explore) ────────────────────────── */
        #ex-hud {
            position:fixed; top:20px; right:170px; z-index:300;
            display:none; flex-direction:column; gap:8px;
        }
        .hud-btn {
            background:var(--glass-bg); border:1px solid var(--glass-bd);
            backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
            color:var(--text); padding:9px 16px; border-radius:var(--radius);
            cursor:pointer; font-size:.78rem; font-weight:600;
            display:flex; align-items:center; gap:8px; font-family:'Inter',sans-serif;
            transition:background .2s, border-color .2s; white-space:nowrap;
        }
        .hud-btn:hover { background:rgba(79,195,247,.12); border-color:var(--accent); }

        /* ── Minimap ─────────────────────────────────────── */
        #minimap-wrap {
            position:fixed; bottom:20px; right:20px; z-index:300; display:none;
        }
        #minimap {
            width:110px; height:110px; border-radius:50%;
            border:2px solid var(--glass-bd); background:rgba(10,12,18,.85);
            overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,.5);
        }
        #mm-canvas { width:100%; height:100%; }
        .mm-label { text-align:center; font-size:.62rem; color:var(--muted); margin-top:4px; letter-spacing:.5px; }

        /* ── Controls Hint (explore) ────────────────────── */
        #ex-hint {
            position:fixed; bottom:20px; left:20px; z-index:300; display:none;
            background:var(--glass-bg); border:1px solid var(--glass-bd);
            backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
            border-radius:var(--radius); padding:10px 14px;
            font-size:.72rem; color:var(--muted); line-height:1.9;
        }
        #ex-hint .k {
            display:inline-block; background:rgba(255,255,255,.1);
            border:1px solid rgba(255,255,255,.2); border-radius:4px;
            padding:0 6px; font-size:.68rem; color:var(--text); margin:0 1px;
        }
        @media (max-width:640px) { #ex-hint { display:none!important; } }

        /* ── Debug Coordinate Panel ──────────────────────── */
        #debug-panel {
            position:fixed; top:70px; left:20px; z-index:500; display:none;
            background:rgba(0,0,0,.78); border:1px solid rgba(255,255,255,.15);
            backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px);
            border-radius:10px; padding:12px 16px;
            font-family:'Courier New',monospace; font-size:.76rem; color:#a0f0b0;
            min-width:195px; line-height:1.85;
        }
        .dbg-title { font-weight:700; color:#fff; margin-bottom:3px; font-size:.8rem; letter-spacing:.5px; }
        .dbg-row   { display:flex; justify-content:space-between; gap:14px; }
        .dbg-k     { color:rgba(255,255,255,.5); }
        .dbg-sep   { border-top:1px solid rgba(255,255,255,.1); margin:5px 0; }
        #dbg-copy {
            margin-top:8px; width:100%;
            background:rgba(79,195,247,.12); border:1px solid rgba(79,195,247,.28);
            color:#4fc3f7; padding:6px 10px; border-radius:6px;
            cursor:pointer; font-size:.74rem; font-family:'Inter',sans-serif;
            font-weight:600; transition:background .2s;
        }
        #dbg-copy:hover { background:rgba(79,195,247,.28); }

        /* ── Mobile Joystick ─────────────────────────────── */
        #mobile-ctrl { display:none; }
        @media (max-width:768px) {
            #mobile-ctrl {
                position:fixed; bottom:28px; left:28px; z-index:400;
            }
            #mobile-ctrl.show { display:block; }
            #jz-zone {
                width:110px; height:110px; border-radius:50%;
                background:rgba(255,255,255,.06); border:2px solid rgba(255,255,255,.15);
                position:relative;
            }
            #jz-thumb {
                width:38px; height:38px; border-radius:50%;
                background:rgba(255,255,255,.25); border:2px solid rgba(255,255,255,.5);
                position:absolute; top:50%; left:50%;
                transform:translate(-50%,-50%); pointer-events:none; transition:transform .05s;
            }
        }
    </style>
</head>
<body>

<!-- Loading Screen -->
<div id="loading-screen">
    <div class="ld-logo">HUST<span>KTX</span></div>
    <div style="font-size:1rem;font-weight:700">Đang tải VR Tour — Phòng B2</div>
    <div class="ld-bar-wrap"><div class="ld-bar" id="ld-bar"></div></div>
    <div class="ld-msg" id="ld-msg">Khởi tạo...</div>
</div>

<!-- Back Button -->
<button id="back-btn" onclick="history.back()"><i class="fas fa-arrow-left"></i> Quay lại</button>

<!-- Hotspot Debug Overlay (toggle with ` key in Matterport mode) -->
<div id="mp-hs-dbg">
    <div class="dbh-title">[ HS DEBUG ] <span style="color:rgba(255,255,255,.4);font-size:.65rem">nhấn ` để tắt</span></div>
    <div class="dbh-sep"></div>
    <div>VP: x=<span id="dbh-vx">–</span> y=<span id="dbh-vy">–</span></div>
    <div>IMG: ix=<span id="dbh-ix">–</span> iy=<span id="dbh-iy">–</span></div>
    <div class="dbh-sep"></div>
    <div class="dbh-hint">Click → log coords để paste vào NODE_HOTSPOTS</div>
    <div class="dbh-hint">imgW=<span id="dbh-iw">?</span> imgH=<span id="dbh-ih">?</span></div>
</div>
<div id="mp-hs-cx"></div>
<div id="mp-hs-cy"></div>

<!-- Mode Toggle -->
<div id="mode-toggle">
    <button class="mode-opt active" data-mode="matterport"
            title="Di chuyển bằng các điểm đánh dấu giống tour khách sạn.">
        <span class="mode-icon"><i class="fas fa-map-pin"></i></span>
        <span class="mode-opt-text">
            <span class="mode-opt-name">Tham quan nhanh</span>
            <span class="mode-opt-desc">Điểm đánh dấu tương tác</span>
        </span>
    </button>
    <button class="mode-opt" data-mode="explore"
            title="Tự do di chuyển trong không gian 3D bằng chuột và bàn phím.">
        <span class="mode-icon"><i class="fas fa-person-walking"></i></span>
        <span class="mode-opt-text">
            <span class="mode-opt-name">Khám phá tự do</span>
            <span class="mode-opt-desc">WASD · chuột · va chạm</span>
        </span>
    </button>
</div>

<!-- ╔══════════════════════════════════════╗
     ║       MATTERPORT PANEL               ║
     ╚══════════════════════════════════════╝ -->
<div id="mp-panel">
    <div id="mp-bg"></div>
    <div id="mp-vignette"></div>
    <div id="mp-fade"></div>
    <div id="mp-hotspots"></div>
</div>
<div id="mp-node-strip"></div>

<!-- ╔══════════════════════════════════════╗
     ║       EXPLORE PANEL (Three.js)        ║
     ╚══════════════════════════════════════╝ -->
<div id="ex-panel">
    <canvas id="three-canvas"></canvas>
</div>

<!-- Crosshair (explore) -->
<div id="crosshair"></div>

<!-- Pointer Lock Prompt (explore) -->
<div id="lock-prompt">
    <div class="lp-icon"><i class="fas fa-person-walking"></i></div>
    <div class="lp-title">Chế độ Khám Phá Tự Do</div>
    <div class="lp-sub">Nhấp để khoá chuột và di chuyển bằng WASD</div>
    <button class="lp-cta" id="enter-btn"><i class="fas fa-lock" style="margin-right:7px"></i>Bắt đầu khám phá</button>
</div>

<!-- Debug Coordinate Panel (Free Explore) -->
<div id="debug-panel">
    <div class="dbg-title">[ DEBUG ]</div>
    <div class="dbg-row"><span class="dbg-k">X:</span> <span id="dbg-x">0.000</span></div>
    <div class="dbg-row"><span class="dbg-k">Y:</span> <span id="dbg-y">0.000</span></div>
    <div class="dbg-row"><span class="dbg-k">Z:</span> <span id="dbg-z">0.000</span></div>
    <div class="dbg-sep"></div>
    <div class="dbg-row"><span class="dbg-k">RotX:</span> <span id="dbg-rx">0.000</span></div>
    <div class="dbg-row"><span class="dbg-k">RotY:</span> <span id="dbg-ry">0.000</span></div>
    <div class="dbg-row"><span class="dbg-k">RotZ:</span> <span id="dbg-rz">0.000</span></div>
    <div class="dbg-sep"></div>
    <div class="dbg-row"><span class="dbg-k">Mode:</span> <span id="dbg-mode">Free Explore</span></div>
    <button id="dbg-copy">📋 Copy Position</button>
</div>

<!-- HUD buttons (explore) -->
<div id="ex-hud">
    <button class="hud-btn" id="overview-btn"><i class="fas fa-eye"></i> Toàn cảnh</button>
    <button class="hud-btn" id="reset-btn"><i class="fas fa-undo"></i> Đặt lại</button>
</div>

<!-- Minimap (explore) -->
<div id="minimap-wrap">
    <div id="minimap"><canvas id="mm-canvas" width="110" height="110"></canvas></div>
    <div class="mm-label">BẢN ĐỒ MINI</div>
</div>

<!-- Controls hint (explore) -->
<div id="ex-hint">
    <span class="k">W</span><span class="k">A</span><span class="k">S</span><span class="k">D</span> Di chuyển<br>
    <span class="k">Chuột</span> Nhìn xung quanh<br>
    <span class="k">P</span> Log tọa độ camera<br>
    <span class="k">Esc</span> Giải phóng chuột
</div>

<!-- Mobile joystick (explore) -->
<div id="mobile-ctrl">
    <div id="jz-zone"><div id="jz-thumb"></div></div>
</div>

<!-- Three.js r128 — same CDN as vr-tour.ejs -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/DRACOLoader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/PointerLockControls.js"></script>
<!-- Post-processing (r128) -->
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/CopyShader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/LuminosityHighPassShader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/EffectComposer.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/RenderPass.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/ShaderPass.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/UnrealBloomPass.js"></script>

<script>
'use strict';

/* ═══════════════════════════════════════════════════════════════
   FORCE LANDSCAPE — tham quan 3D cần chế độ nằm ngang
   ═══════════════════════════════════════════════════════════════ */
(function forceLandscape() {
  if (screen.orientation && screen.orientation.lock) {
    screen.orientation.lock('landscape').catch(function (err) {
      console.log('Orientation lock failed (expected on desktop):', err && err.message);
    });
  }

  function checkAndRotate() {
    var overlay = document.getElementById('rotate-overlay');
    if (window.innerWidth < window.innerHeight) {
      if (!overlay) {
        overlay = document.createElement('div');
        overlay.id = 'rotate-overlay';
        overlay.style.cssText = [
          'position:fixed', 'inset:0', 'z-index:99999',
          'background:rgba(0,0,0,0.92)',
          'display:flex', 'flex-direction:column',
          'align-items:center', 'justify-content:center',
          'color:#fff', 'font-family:sans-serif',
        ].join(';');
        overlay.innerHTML = [
          '<div style="font-size:64px;margin-bottom:16px;animation:rotspin 2s linear infinite">📱</div>',
          '<div style="font-size:18px;font-weight:700;margin-bottom:8px">Xoay ngang điện thoại</div>',
          '<div style="font-size:14px;color:rgba(255,255,255,0.7);text-align:center;max-width:280px">',
          'Tham quan 3D cần chế độ nằm ngang để hiển thị đúng',
          '</div>',
          '<style>@keyframes rotspin{0%{transform:rotate(0deg)}50%{transform:rotate(90deg)}100%{transform:rotate(90deg)}}</style>',
        ].join('');
        document.body.appendChild(overlay);
      }
      overlay.style.display = 'flex';
    } else if (overlay) {
      overlay.style.display = 'none';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', checkAndRotate);
  } else {
    checkAndRotate();
  }
  window.addEventListener('orientationchange', function () { setTimeout(checkAndRotate, 300); });
  window.addEventListener('resize', checkAndRotate);
})();

