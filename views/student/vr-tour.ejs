<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>VR Tour – Ký túc xá HUST</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --brand:       #e63946;
            --brand-glow:  rgba(230,57,70,.35);
            --glass-bg:    rgba(10,12,18,.72);
            --glass-bd:    rgba(255,255,255,.12);
            --surface:     rgba(15,17,25,.90);
            --text:        #f0f2f7;
            --muted:       rgba(240,242,247,.6);
            --accent:      #4fc3f7;
            --radius:      14px;
        }

        body { font-family:'Inter',sans-serif; background:#0a0c12; color:var(--text); overflow:hidden; width:100vw; height:100vh; }

        /* ── Loading ──────────────────────────────────────── */
        #loading-screen {
            position:fixed; inset:0; z-index:2000; background:#0a0c12;
            display:flex; flex-direction:column; align-items:center; justify-content:center; gap:20px;
        }
        .ld-logo   { font-size:2rem; font-weight:800; color:var(--brand); letter-spacing:-1px; }
        .ld-logo span { color:var(--text); }
        .ld-bar-wrap { width:280px; height:4px; background:rgba(255,255,255,.1); border-radius:2px; overflow:hidden; }
        .ld-bar  { height:100%; width:0; background:var(--brand); border-radius:2px; transition:width .15s; }
        .ld-msg  { font-size:.8rem; color:var(--muted); }

        /* ── Mode Toggle (bottom-left) ──────────────────── */
        #mode-toggle {
            position:fixed; bottom:20px; left:20px; z-index:500;
            background:rgba(20,20,20,.78);
            border:1px solid rgba(255,255,255,.08);
            backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
            border-radius:18px; padding:10px;
            display:flex; flex-direction:column; gap:4px;
            box-shadow:0 10px 40px rgba(0,0,0,.38);
        }
        .mode-opt {
            display:flex; align-items:center; gap:11px;
            padding:11px 16px; border-radius:11px;
            background:none; border:1px solid transparent; cursor:pointer;
            color:rgba(255,255,255,.55); font-size:.83rem; font-weight:600;
            font-family:'Inter',sans-serif; transition:all .2s ease;
            white-space:nowrap; text-align:left;
        }
        .mode-opt:hover {
            color:rgba(255,255,255,.85);
            background:rgba(255,255,255,.06);
            border-color:rgba(255,255,255,.1);
        }
        .mode-opt.active {
            color:#fff;
            background:rgba(255,255,255,.1);
            border-color:rgba(255,255,255,.18);
        }
        .mode-icon {
            width:30px; height:30px; border-radius:8px; flex-shrink:0;
            background:rgba(255,255,255,.07); display:flex;
            align-items:center; justify-content:center;
            font-size:.95rem; transition:background .2s;
        }
        .mode-opt.active .mode-icon { background:rgba(255,255,255,.14); }
        .mode-opt-text { display:flex; flex-direction:column; gap:1px; }
        .mode-opt-name { font-size:.83rem; font-weight:700; line-height:1.1; }
        .mode-opt-desc { font-size:.66rem; font-weight:400; opacity:.55; line-height:1.2; }

        /* ── Back Button ─────────────────────────────────── */
        #back-btn {
            position:fixed; top:20px; left:20px; z-index:500;
            background:var(--glass-bg); border:1px solid var(--glass-bd);
            backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
            color:var(--text); padding:10px 18px; border-radius:var(--radius);
            cursor:pointer; font-size:.82rem; font-weight:600;
            display:flex; align-items:center; gap:8px; font-family:'Inter',sans-serif;
            transition:background .2s, border-color .2s;
        }
        #back-btn:hover { background:rgba(230,57,70,.15); border-color:var(--brand); }

        /* ══════════════════════════════════════════════════
           MATTERPORT PANEL
           ══════════════════════════════════════════════════ */
        #mp-panel { position:fixed; inset:0; z-index:10; }

        /* Image background — larger than viewport for parallax room */
        #mp-bg {
            position:absolute; inset:-10%;
            background-size:cover; background-position:center; background-repeat:no-repeat;
            will-change:transform;
        }

        /* Edge vignette */
        #mp-vignette {
            position:absolute; inset:0; pointer-events:none;
            background: radial-gradient(ellipse 90% 80% at 50% 50%, transparent 55%, rgba(0,0,0,.55) 100%);
        }

        /* Fade overlay for node transitions */
        #mp-fade {
            position:absolute; inset:0; background:#000; opacity:0;
            pointer-events:none; transition:opacity .28s ease;
        }

        /* Hotspot layer */
        #mp-hotspots { position:absolute; inset:0; pointer-events:none; }

        /* Matterport-style hotspot circle */
        .mp-hs {
            position:absolute; transform:translate(-50%,-50%);
            width:40px; height:40px; cursor:pointer; pointer-events:all;
        }
        .mp-hs-ring {
            position:absolute; inset:0; border-radius:50%;
            background:rgba(255,255,255,.18);
            border:2px solid rgba(255,255,255,.82);
            box-shadow:0 0 14px rgba(255,255,255,.35), 0 3px 10px rgba(0,0,0,.45);
            transition:transform .2s cubic-bezier(.34,1.56,.64,1), box-shadow .2s;
            animation:mpPulse 2.8s ease-in-out infinite;
        }
        .mp-hs:hover .mp-hs-ring {
            transform:scale(1.32);
            box-shadow:0 0 24px rgba(255,255,255,.65), 0 3px 14px rgba(0,0,0,.55);
        }
        /* Outer glow ring (decorative) */
        .mp-hs-glow {
            position:absolute; inset:-6px; border-radius:50%;
            border:1px solid rgba(255,255,255,.22);
            animation:mpPulse 2.8s ease-in-out infinite .4s;
            pointer-events:none;
        }
        @keyframes mpPulse {
            0%,100% { box-shadow:0 0 12px rgba(255,255,255,.28); }
            50%      { box-shadow:0 0 22px rgba(255,255,255,.60); }
        }

        /* Node strip (bottom) */
        #mp-node-strip {
            position:fixed; bottom:20px; left:50%; transform:translateX(-50%);
            z-index:500; display:flex; gap:8px; align-items:center;
        }
        .mp-node-dot {
            width:8px; height:8px; border-radius:50%;
            background:rgba(255,255,255,.35); border:1px solid rgba(255,255,255,.5);
            cursor:pointer; transition:all .2s;
        }
        .mp-node-dot.active { background:#fff; width:10px; height:10px; }

        /* ══════════════════════════════════════════════════
           EXPLORE PANEL (Three.js)
           ══════════════════════════════════════════════════ */
        #ex-panel { position:fixed; inset:0; z-index:10; display:none; }

        #three-canvas {
            position:absolute; inset:0;
            display:block; width:100%!important; height:100%!important;
            cursor:none;
        }

        /* Crosshair */
        #crosshair {
            position:fixed; top:50%; left:50%;
            transform:translate(-50%,-50%);
            width:20px; height:20px; pointer-events:none; z-index:200; display:none;
        }
        #crosshair::before, #crosshair::after {
            content:''; position:absolute; background:rgba(255,255,255,.85);
        }
        #crosshair::before { left:50%; top:4px; bottom:4px; width:1.5px; transform:translateX(-50%); }
        #crosshair::after  { top:50%; left:4px; right:4px; height:1.5px; transform:translateY(-50%); }

        /* Pointer Lock Prompt */
        #lock-prompt {
            position:fixed; inset:0; z-index:400; display:none;
            flex-direction:column; align-items:center; justify-content:center; gap:16px;
            background:rgba(10,12,18,.88); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px);
        }
        #lock-prompt.show { display:flex; }
        .lp-icon {
            width:60px; height:60px;
            background:rgba(230,57,70,.12); border:2px solid var(--brand); border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            font-size:1.6rem; color:var(--brand);
            animation:lpPulse 2s ease-in-out infinite;
        }
        @keyframes lpPulse {
            0%,100% { box-shadow:0 0 0 0 var(--brand-glow); }
            50%      { box-shadow:0 0 0 14px transparent; }
        }
        .lp-title { font-size:1.2rem; font-weight:800; }
        .lp-sub   { font-size:.84rem; color:var(--muted); max-width:300px; text-align:center; }
        .lp-cta {
            background:var(--brand); color:#fff; border:none;
            border-radius:var(--radius); padding:12px 32px;
            font-size:.92rem; font-weight:700; cursor:pointer;
            box-shadow:0 4px 20px var(--brand-glow); font-family:'Inter',sans-serif;
            transition:transform .15s, box-shadow .15s;
        }
        .lp-cta:hover { transform:translateY(-2px); box-shadow:0 8px 28px var(--brand-glow); }

        /* ── Shared HUD (explore) ────────────────────────── */
        #ex-hud {
            position:fixed; top:20px; right:170px; z-index:300;
            display:none; flex-direction:column; gap:8px;
        }
        .hud-btn {
            background:var(--glass-bg); border:1px solid var(--glass-bd);
            backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
            color:var(--text); padding:9px 16px; border-radius:var(--radius);
            cursor:pointer; font-size:.78rem; font-weight:600;
            display:flex; align-items:center; gap:8px; font-family:'Inter',sans-serif;
            transition:background .2s, border-color .2s; white-space:nowrap;
        }
        .hud-btn:hover { background:rgba(79,195,247,.12); border-color:var(--accent); }

        /* ── Minimap ─────────────────────────────────────── */
        #minimap-wrap {
            position:fixed; bottom:20px; right:20px; z-index:300; display:none;
        }
        #minimap {
            width:110px; height:110px; border-radius:50%;
            border:2px solid var(--glass-bd); background:rgba(10,12,18,.85);
            overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,.5);
        }
        #mm-canvas { width:100%; height:100%; }
        .mm-label { text-align:center; font-size:.62rem; color:var(--muted); margin-top:4px; letter-spacing:.5px; }

        /* ── Controls Hint (explore) ────────────────────── */
        #ex-hint {
            position:fixed; bottom:20px; left:20px; z-index:300; display:none;
            background:var(--glass-bg); border:1px solid var(--glass-bd);
            backdrop-filter:blur(14px); -webkit-backdrop-filter:blur(14px);
            border-radius:var(--radius); padding:10px 14px;
            font-size:.72rem; color:var(--muted); line-height:1.9;
        }
        #ex-hint .k {
            display:inline-block; background:rgba(255,255,255,.1);
            border:1px solid rgba(255,255,255,.2); border-radius:4px;
            padding:0 6px; font-size:.68rem; color:var(--text); margin:0 1px;
        }
        @media (max-width:640px) { #ex-hint { display:none!important; } }

        /* ── Mobile Joystick ─────────────────────────────── */
        #mobile-ctrl { display:none; }
        @media (max-width:768px) {
            #mobile-ctrl {
                position:fixed; bottom:28px; left:28px; z-index:400;
            }
            #mobile-ctrl.show { display:block; }
            #jz-zone {
                width:110px; height:110px; border-radius:50%;
                background:rgba(255,255,255,.06); border:2px solid rgba(255,255,255,.15);
                position:relative;
            }
            #jz-thumb {
                width:38px; height:38px; border-radius:50%;
                background:rgba(255,255,255,.25); border:2px solid rgba(255,255,255,.5);
                position:absolute; top:50%; left:50%;
                transform:translate(-50%,-50%); pointer-events:none; transition:transform .05s;
            }
        }
    </style>
</head>
<body>

<!-- Loading Screen -->
<div id="loading-screen">
    <div class="ld-logo">HUST<span>KTX</span></div>
    <div style="font-size:1rem;font-weight:700">Đang tải VR Tour</div>
    <div class="ld-bar-wrap"><div class="ld-bar" id="ld-bar"></div></div>
    <div class="ld-msg" id="ld-msg">Khởi tạo...</div>
</div>

<!-- Back Button -->
<button id="back-btn" onclick="history.back()"><i class="fas fa-arrow-left"></i> Quay lại</button>

<!-- Mode Toggle -->
<div id="mode-toggle">
    <button class="mode-opt active" data-mode="matterport"
            title="Di chuyển bằng các điểm đánh dấu giống tour khách sạn.">
        <span class="mode-icon"><i class="fas fa-map-pin"></i></span>
        <span class="mode-opt-text">
            <span class="mode-opt-name">Tham quan nhanh</span>
            <span class="mode-opt-desc">Điểm đánh dấu tương tác</span>
        </span>
    </button>
    <button class="mode-opt" data-mode="explore"
            title="Tự do di chuyển trong không gian 3D bằng chuột và bàn phím.">
        <span class="mode-icon"><i class="fas fa-person-walking"></i></span>
        <span class="mode-opt-text">
            <span class="mode-opt-name">Khám phá tự do</span>
            <span class="mode-opt-desc">WASD · chuột · va chạm</span>
        </span>
    </button>
</div>

<!-- ╔══════════════════════════════════════╗
     ║       MATTERPORT PANEL               ║
     ╚══════════════════════════════════════╝ -->
<div id="mp-panel">
    <div id="mp-bg"></div>
    <div id="mp-vignette"></div>
    <div id="mp-fade"></div>
    <div id="mp-hotspots"></div>
</div>
<div id="mp-node-strip"></div>

<!-- ╔══════════════════════════════════════╗
     ║       EXPLORE PANEL (Three.js)        ║
     ╚══════════════════════════════════════╝ -->
<div id="ex-panel">
    <canvas id="three-canvas"></canvas>
</div>

<!-- Crosshair (explore) -->
<div id="crosshair"></div>

<!-- Pointer Lock Prompt (explore) -->
<div id="lock-prompt">
    <div class="lp-icon"><i class="fas fa-person-walking"></i></div>
    <div class="lp-title">Chế độ Khám Phá Tự Do</div>
    <div class="lp-sub">Nhấp để khoá chuột và di chuyển bằng WASD</div>
    <button class="lp-cta" id="enter-btn"><i class="fas fa-lock" style="margin-right:7px"></i>Bắt đầu khám phá</button>
</div>

<!-- HUD buttons (explore) -->
<div id="ex-hud">
    <button class="hud-btn" id="overview-btn"><i class="fas fa-eye"></i> Toàn cảnh</button>
    <button class="hud-btn" id="reset-btn"><i class="fas fa-undo"></i> Đặt lại</button>
</div>

<!-- Minimap (explore) -->
<div id="minimap-wrap">
    <div id="minimap"><canvas id="mm-canvas" width="110" height="110"></canvas></div>
    <div class="mm-label">BẢN ĐỒ MINI</div>
</div>

<!-- Controls hint (explore) -->
<div id="ex-hint">
    <span class="k">W</span><span class="k">A</span><span class="k">S</span><span class="k">D</span> Di chuyển<br>
    <span class="k">Chuột</span> Nhìn xung quanh<br>
    <span class="k">Click</span> hotspot để đến nhanh<br>
    <span class="k">Esc</span> Giải phóng chuột
</div>

<!-- Mobile joystick (explore) -->
<div id="mobile-ctrl">
    <div id="jz-zone"><div id="jz-thumb"></div></div>
</div>

<!-- Three.js r128 -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/DRACOLoader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/PointerLockControls.js"></script>

<script>
'use strict';

/* ═══════════════════════════════════════════════════════════════
   CONSTANTS
   ═══════════════════════════════════════════════════════════════ */

const GROUND_Y      = -0.28;
const PLAYER_SPEED  = 4.5;
const PLAYER_RADIUS = 0.25;
const FLY_DUR       = 1.0;
const OVR_DUR       = 1.8;

/* Matterport mode parallax limits */
const MP_MAX_YAW   = 20;   /* degrees */
const MP_MAX_PITCH = 10;   /* degrees */

/* Guided pitch limits (used in Matterport parallax for visual comfort) */
const EX_MIN_PITCH = -20 * Math.PI / 180;
const EX_MAX_PITCH =  15 * Math.PI / 180;

/* ─── NODE DEFINITIONS ──────────────────────────────────────── */
/* Each node maps a Matterport image to a 3D camera position.    */
/* rot = camera.rotation.x/y/z captured via XYZ euler order.    */
const NODES = [
    {
        id: 'front',
        image: '/assets/matterport/ai/01-front.png',
        pos: { x:  2.2677, y: GROUND_Y, z: -4.6195 },
        rot: { x:  3.0912, y:  0.3096,  z: -3.1262 }
    },
    {
        id: 'center',
        image: '/assets/matterport/ai/02-room-center.png',
        pos: { x:  0.0,    y: GROUND_Y, z: -1.0    },
        rot: { x:  0,      y: Math.PI,  z:  0      }
    },
    {
        id: 'desk',
        image: '/assets/matterport/ai/03-desk.png',
        pos: { x: -2.9391, y: GROUND_Y, z:  0.0203 },
        rot: { x: -0.546,  y:  0.5929,  z:  0.3273 }
    },
    {
        id: 'bed-left',
        image: '/assets/matterport/ai/04-bed-left.png',
        pos: { x:  1.3779, y: GROUND_Y, z:  2.6674 },
        rot: { x: -3.0298, y: -0.2604,  z: -3.1127 }
    },
    {
        id: 'bed-right',
        image: '/assets/matterport/ai/05-bed-right.png',
        pos: { x: -1.6482, y: GROUND_Y, z:  2.8882 },
        rot: { x: -2.9532, y:  0.4668,  z:  3.056  }
    },
    {
        id: 'door',
        image: '/assets/matterport/ai/06-door.png',
        pos: { x:  0.0,    y: GROUND_Y, z: -4.0    },
        rot: { x:  0,      y: Math.PI,  z:  0      }
    },
    {
        id: 'corner',
        image: '/assets/matterport/ai/07-corner.png',
        pos: { x:  2.9846, y: GROUND_Y, z:  0.0957 },
        rot: { x: -0.8994, y: -0.7635,  z: -0.7161 }
    },
    {
        id: 'left-table',
        image: '/assets/matterport/ai/left-table.png',
        pos: { x: -2.8,    y: GROUND_Y, z: -1.0    },
        rot: { x:  0,      y:  0,       z:  0      }
    },
    {
        id: 'left-bed',
        image: '/assets/matterport/ai/left-bed.png',
        pos: { x: -1.8,    y: GROUND_Y, z:  2.5    },
        rot: { x:  0,      y:  0,       z:  0      }
    },
    {
        id: 'shelf',
        image: '/assets/matterport/ai/shelf.png',
        pos: { x:  0.0,    y: GROUND_Y, z:  0.0    },
        rot: { x:  0,      y:  Math.PI, z:  0      }
    },
    {
        id: 'right-bed',
        image: '/assets/matterport/ai/right-bed.png',
        pos: { x:  1.8,    y: GROUND_Y, z:  2.5    },
        rot: { x:  0,      y:  0,       z:  0      }
    },
    {
        id: 'meow',
        image: '/assets/matterport/ai/meow.png',
        pos: { x:  0.0,    y: GROUND_Y, z:  1.0    },
        rot: { x:  0,      y:  0,       z:  0      }
    }
];

/* ═══════════════════════════════════════════════════════════════
   GLOBAL STATE
   ═══════════════════════════════════════════════════════════════ */

let currentMode    = 'matterport';   /* 'matterport' | 'explore' */
let currentNodeId  = 'front';
let mpTransitioning = false;
let glbReady       = false;
let imagesReady    = false;

function maybeHideLd() {
    if (glbReady && imagesReady) {
        setLd(100, 'Sẵn sàng!');
        setTimeout(hideLd, 300);
    }
}

/* Matterport parallax angles (degrees, lerped) */
let mpYaw = 0, mpPitch = 0, mpYawT = 0, mpPitchT = 0;
let mpDrag = { active: false, moved: false, x: 0, y: 0 };

/* Explore state */
let exFlyActive   = false;
let exFlyElapsed  = 0;
let exFlyDur      = FLY_DUR;
let exFlyStartPos  = new THREE.Vector3();
let exFlyTargetPos = new THREE.Vector3();
let exFlyStartQ    = new THREE.Quaternion();
let exFlyTargetQ   = new THREE.Quaternion();
let exFlyOnDone    = null;
let exExitToGuided = false;   /* suppress lock-prompt on intentional unlock */

/* Explore guided pitch */
let exYaw = 0, exPitch = 0;

const exMove    = { forward: false, backward: false, left: false, right: false };
let   exRoomBounds = { minX: -5, maxX: 5, minZ: -6, maxZ: 5 };

/* Explore hover */
const exRaycaster  = new THREE.Raycaster();
exRaycaster.far    = 6;
let   exHoveredHs  = null;   /* hovered 3D hotspot group */
const exInteract   = [];     /* {focusKey, meshes[]} for mesh-based hover */

/* Mouse NDC (for Matterport hotspot hover) */
const mpMouseNDC = new THREE.Vector2();

/* 3D hotspot groups in explore mode */
const exHotspots = [];

/* Reusable vectors */
const _fwd = new THREE.Vector3();
const _rgt = new THREE.Vector3();
const _up  = new THREE.Vector3(0, 1, 0);
const _sp  = new THREE.Vector3();   /* screen-space projection */

const clock = new THREE.Clock();

/* ═══════════════════════════════════════════════════════════════
   DOM REFS
   ═══════════════════════════════════════════════════════════════ */

const mpPanel    = document.getElementById('mp-panel');
const mpBg       = document.getElementById('mp-bg');
const mpFade     = document.getElementById('mp-fade');
const mpHsLayer  = document.getElementById('mp-hotspots');
const mpStrip    = document.getElementById('mp-node-strip');
const exPanel    = document.getElementById('ex-panel');
const crosshair  = document.getElementById('crosshair');
const lockPrompt = document.getElementById('lock-prompt');
const exHud      = document.getElementById('ex-hud');
const minimapWrap = document.getElementById('minimap-wrap');
const exHint     = document.getElementById('ex-hint');
const mobileCtr  = document.getElementById('mobile-ctrl');

/* ═══════════════════════════════════════════════════════════════
   LOADING HELPERS
   ═══════════════════════════════════════════════════════════════ */

function setLd(pct, msg) {
    document.getElementById('ld-bar').style.width = pct + '%';
    document.getElementById('ld-msg').textContent  = msg;
}

function hideLd() {
    const el = document.getElementById('loading-screen');
    el.style.transition = 'opacity .6s';
    el.style.opacity    = '0';
    setTimeout(() => { el.style.display = 'none'; }, 650);
}

/* ═══════════════════════════════════════════════════════════════
   THREE.JS SCENE (explore)
   ═══════════════════════════════════════════════════════════════ */

const canvas3  = document.getElementById('three-canvas');
const renderer = new THREE.WebGLRenderer({ canvas: canvas3, antialias: true, powerPreference: 'high-performance' });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.outputEncoding      = THREE.sRGBEncoding;
renderer.shadowMap.enabled   = true;
renderer.shadowMap.type      = THREE.PCFSoftShadowMap;
renderer.toneMapping         = THREE.ACESFilmicToneMapping;
renderer.toneMappingExposure = 1.2;

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x0a0c14);
scene.fog = new THREE.Fog(0x0a0c14, 15, 35);

const camera = new THREE.PerspectiveCamera(72, window.innerWidth / window.innerHeight, 0.05, 80);
camera.rotation.order = 'XYZ';

scene.add(new THREE.AmbientLight(0xffffff, 0.45));
const sun = new THREE.DirectionalLight(0xfff4e0, 1.2);
sun.position.set(3, 8, 4); sun.castShadow = true;
sun.shadow.mapSize.set(1024, 1024);
Object.assign(sun.shadow.camera, { near:.1, far:30, left:-8, right:8, top:8, bottom:-8 });
scene.add(sun);
const fill = new THREE.PointLight(0x4fc3f7, 0.4, 12);
fill.position.set(-3, 2, 0);
scene.add(fill);

const controls = new THREE.PointerLockControls(camera, document.body);
const ctrlObj  = controls.getObject ? controls.getObject() : camera;
if (ctrlObj !== camera) scene.add(ctrlObj); else scene.add(camera);

/* ═══════════════════════════════════════════════════════════════
   GLB LOADING (loads in background, used by explore mode)
   ═══════════════════════════════════════════════════════════════ */

setLd(5, 'Đang tải mô hình 3D...');

const dracoLoader = new THREE.DRACOLoader();
dracoLoader.setDecoderPath('https://www.gstatic.com/draco/versioned/decoders/1.5.6/');

const gltfLoader = new THREE.GLTFLoader();
gltfLoader.setDRACOLoader(dracoLoader);

gltfLoader.load(
    '/models/room.glb',
    onGLBLoaded,
    (xhr) => { if (xhr.total > 0) setLd(5 + xhr.loaded / xhr.total * 70, 'Đang tải mô hình 3D...'); },
    (err) => { console.error('GLB:', err); }
);

function onGLBLoaded(gltf) {
    setLd(85, 'Đang xử lý mô hình...');

    const model = gltf.scene;
    model.traverse(child => {
        if (!child.isMesh) return;
        child.castShadow = child.receiveShadow = true;
        if (child.material) {
            child.material.envMapIntensity = 0.4;
            if (child.material.map) child.material.map.encoding = THREE.sRGBEncoding;
        }
    });
    scene.add(model);

    /* Room bounds */
    const bbox = new THREE.Box3().setFromObject(model);
    const m = 0.4;
    exRoomBounds = { minX: bbox.min.x + m, maxX: bbox.max.x - m, minZ: bbox.min.z + m, maxZ: bbox.max.z - m };

    /* Interactable mesh groups (for explore mesh hover - optional) */
    const meshGroups = NODES.map(n => ({ focusKey: n.id, meshes: [] }));
    model.traverse(child => {
        if (!child.isMesh) return;
        const name = child.name || '';
        for (const g of meshGroups) {
            if (name === g.focusKey || name.startsWith(g.focusKey + '_')) {
                g.meshes.push(child); break;
            }
        }
    });
    meshGroups.forEach(g => exInteract.push(g));

    /* 3D hotspots (explore mode) */
    createExHotspots();

    exSpawnAtDefault();
    glbReady = true;
    maybeHideLd();
}

/* ═══════════════════════════════════════════════════════════════
   EXPLORE 3D HOTSPOT CREATION (Matterport circles, no labels)
   ═══════════════════════════════════════════════════════════════ */

function createExHotspots() {
    NODES.forEach((node, idx) => {
        const grp = new THREE.Group();

        /* Inner fill */
        grp.add(new THREE.Mesh(
            new THREE.CircleGeometry(0.20, 40),
            new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.15, side: THREE.DoubleSide, depthWrite: false })
        ));
        /* Main ring */
        grp.add(new THREE.Mesh(
            new THREE.RingGeometry(0.20, 0.28, 40),
            new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.80, side: THREE.DoubleSide, depthWrite: false })
        ));
        /* Outer glow */
        grp.add(new THREE.Mesh(
            new THREE.RingGeometry(0.30, 0.40, 40),
            new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.20, side: THREE.DoubleSide, depthWrite: false })
        ));
        /* Hit area */
        grp.add(new THREE.Mesh(
            new THREE.CircleGeometry(0.50, 16),
            new THREE.MeshBasicMaterial({ visible: false, side: THREE.DoubleSide })
        ));

        grp.position.set(node.pos.x, GROUND_Y + 0.02, node.pos.z);
        grp.renderOrder = 1;
        scene.add(grp);

        exHotspots.push({ grp, nodeId: node.id, phase: idx * 1.57, hovered: false });
    });
}

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — SPAWN / RESET
   ═══════════════════════════════════════════════════════════════ */

function exSpawnAtDefault() {
    const n = NODES[0];
    camera.position.set(n.pos.x, n.pos.y, n.pos.z);
    camera.rotation.set(n.rot.x, n.rot.y, n.rot.z);
    syncExAngles();
}

function syncExAngles() {
    const e = new THREE.Euler().setFromQuaternion(camera.quaternion, 'YXZ');
    exYaw   = e.y;
    exPitch = Math.max(EX_MIN_PITCH, Math.min(EX_MAX_PITCH, e.x));
}

function applyExRotation() {
    camera.quaternion.setFromEuler(new THREE.Euler(exPitch, exYaw, 0, 'YXZ'));
}

document.getElementById('reset-btn').addEventListener('click', () => {
    exFlyActive = false;
    exSpawnAtDefault();
});

document.getElementById('overview-btn').addEventListener('click', () => {
    const cx   = (exRoomBounds.minX + exRoomBounds.maxX) * .5;
    const cz   = (exRoomBounds.minZ + exRoomBounds.maxZ) * .5;
    const quat = new THREE.Quaternion().setFromEuler(new THREE.Euler(-Math.PI / 2, 0, 0, 'XYZ'));
    exFlyTo(new THREE.Vector3(cx, 5.5, cz), quat, OVR_DUR, null);
});

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — POINTER LOCK
   ═══════════════════════════════════════════════════════════════ */

controls.addEventListener('lock', () => {
    lockPrompt.classList.remove('show');
    crosshair.style.display = 'block';
});
controls.addEventListener('unlock', () => {
    if (exExitToGuided) { exExitToGuided = false; return; }
    if (currentMode === 'explore') {
        lockPrompt.classList.add('show');
        crosshair.style.display = 'none';
    }
    exMove.forward = exMove.backward = exMove.left = exMove.right = false;
});

document.getElementById('enter-btn').addEventListener('click', () => controls.lock());

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — KEYBOARD
   ═══════════════════════════════════════════════════════════════ */

document.addEventListener('keydown', e => {
    if (!controls.isLocked) return;
    switch (e.code) {
        case 'KeyW': case 'ArrowUp':    exMove.forward  = true; break;
        case 'KeyS': case 'ArrowDown':  exMove.backward = true; break;
        case 'KeyA': case 'ArrowLeft':  exMove.left     = true; break;
        case 'KeyD': case 'ArrowRight': exMove.right    = true; break;
    }
});
document.addEventListener('keyup', e => {
    switch (e.code) {
        case 'KeyW': case 'ArrowUp':    exMove.forward  = false; break;
        case 'KeyS': case 'ArrowDown':  exMove.backward = false; break;
        case 'KeyA': case 'ArrowLeft':  exMove.left     = false; break;
        case 'KeyD': case 'ArrowRight': exMove.right    = false; break;
    }
});

/* Click to fly to hotspot */
document.addEventListener('click', () => {
    if (currentMode !== 'explore' || !controls.isLocked || exFlyActive) return;
    if (exHoveredHs) exFlyToNode(exHoveredHs.nodeId);
});

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — MOVEMENT
   ═══════════════════════════════════════════════════════════════ */

function tickExMovement(dt) {
    if (!controls.isLocked || exFlyActive) return;

    const spd = PLAYER_SPEED * dt;
    camera.getWorldDirection(_fwd);
    _fwd.y = 0; _fwd.normalize();
    _rgt.crossVectors(_fwd, _up).normalize();

    let dx = 0, dz = 0;
    if (exMove.forward)  { dx += _fwd.x * spd; dz += _fwd.z * spd; }
    if (exMove.backward) { dx -= _fwd.x * spd; dz -= _fwd.z * spd; }
    if (exMove.right)    { dx += _rgt.x * spd; dz += _rgt.z * spd; }
    if (exMove.left)     { dx -= _rgt.x * spd; dz -= _rgt.z * spd; }

    if (dx || dz) {
        camera.position.x = Math.max(exRoomBounds.minX + PLAYER_RADIUS, Math.min(exRoomBounds.maxX - PLAYER_RADIUS, camera.position.x + dx));
        camera.position.z = Math.max(exRoomBounds.minZ + PLAYER_RADIUS, Math.min(exRoomBounds.maxZ - PLAYER_RADIUS, camera.position.z + dz));
    }
    camera.position.y = GROUND_Y;
}

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — FLY-TO
   ═══════════════════════════════════════════════════════════════ */

function exFlyTo(targetPos, targetQ, dur, onDone) {
    exFlyActive  = true;
    exFlyElapsed = 0;
    exFlyDur     = dur || FLY_DUR;
    exFlyOnDone  = onDone || null;
    exFlyStartPos.copy(camera.position);
    exFlyTargetPos.copy(targetPos);
    exFlyStartQ.copy(camera.quaternion);
    exFlyTargetQ.copy(targetQ);
}

function exFlyToNode(nodeId) {
    const node = NODES.find(n => n.id === nodeId);
    if (!node) return;
    const pos  = new THREE.Vector3(node.pos.x, node.pos.y, node.pos.z);
    const quat = new THREE.Quaternion().setFromEuler(new THREE.Euler(node.rot.x, node.rot.y, node.rot.z, 'XYZ'));
    exFlyTo(pos, quat, FLY_DUR, () => { currentNodeId = nodeId; syncExAngles(); });
}

function tickExFly(dt) {
    if (!exFlyActive) return;
    exFlyElapsed += dt;
    const t    = Math.min(exFlyElapsed / exFlyDur, 1);
    const ease = t < .5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3) / 2;

    camera.position.lerpVectors(exFlyStartPos, exFlyTargetPos, ease);
    camera.quaternion.slerpQuaternions(exFlyStartQ, exFlyTargetQ, ease);

    if (t >= 1) {
        exFlyActive = false;
        camera.position.copy(exFlyTargetPos);
        camera.quaternion.copy(exFlyTargetQ);
        syncExAngles();
        if (exFlyOnDone) { exFlyOnDone(); exFlyOnDone = null; }
    }
}

/* ═══════════════════════════════════════════════════════════════
   EXPLORE — 3D HOTSPOT TICK
   ═══════════════════════════════════════════════════════════════ */

function tickExHotspots() {
    const t = performance.now() * .001;
    const rc = new THREE.Raycaster();
    rc.setFromCamera({ x: 0, y: 0 }, camera);
    let anyCurr = false;

    exHotspots.forEach(hs => {
        /* Hide hotspot for current node (already here) */
        const isCurrent = hs.nodeId === currentNodeId;
        hs.grp.visible = !isCurrent;
        if (isCurrent) { hs.hovered = false; return; }

        /* Billboard */
        hs.grp.lookAt(camera.position);

        /* Pulse + hover scale */
        const pulse = 1 + Math.sin(t * 2.4 + hs.phase) * 0.06;
        const hits  = controls.isLocked && !exFlyActive ? rc.intersectObject(hs.grp, true) : [];
        hs.hovered  = hits.length > 0;
        if (hs.hovered) anyCurr = true;
        hs.grp.scale.setScalar(pulse * (hs.hovered ? 1.28 : 1.0));

        /* Opacity */
        const baseO = [0.15, 0.80, 0.20];
        hs.grp.children.forEach((m, i) => {
            if (i >= 3) return;
            m.material.opacity = hs.hovered ? Math.min(1, baseO[i] * 1.55) : baseO[i];
        });
    });

    exHoveredHs = exHotspots.find(h => h.hovered) || null;
}

/* ═══════════════════════════════════════════════════════════════
   MATTERPORT — NODE NAVIGATION
   ═══════════════════════════════════════════════════════════════ */

function mpGoToNode(nodeId) {
    if (mpTransitioning || nodeId === currentNodeId) return;
    mpTransitioning = true;

    mpFade.style.opacity = '1';

    setTimeout(() => {
        currentNodeId = nodeId;
        const node = NODES.find(n => n.id === nodeId);
        mpBg.style.backgroundImage = `url('${node.image}')`;

        /* Reset parallax to center */
        mpYaw = 0; mpPitch = 0; mpYawT = 0; mpPitchT = 0;

        renderMPHotspots();
        updateMPStrip();
        mpFade.style.opacity = '0';
        setTimeout(() => { mpTransitioning = false; }, 280);
    }, 280);
}

/* ─── Project a node position into screen-space for current node's view ─── */
const _projV = new THREE.Vector3();

function projectNodePos(fromNode, toNode) {
    const camPos = new THREE.Vector3(fromNode.pos.x, fromNode.pos.y, fromNode.pos.z);
    const target = new THREE.Vector3(toNode.pos.x, GROUND_Y - 0.08, toNode.pos.z);

    /* Camera quaternion from stored XYZ rotation */
    const camQ = new THREE.Quaternion().setFromEuler(
        new THREE.Euler(fromNode.rot.x, fromNode.rot.y, fromNode.rot.z, 'XYZ')
    );

    /* Direction in camera-local space */
    const worldDir = target.clone().sub(camPos);
    const localDir = worldDir.clone().applyQuaternion(camQ.clone().invert());

    /* Three.js camera looks in -Z by default */
    if (localDir.z >= 0) return null;

    const fovY = 72 * Math.PI / 180;
    const tanH = Math.tan(fovY / 2);
    const asp  = window.innerWidth / window.innerHeight;
    const tanW = tanH * asp;

    const ndcX =  localDir.x / (-localDir.z) / tanW;
    const ndcY = -localDir.y / (-localDir.z) / tanH;

    const sx = (ndcX *  .5 + .5) * 100;
    const sy = (ndcY *  .5 + .5) * 100;

    /* Only show in lower 45–90% vertically (floor) and safe horizontal range */
    if (sx < 4 || sx > 96 || sy < 48 || sy > 93) return null;

    return { x: sx, y: sy };
}

/* ─── NODE_HOTSPOTS: normalized 0-1 viewport coords per node ────────────
 *  Built automatically from 3D projection at init.
 *  Override individual nodes with hand-tuned values after using Debug Hotspot mode.
 *  Example:
 *    NODE_HOTSPOTS['spawn'] = [
 *      { x: 0.423, y: 0.612, target: 'desk' },
 *      { x: 0.234, y: 0.710, target: 'bed-left' },
 *    ];
 * ─────────────────────────────────────────────────────────────────────── */
let NODE_HOTSPOTS = {};

function buildDefaultHotspots() {
    const result = {};
    NODES.forEach(fromNode => {
        result[fromNode.id] = [];
        NODES.forEach(toNode => {
            if (toNode.id === fromNode.id) return;
            const pos = projectNodePos(fromNode, toNode);
            if (!pos) return;
            result[fromNode.id].push({
                x: parseFloat((pos.x / 100).toFixed(4)),
                y: parseFloat((pos.y / 100).toFixed(4)),
                target: toNode.id
            });
        });
    });
    return result;
}

function renderMPHotspots() {
    mpHsLayer.innerHTML = '';
    const spots = NODE_HOTSPOTS[currentNodeId];
    if (!spots || spots.length === 0) return;

    spots.forEach(hs => {
        const el = document.createElement('div');
        el.className = 'mp-hs';
        el.style.cssText = `left:${hs.x * 100}%;top:${hs.y * 100}%`;
        el.innerHTML = '<div class="mp-hs-ring"></div><div class="mp-hs-glow"></div>';
        el.setAttribute('data-target', hs.target);
        el.addEventListener('click', (e) => {
            e.stopPropagation();
            mpGoToNode(hs.target);
        });
        mpHsLayer.appendChild(el);
    });
}

function updateMPStrip() {
    mpStrip.innerHTML = '';
    NODES.forEach(node => {
        const dot = document.createElement('div');
        dot.className = 'mp-node-dot' + (node.id === currentNodeId ? ' active' : '');
        dot.title = node.id;
        dot.addEventListener('click', () => mpGoToNode(node.id));
        mpStrip.appendChild(dot);
    });
}

/* ─── Matterport drag-to-look (parallax) ─── */

document.getElementById('mp-panel').addEventListener('mousedown', e => {
    if (currentMode !== 'matterport') return;
    mpDrag.active = true; mpDrag.moved = false;
    mpDrag.x = e.clientX; mpDrag.y = e.clientY;
    mpBg.style.cursor = 'grabbing';
});

document.addEventListener('mousemove', e => {
    if (currentMode !== 'matterport' || !mpDrag.active) return;
    const dx = e.clientX - mpDrag.x;
    const dy = e.clientY - mpDrag.y;
    if (Math.hypot(dx, dy) > 4) mpDrag.moved = true;
    if (mpDrag.moved) {
        mpYawT   -= dx * 0.07;
        mpPitchT -= dy * 0.07;
        mpYawT   = Math.max(-MP_MAX_YAW,   Math.min(MP_MAX_YAW,   mpYawT));
        mpPitchT = Math.max(-MP_MAX_PITCH, Math.min(MP_MAX_PITCH, mpPitchT));
        mpDrag.x = e.clientX;
        mpDrag.y = e.clientY;
    }
});

document.addEventListener('mouseup', () => {
    mpDrag.active = false; mpDrag.moved = false;
    if (currentMode === 'matterport') mpBg.style.cursor = '';
});

/* ─── Tick Matterport parallax (called in animate) ─── */

function tickMPParallax() {
    if (currentMode !== 'matterport') return;

    const lerpF = 0.10;
    mpYaw   += (mpYawT   - mpYaw)   * lerpF;
    mpPitch += (mpPitchT - mpPitch) * lerpF;

    const maxSX = window.innerWidth  * 0.10;
    const maxSY = window.innerHeight * 0.10;
    const sx = -(mpYaw   / MP_MAX_YAW)   * maxSX;
    const sy = -(mpPitch / MP_MAX_PITCH) * maxSY;
    mpBg.style.transform = `translate(${sx}px,${sy}px)`;
}

/* ─── Mobile touch look for Matterport ─── */

let mpTouch = { active: false, x: 0, y: 0 };
document.getElementById('mp-panel').addEventListener('touchstart', e => {
    if (e.touches.length === 1) {
        mpTouch.active = true; mpTouch.x = e.touches[0].clientX; mpTouch.y = e.touches[0].clientY;
    }
});
document.getElementById('mp-panel').addEventListener('touchmove', e => {
    if (!mpTouch.active || e.touches.length !== 1) return;
    e.preventDefault();
    const dx = e.touches[0].clientX - mpTouch.x;
    const dy = e.touches[0].clientY - mpTouch.y;
    mpTouch.x = e.touches[0].clientX;
    mpTouch.y = e.touches[0].clientY;
    mpYawT   -= dx * 0.07;
    mpPitchT -= dy * 0.07;
    mpYawT   = Math.max(-MP_MAX_YAW,   Math.min(MP_MAX_YAW,   mpYawT));
    mpPitchT = Math.max(-MP_MAX_PITCH, Math.min(MP_MAX_PITCH, mpPitchT));
}, { passive: false });
document.getElementById('mp-panel').addEventListener('touchend', () => { mpTouch.active = false; });

/* ═══════════════════════════════════════════════════════════════
   MODE SWITCHING
   ═══════════════════════════════════════════════════════════════ */

function setMode(m) {
    currentMode = m;

    if (m === 'matterport') {
        /* ── Matterport ── */
        mpPanel.style.display    = '';
        mpStrip.style.display    = '';
        exPanel.style.display    = 'none';
        lockPrompt.classList.remove('show');
        crosshair.style.display  = 'none';
        exHud.style.display      = 'none';
        minimapWrap.style.display = 'none';
        exHint.style.display     = 'none';
        mobileCtr.classList.remove('show');

        /* Release pointer lock if active */
        if (controls.isLocked) { exExitToGuided = true; controls.unlock(); }

        /* Sync matterport to closest node */
        const nearNode = closestNode(camera.position);
        currentNodeId = nearNode.id;
        mpBg.style.backgroundImage = `url('${nearNode.image}')`;
        mpYaw = 0; mpPitch = 0; mpYawT = 0; mpPitchT = 0;
        renderMPHotspots();
        updateMPStrip();

        mpFade.style.transition = 'none';
        mpFade.style.opacity    = '0';
        setTimeout(() => { mpFade.style.transition = 'opacity .28s ease'; }, 50);

    } else {
        /* ── Explore ── */
        mpPanel.style.display    = 'none';
        mpStrip.style.display    = 'none';
        exPanel.style.display    = 'block';   /* must be explicit — CSS has display:none */
        lockPrompt.classList.add('show');
        exHud.style.display      = 'flex';
        minimapWrap.style.display = 'block';  /* must be explicit — CSS has display:none */
        exHint.style.display     = 'block';
        mobileCtr.classList.add('show');

        /* Camera stays at current position; snap to matching node camera pos if coming from matterport */
        const node = NODES.find(n => n.id === currentNodeId);
        if (node) {
            camera.position.set(node.pos.x, node.pos.y, node.pos.z);
            camera.rotation.set(node.rot.x, node.rot.y, node.rot.z);
            syncExAngles();
        }
    }

    /* Update radio buttons */
    document.querySelectorAll('.mode-opt').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.mode === m);
    });
}

function closestNode(pos) {
    let best = NODES[0], bestDist = Infinity;
    NODES.forEach(n => {
        const d = Math.hypot(n.pos.x - pos.x, n.pos.z - pos.z);
        if (d < bestDist) { bestDist = d; best = n; }
    });
    return best;
}

/* Mode toggle buttons */
document.querySelectorAll('.mode-opt').forEach(btn => {
    btn.addEventListener('click', () => setMode(btn.dataset.mode));
});

/* ═══════════════════════════════════════════════════════════════
   MINIMAP
   ═══════════════════════════════════════════════════════════════ */

const mmCanvas = document.getElementById('mm-canvas');
const mmCtx    = mmCanvas.getContext('2d');
const MM_S     = 110;

function drawMinimap() {
    const rb = exRoomBounds;
    const sc = Math.min((MM_S * .78) / (rb.maxX - rb.minX), (MM_S * .78) / (rb.maxZ - rb.minZ));
    const cx = (rb.minX + rb.maxX) / 2, cz = (rb.minZ + rb.maxZ) / 2;
    const toMM = (x, z) => ({ x: MM_S/2 + (x - cx) * sc, y: MM_S/2 + (z - cz) * sc });

    mmCtx.clearRect(0, 0, MM_S, MM_S);
    const tl = toMM(rb.minX, rb.minZ), br = toMM(rb.maxX, rb.maxZ);
    mmCtx.strokeStyle = 'rgba(255,255,255,.2)'; mmCtx.lineWidth = 1.5;
    mmCtx.strokeRect(tl.x, tl.y, br.x - tl.x, br.y - tl.y);

    /* Node dots */
    NODES.forEach(n => {
        const p = toMM(n.pos.x, n.pos.z);
        mmCtx.fillStyle = n.id === currentNodeId ? 'rgba(79,195,247,.8)' : 'rgba(255,255,255,.4)';
        mmCtx.beginPath(); mmCtx.arc(p.x, p.y, 3.5, 0, Math.PI * 2); mmCtx.fill();
    });

    /* Player */
    const pp = toMM(camera.position.x, camera.position.z);
    mmCtx.fillStyle = '#e63946';
    mmCtx.beginPath(); mmCtx.arc(pp.x, pp.y, 4.5, 0, Math.PI * 2); mmCtx.fill();
    camera.getWorldDirection(_fwd);
    const ang = Math.atan2(_fwd.x, _fwd.z);
    mmCtx.strokeStyle = '#e63946'; mmCtx.lineWidth = 2;
    mmCtx.beginPath();
    mmCtx.moveTo(pp.x, pp.y);
    mmCtx.lineTo(pp.x + Math.sin(ang) * 11, pp.y + Math.cos(ang) * 11);
    mmCtx.stroke();
}

/* ═══════════════════════════════════════════════════════════════
   MOBILE — Joystick + touch look (explore)
   ═══════════════════════════════════════════════════════════════ */

(function initMobile() {
    const zone  = document.getElementById('jz-zone');
    const thumb = document.getElementById('jz-thumb');
    if (!zone) return;

    let active = false, ox = 0, oy = 0;
    const maxR = 38;
    zone.addEventListener('touchstart', e => {
        e.preventDefault(); active = true;
        const r = zone.getBoundingClientRect();
        ox = r.left + r.width/2; oy = r.top + r.height/2;
    }, { passive: false });
    zone.addEventListener('touchmove', e => {
        e.preventDefault(); if (!active) return;
        let dx = e.touches[0].clientX - ox, dy = e.touches[0].clientY - oy;
        const len = Math.hypot(dx, dy);
        if (len > maxR) { dx = dx/len*maxR; dy = dy/len*maxR; }
        thumb.style.transform = `translate(calc(-50% + ${dx}px),calc(-50% + ${dy}px))`;
        exMove.forward  = dy/maxR < -.3; exMove.backward = dy/maxR > .3;
        exMove.left     = dx/maxR < -.3; exMove.right    = dx/maxR > .3;
    }, { passive: false });
    zone.addEventListener('touchend', () => {
        active = false;
        thumb.style.transform = 'translate(-50%,-50%)';
        exMove.forward = exMove.backward = exMove.left = exMove.right = false;
    });

    /* Touch look on 3D canvas */
    let lookActive = false, lx = 0, ly = 0;
    canvas3.addEventListener('touchstart', e => {
        if (e.touches.length === 1) { lookActive = true; lx = e.touches[0].clientX; ly = e.touches[0].clientY; }
    });
    canvas3.addEventListener('touchmove', e => {
        if (!lookActive || e.touches.length !== 1) return;
        e.preventDefault();
        const dx = (e.touches[0].clientX - lx) * .003;
        const dy = (e.touches[0].clientY - ly) * .003;
        lx = e.touches[0].clientX; ly = e.touches[0].clientY;
        /* Explore: free rotation */
        camera.rotation.y -= dx;
        camera.rotation.x  = Math.max(-Math.PI/2 + .1, Math.min(Math.PI/2 - .1, camera.rotation.x - dy));
    }, { passive: false });
    canvas3.addEventListener('touchend', () => { lookActive = false; });
})();

/* ═══════════════════════════════════════════════════════════════
   RESIZE
   ═══════════════════════════════════════════════════════════════ */

window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
    if (currentMode === 'matterport') renderMPHotspots();
});

/* ═══════════════════════════════════════════════════════════════
   ANIMATION LOOP
   ═══════════════════════════════════════════════════════════════ */

let mmTick = 0;

function animate() {
    requestAnimationFrame(animate);
    const dt = Math.min(clock.getDelta(), 0.05);

    /* ── Matterport ── */
    tickMPParallax();

    /* ── Explore ── */
    if (currentMode === 'explore') {
        tickExFly(dt);
        tickExMovement(dt);
        if (glbReady) tickExHotspots();

        mmTick += dt;
        if (mmTick > 0.05) { drawMinimap(); mmTick = 0; }

        renderer.render(scene, camera);
    }
}

/* ═══════════════════════════════════════════════════════════════
