    setLd(15, 'Đang tải ảnh chất lượng cao...');

    /* Preload all node images (progress bar driven by GLB, not images) */
    let loaded = 0;
    NODES.forEach(n => {
        const img = new Image();
        img.onload = img.onerror = () => {
            loaded++;
            if (loaded === NODES.length) {
                imagesReady = true;
                maybeHideLd();
            }
        };
        img.src = n.image;
    });

    animate();
})();
