        ],
        'corner': [
            { x: 0.383, y: 0.385, target: 'meow'       },
            { x: 0.772, y: 0.436, target: 'front'       }
        ],
        'left-bed': [
            { x: 0.110, y: 0.525, target: 'meow'       },
            { x: 0.533, y: 0.426, target: 'front'       },
