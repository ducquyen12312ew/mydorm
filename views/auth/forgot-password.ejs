<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quên mật khẩu | KTX HUST</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/auth-forms.css">
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-layout" aria-label="Quên mật khẩu">
            <aside class="auth-brand">
                <div class="brand-visual fade-up" aria-hidden="true">
                    <div class="brand-media-card">
                        <img src="https://res.cloudinary.com/dysgt8t4d/image/upload/v1773728947/e798a5fcd468c4914b9d4fa0a0d1d20f_vwlgof.jpg" alt="Interior preview">
                        <div class="brand-media-overlay"></div>
                        <div class="brand-media-copy">
                            <h3>Trải Nghiệm Ký Túc Xá Đại Học Bách Khoa</h3>
                            <p>Môi trường sống hiện đại, tiện nghi và an toàn dành cho sinh viên.</p>
                        </div>
                    </div>
                    <span class="brand-orbit orbit-1"></span>
                    <span class="brand-orbit orbit-2"></span>
                    <span class="brand-orbit orbit-3"></span>
                    <span class="brand-orbit orbit-4"></span>
                </div>
            </aside>

            <section class="auth-panel">
                <div class="auth-topbar">
                    <a href="/login" class="auth-back" aria-label="Quay lại đăng nhập">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                </div>

                <h1 class="auth-title">Quên mật khẩu</h1>
                <p class="auth-subtitle">Nhập email đã đăng ký. Chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu.</p>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="auth-alert error" role="alert">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="auth-alert success" role="status">
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= success %></span>
                    </div>
                <% } %>

                <form action="/forgot-password" method="post" class="auth-form" novalidate>
                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-regular fa-envelope field-icon"></i>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                placeholder=" "
                                required
                                autocomplete="email"
                                autocapitalize="none"
                            >
                            <label for="email">Địa chỉ email</label>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <button type="submit" class="primary-btn fade-up">
                        <span class="btn-loader" aria-hidden="true"></span>
                        <span>Gửi hướng dẫn</span>
                    </button>
                </form>

                <p class="auth-footnote">
                    Nhớ mật khẩu rồi? <a href="/login" class="text-link">Đăng nhập</a>
                </p>
            </section>
        </section>
    </main>

    <script src="/js/auth-ui.js"></script>
</body>
</html>
