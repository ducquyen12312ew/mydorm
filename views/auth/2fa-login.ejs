<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác thực 2 lớp - Dormitory Management</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .auth-container {
            max-width: 450px;
            width: 100%;
            padding: 20px;
        }
        .auth-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 40px;
        }
        .auth-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .auth-header i {
            font-size: 48px;
            color: #667eea;
            margin-bottom: 15px;
        }
        .auth-header h2 {
            color: #333;
            font-weight: 600;
            margin-bottom: 10px;
        }
        .auth-header p {
            color: #666;
            font-size: 14px;
        }
        .otp-input {
            text-align: center;
            font-size: 24px;
            letter-spacing: 10px;
            font-weight: 600;
            padding: 15px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            transition: all 0.3s;
        }
        .otp-input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        .btn-verify {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 12px;
            font-weight: 600;
            border-radius: 10px;
            transition: transform 0.2s;
        }
        .btn-verify:hover {
            transform: translateY(-2px);
        }
        .backup-code-link {
            text-align: center;
            margin-top: 20px;
        }
        .backup-code-link a {
            color: #667eea;
            text-decoration: none;
            font-size: 14px;
        }
        .backup-code-link a:hover {
            text-decoration: underline;
        }
        .alert {
            border-radius: 10px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <i class="fas fa-shield-alt"></i>
                <h2>Xác thực 2 lớp</h2>
                <p>Nhập mã xác thực từ ứng dụng Authenticator</p>
            </div>

            <div id="alertContainer"></div>

            <form id="verifyForm">
                <div class="mb-4">
                    <label class="form-label">Mã xác thực 6 chữ số</label>
                    <input type="text" class="form-control otp-input" id="otpCode" 
                           maxlength="6" pattern="[0-9]{6}" required 
                           placeholder="000000" autocomplete="off">
                </div>

                <button type="submit" class="btn btn-primary btn-verify w-100">
                    <i class="fas fa-check me-2"></i> Xác nhận
                </button>
            </form>

            <div class="backup-code-link">
                <a href="#" id="useBackupCode">Sử dụng mã dự phòng</a>
            </div>

            <div class="text-center mt-3">
                <a href="/login" class="text-muted" style="font-size: 14px;">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại đăng nhập
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const otpInput = document.getElementById('otpCode');
        const verifyForm = document.getElementById('verifyForm');
        const alertContainer = document.getElementById('alertContainer');

        // Auto-format OTP input
        otpInput.addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/[^0-9]/g, '');
        });

        // Handle form submission
        verifyForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const code = otpInput.value.trim();
            if (code.length !== 6) {
                showAlert('Vui lòng nhập đủ 6 chữ số', 'danger');
                return;
            }

            try {
                const response = await fetch('/api/auth/verify-2fa', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ code })
                });

                const data = await response.json();

                if (response.ok) {
                    showAlert('Xác thực thành công! Đang chuyển hướng...', 'success');
                    setTimeout(() => {
                        window.location.href = data.redirect || '/home';
                    }, 1000);
                } else {
                    showAlert(data.error || 'Mã xác thực không đúng', 'danger');
                    otpInput.value = '';
                    otpInput.focus();
                }
            } catch (error) {
                showAlert('Có lỗi xảy ra. Vui lòng thử lại.', 'danger');
            }
        });

        // Handle backup code
        document.getElementById('useBackupCode').addEventListener('click', (e) => {
            e.preventDefault();
            const backupCode = prompt('Nhập mã dự phòng 8 ký tự:');
            if (backupCode) {
                otpInput.value = backupCode;
                verifyForm.dispatchEvent(new Event('submit'));
            }
        });

        function showAlert(message, type) {
            alertContainer.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
        }

        // Auto-focus on OTP input
        otpInput.focus();
    </script>
</body>
</html>
