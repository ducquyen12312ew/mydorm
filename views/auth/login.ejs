<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập | KTX HUST</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/auth-forms.css">
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-layout" aria-label="Trang đăng nhập">
            <aside class="auth-brand">
                <div class="brand-visual fade-up" aria-hidden="true">
                    <div class="brand-media-card">
                        <img src="https://res.cloudinary.com/dysgt8t4d/image/upload/v1773728947/e798a5fcd468c4914b9d4fa0a0d1d20f_vwlgof.jpg" alt="Interior preview">
                        <div class="brand-media-overlay"></div>
                        <div class="brand-media-copy">
                            <h3>Discovering the Best Space for Your Home</h3>
                            <p>Clean, calm and beautifully arranged.</p>
                        </div>
                    </div>
                    <span class="brand-orbit orbit-1"></span>
                    <span class="brand-orbit orbit-2"></span>
                    <span class="brand-orbit orbit-3"></span>
                    <span class="brand-orbit orbit-4"></span>
                </div>
            </aside>

            <section class="auth-panel">
                <div class="auth-topbar">
                    <a href="/" class="auth-back" aria-label="Quay lại trang chủ">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <button type="button" class="theme-toggle" data-theme-toggle aria-label="Đổi giao diện sáng tối">
                        <i class="fa-regular fa-moon"></i>
                    </button>
                </div>

                <h1 class="auth-title">Đăng nhập</h1>
                <p class="auth-subtitle">Chào mừng quay lại, đăng nhập để tiếp tục quản lý hồ sơ ký túc xá của bạn.</p>

                <% if (typeof error !== 'undefined') { %>
                    <div class="auth-alert error" role="alert">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <% if (typeof success !== 'undefined') { %>
                    <div class="auth-alert success" role="status">
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= success %></span>
                    </div>
                <% } %>

                <form action="/login" method="post" class="auth-form" data-login-form novalidate>
                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-regular fa-user field-icon"></i>
                            <input
                                type="text"
                                id="username"
                                name="username"
                                placeholder=" "
                                required
                                autocomplete="username"
                                autocapitalize="none"
                                autocorrect="off"
                                spellcheck="false"
                                value="<%= typeof formData !== 'undefined' && formData.username ? formData.username : '' %>"
                            >
                            <label for="username">Email hoặc MSSV</label>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-solid fa-lock field-icon"></i>
                            <input
                                type="password"
                                id="password"
                                name="password"
                                placeholder=" "
                                required
                                autocomplete="current-password"
                            >
                            <label for="password">Mật khẩu</label>
                            <button type="button" class="field-action" data-password-toggle="password" aria-label="Hiện hoặc ẩn mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="row-inline fade-up">
                        <label class="checkbox-wrap" for="remember">
                            <input type="checkbox" id="remember" name="remember" <%= typeof formData !== 'undefined' && formData.remember ? 'checked' : '' %>>
                            <span>Ghi nhớ đăng nhập</span>
                        </label>
                        <a href="/forgot-password" class="text-link">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="primary-btn fade-up">
                        <span class="btn-loader" aria-hidden="true"></span>
                        <span>Đăng nhập</span>
                    </button>

                    <div class="social-row fade-up" aria-label="Đăng nhập mạng xã hội">
                        <button type="button" class="social-btn" aria-label="Đăng nhập Google">
                            <i class="fa-brands fa-google"></i>
                            <span>Google</span>
                        </button>
                        <button type="button" class="social-btn" aria-label="Đăng nhập Facebook">
                            <i class="fa-brands fa-facebook-f"></i>
                            <span>Facebook</span>
                        </button>
                    </div>
                </form>

                <p class="auth-footnote">
                    Chưa có tài khoản? <a href="/signup">Đăng ký</a>
                </p>
            </section>
        </section>
    </main>

    <script src="/js/auth-ui.js"></script>
</body>
</html>