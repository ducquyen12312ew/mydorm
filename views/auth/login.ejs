<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập | KTX HUST</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/auth-forms.css">
    <script src="/js/i18n.js"></script>
    <%- include('../shared/pwa-head') %>
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-layout" aria-label="Trang đăng nhập">
            <aside class="auth-brand">
                <div class="brand-visual fade-up" aria-hidden="true">
                    <div class="brand-media-card">
                        <img src="https://res.cloudinary.com/dysgt8t4d/image/upload/v1773728947/e798a5fcd468c4914b9d4fa0a0d1d20f_vwlgof.jpg" alt="Interior preview">
                        <div class="brand-media-overlay"></div>
                        <div class="brand-media-copy">
                            <h3 data-i18n="auth.brandTitle">Trải Nghiệm Ký Túc Xá Đại Học Bách Khoa</h3>
                            <p data-i18n="auth.brandSubtitle">Môi trường sống hiện đại, tiện nghi và an toàn dành cho sinh viên.</p>
                        </div>
                    </div>
                    <span class="brand-orbit orbit-1"></span>
                    <span class="brand-orbit orbit-2"></span>
                    <span class="brand-orbit orbit-3"></span>
                    <span class="brand-orbit orbit-4"></span>
                </div>
            </aside>

            <section class="auth-panel">
                <div class="auth-topbar">
                    <a href="/" class="auth-back" aria-label="Quay lại trang chủ">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <button type="button" class="theme-toggle" data-theme-toggle aria-label="Đổi giao diện sáng tối">
                        <i class="fa-regular fa-moon"></i>
                    </button>
                </div>

                <h1 class="auth-title" data-i18n="auth.loginTitle">Đăng nhập</h1>
                <p class="auth-subtitle" data-i18n="auth.loginSubtitle">Chào mừng quay lại, đăng nhập để tiếp tục quản lý hồ sơ ký túc xá của bạn.</p>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="auth-alert error" role="alert">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <% if (typeof oauthError !== 'undefined' && oauthError) { %>
                    <div class="auth-alert error" role="alert">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= oauthError %></span>
                    </div>
                <% } %>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="auth-alert success" role="status">
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= success %></span>
                    </div>
                <% } %>

                <form action="/login" method="post" class="auth-form" data-login-form novalidate>
                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-regular fa-user field-icon"></i>
                            <input
                                type="text"
                                id="username"
                                name="username"
                                placeholder=" "
                                required
                                autocomplete="username"
                                autocapitalize="none"
                                autocorrect="off"
                                spellcheck="false"
                                value="<%= typeof formData !== 'undefined' && formData.username ? formData.username : '' %>"
                            >
                            <label for="username" data-i18n="auth.username">Email hoặc MSSV</label>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-solid fa-lock field-icon"></i>
                            <input
                                type="password"
                                id="password"
                                name="password"
                                placeholder=" "
                                required
                                autocomplete="current-password"
                            >
                            <label for="password" data-i18n="auth.password">Mật khẩu</label>
                            <button type="button" class="field-action" data-password-toggle="password" aria-label="Hiện hoặc ẩn mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="row-inline fade-up">
                        <label class="checkbox-wrap" for="remember">
                            <input type="checkbox" id="remember" name="remember" <%= typeof formData !== 'undefined' && formData.remember ? 'checked' : '' %>>
                            <span data-i18n="auth.rememberMe">Ghi nhớ đăng nhập</span>
                        </label>
                        <a href="/forgot-password" class="text-link" data-i18n="auth.forgotPassword">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="primary-btn fade-up">
                        <span class="btn-loader" aria-hidden="true"></span>
                        <span data-i18n="auth.loginBtn">Đăng nhập</span>
                    </button>

                    <div class="social-divider fade-up"><span data-i18n="auth.orLoginWith">hoặc đăng nhập bằng</span></div>

                    <div class="social-row fade-up" aria-label="Đăng nhập SSO">
                        <a href="/auth/google" class="social-btn social-btn--google" aria-label="Đăng nhập bằng Google HUST">
                            <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
                            <span data-i18n="auth.continueGoogle">Google HUST</span>
                        </a>
                        <button type="button" class="social-btn social-btn--ms" data-ms-login aria-label="Đăng nhập bằng Outlook HUST">
                            <svg width="18" height="18" viewBox="0 0 23 23" aria-hidden="true"><path fill="#f25022" d="M1 1h10v10H1z"/><path fill="#00a4ef" d="M12 1h10v10H12z"/><path fill="#7fba00" d="M1 12h10v10H1z"/><path fill="#ffb900" d="M12 12h10v10H12z"/></svg>
                            <span>Outlook HUST</span>
                        </button>
                    </div>
                </form>

                <p class="auth-footnote" data-i18n-html="auth.hustNote">
                    Sinh viên HUST đăng nhập bằng tài khoản <strong>@sis.hust.edu.vn</strong>
                </p>
            </section>
        </section>
    </main>

    <!-- Microsoft email picker modal -->
    <div class="ms-modal-backdrop" id="msModal" hidden aria-modal="true" role="dialog" aria-label="Đăng nhập Microsoft">
        <div class="ms-modal">
            <div class="ms-modal-header">
                <svg width="108" height="24" viewBox="0 0 108 24" fill="none" aria-label="Microsoft">
                    <path d="M0 0h11.5v11.5H0V0z" fill="#F25022"/><path d="M12.5 0H24v11.5H12.5V0z" fill="#7FBA00"/>
                    <path d="M0 12.5h11.5V24H0V12.5z" fill="#00A4EF"/><path d="M12.5 12.5H24V24H12.5V12.5z" fill="#FFB900"/>
                    <text x="30" y="18" font-family="Segoe UI,Arial" font-size="16" font-weight="600" fill="#201a17">Microsoft</text>
                </svg>
                <h2 class="ms-modal-title" data-i18n="auth.msTitle">Đăng nhập</h2>
            </div>
            <div id="msError" class="ms-error" hidden></div>
            <div class="ms-modal-body">
                <div class="field-shell">
                    <input type="email" id="msEmailInput" class="ms-input" placeholder="Email trường (@sis.hust.edu.vn)" data-i18n-placeholder="auth.msEmailPlaceholder" autocomplete="email" autocapitalize="none" spellcheck="false">
                </div>
                <p class="ms-hint" data-i18n="auth.msHint">Dùng tài khoản trường của bạn</p>
            </div>
            <div class="ms-modal-footer">
                <button type="button" class="ms-cancel" id="msCancelBtn" data-i18n="auth.cancel">Hủy</button>
                <button type="button" class="ms-next" id="msNextBtn" data-i18n="auth.next">Tiếp theo</button>
            </div>
        </div>
    </div>

    <script src="/js/auth-ui.js"></script>
    <%- include('../shared/pwa-scripts') %>
</body>
</html>