<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hoàn tất hồ sơ | KTX HUST</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/auth-forms.css">
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-layout" aria-label="Hoàn tất hồ sơ">
            <aside class="auth-brand">
                <div class="brand-visual fade-up" aria-hidden="true">
                    <div class="brand-media-card">
                        <img src="https://res.cloudinary.com/dysgt8t4d/image/upload/v1773728947/e798a5fcd468c4914b9d4fa0a0d1d20f_vwlgof.jpg" alt="Interior preview">
                        <div class="brand-media-overlay"></div>
                        <div class="brand-media-copy">
                            <h3>Trải Nghiệm Ký Túc Xá Đại Học Bách Khoa</h3>
                            <p>Môi trường sống hiện đại, tiện nghi và an toàn dành cho sinh viên.</p>
                        </div>
                    </div>
                    <span class="brand-orbit orbit-1"></span>
                    <span class="brand-orbit orbit-2"></span>
                    <span class="brand-orbit orbit-3"></span>
                    <span class="brand-orbit orbit-4"></span>
                </div>
            </aside>

            <section class="auth-panel">
                <div class="auth-topbar">
                    <a href="/login" class="auth-back" aria-label="Quay lại đăng nhập">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                </div>

                <!-- Progress indicator -->
                <div class="onboard-steps">
                    <div class="onboard-step done"><i class="fa-solid fa-check"></i></div>
                    <div class="onboard-step-line done"></div>
                    <div class="onboard-step active">2</div>
                    <div class="onboard-step-line"></div>
                    <div class="onboard-step">3</div>
                </div>

                <h1 class="auth-title" style="margin-top:16px">Hoàn tất hồ sơ</h1>
                <p class="auth-subtitle">
                    Đăng nhập thành công với
                    <% if (oauthProvider === 'google') { %>
                        <strong><i class="fa-brands fa-google" style="color:#EA4335"></i> Google</strong>
                    <% } else { %>
                        <strong><i class="fa-brands fa-microsoft" style="color:#0078d4"></i> Microsoft</strong>
                    <% } %>
                    — <span style="font-family:monospace;font-size:0.88em"><%= email %></span>
                </p>

                <% if (error) { %>
                    <div class="auth-alert error" role="alert">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/auth/onboarding" method="post" class="auth-form" novalidate>
                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-regular fa-id-card field-icon"></i>
                            <input type="text" id="studentId" name="studentId" placeholder=" " required
                                   autocomplete="off" pattern="[0-9]{6}" maxlength="8"
                                   title="MSSV gồm 6-8 chữ số">
                            <label for="studentId">Mã sinh viên (MSSV)</label>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-regular fa-user field-icon"></i>
                            <input type="text" id="name" name="name" placeholder=" " required
                                   autocomplete="name" value="<%= name || '' %>">
                            <label for="name">Họ và tên đầy đủ</label>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-solid fa-phone field-icon"></i>
                            <input type="tel" id="phone" name="phone" placeholder=" " autocomplete="tel">
                            <label for="phone">Số điện thoại</label>
                        </div>
                    </div>

                    <div class="onboard-row fade-up">
                        <div class="input-group" style="flex:1">
                            <div class="field-shell">
                                <i class="fa-solid fa-venus-mars field-icon" style="font-size:0.8rem"></i>
                                <select id="gender" name="gender" class="field-select">
                                    <option value="">Giới tính</option>
                                    <option value="male">Nam</option>
                                    <option value="female">Nữ</option>
                                    <option value="other">Khác</option>
                                </select>
                            </div>
                        </div>
                        <div class="input-group" style="flex:1">
                            <div class="field-shell">
                                <i class="fa-solid fa-graduation-cap field-icon" style="font-size:0.8rem"></i>
                                <input type="text" id="academicYear" name="academicYear" placeholder=" ">
                                <label for="academicYear">Khóa (VD: 2023)</label>
                            </div>
                        </div>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-solid fa-building-columns field-icon"></i>
                            <select id="faculty" name="faculty" class="field-select">
                                <option value="">Chọn Viện / Khoa</option>
                                <option value="Viện Công nghệ Thông tin và Truyền thông">Viện CNTT&TT (SOICT)</option>
                                <option value="Viện Điện">Viện Điện (SEE)</option>
                                <option value="Viện Điện tử - Viễn thông">Viện Điện tử - Viễn thông (SET)</option>
                                <option value="Viện Cơ khí">Viện Cơ khí (SME)</option>
                                <option value="Viện Kỹ thuật Hóa học">Viện Hóa (SCE)</option>
                                <option value="Viện Vật lý Kỹ thuật">Viện Vật lý (SEP)</option>
                                <option value="Viện Toán ứng dụng và Tin học">Viện Toán - Tin (SAMI)</option>
                                <option value="Viện Kinh tế và Quản lý">Viện Kinh tế (SEM)</option>
                                <option value="Viện Khoa học và Công nghệ môi trường">Viện Môi trường (SESE)</option>
                                <option value="Viện Dệt May - Da Giầy và Thời trang">Viện Dệt May (FTET)</option>
                                <option value="Viện Năng lượng">Viện Năng lượng</option>
                                <option value="Khoa Ngoại ngữ">Khoa Ngoại ngữ</option>
                                <option value="Khoa Giáo dục Thể chất">Khoa GDTC</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="primary-btn fade-up">
                        <span class="btn-loader" aria-hidden="true"></span>
                        <span>Hoàn tất & Đăng nhập</span>
                    </button>
                </form>
            </section>
        </section>
    </main>

    <style>
        .onboard-steps {
            display: flex;
            align-items: center;
            gap: 0;
            margin-bottom: 8px;
        }
        .onboard-step {
            width: 28px; height: 28px;
            border-radius: 50%;
            border: 2px solid var(--auth-border);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.78rem; font-weight: 700;
            color: var(--auth-text-muted);
            flex-shrink: 0;
        }
        .onboard-step.active {
            border-color: var(--auth-primary);
            color: var(--auth-primary);
        }
        .onboard-step.done {
            background: var(--auth-primary);
            border-color: var(--auth-primary);
            color: #fff;
        }
        .onboard-step-line {
            flex: 1; height: 2px; background: var(--auth-border);
        }
        .onboard-step-line.done {
            background: var(--auth-primary);
        }
        .onboard-row {
            display: flex; gap: 12px;
        }
        .field-select {
            width: 100%; height: 54px;
            border-radius: 14px;
            border: 1px solid var(--auth-border);
            background: #fff;
            color: var(--auth-text);
            padding: 0 44px 0 44px;
            font-size: 0.95rem;
            appearance: none;
            cursor: pointer;
        }
        .field-select:focus {
            outline: none;
            border-color: rgba(214,45,45,0.5);
            box-shadow: 0 0 0 4px var(--auth-primary-soft);
        }
    </style>

    <script src="/js/auth-ui.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Client-side validation for onboarding form
            var form = document.querySelector('form');
            if (!form) return;
            form.addEventListener('submit', function(e) {
                var sid = document.getElementById('studentId');
                var name = document.getElementById('name');
                var valid = true;
                if (!sid.value.trim()) { valid = false; }
                if (!name.value.trim()) { valid = false; }
                if (!valid) { e.preventDefault(); return; }
                var btn = form.querySelector('button[type=submit]');
                if (btn) btn.classList.add('loading');
            });
        });
    </script>
</body>
</html>
