<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký tài khoản | KTX HUST</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/auth-forms.css">
</head>
<body class="auth-page">
    <main class="auth-shell">
        <section class="auth-layout" aria-label="Trang đăng ký tài khoản">
            <aside class="auth-brand">
                <div class="brand-visual fade-up" aria-hidden="true">
                    <div class="brand-media-card">
                        <img src="https://res.cloudinary.com/dysgt8t4d/image/upload/v1773728947/e798a5fcd468c4914b9d4fa0a0d1d20f_vwlgof.jpg" alt="Interior preview">
                        <div class="brand-media-overlay"></div>
                        <div class="brand-media-copy">
                            <h3>Discovering the Best Space for Your Home</h3>
                            <p>Elegant visuals with a softer layout.</p>
                        </div>
                    </div>
                    <span class="brand-orbit orbit-1"></span>
                    <span class="brand-orbit orbit-2"></span>
                    <span class="brand-orbit orbit-3"></span>
                    <span class="brand-orbit orbit-4"></span>
                </div>
            </aside>

            <section class="auth-panel">
                <div class="auth-topbar">
                    <a href="/" class="auth-back" aria-label="Quay lại trang chủ">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <button type="button" class="theme-toggle" data-theme-toggle aria-label="Đổi giao diện sáng tối">
                        <i class="fa-regular fa-moon"></i>
                    </button>
                </div>

                <h1 class="auth-title">Tạo tài khoản</h1>
                <p class="auth-subtitle">Điền một vài thông tin cơ bản để bắt đầu sử dụng hệ thống KTX HUST.</p>

                <% if (typeof error !== 'undefined') { %>
                    <div class="auth-alert error" role="alert">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/signup" method="post" class="auth-form" data-signup-form novalidate>
                    <input type="hidden" id="username" name="username">
                    <input type="hidden" id="email" name="email">
                    <input type="hidden" id="studentId" name="studentId">

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-regular fa-user field-icon"></i>
                            <input type="text" id="name" name="name" placeholder=" " required autocomplete="name">
                            <label for="name">Họ tên</label>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-regular fa-envelope field-icon"></i>
                            <input type="text" id="identity" placeholder=" " required autocomplete="email">
                            <label for="identity">Email hoặc MSSV</label>
                        </div>
                        <p class="field-hint">Trường này sẽ tự động liên kết vào tài khoản đăng nhập của bạn.</p>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-solid fa-lock field-icon"></i>
                            <input type="password" id="password" name="password" placeholder=" " required autocomplete="new-password">
                            <label for="password">Mật khẩu</label>
                            <button type="button" class="field-action" data-password-toggle="password" aria-label="Hiện hoặc ẩn mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <div class="password-meter" aria-hidden="true"><span data-password-meter></span></div>
                        <p class="password-feedback" data-password-feedback>Nhập mật khẩu để kiểm tra độ mạnh</p>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <div class="field-shell">
                            <i class="fa-solid fa-shield-halved field-icon"></i>
                            <input type="password" id="confirmPassword" name="confirmPassword" placeholder=" " required autocomplete="new-password">
                            <label for="confirmPassword">Xác nhận mật khẩu</label>
                            <button type="button" class="field-action" data-password-toggle="confirmPassword" aria-label="Hiện hoặc ẩn xác nhận mật khẩu">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <div class="input-group fade-up">
                        <label class="checkbox-wrap" for="agreeTerms">
                            <input type="checkbox" id="agreeTerms" name="agreeTerms" required>
                            <span>Tôi đồng ý điều khoản</span>
                        </label>
                        <p class="field-error" aria-live="polite"></p>
                    </div>

                    <button type="submit" class="primary-btn fade-up">
                        <span class="btn-loader" aria-hidden="true"></span>
                        <span>Đăng ký</span>
                    </button>
                </form>

                <p class="auth-footnote">
                    Đã có tài khoản? <a href="/login">Đăng nhập</a>
                </p>
            </section>
        </section>
    </main>

    <script src="/js/auth-ui.js"></script>
</body>
</html>