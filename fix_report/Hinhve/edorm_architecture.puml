@startuml eDorm_Architecture_Final

title eDorm вЂ” HUST Dormitory Management System\nMulti-tier Client-Server Architecture

top to bottom direction

skinparam shadowing false
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultTextAlignment center
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam ArrowThickness 1.5
skinparam ArrowColor #444444
skinparam NoteBackgroundColor #FFFFEE
skinparam NoteBorderColor #AAAAAA

skinparam package {
    BorderColor #444444
    FontStyle bold
    FontSize 13
}
skinparam rectangle {
    BorderColor #666666
    BorderThickness 1.5
    FontSize 10
}
skinparam database {
    BorderColor #666666
    BorderThickness 1.5
    FontSize 10
}

'================================================
' TIER 1 вЂ” PRESENTATION
'================================================
package "TIER 1  В·  PRESENTATION" #DAE8FC {
    rectangle "Student Portal\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEJS Template Engine\nHTML / CSS / JavaScript" as STUDENT_WEB
    rectangle "Admin Portal\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEJS Template Engine\nHTML / CSS / JavaScript" as ADMIN_WEB
    rectangle "Mobile Application\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nReact Native (Expo SDK 52)\nExpo Router В· TypeScript" as MOBILE
}

'================================================
' TIER 2 вЂ” APPLICATION (Security & Routing)
'================================================
package "TIER 2  В·  APPLICATION" #E1D5E7 {

    rectangle "Authentication & Authorization\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nWeb: express-session (cookie)  |  Mobile: JWT (access 15m В· refresh 30d)\nOAuth 2.0 via Passport.js  В·  2FA: TOTP / Email OTP\nbcrypt В· express-validator В· MobileRefreshToken risk scoring" as AUTH

    rectangle "Routing & Middleware Chain\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nWeb Routes В· Admin Routes В· Mobile API Routes (/api/student-app/*)\nRBAC: requireAuth В· requireAdmin В· requireQuotaAdmin\nHelmet В· express-rate-limit В· express-mongo-sanitize" as ROUTER

    AUTH -down-> ROUTER : validated identity / decoded token
}

'================================================
' TIER 3 вЂ” BUSINESS LOGIC
'================================================
package "TIER 3  В·  BUSINESS LOGIC" #D5E8D4 {

    rectangle "ALLOCATION ENGINE\nв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\nQuota Config (year1 В· year2_3 В· year4_plus)\nPolicy Evaluation\nPriority Scoring:\n  35% Geographic Distance\n  35% Financial Hardship\n  30% Priority Level\nAutomatic Room Assignment\nFairness Check (max В±10% deviation)\nCycle Management & Audit Log" as ALLOC #AADDAA

    together {
        rectangle "Registration\nManagement\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nApplications\nAcademic Windows\nPriority Claims\nReview History" as REG

        rectangle "Student\nManagement\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nProfile & Avatar\nPriority Scoring\nQR Resident Card\nRoommate Info" as STUDENT

        rectangle "Dormitory\nManagement\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBuildings & Rooms\n360В° / VR Viewer\nMedia Upload" as DORM
    }

    together {
        rectangle "Service\nRequests\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMaintenance Req.\nRoom Transfer\nRequest Tracking" as REQUEST

        rectangle "Violation\nManagement\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nViolation Records\nDisciplinary Actions\nAppeals & History" as VIOLATION

        rectangle "Analytics &\nReporting\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOccupancy Dashboard\nAllocation Statistics\nDemand Forecasting\nEnrollment Planning\nExcel Export" as ANALYTICS
    }

    rectangle "Notification Center\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIn-app В· Email В· Push Notifications  В·  Activity Log\nTriggered by: Allocation Result В· Application Update В· System Events" as NOTIFY

}

'================================================
' REALTIME вЂ” embedded inside Express process
'================================================
package "REALTIME  (embedded in Express)" #FFE6CC {
    rectangle "Socket.IO Server\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEvent Namespace: /student\nJWT handshake auth\nEvents: allocation:result В· notification:new\n         student:assigned В· application:updated" as SOCKET
}

'================================================
' TIER 4 вЂ” DATA
'================================================
package "TIER 4  В·  DATA" #F5F5F5 {

    database "MongoDB Atlas\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nStudents  В·  Applications\nDormitories  В·  Rooms\nAllocations  В·  AllocationCycles\nQuotaConfig  В·  AllocationPolicies\nViolations  В·  Notifications\nMaintenanceRequests  В·  RoomTransfers\nEnrollmentPlans  В·  DemandForecasts\nTwoFactor  В·  MobileRefreshTokens" as MONGO

    database "Redis\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSession Store\n(express-session)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSocket.IO\nCluster Adapter\n(@socket.io/redis-adapter)" as REDIS

}

'================================================
' EXTERNAL SERVICES
'================================================
package "EXTERNAL SERVICES" #FFF2CC {
    rectangle "Cloudinary\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRoom Images\n360В° Media\nStudent Avatars" as CLOUDINARY
    rectangle "Google OAuth 2.0\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSingle Sign-On\npassport-google-oauth20" as GOOGLE
    rectangle "SMTP / Nodemailer\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOTP В· Notifications\nPassword Reset" as EMAIL
    rectangle "Sentry\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nError Tracking\nPerf. Monitoring" as SENTRY
}

